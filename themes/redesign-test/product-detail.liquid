{% layout "layout" %}
{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20 animate-fade-in text-wood-800">
  <div class="flex flex-col md:flex-row gap-12">
    <!-- Cột trái: Ảnh -->
    <div class="md:w-1/2">
      {% if product.image %}
        <img src="{{ product.image }}" alt="{{ product.name }}" class="w-full h-auto object-cover rounded-lg shadow-sm main-product-image">
      {% else %}
        <div class="w-full h-96 bg-cream-200 rounded-lg flex items-center justify-center text-wood-400">No Image</div>
      {% endif %}
      
      <!-- Gallery -->
      {% if product.images and product.images.size > 0 %}
        <div class="grid grid-cols-4 gap-4 mt-4">
          {% for img in product.images %}
            <img src="{{ img }}" alt="{{ product.name }}" class="w-full h-24 object-cover rounded-md cursor-pointer hover:opacity-80 transition gallery-image">
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Cột phải: Thông tin -->
    <div class="md:w-1/2 flex flex-col">
      <h1 class="text-3xl md:text-4xl font-serif text-wood-900 mb-4">{{ product.name }}</h1>
      
      <div class="text-2xl font-serif text-wood-700 mb-4" id="variant-price">{{ product.price | money }}</div>
      
      <div class="text-sm text-wood-500 mb-6" id="variant-stock">
        {% if product.stock > 0 %}
          Còn hàng
        {% else %}
          Hết hàng
        {% endif %}
      </div>
      
      <!-- Variant Picker Container -->
      <div id="variant-picker" class="mb-6">
        <!-- JS will inject selects here -->
      </div>
      
      <script type="application/json" id="variants-data">{{ variantsJson }}</script>

      <div class="flex flex-col sm:flex-row gap-4 mb-8">
        <button id="add-to-cart" data-id="{{ product.id }}" class="flex-1 bg-wood-800 text-cream-50 py-3 px-6 rounded-md hover:bg-wood-700 transition uppercase tracking-wider text-sm font-medium">Thêm vào giỏ</button>
        <button id="buy-now-btn" class="flex-1 bg-wood-600 text-cream-50 py-3 px-6 rounded-md hover:bg-wood-500 transition uppercase tracking-wider text-sm font-medium">Mua ngay</button>
      </div>

      <!-- Buy Now Form (Hidden by default) -->
      <form id="buy-now-form" class="hidden bg-cream-100 p-6 rounded-lg mb-8 border border-wood-200">
        <h3 class="text-xl font-serif text-wood-900 mb-4">Thông tin mua ngay</h3>
        <div id="buy-now-error" class="text-red-600 text-sm mb-4 hidden"></div>
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-wood-700 mb-1">Họ tên *</label>
            <input type="text" name="customerName" class="w-full border border-wood-300 bg-white p-2 rounded-md focus:ring-wood-500 focus:border-wood-500 text-wood-800" required>
          </div>
          <div>
            <label class="block text-sm text-wood-700 mb-1">Số điện thoại *</label>
            <input type="tel" name="customerPhone" class="w-full border border-wood-300 bg-white p-2 rounded-md focus:ring-wood-500 focus:border-wood-500 text-wood-800" required>
          </div>
          <div>
            <label class="block text-sm text-wood-700 mb-1">Địa chỉ *</label>
            <input type="text" name="customerAddress" class="w-full border border-wood-300 bg-white p-2 rounded-md focus:ring-wood-500 focus:border-wood-500 text-wood-800" required>
          </div>
          <div class="flex gap-4 mt-6">
            <button type="submit" class="flex-1 bg-wood-800 text-cream-50 py-2 px-4 rounded-md hover:bg-wood-700 transition">Xác nhận mua</button>
            <button type="button" id="buy-now-cancel" class="flex-1 bg-gray-200 text-wood-800 py-2 px-4 rounded-md hover:bg-gray-300 transition">Hủy</button>
          </div>
        </div>
      </form>

      <!-- Custom Fields -->
      <div class="mb-6 prose prose-wood max-w-none text-wood-700 text-sm">
        {% render "custom-fields", fields: product.customFields %}
      </div>

      <!-- Description -->
      <div class="prose prose-wood max-w-none text-wood-700">
        {{ product.description }}
      </div>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="mt-20 border-t border-wood-200 pt-12">
    <h2 class="text-2xl font-serif text-wood-900 mb-8 text-center">Đánh giá sản phẩm</h2>
    <div class="flex flex-col md:flex-row gap-12">
      <!-- Form đánh giá -->
      <div class="md:w-1/3">
        <h3 class="text-lg font-medium text-wood-800 mb-4">Viết đánh giá</h3>
        <div id="review-msg" class="mb-4 text-sm hidden"></div>
        <form id="review-form" class="space-y-4">
          <div>
            <label class="block text-sm text-wood-700 mb-1">Tên của bạn *</label>
            <input type="text" name="customerName" required class="w-full border border-wood-300 bg-cream-50 p-2 rounded-md focus:ring-wood-500 focus:border-wood-500 text-wood-800">
          </div>
          <div>
            <label class="block text-sm text-wood-700 mb-1">Đánh giá *</label>
            <select name="rating" required class="w-full border border-wood-300 bg-cream-50 p-2 rounded-md focus:ring-wood-500 focus:border-wood-500 text-wood-800">
              <option value="5">5 Sao - Tuyệt vời</option>
              <option value="4">4 Sao - Rất tốt</option>
              <option value="3">3 Sao - Bình thường</option>
              <option value="2">2 Sao - Kém</option>
              <option value="1">1 Sao - Tệ</option>
            </select>
          </div>
          <div>
            <label class="block text-sm text-wood-700 mb-1">Bình luận *</label>
            <textarea name="comment" rows="4" required class="w-full border border-wood-300 bg-cream-50 p-2 rounded-md focus:ring-wood-500 focus:border-wood-500 text-wood-800"></textarea>
          </div>
          <button type="submit" class="bg-wood-800 text-cream-50 py-2 px-6 rounded-md hover:bg-wood-700 transition">Gửi đánh giá</button>
        </form>
      </div>
      
      <!-- Danh sách đánh giá -->
      <div class="md:w-2/3">
        {% if product.reviews and product.reviews.size > 0 %}
          <div class="space-y-6">
            {% for review in product.reviews %}
              <div class="border-b border-wood-200 pb-6 last:border-0">
                <div class="flex items-center gap-2 mb-2">
                  <span class="font-medium text-wood-900">{{ review.customerName }}</span>
                  <span class="text-sm text-wood-500">{{ review.createdAt | date: "%d/%m/%Y" }}</span>
                </div>
                <div class="text-yellow-500 text-sm mb-2">
                  {% for i in (1..5) %}
                    {% if i <= review.rating %}★{% else %}☆{% endif %}
                  {% endfor %}
                </div>
                <p class="text-wood-700">{{ review.comment }}</p>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="text-wood-500 italic">Chưa có đánh giá nào cho sản phẩm này. Hãy là người đầu tiên đánh giá!</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
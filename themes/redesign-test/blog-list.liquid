{% layout "layout" %}

{% block content %}
<div class="bg-cream min-h-screen pt-24 pb-16">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center mb-16 fade-in">
      <h1 class="text-4xl md:text-5xl font-serif text-wood mb-4">Our Journal</h1>
      <p class="text-wood/70 max-w-2xl mx-auto font-sans">Insights, inspiration, and stories from the world of fine wooden furniture.</p>
    </div>

    {% if posts.length > 0 %}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 mb-16">
        {% for post in posts %}
          <article class="group fade-in flex flex-col h-full">
            <a href="/blog/{{ post.slug }}" class="block overflow-hidden relative aspect-[4/3] mb-6 rounded-sm">
              {% if post.coverImage %}
                <img src="{{ post.coverImage }}" alt="{{ post.title }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
              {% else %}
                <div class="w-full h-full bg-wood/10 flex items-center justify-center">
                  <span class="text-wood/50 font-serif italic">No image</span>
                </div>
              {% endif %}
            </a>
            
            <div class="flex-grow flex flex-col">
              {% if post.categories.length > 0 %}
                <div class="flex flex-wrap gap-2 mb-3">
                  {% for category in post.categories %}
                    <span class="text-xs uppercase tracking-widest text-wood/60 font-sans">{{ category }}</span>
                  {% endfor %}
                </div>
              {% endif %}
              
              <h2 class="text-2xl font-serif text-wood mb-3 line-clamp-2 group-hover:text-wood/80 transition-colors">
                <a href="/blog/{{ post.slug }}">{{ post.title }}</a>
              </h2>
              
              <div class="text-sm text-wood/60 mb-4 font-sans">
                {{ post.publishedAt | date: "%B %d, %Y" }}
              </div>
              
              <p class="text-wood/80 mb-6 line-clamp-3 font-sans flex-grow">
                {{ post.excerpt }}
              </p>
              
              <div class="mt-auto">
                <a href="/blog/{{ post.slug }}" class="inline-flex items-center text-wood uppercase tracking-widest text-sm font-sans group-hover:underline underline-offset-4 decoration-wood/50 transition-all">
                  Read Article
                  <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </a>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>

      {% if hasPrev or hasNext %}
        <div class="flex justify-center items-center space-x-6 border-t border-wood/20 pt-8 font-sans">
          {% if hasPrev %}
            <a href="?page={{ prevPage }}" class="text-wood uppercase tracking-widest text-sm hover:text-wood/70 transition-colors flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path></svg>
              Previous
            </a>
          {% else %}
            <span class="text-wood/30 uppercase tracking-widest text-sm flex items-center cursor-not-allowed">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path></svg>
              Previous
            </span>
          {% endif %}

          <span class="w-px h-4 bg-wood/20"></span>

          {% if hasNext %}
            <a href="?page={{ nextPage }}" class="text-wood uppercase tracking-widest text-sm hover:text-wood/70 transition-colors flex items-center">
              Next
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path></svg>
            </a>
          {% else %}
            <span class="text-wood/30 uppercase tracking-widest text-sm flex items-center cursor-not-allowed">
              Next
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path></svg>
            </span>
          {% endif %}
        </div>
      {% endif %}

    {% else %}
      <div class="text-center py-20 border border-wood/10 rounded-sm bg-white/50">
        <p class="text-wood/70 font-sans text-lg">No articles found at the moment.</p>
        <a href="/" class="inline-block mt-6 px-8 py-3 bg-wood text-cream uppercase tracking-widest text-sm hover:bg-wood/90 transition-colors">Return to Home</a>
      </div>
    {% endif %}
  </div>
</div>
{% endblock %}
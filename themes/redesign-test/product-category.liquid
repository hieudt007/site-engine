{% layout "layout" %}

{% block content %}
<main class="bg-[#fdfbf7] min-h-screen py-16 px-4 sm:px-6 lg:px-8 text-[#4a3b32] font-sans fade-in-up">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <header class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-serif text-[#4a3b32] mb-4">{{ category.name }}</h1>
      {% if category.description %}
        <div class="max-w-2xl mx-auto text-gray-600 mb-6">{{ category.description }}</div>
      {% endif %}
      
      {% if category.children.size > 0 %}
        <div class="flex flex-wrap justify-center gap-3 mt-6">
          {% for child in category.children %}
            <a href="{{ child.url }}" class="px-4 py-2 border border-[#4a3b32] text-[#4a3b32] hover:bg-[#4a3b32] hover:text-[#fdfbf7] transition-colors duration-300 text-sm tracking-wide">{{ child.name }}</a>
          {% endfor %}
        </div>
      {% endif %}
      
      <div class="mt-8">
        {% render "custom-fields", fields: category.customFields %}
      </div>
    </header>

    <!-- Product Grid -->
    {% if products.size > 0 %}
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
        {% for product in products %}
          <div class="group relative bg-white overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
            <!-- Image -->
            <a href="{{ product.url }}" class="block w-full aspect-[4/5] overflow-hidden bg-gray-100 relative">
              {% if product.image %}
                <img src="{{ product.image }}" alt="{{ product.name }}" class="absolute inset-0 w-full h-full object-cover object-center transform transition-transform duration-700 group-hover:scale-105">
              {% else %}
                <div class="absolute inset-0 flex items-center justify-center text-gray-400">No Image</div>
              {% endif %}
              
              <!-- Sale Badge -->
              {% if product.compareAtPrice > product.price %}
                <span class="absolute top-3 left-3 bg-[#8b0000] text-white text-xs px-2 py-1 uppercase tracking-wider font-medium z-10">Sale</span>
              {% endif %}
            </a>
            
            <!-- Info -->
            <div class="p-5 text-center">
              <h3 class="text-lg font-serif text-[#4a3b32] mb-2">
                <a href="{{ product.url }}" class="hover:underline">{{ product.name }}</a>
              </h3>
              <div class="flex items-center justify-center gap-2">
                <span class="text-[#4a3b32] font-medium">{{ product.price | money }}</span>
                {% if product.compareAtPrice > product.price %}
                  <span class="text-gray-400 line-through text-sm">{{ product.compareAtPrice | money }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
      
      <!-- Pagination -->
      {% if pagination %}
        <div class="mt-16 flex justify-center items-center gap-2">
          {% if pagination.prev %}
            <a href="{{ pagination.prev }}" class="px-4 py-2 border border-[#4a3b32] text-[#4a3b32] hover:bg-[#4a3b32] hover:text-[#fdfbf7] transition-colors duration-300">&larr; Prev</a>
          {% endif %}
          
          <div class="flex gap-1">
            {% for page in pagination.pages %}
              {% if page.current %}
                <span class="px-4 py-2 bg-[#4a3b32] text-[#fdfbf7] border border-[#4a3b32]">{{ page.number }}</span>
              {% else %}
                <a href="{{ page.url }}" class="px-4 py-2 border border-[#4a3b32] text-[#4a3b32] hover:bg-[#4a3b32] hover:text-[#fdfbf7] transition-colors duration-300">{{ page.number }}</a>
              {% endif %}
            {% endfor %}
          </div>
          
          {% if pagination.next %}
            <a href="{{ pagination.next }}" class="px-4 py-2 border border-[#4a3b32] text-[#4a3b32] hover:bg-[#4a3b32] hover:text-[#fdfbf7] transition-colors duration-300">Next &rarr;</a>
          {% endif %}
        </div>
      {% endif %}
      
    {% else %}
      <div class="text-center py-20">
        <p class="text-gray-500 text-lg">Chưa có sản phẩm nào trong danh mục này.</p>
        <a href="/products" class="inline-block mt-6 px-6 py-3 bg-[#4a3b32] text-[#fdfbf7] hover:bg-opacity-90 transition-colors duration-300">Xem tất cả sản phẩm</a>
      </div>
    {% endif %}
  </div>
</main>
{% endblock %}
{% layout "layout" %}
{% block content %}
<main class="flex-grow flex items-center justify-center py-24 px-4 bg-[#FAF8F5]">
    <div class="max-w-md w-full bg-white p-8 md:p-12 shadow-sm border border-[#E8E3DB] text-center fade-in">
        <!-- Lock Icon -->
        <div class="mx-auto w-16 h-16 mb-6 text-[#5C4033] flex items-center justify-center rounded-full bg-[#FAF8F5]">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
            </svg>
        </div>

        <h1 class="text-3xl font-serif text-[#5C4033] mb-4">{{ pageTitle }}</h1>
        <p class="text-gray-600 mb-8 font-sans leading-relaxed">Bài viết này được bảo vệ. Vui lòng nhập mật khẩu để tiếp tục xem nội dung.</p>

        <form id="unlock-form" class="space-y-5">
            <div>
                <input type="password" id="password" name="password" placeholder="Nhập mật khẩu..." required
                    class="w-full px-4 py-3 border border-[#E8E3DB] focus:outline-none focus:border-[#5C4033] focus:ring-1 focus:ring-[#5C4033] transition-colors font-sans bg-[#FAF8F5] text-gray-800 placeholder-gray-400">
            </div>
            <div id="unlock-error" class="text-red-600 text-sm hidden font-sans text-left bg-red-50 p-3 rounded border border-red-100">
                Mật khẩu không chính xác. Vui lòng thử lại.
            </div>
            <button type="submit"
                class="w-full bg-[#5C4033] text-white px-6 py-3 font-medium hover:bg-[#4A332A] transition-colors duration-300 font-sans tracking-wide">
                Mở Khóa Bài Viết
            </button>
        </form>
    </div>
</main>
{% endblock %}
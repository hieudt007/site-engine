{% layout "layout" %}

{% block content %}
<main class="bg-cream text-wood font-sans">
  <!-- Hero Section -->
  <section class="relative w-full h-[70vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?q=80&w=2000&auto=format&fit=crop" alt="Luxury Wooden Furniture" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    <div class="relative z-10 text-center px-4 max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-serif text-white mb-6 drop-shadow-lg">Nghệ thuật Mộc Đương đại</h1>
      <p class="text-lg md:text-xl text-white/90 mb-8 font-light drop-shadow">Mang vẻ đẹp tự nhiên và sự sang trọng vượt thời gian vào không gian sống của bạn.</p>
      <a href="/search" class="inline-block px-8 py-3 bg-white text-wood font-medium tracking-wider uppercase text-sm hover:bg-wood hover:text-white transition-colors duration-300">
        Khám phá ngay
      </a>
    </div>
  </section>

  <!-- New Products Section -->
  <section class="py-16 px-4 md:px-8 max-w-7xl mx-auto section-animate opacity-0 translate-y-8 transition-all duration-1000 ease-out">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-serif mb-4">Bộ sưu tập mới</h2>
      <div class="w-16 h-0.5 bg-wood mx-auto"></div>
    </div>

    {% if products.size > 0 %}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {% for product in products %}
          <a href="/products/{{ product.id }}" class="group block">
            <div class="relative aspect-[4/5] overflow-hidden bg-white mb-4">
              {% if product.imageUrls.size > 0 %}
                <img src="{{ product.imageUrls[0] }}" alt="{{ product.name }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              {% else %}
                <div class="w-full h-full bg-gray-100 flex items-center justify-center text-gray-400 text-sm">Không có ảnh</div>
              {% endif %}
              
              {% if product.salePrice and product.salePrice < product.price %}
                <div class="absolute top-4 right-4 bg-wood text-white text-xs px-2 py-1 uppercase tracking-wider">Sale</div>
              {% endif %}
            </div>
            <div class="text-center">
              <h3 class="font-serif text-lg mb-2 group-hover:text-wood/70 transition-colors">{{ product.name }}</h3>
              <div class="flex items-center justify-center space-x-3 text-sm">
                {% if product.salePrice and product.salePrice < product.price %}
                  <span class="text-wood font-medium">{{ product.salePrice | money }}</span>
                  <span class="text-wood/50 line-through">{{ product.price | money }}</span>
                {% else %}
                  <span class="text-wood font-medium">{{ product.price | money }}</span>
                {% endif %}
              </div>
            </div>
          </a>
        {% endfor %}
      </div>
      <div class="text-center mt-12">
        <a href="/search" class="inline-block border-b border-wood pb-1 text-sm uppercase tracking-widest hover:text-wood/70 hover:border-wood/70 transition-colors">Xem tất cả sản phẩm</a>
      </div>
    {% else %}
      <div class="text-center py-12 bg-white/50 border border-wood/10">
        <p class="text-wood/70 italic">Chưa có sản phẩm nào được cập nhật.</p>
      </div>
    {% endif %}
  </section>

  <!-- Latest Posts Section -->
  <section class="py-16 px-4 md:px-8 max-w-7xl mx-auto section-animate opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-200">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-serif mb-4">Câu chuyện Mộc</h2>
      <div class="w-16 h-0.5 bg-wood mx-auto"></div>
    </div>

    {% if posts.size > 0 %}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {% for post in posts %}
          <article class="bg-white group overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <a href="/posts/{{ post.slug }}" class="block">
              <div class="aspect-[16/10] overflow-hidden relative">
                {% if post.coverImage %}
                  <img src="{{ post.coverImage }}" alt="{{ post.title }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                {% else %}
                  <div class="w-full h-full bg-gray-100 flex items-center justify-center text-gray-400 text-sm">Không có ảnh</div>
                {% endif %}
              </div>
              <div class="p-6">
                <time class="text-xs text-wood/60 uppercase tracking-wider mb-3 block">{{ post.publishedAt | date: "%d/%m/%Y" }}</time>
                <h3 class="font-serif text-xl mb-3 group-hover:text-wood/70 transition-colors line-clamp-2">{{ post.title }}</h3>
                <p class="text-wood/80 text-sm line-clamp-3 mb-4">{{ post.excerpt }}</p>
                <span class="text-xs font-medium uppercase tracking-widest border-b border-wood pb-1 inline-block group-hover:text-wood/70 group-hover:border-wood/70 transition-colors">Đọc thêm</span>
              </div>
            </a>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="text-center py-12 bg-white/50 border border-wood/10">
        <p class="text-wood/70 italic">Chưa có bài viết nào.</p>
      </div>
    {% endif %}
  </section>
</main>
{% endblock %}
{% layout "layout" %}

{% block content %}
<main class="bg-[#FDFBF7] min-h-screen py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto reveal">
    <header class="text-center mb-12">
      <h1 class="font-playfair text-4xl md:text-5xl text-[#5C4033] mb-4">{{ page.title }}</h1>
      <div class="w-16 h-0.5 bg-[#8B5A2B] mx-auto"></div>
    </header>

    <article class="prose prose-stone prose-lg max-w-none font-inter text-gray-700 page-body">
      {{ page.body }}
    </article>
  </div>
</main>
{% endblock %}
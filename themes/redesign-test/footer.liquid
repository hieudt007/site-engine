<footer class="bg-wood text-cream pt-16 pb-8 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-12">
      <div class="md:col-span-5">
        <h2 class="font-serif text-3xl mb-6">{{ site.siteName }}</h2>
        <p class="font-sans text-sm leading-relaxed opacity-80 max-w-md">
          Chuyên cung cấp các sản phẩm nội thất gỗ cao cấp, mang đậm phong cách tối giản và sang trọng. Chúng tôi kiến tạo không gian sống hoàn mỹ với những giá trị bền vững vượt thời gian.
        </p>
      </div>
      
      <div class="md:col-span-3 md:col-start-7">
        <h3 class="font-serif text-lg mb-6 tracking-wide">Khám phá</h3>
        <ul class="space-y-4 font-sans text-sm">
          {% for link in footerMenu %}
            <li>
              <a href="{{ link.url }}" class="opacity-80 hover:opacity-100 transition-opacity duration-300 relative inline-block group">
                {{ link.title }}
                <span class="absolute -bottom-1 left-0 w-0 h-[1px] bg-cream transition-all duration-300 group-hover:w-full"></span>
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
      
      <div class="md:col-span-3">
        <h3 class="font-serif text-lg mb-6 tracking-wide">Liên hệ</h3>
        <ul class="space-y-4 font-sans text-sm opacity-80">
          <li>Email: contact@example.com</li>
          <li>Hotline: 1900 1234</li>
          <li>Giờ làm việc: 8:00 - 20:00</li>
        </ul>
      </div>
    </div>
    
    <div class="pt-8 border-t border-cream/20 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-sans opacity-60">
      <p>&copy; {{ "now" | date: "%Y" }} {{ site.siteName }}. All rights reserved.</p>
      <div class="flex space-x-6">
        <a href="#" class="hover:opacity-100 transition-opacity">Chính sách bảo mật</a>
        <a href="#" class="hover:opacity-100 transition-opacity">Điều khoản dịch vụ</a>
      </div>
    </div>
  </div>
</footer>
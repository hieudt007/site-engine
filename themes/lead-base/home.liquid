{% layout "layout" %}
{% block content %}
<section class="text-center py-10 border-b border-gray-200 mb-10">
  <h1 class="text-3xl font-bold mb-2">{{ site.siteName }}</h1>
  {% if site.tagline %}<p class="text-gray-500 text-lg">{{ site.tagline }}</p>{% endif %}
  <div class="flex justify-center gap-4 mt-5">
    <a href="/products" class="bg-brand hover:bg-brand-dark text-white no-underline px-5 py-2.5 rounded-md text-sm">Xem sản phẩm</a>
    <a href="/blog" class="border border-gray-300 hover:border-brand text-gray-700 no-underline px-5 py-2.5 rounded-md text-sm">Đọc blog</a>
  </div>
</section>

{% if products.size > 0 %}
  <section class="mb-12">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold">Sản phẩm mới</h2>
      <a href="/products" class="text-brand text-sm">Xem tất cả →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-5">
      {% for product in products %}
        <a href="/products/{{ product.id }}" class="no-underline text-inherit border border-gray-200 rounded-lg overflow-hidden bg-white hover:border-brand transition-colors">
          {% if product.imageUrls.size > 0 %}
            <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}" class="w-full h-36 object-cover">
          {% else %}
            <div class="w-full h-36 bg-gray-100"></div>
          {% endif %}
          <div class="p-3">
            <div class="text-sm text-gray-900 mb-1">{{ product.name | escape }}</div>
            {% if product.salePrice %}
              <div><span class="text-red-600 font-semibold">{{ product.salePrice }}₫</span> <span class="text-gray-400 line-through text-sm">{{ product.price }}₫</span></div>
            {% else %}
              <div class="font-semibold">{{ product.price }}₫</div>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </section>
{% endif %}

{% if posts.size > 0 %}
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold">Bài viết mới</h2>
      <a href="/blog" class="text-brand text-sm">Xem tất cả →</a>
    </div>
    <div class="flex flex-col gap-6">
      {% for post in posts %}
        <article class="flex gap-4 items-start">
          {% if post.coverImage %}
            <a href="/blog/{{ post.slug }}" class="shrink-0">
              <img src="{{ post.coverImage }}" alt="{{ post.title }}" class="w-28 h-20 object-cover rounded-md">
            </a>
          {% endif %}
          <div>
            <h3 class="font-semibold mb-1">
              <a href="/blog/{{ post.slug }}" class="text-gray-900 no-underline hover:text-brand">{{ post.title | escape }}</a>
            </h3>
            <div class="text-gray-400 text-xs mb-1">{{ post.publishedAt | date: "%d/%m/%Y" }}</div>
            {% if post.excerpt %}<p class="text-gray-600 text-sm">{{ post.excerpt | escape }}</p>{% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </section>
{% endif %}

{% if posts.size == 0 and products.size == 0 %}
  <p class="text-gray-500 text-center">Chưa có nội dung nào được xuất bản.</p>
{% endif %}
{% endblock %}

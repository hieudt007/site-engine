{% layout "layout" %}
{% block content %}
<a href="/products">← Tất cả sản phẩm</a>

<h1>{{ category.name | escape }}</h1>
{% if category.excerpt %}<p>{{ category.excerpt | escape }}</p>{% endif %}
{% if category.body %}<div>{{ category.body }}</div>{% endif %}
{% render "custom-fields", fields: category.customFields %}

{% if category.children.size > 0 %}
  <div>
    {% for child in category.children %}
      <a href="/products/danh-muc/{{ child.slug }}">{{ child.name | escape }}</a>
    {% endfor %}
  </div>
{% endif %}

{% if products.size == 0 %}
  <p>Chưa có sản phẩm nào trong danh mục này.</p>
{% else %}
  <div>
    {% for product in products %}
      <a href="/products/{{ product.id }}">
        {% if product.imageUrls.size > 0 %}
          <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}">
        {% endif %}
        <div>{{ product.name | escape }}</div>
        {% if product.salePrice %}
          <div>{{ product.salePrice }}₫ {{ product.price }}₫</div>
        {% else %}
          <div>{{ product.price }}₫</div>
        {% endif %}
      </a>
    {% endfor %}
  </div>

  <div>
    {% if hasPrev %}<a href="/products/danh-muc/{{ category.slug }}?page={{ prevPage }}">← Trang trước</a>{% else %}<span></span>{% endif %}
    {% if hasNext %}<a href="/products/danh-muc/{{ category.slug }}?page={{ nextPage }}">Trang sau →</a>{% endif %}
  </div>
{% endif %}
{% endblock %}

{% layout "layout" %}
{% block content %}
<a href="{{ backHref | default: "/products" }}">← {{ backLabel | default: "Tất cả sản phẩm" }}</a>

<h1>{{ category.name | escape }}</h1>
{% if category.excerpt %}<p>{{ category.excerpt | escape }}</p>{% endif %}
{% if category.body %}<div>{{ category.body }}</div>{% endif %}
{% render "custom-fields", fields: category.customFields %}

{% if category.faq and category.faq.size > 0 %}
  <div style="margin-top: 2rem;">
    <h2>Câu hỏi thường gặp</h2>
    <dl>
      {% for item in category.faq %}
        <dt style="font-weight: bold; margin-top: 1rem;">{{ item.question | escape }}</dt>
        <dd style="margin-left: 0; margin-bottom: 1rem;">{{ item.answer | escape | newline_to_br }}</dd>
      {% endfor %}
    </dl>
  </div>
{% endif %}

{% if category.children.size > 0 %}
  <div> 
    {% for child in category.children %}
      <a href="{{ childPathPrefix | default: productCategoryPathPrefix }}/{{ child.slug }}">{{ child.name | escape }}</a>
    {% endfor %}
  </div>
{% endif %}

{% if products.size == 0 %}
  <p>{{ emptyText | default: "Chưa có sản phẩm nào trong danh mục này." }}</p>
{% else %}
  <div>
    {% for product in products %}
      {% render "components/product/card", product: product, variant: "category", productUrlPrefix: productUrlPrefix %}
    {% endfor %}
  </div>

  {% render "components/common/pagination", basePath: categoryPath, hasPrev: hasPrev, hasNext: hasNext, prevPage: prevPage, nextPage: nextPage %}
{% endif %}
{% endblock %}


{% layout "layout" %}
{% block content %}
<h1>{{ pageTitle }}</h1>

{% if products.size == 0 %}
  <p>Chưa có sản phẩm nào.</p>
{% else %}
  <div>
    {% for product in products %}
      <a href="/products/{{ product.id }}">
        {% if product.imageUrls.size > 0 %}
          <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}">
        {% endif %}
        <div>{{ product.name | escape }}</div>
        {% if product.salePrice %}
          <div>{{ product.salePrice }}₫ {{ product.price }}₫</div>
        {% else %}
          <div>{{ product.price }}₫</div>
        {% endif %}
      </a>
    {% endfor %}
  </div>

  <div>
    {% if hasPrev %}<a href="/products?page={{ prevPage }}">← Trang trước</a>{% else %}<span></span>{% endif %}
    {% if hasNext %}<a href="/products?page={{ nextPage }}">Trang sau →</a>{% endif %}
  </div>
{% endif %}
{% endblock %}

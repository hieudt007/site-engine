{% layout "layout" %}
{% block content %}
<h1 class="text-2xl font-bold mt-0 mb-6">{{ pageTitle }}</h1>

{% if products.size == 0 %}
  <p class="text-gray-500">Chưa có sản phẩm nào.</p>
{% else %}
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-5">
    {% for product in products %}
      <a href="/products/{{ product.id }}" class="no-underline text-inherit border border-gray-200 rounded-lg overflow-hidden bg-white hover:border-brand transition-colors">
        {% if product.imageUrls.size > 0 %}
          <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}" class="w-full h-44 object-cover">
        {% else %}
          <div class="w-full h-44 bg-gray-100"></div>
        {% endif %}
        <div class="p-3">
          <div class="text-sm text-gray-900 mb-1">{{ product.name | escape }}</div>
          {% if product.salePrice %}
            <div><span class="text-red-600 font-semibold">{{ product.salePrice }}₫</span> <span class="text-gray-400 line-through text-sm">{{ product.price }}₫</span></div>
          {% else %}
            <div class="font-semibold">{{ product.price }}₫</div>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>

  <div class="flex justify-between mt-8 text-sm">
    {% if hasPrev %}<a href="/products?page={{ prevPage }}" class="text-brand">← Trang trước</a>{% else %}<span></span>{% endif %}
    {% if hasNext %}<a href="/products?page={{ nextPage }}" class="text-brand">Trang sau →</a>{% endif %}
  </div>
{% endif %}
{% endblock %}

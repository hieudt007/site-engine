{% layout "layout" %}
{% block content %}
<h1>{{ pageTitle }}</h1>

{% if products.size == 0 %}
  <p>Chưa có sản phẩm nào.</p>
{% else %}
  <div>
    {% for product in products %}
      {% render "components/product/card", product: product, variant: "list", productUrlPrefix: productUrlPrefix %}
    {% endfor %}
  </div>

  {% render "components/common/pagination", basePath: "/products", hasPrev: hasPrev, hasNext: hasNext, prevPage: prevPage, nextPage: nextPage %}
{% endif %}
{% endblock %}

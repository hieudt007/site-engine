{% if blocks.size > 0 %}
  <div class="plugin-area">
    {% for block in blocks %}
      <section class="plugin-block plugin-block--{{ block.variant }}">
        {% if block.title %}<h2>{{ block.title | escape }}</h2>{% endif %}
        {% if block.variant == "form" and block.action %}
          <form class="plugin-action-form" data-plugin-slug="{{ block.pluginSlug | escape }}" data-action-key="{{ block.actionKey | escape }}">
            <input type="text" name="website" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" aria-hidden="true">
            {% for field in block.action.fields %}
              <label>
                <span>{{ field.label | default: field.name | escape }}</span>
                {% if field.type == "textarea" %}
                  <textarea name="{{ field.name | escape }}" {% if field.required %}required{% endif %} maxlength="{{ field.maxLength }}"></textarea>
                {% elsif field.type == "select" %}
                  <select name="{{ field.name | escape }}" {% if field.required %}required{% endif %}>
                    <option value=""></option>
                    {% for option in field.options %}
                      <option value="{{ option | escape }}">{{ option | escape }}</option>
                    {% endfor %}
                  </select>
                {% elsif field.type == "checkbox" %}
                  <input type="checkbox" name="{{ field.name | escape }}" value="true">
                {% else %}
                  <input type="{{ field.type | escape }}" name="{{ field.name | escape }}" {% if field.required %}required{% endif %} maxlength="{{ field.maxLength }}">
                {% endif %}
              </label>
            {% endfor %}
            <button type="submit">{{ block.action.submitLabel | default: "Submit" | escape }}</button>
            <div class="plugin-action-form__message" aria-live="polite"></div>
          </form>
        {% elsif block.variant == "json" %}
          <pre>{{ block.items | json }}</pre>
        {% elsif block.variant == "chat" %}
          {% render "components/plugin/blocks/chat", block: block, site: site, chatSessionId: chatSessionId, chatHmacToken: chatHmacToken %}
        {% elsif block.items.size > 0 %}
          <div class="plugin-block__items">
            {% for item in block.items %}
              {% assign payload = item.data | default: item %}
              <article class="plugin-block__item">
                {% if payload.imageUrl %}
                  <img src="{{ payload.imageUrl | escape }}" alt="{{ payload.title | default: payload.name | default: block.title | escape }}">
                {% endif %}
                {% if payload.title or payload.name %}
                  <h3>{{ payload.title | default: payload.name | escape }}</h3>
                {% endif %}
                {% if payload.excerpt or payload.description %}
                  <p>{{ payload.excerpt | default: payload.description | escape }}</p>
                {% endif %}
                {% if payload.url %}
                  <a href="{{ payload.url | escape }}">{{ payload.linkLabel | default: "View" | escape }}</a>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        {% endif %}
      </section>
    {% endfor %}
  </div>
{% endif %}

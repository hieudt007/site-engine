{% layout "layout" %}
{% block content %}
{% render "components/plugin/area", blocks: pluginAreas.home_top %}

<section>
  <h1>{{ site.siteName }}</h1>
  {% if site.tagline %}<p>{{ site.tagline }}</p>{% endif %}
  <a href="/products">Xem sản phẩm</a>
  <a href="/blog">Đọc blog</a>
</section>

{% if products.size > 0 %}
  <section>
    <h2>Sản phẩm mới</h2>
    <a href="/products">Xem tất cả →</a>
    {% for product in products %}
      {% render "components/product/card", product: product, variant: "home", productUrlPrefix: productUrlPrefix %}
    {% endfor %}
  </section>
{% endif %}

{% render "components/plugin/area", blocks: pluginAreas.home_after_products %}

{% if posts.size > 0 %}
  <section>
    <h2>Bài viết mới</h2>
    <a href="/blog">Xem tất cả →</a>
    {% for post in posts %}
      {% render "components/post/card", post: post, variant: "home", postUrlPrefix: postUrlPrefix, postCategoryPathPrefix: postCategoryPathPrefix %}
    {% endfor %}
  </section>
{% endif %}

{% if posts.size == 0 and products.size == 0 %}
  <p>Chưa có nội dung nào được xuất bản.</p>
{% endif %}
{% render "components/plugin/area", blocks: pluginAreas.home_bottom %}
{% endblock %}

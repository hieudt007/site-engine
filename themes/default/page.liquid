{% layout "layout" %}
{% block content %}
<article>
  {% if page.coverImage %}
    <img src="{{ page.coverImage }}" alt="{{ page.title }}" style="width:100%;max-height:360px;object-fit:cover;border-radius:8px;">
  {% endif %}
  <h1 style="margin-bottom:1.5rem;">{{ page.title | escape }}</h1>
  <div style="line-height:1.7;font-size:1.05rem;">
    {{ page.body }}
  </div>
</article>
{% endblock %}

{% layout "layout" %}
{% block content %}
<a href="/blog">← Tất cả bài viết</a>

<article>
  {% if post.coverImage %}
    <img src="{{ post.coverImage }}" alt="{{ post.title }}">
  {% endif %}
  <h1>{{ post.title | escape }}</h1>
  <div>
    {{ post.publishedAt | date: "%d/%m/%Y" }}{% for c in post.categories %} · <a href="/blog/danh-muc/{{ c.slug }}">{{ c.name | escape }}</a>{% endfor %}
  </div>
  <div>
    {{ post.body }}
  </div>
  {% render "custom-fields", fields: post.customFields %}
</article>
{% endblock %}

{% layout "layout" %}
{% block content %}
<a href="/blog" style="color:#777;font-size:0.9rem;">← Tất cả bài viết</a>

<article style="margin-top:1rem;">
  {% if post.coverImage %}
    <img src="{{ post.coverImage }}" alt="{{ post.title }}" style="width:100%;max-height:360px;object-fit:cover;border-radius:8px;">
  {% endif %}
  <h1 style="margin-bottom:0.25rem;">{{ post.title | escape }}</h1>
  <div style="color:#999;font-size:0.85rem;margin-bottom:1.5rem;">
    {{ post.publishedAt | date: "%d/%m/%Y" }}{% if post.authorName %} · {{ post.authorName | escape }}{% endif %}
  </div>
  <div style="line-height:1.7;font-size:1.05rem;">
    {{ post.body }}
  </div>
</article>
{% endblock %}

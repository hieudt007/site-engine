<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.siteName }}</title>
  {% if metaDescription %}<meta name="description" content="{{ metaDescription }}">{% endif %}
  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  {% if site.faviconUrl %}<link rel="icon" href="{{ site.faviconUrl }}">{% endif %}
  <link rel="alternate" type="application/rss+xml" title="{{ site.siteName }} RSS" href="/feed.xml">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/theme-assets/{{ themeSlug }}/assets/custom.css">
</head>
<body>
  {% render "header", site: site, headerMenu: headerMenu %}

  <main style="max-width:1200px;margin:0 auto;">
    {% render "components/common/breadcrumb", breadcrumbs: breadcrumbs, breadcrumbVariant: breadcrumbVariant %}
    {% block content %}{% endblock %}
  </main>

  {% render "components/plugin/area", blocks: pluginAreas.layout_before_footer %}
  {% render "footer", site: site, footerMenu: footerMenu, year: year %}
  <script src="/theme-assets/{{ themeSlug }}/assets/custom.js" defer></script>
</body>
</html>

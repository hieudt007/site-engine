<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.siteName }}</title>
  {% if metaDescription %}<meta name="description" content="{{ metaDescription }}">{% endif %}
  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  {% if site.faviconUrl %}<link rel="icon" href="{{ site.faviconUrl }}">{% endif %}
  <link rel="alternate" type="application/rss+xml" title="{{ site.siteName }} RSS" href="/feed.xml">
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; color: #1a1a1a; background: #fafafa; }
    header.site-header { background: #fff; border-bottom: 1px solid #eee; padding: 1rem 1.5rem; }
    header.site-header a.brand { font-weight: 700; font-size: 1.1rem; color: #111; text-decoration: none; }
    header.site-header .tagline { color: #777; font-size: 0.85rem; margin-top: 0.15rem; }
    main { max-width: 760px; margin: 0 auto; padding: 2rem 1.5rem; }
    footer.site-footer { text-align: center; color: #999; font-size: 0.8rem; padding: 2rem 1rem; }
    a { color: #2563eb; }
  </style>
</head>
<body>
  <header class="site-header" style="display:flex;align-items:center;justify-content:space-between;">
    <div>
      <a class="brand" href="/" style="display:inline-flex;align-items:center;gap:0.5rem;">
        {% if site.logoUrl %}<img src="{{ site.logoUrl }}" alt="{{ site.siteName }}" style="height:28px;">{% endif %}
        {{ site.siteName }}
      </a>
      {% if site.tagline %}<div class="tagline">{{ site.tagline }}</div>{% endif %}
    </div>
    <nav>
      {% if headerMenu and headerMenu.items.size > 0 %}
        {% for item in headerMenu.items %}<a href="{{ item.url }}" style="margin-right:1rem;">{{ item.label | escape }}</a>{% endfor %}
      {% else %}
        <a href="/products" style="margin-right:1rem;">Sản phẩm</a>
        <a href="/blog" style="margin-right:1rem;">Blog</a>
        <a href="/cart">Giỏ hàng</a>
      {% endif %}
    </nav>
  </header>
  <main>
    {% block content %}{% endblock %}
  </main>
  <footer class="site-footer">
    {% if footerMenu and footerMenu.items.size > 0 %}
      <nav style="margin-bottom:0.6rem;">
        {% for item in footerMenu.items %}<a href="{{ item.url }}" style="margin:0 0.6rem;color:#777;">{{ item.label | escape }}</a>{% endfor %}
      </nav>
    {% endif %}
    © {{ year }} {{ site.siteName }}
  </footer>
</body>
</html>

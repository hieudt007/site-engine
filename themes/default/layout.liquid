<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.siteName }}</title>
  {% if metaDescription %}<meta name="description" content="{{ metaDescription }}">{% endif %}
  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; color: #1a1a1a; background: #fafafa; }
    header.site-header { background: #fff; border-bottom: 1px solid #eee; padding: 1rem 1.5rem; }
    header.site-header a.brand { font-weight: 700; font-size: 1.1rem; color: #111; text-decoration: none; }
    header.site-header .tagline { color: #777; font-size: 0.85rem; margin-top: 0.15rem; }
    main { max-width: 760px; margin: 0 auto; padding: 2rem 1.5rem; }
    footer.site-footer { text-align: center; color: #999; font-size: 0.8rem; padding: 2rem 1rem; }
    a { color: #2563eb; }
  </style>
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/">{{ site.siteName }}</a>
    {% if site.tagline %}<div class="tagline">{{ site.tagline }}</div>{% endif %}
  </header>
  <main>
    {% block content %}{% endblock %}
  </main>
  <footer class="site-footer">© {{ year }} {{ site.siteName }}</footer>
</body>
</html>

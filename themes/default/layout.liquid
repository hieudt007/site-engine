<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.siteName }}</title>
  {% if metaDescription %}<meta name="description" content="{{ metaDescription }}">{% endif %}
  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  {% if site.faviconUrl %}<link rel="icon" href="{{ site.faviconUrl }}">{% endif %}
  <link rel="alternate" type="application/rss+xml" title="{{ site.siteName }} RSS" href="/feed.xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com?plugins=typography,forms"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ["Inter", "sans-serif"] },
          colors: { brand: { DEFAULT: "#2563eb", dark: "#1d4ed8" } },
        },
      },
    };
  </script>
</head>
<body class="font-sans text-gray-900 bg-gray-50 flex flex-col min-h-screen">
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between flex-wrap gap-3">
      <div>
        <a href="/" class="inline-flex items-center gap-2 font-bold text-lg text-gray-900 no-underline">
          {% if site.logoUrl %}<img src="{{ site.logoUrl }}" alt="{{ site.siteName }}" class="h-7">{% endif %}
          {{ site.siteName }}
        </a>
        {% if site.tagline %}<div class="text-sm text-gray-500 mt-0.5">{{ site.tagline }}</div>{% endif %}
      </div>
      <nav class="flex items-center gap-5 text-sm">
        {% if headerMenu and headerMenu.items.size > 0 %}
          {% for item in headerMenu.items %}<a href="{{ item.url }}" class="text-gray-700 hover:text-brand">{{ item.label | escape }}</a>{% endfor %}
        {% else %}
          <a href="/products" class="text-gray-700 hover:text-brand">Sản phẩm</a>
          <a href="/blog" class="text-gray-700 hover:text-brand">Blog</a>
          <a href="/cart" class="text-gray-700 hover:text-brand">Giỏ hàng</a>
        {% endif %}
      </nav>
    </div>
  </header>

  <main class="flex-1 max-w-3xl w-full mx-auto px-6 py-10">
    {% block content %}{% endblock %}
  </main>

  <footer class="text-center text-gray-400 text-sm py-8 border-t border-gray-200">
    {% if footerMenu and footerMenu.items.size > 0 %}
      <nav class="mb-2 flex items-center justify-center gap-4">
        {% for item in footerMenu.items %}<a href="{{ item.url }}" class="text-gray-500 hover:text-brand">{{ item.label | escape }}</a>{% endfor %}
      </nav>
    {% endif %}
    © {{ year }} {{ site.siteName }}
  </footer>
</body>
</html>

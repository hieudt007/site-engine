<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.siteName }}</title>
  {% if metaDescription %}<meta name="description" content="{{ metaDescription }}">{% endif %}
  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  {% if site.faviconUrl %}<link rel="icon" href="{{ site.faviconUrl }}">{% endif %}
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/theme-assets/{{ themeSlug }}/assets/custom.css">
</head>
<body>
{{ rawHtml }}
{% render "components/common/cart-drawer" %}
<script src="/theme-assets/{{ themeSlug }}/assets/custom.js" defer></script>
</body>
</html>

{% layout "layout" %}
{% block content %}
<h1 class="text-2xl font-bold mt-0 mb-6">{{ pageTitle }}</h1>

{% if posts.size == 0 %}
  <p class="text-gray-500">Chưa có bài viết nào.</p>
{% else %}
  <div class="flex flex-col gap-8">
    {% for post in posts %}
      <article class="border-b border-gray-200 pb-8">
        {% if post.coverImage %}
          <a href="/blog/{{ post.slug }}">
            <img src="{{ post.coverImage }}" alt="{{ post.title }}" class="w-full max-h-72 object-cover rounded-lg mb-3">
          </a>
        {% endif %}
        <h2 class="text-xl font-semibold mb-1">
          <a href="/blog/{{ post.slug }}" class="text-gray-900 no-underline hover:text-brand">{{ post.title | escape }}</a>
        </h2>
        <div class="text-gray-400 text-sm mb-2">
          {{ post.publishedAt | date: "%d/%m/%Y" }}{% for c in post.categories %} · <a href="/blog/danh-muc/{{ c.slug }}" class="text-gray-400 hover:text-brand">{{ c.name | escape }}</a>{% endfor %}
        </div>
        {% if post.excerpt %}<p class="text-gray-600">{{ post.excerpt | escape }}</p>{% endif %}
        <a href="/blog/{{ post.slug }}" class="text-brand text-sm font-medium">Đọc tiếp →</a>
      </article>
    {% endfor %}
  </div>

  <div class="flex justify-between mt-8 text-sm">
    {% if hasPrev %}<a href="/blog?page={{ prevPage }}" class="text-brand">← Trang trước</a>{% else %}<span></span>{% endif %}
    {% if hasNext %}<a href="/blog?page={{ nextPage }}" class="text-brand">Trang sau →</a>{% endif %}
  </div>
{% endif %}
{% endblock %}

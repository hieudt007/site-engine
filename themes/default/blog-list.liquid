{% layout "layout" %}
{% block content %}
<h1>{{ pageTitle }}</h1>

{% if posts.size == 0 %}
  <p>Chưa có bài viết nào.</p>
{% else %}
  <div>
    {% for post in posts %}
      <article>
        {% if post.coverImage %}
          <a href="/blog/{{ post.slug }}">
            <img src="{{ post.coverImage }}" alt="{{ post.title }}">
          </a>
        {% endif %}
        <h2>
          <a href="/blog/{{ post.slug }}">{{ post.title | escape }}</a>
        </h2>
        <div>
          {{ post.publishedAt | date: "%d/%m/%Y" }}{% for c in post.categories %} · <a href="/blog/danh-muc/{{ c.slug }}">{{ c.name | escape }}</a>{% endfor %}
        </div>
        {% if post.excerpt %}<p>{{ post.excerpt | escape }}</p>{% endif %}
        <a href="/blog/{{ post.slug }}">Đọc tiếp →</a>
      </article>
    {% endfor %}
  </div>

  <div>
    {% if hasPrev %}<a href="/blog?page={{ prevPage }}">← Trang trước</a>{% else %}<span></span>{% endif %}
    {% if hasNext %}<a href="/blog?page={{ nextPage }}">Trang sau →</a>{% endif %}
  </div>
{% endif %}
{% endblock %}

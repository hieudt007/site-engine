{% layout "layout" %}
{% block content %}
<a href="/blog">← Tất cả bài viết</a>

<h1>{{ category.name | escape }}</h1>
{% if category.excerpt %}<p>{{ category.excerpt | escape }}</p>{% endif %}
{% if category.body %}<div>{{ category.body }}</div>{% endif %}
{% render "custom-fields", fields: category.customFields %}

{% if category.children.size > 0 %}
  <div>
    {% for child in category.children %}
      <a href="/blog/danh-muc/{{ child.slug }}">{{ child.name | escape }}</a>
    {% endfor %}
  </div>
{% endif %}

{% if posts.size == 0 %}
  <p>Chưa có bài viết nào trong danh mục này.</p>
{% else %}
  <div>
    {% for post in posts %}
      <article>
        {% if post.coverImage %}
          <a href="/blog/{{ post.slug }}">
            <img src="{{ post.coverImage }}" alt="{{ post.title }}">
          </a>
        {% endif %}
        <h2>
          <a href="/blog/{{ post.slug }}">{{ post.title | escape }}</a>
        </h2>
        <div>{{ post.publishedAt | date: "%d/%m/%Y" }}</div>
        {% if post.excerpt %}<p>{{ post.excerpt | escape }}</p>{% endif %}
        <a href="/blog/{{ post.slug }}">Đọc tiếp →</a>
      </article>
    {% endfor %}
  </div>

  <div>
    {% if hasPrev %}<a href="/blog/danh-muc/{{ category.slug }}?page={{ prevPage }}">← Trang trước</a>{% else %}<span></span>{% endif %}
    {% if hasNext %}<a href="/blog/danh-muc/{{ category.slug }}?page={{ nextPage }}">Trang sau →</a>{% endif %}
  </div>
{% endif %}
{% endblock %}

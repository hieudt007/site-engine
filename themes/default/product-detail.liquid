{% layout "layout" %}
{% block content %}
<a href="/products" style="color:#777;font-size:0.9rem;">← Tất cả sản phẩm</a>

<article style="margin-top:1rem;">
  {% if product.imageUrls.size > 0 %}
    <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}" style="width:100%;max-height:420px;object-fit:cover;border-radius:8px;">
  {% endif %}
  <h1 style="margin-bottom:0.5rem;">{{ product.name | escape }}</h1>
  <div style="margin-bottom:1rem;">
    {% if product.salePrice %}
      <span style="color:#dc2626;font-weight:700;font-size:1.4rem;">{{ product.salePrice }}₫</span>
      <span style="color:#999;text-decoration:line-through;margin-left:0.5rem;">{{ product.price }}₫</span>
    {% else %}
      <span style="font-weight:700;font-size:1.4rem;">{{ product.price }}₫</span>
    {% endif %}
  </div>
  {% if product.stock != nil and product.stock <= 0 %}
    <div style="color:#dc2626;font-size:0.9rem;margin-bottom:1rem;">Hết hàng</div>
  {% else %}
    <button id="add-to-cart" data-id="{{ product.id }}" style="background:#2563eb;color:#fff;border:none;padding:0.65rem 1.4rem;border-radius:6px;font-size:0.95rem;cursor:pointer;margin-bottom:1rem;">Thêm vào giỏ</button>
    <span id="add-to-cart-msg" style="color:#16a34a;font-size:0.85rem;margin-left:0.5rem;"></span>
  {% endif %}
  {% if product.description %}
    <div style="line-height:1.7;">{{ product.description | escape | newline_to_br }}</div>
  {% endif %}

  {% if product.imageUrls.size > 1 %}
    <div style="display:flex;gap:0.5rem;margin-top:1.5rem;flex-wrap:wrap;">
      {% for url in product.imageUrls offset: 1 %}
        <img src="{{ url }}" alt="{{ product.name | escape }}" style="width:90px;height:90px;object-fit:cover;border-radius:6px;">
      {% endfor %}
    </div>
  {% endif %}
</article>

<script>
(function () {
  const btn = document.getElementById("add-to-cart");
  if (!btn) return;
  btn.addEventListener("click", () => {
    const CART_KEY = "site_engine_cart";
    const cart = JSON.parse(localStorage.getItem(CART_KEY) || "[]");
    const existing = cart.find((c) => c.productId === btn.dataset.id);
    if (existing) {
      existing.quantity += 1;
    } else {
      cart.push({ productId: btn.dataset.id, quantity: 1 });
    }
    localStorage.setItem(CART_KEY, JSON.stringify(cart));
    document.getElementById("add-to-cart-msg").textContent = "Đã thêm vào giỏ — xem giỏ hàng";
  });
})();
</script>
{% endblock %}

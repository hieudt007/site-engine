{% layout "layout" %}
{% block content %}
<!-- Header Section -->
<div class="bg-slate-900 text-white pt-12 pb-16">
    <div class="container mx-auto px-4">
        <a href="/products" class="inline-flex items-center text-slate-400 hover:text-white mb-6 transition-colors text-sm font-medium">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Tất cả giải pháp
        </a>
        
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 tracking-tight">{{ category.name | escape }}</h1>
        
        {% if category.excerpt %}
            <p class="text-lg text-slate-300 max-w-3xl mb-6 leading-relaxed">{{ category.excerpt | escape }}</p>
        {% endif %}
        
        {% if category.body %}
            <div class="category-body-content max-w-3xl mb-8">{{ category.body }}</div>
        {% endif %}
        
        <div class="mt-6">
            {% render "custom-fields", fields: category.customFields %}
        </div>
    </div>
</div>

<!-- Main Content Section -->
<div class="container mx-auto px-4 py-12">
    
    <!-- Child Categories -->
    {% if category.children.size > 0 %}
    <div class="mb-10">
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4">Danh mục con</h2>
        <div class="flex flex-wrap gap-3">
            {% for child in category.children %}
                <a href="/products/danh-muc/{{ child.slug }}" class="inline-block bg-slate-100 text-slate-700 hover:bg-blue-600 hover:text-white px-5 py-2 rounded-full text-sm font-medium transition-colors shadow-sm">
                    {{ child.name | escape }}
                </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <!-- Product Grid -->
    {% if products.size == 0 %}
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-16 text-center">
            <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
            <h3 class="text-xl font-medium text-slate-700 mb-2">Chưa có giải pháp nào</h3>
            <p class="text-slate-500">Chúng tôi đang cập nhật các giải pháp cho danh mục này. Vui lòng quay lại sau.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {% for product in products %}
                <a href="/products/{{ product.id }}" class="category-product-card group bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg transition-all duration-300 flex flex-col opacity-0 translate-y-4">
                    <div class="relative aspect-[4/3] bg-slate-50 overflow-hidden">
                        {% if product.imageUrls.size > 0 %}
                            <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center text-slate-300">
                                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            </div>
                        {% endif %}
                    </div>
                    <div class="p-5 flex flex-col flex-grow">
                        <h3 class="text-lg font-semibold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">{{ product.name | escape }}</h3>
                        <div class="mt-auto pt-4 flex items-end gap-2">
                            {% if product.salePrice %}
                                <span class="text-xl font-bold text-blue-600 category-product-price" data-price="{{ product.salePrice }}">{{ product.salePrice }}₫</span>
                                <span class="text-sm text-slate-400 line-through category-product-price" data-price="{{ product.price }}">{{ product.price }}₫</span>
                            {% else %}
                                <span class="text-xl font-bold text-slate-900 category-product-price" data-price="{{ product.price }}">{{ product.price }}₫</span>
                            {% endif %}
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>

        <!-- Pagination -->
        <div class="mt-12 flex justify-center items-center gap-4">
            {% if hasPrev %}
                <a href="/products/danh-muc/{{ category.slug }}?page={{ prevPage }}" class="inline-flex items-center px-4 py-2 bg-white border border-slate-300 rounded-lg text-slate-700 hover:bg-slate-50 hover:text-blue-600 transition-colors font-medium text-sm shadow-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    Trang trước
                </a>
            {% else %}
                <span class="inline-flex items-center px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-slate-400 cursor-not-allowed font-medium text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    Trang trước
                </span>
            {% endif %}
            
            {% if hasNext %}
                <a href="/products/danh-muc/{{ category.slug }}?page={{ nextPage }}" class="inline-flex items-center px-4 py-2 bg-white border border-slate-300 rounded-lg text-slate-700 hover:bg-slate-50 hover:text-blue-600 transition-colors font-medium text-sm shadow-sm">
                    Trang sau
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
            {% else %}
                <span class="inline-flex items-center px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-slate-400 cursor-not-allowed font-medium text-sm">
                    Trang sau
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </span>
            {% endif %}
        </div>
    {% endif %}
</div>
{% endblock %}
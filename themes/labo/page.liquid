{% layout "layout" %}
{% block content %}
<div class="bg-slate-50 min-h-screen py-12 lg:py-20">
  <div class="container mx-auto px-4 max-w-4xl">
    <article class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
      {% if page.coverImage %}
        <div class="w-full h-64 md:h-96 relative bg-slate-100">
          <img src="{{ page.coverImage }}" alt="{{ page.title | escape }}" class="w-full h-full object-cover">
        </div>
      {% endif %}
      
      <div class="p-6 md:p-12 lg:p-16">
        <header class="mb-10 border-b border-slate-100 pb-8 text-center md:text-left">
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 tracking-tight">{{ page.title | escape }}</h1>
        </header>
        
        <div class="page-content text-slate-700">
          {{ page.body }}
        </div>
      </div>
    </article>
  </div>
</div>
{% endblock %}
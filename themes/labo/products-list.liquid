{% layout "layout" %}
{% block content %}
<div class="bg-slate-900 text-white py-12 md:py-16 mb-10">
  <div class="container mx-auto px-4 text-center">
    <h1 class="text-3xl md:text-4xl font-bold mb-4 text-white">{{ pageTitle | default: "Giải pháp & Dịch vụ" }}</h1>
    <p class="text-slate-400 max-w-2xl mx-auto text-lg">Khám phá các giải pháp phần mềm và dịch vụ giúp tối ưu hóa vận hành doanh nghiệp của bạn.</p>
  </div>
</div>

<div class="container mx-auto px-4 pb-20">
  {% if products.size == 0 %}
    <div class="text-center py-20 bg-white rounded-2xl shadow-sm border border-slate-100 max-w-2xl mx-auto">
      <div class="text-slate-300 mb-5 flex justify-center">
        <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
      </div>
      <h2 class="text-2xl font-semibold text-slate-800 mb-2">Chưa có sản phẩm nào</h2>
      <p class="text-slate-500">Hệ thống đang cập nhật các giải pháp mới. Vui lòng quay lại sau.</p>
    </div>
  {% else %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8 mb-12">
      {% for product in products %}
        <div class="product-card bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 flex flex-col group opacity-0 translate-y-4">
          <a href="/products/{{ product.id }}" class="block relative aspect-[4/3] overflow-hidden bg-slate-50 border-b border-slate-100">
            {% if product.imageUrls.size > 0 %}
              <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
            {% else %}
              <div class="w-full h-full flex items-center justify-center text-slate-300 bg-slate-100">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              </div>
            {% endif %}
            {% if product.salePrice %}
              <span class="absolute top-3 right-3 bg-blue-600 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-sm">Ưu đãi</span>
            {% endif %}
          </a>
          
          <div class="p-5 flex flex-col flex-grow">
            <a href="/products/{{ product.id }}" class="block mb-2">
              <h3 class="text-lg font-semibold text-slate-900 line-clamp-2 group-hover:text-blue-600 transition-colors">{{ product.name | escape }}</h3>
            </a>
            
            <div class="mt-auto pt-4 flex items-center justify-between border-t border-slate-50">
              <div class="flex flex-col">
                {% if product.salePrice %}
                  <div class="flex items-baseline gap-2">
                    <span class="text-lg font-bold text-slate-900"><span class="price-value">{{ product.salePrice }}</span>₫</span>
                    <span class="text-sm text-slate-400 line-through"><span class="price-value">{{ product.price }}</span>₫</span>
                  </div>
                {% else %}
                  <span class="text-lg font-bold text-slate-900"><span class="price-value">{{ product.price }}</span>₫</span>
                {% endif %}
              </div>
              <a href="/products/{{ product.id }}" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-slate-50 text-slate-600 group-hover:bg-blue-600 group-hover:text-white transition-colors" title="Xem chi tiết">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </a>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="flex justify-center items-center space-x-3 mt-8">
      {% if hasPrev %}
        <a href="/products?page={{ prevPage }}" class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 rounded-lg hover:bg-slate-50 hover:text-blue-600 transition-colors flex items-center shadow-sm font-medium">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
          Trang trước
        </a>
      {% else %}
         <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-400 rounded-lg flex items-center cursor-not-allowed opacity-70 font-medium">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
          Trang trước
        </span>
      {% endif %}
      
      {% if hasNext %}
        <a href="/products?page={{ nextPage }}" class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 rounded-lg hover:bg-slate-50 hover:text-blue-600 transition-colors flex items-center shadow-sm font-medium">
          Trang sau
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      {% else %}
         <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-400 rounded-lg flex items-center cursor-not-allowed opacity-70 font-medium">
          Trang sau
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </span>
      {% endif %}
    </div>
  {% endif %}
</div>
{% endblock %}
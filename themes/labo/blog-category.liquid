{% layout "layout" %}
{% block content %}
<div class="bg-slate-50 min-h-screen py-12">
  <div class="container mx-auto px-4 max-w-6xl">
    <!-- Breadcrumb / Back Link -->
    <div class="mb-8">
      <a href="/blog" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-blue-900 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Tất cả bài viết
      </a>
    </div>

    <!-- Category Header -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">{{ category.name | escape }}</h1>
      
      {% if category.excerpt %}
        <p class="text-lg text-slate-600 mb-6">{{ category.excerpt | escape }}</p>
      {% endif %}
      
      {% if category.body %}
        <div class="prose prose-slate max-w-none mb-6 text-slate-700 leading-relaxed">{{ category.body }}</div>
      {% endif %}
      
      <div class="mb-2">
        {% render "custom-fields", fields: category.customFields %}
      </div>

      <!-- Subcategories -->
      {% if category.children.size > 0 %}
        <div class="mt-8 pt-6 border-t border-slate-100">
          <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-4">Danh mục con</h3>
          <div class="flex flex-wrap gap-2">
            {% for child in category.children %}
              <a href="/blog/danh-muc/{{ child.slug }}" class="inline-flex items-center px-4 py-2 rounded-full bg-slate-100 text-sm font-medium text-slate-700 hover:bg-blue-900 hover:text-white transition-colors">
                {{ child.name | escape }}
              </a>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>

    <!-- Posts List -->
    {% if posts.size == 0 %}
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-12 text-center">
        <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
        <h3 class="text-xl font-semibold text-slate-900 mb-2">Chưa có bài viết</h3>
        <p class="text-slate-500">Chưa có bài viết nào trong danh mục này. Vui lòng quay lại sau.</p>
      </div>
    {% else %}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        {% for post in posts %}
          <article class="group bg-white rounded-2xl shadow-sm hover:shadow-xl border border-slate-200 overflow-hidden transition-all duration-300 flex flex-col hover:-translate-y-1">
            {% if post.coverImage %}
              <a href="/blog/{{ post.slug }}" class="block aspect-video overflow-hidden relative">
                <img src="{{ post.coverImage }}" alt="{{ post.title }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors duration-300"></div>
              </a>
            {% endif %}
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center text-sm text-slate-500 mb-3">
                <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <time datetime="{{ post.publishedAt }}">{{ post.publishedAt | date: "%d/%m/%Y" }}</time>
              </div>
              <h2 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-blue-600 transition-colors line-clamp-2">
                <a href="/blog/{{ post.slug }}">{{ post.title | escape }}</a>
              </h2>
              {% if post.excerpt %}
                <p class="text-slate-600 mb-6 line-clamp-3 flex-grow">{{ post.excerpt | escape }}</p>
              {% endif %}
              <div class="mt-auto pt-4 border-t border-slate-100">
                <a href="/blog/{{ post.slug }}" class="inline-flex items-center text-sm font-semibold text-blue-600 group-hover:text-blue-800 transition-colors">
                  Đọc tiếp
                  <svg class="w-4 h-4 ml-1.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </a>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>

      <!-- Pagination -->
      {% if hasPrev or hasNext %}
        <div class="flex justify-center items-center space-x-2">
          {% if hasPrev %}
            <a href="/blog/danh-muc/{{ category.slug }}?page={{ prevPage }}" class="inline-flex items-center justify-center px-4 py-2 border border-slate-200 rounded-lg text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 hover:text-blue-600 transition-colors shadow-sm">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
              Trang trước
            </a>
          {% else %}
            <span class="inline-flex items-center justify-center px-4 py-2 border border-slate-100 rounded-lg text-sm font-medium text-slate-400 bg-slate-50 cursor-not-allowed">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
              Trang trước
            </span>
          {% endif %}

          {% if hasNext %}
            <a href="/blog/danh-muc/{{ category.slug }}?page={{ nextPage }}" class="inline-flex items-center justify-center px-4 py-2 border border-slate-200 rounded-lg text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 hover:text-blue-600 transition-colors shadow-sm">
              Trang sau
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </a>
          {% else %}
            <span class="inline-flex items-center justify-center px-4 py-2 border border-slate-100 rounded-lg text-sm font-medium text-slate-400 bg-slate-50 cursor-not-allowed">
              Trang sau
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </span>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>
{% endblock %}
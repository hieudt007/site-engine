{% layout "layout" %}
{% block content %}
<div class="bg-slate-50 min-h-screen py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Giỏ hàng</h1>
      <p class="mt-2 text-sm text-slate-500">Kiểm tra lại thông tin sản phẩm và tiến hành đặt hàng.</p>
    </div>

    <div class="lg:grid lg:grid-cols-12 lg:gap-x-12 lg:items-start">
      <!-- Cột Danh sách sản phẩm -->
      <div class="lg:col-span-7">
        <div id="cart-items" class="bg-white shadow-sm rounded-xl border border-slate-200 overflow-hidden min-h-[200px]">
          <!-- JS sẽ bơm nội dung giỏ hàng vào đây -->
        </div>
      </div>

      <!-- Cột Form thanh toán -->
      <div class="lg:col-span-5 mt-8 lg:mt-0">
        <form id="checkout-form" class="hidden bg-white shadow-sm rounded-xl border border-slate-200 p-6 sm:p-8">
          <h2 class="text-lg font-semibold text-slate-900 mb-6">Thông tin nhận hàng</h2>
          
          <div class="space-y-4 mb-6">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Họ tên *</label>
              <input type="text" name="customerName" placeholder="Nhập họ và tên" required
                class="w-full rounded-lg border-slate-300 py-2.5 px-3 text-sm focus:border-blue-600 focus:ring-blue-600 shadow-sm transition-colors">
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Số điện thoại *</label>
              <input type="tel" name="customerPhone" placeholder="Nhập số điện thoại" required
                class="w-full rounded-lg border-slate-300 py-2.5 px-3 text-sm focus:border-blue-600 focus:ring-blue-600 shadow-sm transition-colors">
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Địa chỉ giao hàng</label>
              <input type="text" name="customerAddress" placeholder="Nhập địa chỉ chi tiết"
                class="w-full rounded-lg border-slate-300 py-2.5 px-3 text-sm focus:border-blue-600 focus:ring-blue-600 shadow-sm transition-colors">
            </div>
            <!-- Trường tùy chỉnh (custom field) tự động được JS thu thập -->
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Ghi chú (Tùy chọn)</label>
              <input type="text" name="orderNotes" placeholder="Ghi chú thêm về thời gian, địa điểm..."
                class="w-full rounded-lg border-slate-300 py-2.5 px-3 text-sm focus:border-blue-600 focus:ring-blue-600 shadow-sm transition-colors">
            </div>
          </div>

          <div class="border-t border-slate-200 pt-6 mb-6">
            <div id="cart-total" class="flex justify-between items-center">
              <!-- JS sẽ bơm tổng tiền vào đây -->
            </div>
          </div>

          <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-600 transition-colors disabled:opacity-70 disabled:cursor-not-allowed">
            Hoàn tất đặt hàng
          </button>
          
          <div id="checkout-error" class="mt-4 text-sm text-red-600 text-center font-medium empty:hidden"></div>
        </form>
      </div>
    </div>
  </div>
</div>
{% endblock %}
<footer class="bg-slate-900 border-t border-slate-800 pt-16 pb-8 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-12 mb-12">
      <div class="md:col-span-5 lg:col-span-4">
        <span class="text-2xl font-bold text-white tracking-tight">{{ site.siteName }}</span>
        <p class="mt-4 text-slate-400 text-sm leading-relaxed">
          Nền tảng quản trị doanh nghiệp toàn diện ứng dụng trí tuệ nhân tạo. Tối ưu hóa quy trình, nâng cao hiệu suất và thúc đẩy tăng trưởng bền vững.
        </p>
      </div>
      
      <div class="md:col-span-7 lg:col-span-8 flex justify-start md:justify-end">
        {% if footerMenu and footerMenu.items.size > 0 %}
          <div class="w-full md:w-auto">
            <h3 class="text-sm font-semibold text-slate-200 tracking-wider uppercase mb-4">Danh mục</h3>
            <nav class="flex flex-col space-y-3">
              {% for item in footerMenu.items %}
                <a href="{{ item.url }}" class="text-slate-400 hover:text-white text-sm transition-colors duration-200">
                  {{ item.label | escape }}
                </a>
              {% endfor %}
            </nav>
          </div>
        {% endif %}
      </div>
    </div>
    
    <div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-sm text-center md:text-left">
        &copy; {{ 'now' | date: "%Y" }} {{ site.siteName }}. Bảo lưu mọi quyền.
      </p>
      <div class="flex space-x-6 text-sm text-slate-500">
        <a href="#" class="hover:text-slate-300 transition-colors">Chính sách bảo mật</a>
        <a href="#" class="hover:text-slate-300 transition-colors">Điều khoản dịch vụ</a>
      </div>
    </div>
  </div>
</footer>
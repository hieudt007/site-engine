{% layout "layout" %}
{% block content %}
<!-- Hero Section -->
<section class="relative bg-gradient-to-br from-blue-900 via-slate-800 to-slate-900 text-white overflow-hidden py-20 lg:py-32">
  <div class="absolute inset-0 hero-pattern opacity-20"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
      {{ site.siteName | default: "Nền tảng AI Vận hành Doanh nghiệp" }}
    </h1>
    <p class="text-lg md:text-xl text-blue-200 max-w-3xl mx-auto mb-10">
      {% if site.tagline %}
        {{ site.tagline }}
      {% else %}
        Tối ưu hóa quy trình, tự động hóa tác vụ và tăng cường hiệu suất với giải pháp phần mềm thông .
      {% endif %}
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/products" class="px-8 py-3.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg font-semibold transition-colors shadow-lg shadow-blue-500/30">
        Khám phá Giải pháp
      </a>
      <a href="/blog" class="px-8 py-3.5 bg-white/10 hover:bg-white/20 text-white rounded-lg font-semibold backdrop-blur-sm transition-colors border border-white/20">
        Đọc Tài liệu & Blog
      </a>
    </div>
  </div>
</section>

<!-- Products / Solutions Section -->
{% if products.size > 0 %}
  <section class="py-16 lg:py-24 bg-slate-50 border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-10">
        <div>
          <h2 class="text-3xl font-bold text-slate-900">Giải pháp & Bảng giá</h2>
          <p class="text-slate-500 mt-2">Các gói dịch vụ phù hợp với mọi quy mô doanh .</p>
        </div>
        <a href="/products" class="hidden sm:inline-flex items-center text-blue-600 hover:text-blue-800 font-medium transition-colors">
          Xem tất cả <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for product in products %}
          <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-slate-200 overflow-hidden flex flex-col">
            {% if product.imageUrls.size > 0 %}
              <div class="h-56 bg-slate-100 relative">
                <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}" class="absolute inset-0 w-full h-full object-cover">
              </div>
            {% else %}
              <div class="h-56 bg-slate-50 border-b border-slate-100 flex items-center justify-center text-slate-300">
                <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              </div>
            {% endif %}
            
            <div class="p-6 flex-1 flex flex-col">
              <h3 class="text-xl font-bold text-slate-900 mb-2">{{ product.name | escape }}</h3>
              <div class="mt-auto pt-4 flex items-center justify-between">
                <div>
                  {% if product.salePrice %}
                    <span class="text-2xl font-bold text-blue-600">{{ product.salePrice }}₫</span>
                    <span class="text-sm text-slate-400 line-through ml-2">{{ product.price }}₫</span>
                  {% else %}
                    <span class="text-2xl font-bold text-slate-900">{{ product.price }}₫</span>
                  {% endif %}
                </div>
              </div>
              <a href="/products/{{ product.id }}" class="mt-6 w-full inline-flex justify-center items-center px-4 py-2 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                Xem chi tiết
              </a>
            </div>
          </div>
        {% endfor %}
      </div>
      
      <div class="mt-8 sm:hidden text-center">
        <a href="/products" class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium">
          Xem tất cả giải pháp <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>
    </div>
  </section>
{% endif %}

<!-- Blog / Updates Section -->
{% if posts.size > 0 %}
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-10">
        <div>
          <h2 class="text-3xl font-bold text-slate-900">Tin tức & Cập nhật</h2>
          <p class="text-slate-500 mt-2">Nắm bắt xu hướng công nghệ và tính năng mới nhất từ hệ thống.</p>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center text-blue-600 hover:text-blue-800 font-medium transition-colors">
          Đọc tất cả <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for post in posts %}
          <article class="group flex flex-col">
            <a href="/blog/{{ post.slug }}" class="block overflow-hidden rounded-xl mb-4 bg-slate-100 h-56 relative">
              {% if post.coverImage %}
                <img src="{{ post.coverImage }}" alt="{{ post.title | escape }}" class="absolute inset-0 w-full h-full object-cover transform transition-transform duration-500 group-hover:scale-105">
              {% else %}
                <div class="absolute inset-0 flex items-center justify-center text-slate-300">
                  <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
                </div>
              {% endif %}
            </a>
            <div class="flex-1 flex flex-col">
              <div class="text-sm text-slate-500 mb-2 font-medium">{{ post.publishedAt | date: "%d/%m/%Y" }}</div>
              <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors">
                <a href="/blog/{{ post.slug }}">{{ post.title | escape }}</a>
              </h3>
              {% if post.excerpt %}
                <p class="text-slate-600 line-clamp-3">{{ post.excerpt | escape }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
      
      <div class="mt-8 sm:hidden text-center">
        <a href="/blog" class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium">
          Đọc tất cả bài viết <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </div>
    </div>
  </section>
{% endif %}

<!-- Empty State -->
{% if posts.size == 0 and products.size == 0 %}
  <section class="py-24 text-center bg-slate-50">
    <div class="max-w-md mx-auto bg-white rounded-xl p-8 border border-slate-200 shadow-sm">
      <svg class="w-12 h-12 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
      <h3 class="text-lg font-bold text-slate-900 mb-2">Hệ thống đang được cập nhật</h3>
      <p class="text-slate-500">Chưa có giải pháp hay bài viết nào được xuất bản. Vui lòng quay lại sau.</p>
    </div>
  </section>
{% endif %}
{% endblock %}
<header class="bg-slate-900 text-white sticky top-0 z-50 border-b border-slate-800 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo & Tagline -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="flex flex-col group">
          <div class="flex items-center gap-2 text-xl font-bold tracking-tight text-white group-hover:text-blue-400 transition-colors">
            {% if site.logoUrl %}
              <img src="{{ site.logoUrl }}" alt="{{ site.siteName }}" class="h-8 w-auto rounded object-contain">
            {% endif %}
            <span>{{ site.siteName }}</span>
          </div>
          {% if site.tagline %}
            <span class="text-[10px] uppercase tracking-wider text-slate-400 font-medium mt-0.5">{{ site.tagline }}</span>
          {% endif %}
        </a>
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden md:flex space-x-8 items-center">
        {% if headerMenu and headerMenu.items.size > 0 %}
          {% for item in headerMenu.items %}
            <a href="{{ item.url }}" class="text-sm font-medium text-slate-300 hover:text-white hover:underline underline-offset-4 decoration-blue-500 transition-all">{{ item.label | escape }}</a>
          {% endfor %}
        {% else %}
          {% if site.siteType != "blog" %}<a href="/products" class="text-sm font-medium text-slate-300 hover:text-white hover:underline underline-offset-4 decoration-blue-500 transition-all">Sản phẩm</a>{% endif %}
          <a href="/blog" class="text-sm font-medium text-slate-300 hover:text-white hover:underline underline-offset-4 decoration-blue-500 transition-all">Blog</a>
          {% if site.siteType != "blog" %}<a href="/cart" class="text-sm font-medium text-slate-300 hover:text-white hover:underline underline-offset-4 decoration-blue-500 transition-all">Giỏ hàng</a>{% endif %}
        {% endif %}
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button type="button" id="mobile-menu-btn" class="text-slate-300 hover:text-white focus:outline-none p-2 rounded-md hover:bg-slate-800 transition-colors" aria-controls="mobile-menu" aria-expanded="false">
          <span class="sr-only">Mở menu</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="md:hidden hidden bg-slate-800 border-t border-slate-700" id="mobile-menu">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3 shadow-inner">
      {% if headerMenu and headerMenu.items.size > 0 %}
        {% for item in headerMenu.items %}
          <a href="{{ item.url }}" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors">{{ item.label | escape }}</a>
        {% endfor %}
      {% else %}
        {% if site.siteType != "blog" %}<a href="/products" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors">Sản phẩm</a>{% endif %}
        <a href="/blog" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors">Blog</a>
        {% if site.siteType != "blog" %}<a href="/cart" class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-700 transition-colors">Giỏ hàng</a>{% endif %}
      {% endif %}
    </div>
  </div>
</header>
{% layout "layout" %}
{% block content %}
<div class="bg-slate-50 py-16 sm:py-24 min-h-screen">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight sm:text-5xl">{{ pageTitle | default: 'Blog & Tin tức' }}</h1>
      <p class="mt-4 max-w-2xl mx-auto text-xl text-slate-500">Cập nhật những thông tin mới nhất về công nghệ, tính năng sản phẩm và giải pháp AI cho doanh nghiệp.</p>
    </div>

    {% if posts.size == 0 %}
      <div class="text-center py-20 bg-white rounded-2xl border border-slate-200 shadow-sm">
        <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-slate-900">Chưa có bài viết</h3>
        <p class="mt-1 text-sm text-slate-500">Chúng tôi đang cập nhật nội dung. Vui lòng quay lại sau.</p>
      </div>
    {% else %}
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {% for post in posts %}
          <article class="flex flex-col bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-lg transition-all duration-300 group">
            {% if post.coverImage %}
              <a href="/blog/{{ post.slug }}" class="block shrink-0 overflow-hidden">
                <img class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105" src="{{ post.coverImage }}" alt="{{ post.title }}">
              </a>
            {% else %}
              <a href="/blog/{{ post.slug }}" class="block shrink-0 bg-slate-100 h-56 flex items-center justify-center overflow-hidden">
                <svg class="h-12 w-12 text-slate-300 transition-transform duration-500 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2-2v12a2 2 0 002 2z" />
                </svg>
              </a>
            {% endif %}
            
            <div class="flex-1 p-6 flex flex-col justify-between">
              <div>
                <div class="flex items-center text-sm text-slate-500 mb-3 space-x-2">
                  <time datetime="{{ post.publishedAt }}">{{ post.publishedAt | date: "%d/%m/%Y" }}</time>
                  {% if post.categories.size > 0 %}
                    <span>&middot;</span>
                    <div class="flex flex-wrap gap-2">
                      {% for c in post.categories %}
                        <a href="/blog/danh-muc/{{ c.slug }}" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 hover:bg-blue-100 transition-colors">
                          {{ c.name | escape }}
                        </a>
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>
                <h2 class="text-xl font-bold text-slate-900 mb-2">
                  <a href="/blog/{{ post.slug }}" class="hover:text-blue-600 transition-colors line-clamp-2">
                    {{ post.title | escape }}
                  </a>
                </h2>
                {% if post.excerpt %}
                  <p class="text-slate-600 line-clamp-3 mb-4 text-sm">{{ post.excerpt | escape }}</p>
                {% endif %}
              </div>
              <div class="mt-4 flex items-center">
                <a href="/blog/{{ post.slug }}" class="inline-flex items-center text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors group-hover:underline">
                  Đọc tiếp
                  <svg class="ml-1.5 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>

      <div class="mt-12 flex items-center justify-between border-t border-slate-200 pt-6">
        <div class="flex flex-1 justify-between sm:hidden">
          {% if hasPrev %}
            <a href="/blog?page={{ prevPage }}" class="relative inline-flex items-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Trước</a>
          {% else %}
            <div></div>
          {% endif %}
          {% if hasNext %}
            <a href="/blog?page={{ nextPage }}" class="relative ml-3 inline-flex items-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Sau</a>
          {% endif %}
        </div>
        
        <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
          <div>
            <p class="text-sm text-slate-700">
              Hiển thị danh sách bài viết
            </p>
          </div>
          <div>
            <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
              {% if hasPrev %}
                <a href="/blog?page={{ prevPage }}" class="relative inline-flex items-center rounded-l-md px-2 py-2 text-slate-400 ring-1 ring-inset ring-slate-300 hover:bg-slate-50 focus:z-20 focus:outline-offset-0">
                  <span class="sr-only">Trang trước</span>
                  <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
                  </svg>
                </a>
              {% else %}
                <span class="relative inline-flex items-center rounded-l-md px-2 py-2 text-slate-300 ring-1 ring-inset ring-slate-300 bg-slate-50 cursor-not-allowed">
                  <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
                  </svg>
                </span>
              {% endif %}
              
              {% if hasNext %}
                <a href="/blog?page={{ nextPage }}" class="relative inline-flex items-center rounded-r-md px-2 py-2 text-slate-400 ring-1 ring-inset ring-slate-300 hover:bg-slate-50 focus:z-20 focus:outline-offset-0">
                  <span class="sr-only">Trang sau</span>
                  <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                  </svg>
                </a>
              {% else %}
                <span class="relative inline-flex items-center rounded-r-md px-2 py-2 text-slate-300 ring-1 ring-inset ring-slate-300 bg-slate-50 cursor-not-allowed">
                  <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                  </svg>
                </span>
              {% endif %}
            </nav>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>
{% endblock %}
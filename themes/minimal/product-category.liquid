{% layout "layout" %}
{% block content %}
<a href="{{ backHref | default: "/products" }}" class="text-stone-500 text-sm no-underline">← {{ backLabel | default: "Tất cả sản phẩm" }}</a>

<h1 class="font-serif text-3xl font-bold mt-3 mb-2 text-center">{{ category.name | escape }}</h1>
{% if category.excerpt %}<p class="text-stone-600 text-center">{{ category.excerpt | escape }}</p>{% endif %}
{% if category.body %}<div class="font-serif leading-relaxed mb-8">{{ category.body }}</div>{% endif %}
{% render "custom-fields", fields: category.customFields %}

{% if category.children.size > 0 %}
  <div class="flex flex-wrap justify-center gap-2 mb-8">
    {% for child in category.children %}
      <a href="{{ childPathPrefix | default: productCategoryPathPrefix }}/{{ child.slug }}" class="text-sm px-3 py-1 border border-stone-300 rounded-full no-underline text-stone-700 hover:border-brand hover:text-brand">{{ child.name | escape }}</a>
    {% endfor %}
  </div>
{% endif %}

{% if products.size == 0 %}
  <p class="text-stone-500 text-center mt-6">{{ emptyText | default: "Chưa có sản phẩm nào trong danh mục này." }}</p>
{% else %}
  <div class="grid grid-cols-2 gap-8 mt-8">
    {% for product in products %}
      <a href="{{ productUrlPrefix }}/{{ product.slug | default: product.id }}" class="no-underline text-inherit text-center block">
        {% if product.imageUrls.size > 0 %}
          <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}" class="w-full h-48 object-cover mb-2">
        {% else %}
          <div class="w-full h-48 bg-stone-100 mb-2"></div>
        {% endif %}
        <div class="text-sm text-stone-900 mb-1">{{ product.name | escape }}</div>
        {% if product.salePrice %}
          <div><span class="text-brand font-semibold">{{ product.salePrice }}₫</span> <span class="text-stone-400 line-through text-sm">{{ product.price }}₫</span></div>
        {% else %}
          <div class="font-semibold">{{ product.price }}₫</div>
        {% endif %}
      </a>
    {% endfor %}
  </div>

  <div class="flex justify-between mt-8 text-sm">
    {% if hasPrev %}<a href="{{ categoryPath }}?page={{ prevPage }}" class="text-brand">← Trang trước</a>{% else %}<span></span>{% endif %}
    {% if hasNext %}<a href="{{ categoryPath }}?page={{ nextPage }}" class="text-brand">Trang sau →</a>{% endif %}
  </div>
{% endif %}
{% endblock %}


<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.siteName }}</title>
  {% if metaDescription %}<meta name="description" content="{{ metaDescription }}">{% endif %}
  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  {% if site.faviconUrl %}<link rel="icon" href="{{ site.faviconUrl }}">{% endif %}
  <link rel="alternate" type="application/rss+xml" title="{{ site.siteName }} RSS" href="/feed.xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com?plugins=typography,forms"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { serif: ["Source Serif 4", "serif"], sans: ["Inter", "sans-serif"] },
          colors: { brand: { DEFAULT: "#b45309", dark: "#92400e" } },
        },
      },
    };
  </script>
</head>
<body class="font-sans text-stone-800 bg-stone-50 flex flex-col min-h-screen">
  <header class="border-b border-stone-200">
    <div class="max-w-2xl mx-auto px-6 py-8 text-center">
      <a href="/" class="inline-flex items-center gap-2 font-serif font-bold text-2xl text-stone-900 no-underline">
        {% if site.logoUrl %}<img src="{{ site.logoUrl }}" alt="{{ site.siteName }}" class="h-8">{% endif %}
        {{ site.siteName }}
      </a>
      {% if site.tagline %}<div class="text-sm text-stone-500 mt-1 italic">{{ site.tagline }}</div>{% endif %}
      <nav class="flex items-center justify-center gap-6 text-sm mt-4 uppercase tracking-wide">
        {% if headerMenu and headerMenu.items.size > 0 %}
          {% for item in headerMenu.items %}<a href="{{ item.url }}" class="text-stone-600 hover:text-brand">{{ item.label | escape }}</a>{% endfor %}
        {% else %}
          <a href="/products" class="text-stone-600 hover:text-brand">Sản phẩm</a>
          <a href="/blog" class="text-stone-600 hover:text-brand">Blog</a>
          <a href="/cart" class="text-stone-600 hover:text-brand">Giỏ hàng</a>
        {% endif %}
      </nav>
    </div>
  </header>

  <main class="flex-1 max-w-2xl w-full mx-auto px-6 py-12">
    {% block content %}{% endblock %}
  </main>

  <footer class="text-center text-stone-400 text-sm py-10 border-t border-stone-200">
    {% if footerMenu and footerMenu.items.size > 0 %}
      <nav class="mb-2 flex items-center justify-center gap-4">
        {% for item in footerMenu.items %}<a href="{{ item.url }}" class="text-stone-500 hover:text-brand">{{ item.label | escape }}</a>{% endfor %}
      </nav>
    {% endif %}
    © {{ year }} {{ site.siteName }}
  </footer>
</body>
</html>

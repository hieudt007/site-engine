{% layout "layout" %}
{% block content %}
<a href="/blog" class="text-stone-500 text-sm no-underline">← Tất cả bài viết</a>

<h1 class="font-serif text-3xl font-bold mt-3 mb-2 text-center">{{ category.name | escape }}</h1>
{% if category.excerpt %}<p class="text-stone-600 text-center">{{ category.excerpt | escape }}</p>{% endif %}
{% if category.body %}<div class="font-serif leading-relaxed mb-8">{{ category.body }}</div>{% endif %}

{% if category.children.size > 0 %}
  <div class="flex flex-wrap justify-center gap-2 mb-8">
    {% for child in category.children %}
      <a href="/blog/danh-muc/{{ child.slug }}" class="text-sm px-3 py-1 border border-stone-300 rounded-full no-underline text-stone-700 hover:border-brand hover:text-brand">{{ child.name | escape }}</a>
    {% endfor %}
  </div>
{% endif %}

{% if posts.size == 0 %}
  <p class="text-stone-500 text-center">Chưa có bài viết nào trong danh mục này.</p>
{% else %}
  <div class="flex flex-col gap-10 mt-8">
    {% for post in posts %}
      <article class="text-center">
        {% if post.coverImage %}
          <a href="/blog/{{ post.slug }}">
            <img src="{{ post.coverImage }}" alt="{{ post.title }}" class="w-full max-h-72 object-cover mb-4">
          </a>
        {% endif %}
        <h2 class="font-serif text-2xl font-semibold mb-1">
          <a href="/blog/{{ post.slug }}" class="text-stone-900 no-underline hover:text-brand">{{ post.title | escape }}</a>
        </h2>
        <div class="text-stone-400 text-sm mb-3 uppercase tracking-wide">{{ post.publishedAt | date: "%d/%m/%Y" }}</div>
        {% if post.excerpt %}<p class="text-stone-600 font-serif">{{ post.excerpt | escape }}</p>{% endif %}
        <a href="/blog/{{ post.slug }}" class="text-brand text-sm mt-2 inline-block">Đọc tiếp →</a>
      </article>
      <hr class="border-stone-200">
    {% endfor %}
  </div>

  <div class="flex justify-between mt-8 text-sm">
    {% if hasPrev %}<a href="/blog/danh-muc/{{ category.slug }}?page={{ prevPage }}" class="text-brand">← Trang trước</a>{% else %}<span></span>{% endif %}
    {% if hasNext %}<a href="/blog/danh-muc/{{ category.slug }}?page={{ nextPage }}" class="text-brand">Trang sau →</a>{% endif %}
  </div>
{% endif %}
{% endblock %}

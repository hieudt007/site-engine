{% layout "layout" %}
{% block content %}
<a href="/products" class="text-stone-500 text-sm no-underline">← Tất cả sản phẩm</a>

<article class="mt-6 text-center">
  {% if product.imageUrls.size > 0 %}
    <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}" class="w-full max-h-[420px] object-cover mb-4">
  {% endif %}
  {% if product.categories.size > 0 %}
    <div class="text-stone-500 text-sm mb-1 uppercase tracking-wide">
      {% for c in product.categories %}<a href="/products/danh-muc/{{ c.slug }}" class="text-stone-500 hover:text-brand">{{ c.name | escape }}</a>{% unless forloop.last %}, {% endunless %}{% endfor %}
    </div>
  {% endif %}
  <h1 class="font-serif text-3xl font-bold mb-4">{{ product.name | escape }}</h1>

  {% if product.hasVariants %}
    <div id="variant-picker" class="mb-4 flex flex-col items-center gap-2"></div>
    <div id="variant-price" class="mb-4"></div>
    <div id="variant-stock" class="text-red-700 text-sm mb-4"></div>
    <button id="add-to-cart" class="bg-brand hover:bg-brand-dark text-white border-none px-6 py-2.5 text-[0.95rem] cursor-pointer mb-4">Thêm vào giỏ</button>
    <span id="add-to-cart-msg" class="text-green-700 text-sm ml-2"></span>
    <script id="variants-data" type="application/json">{{ variantsJson }}</script>
  {% else %}
    <div class="mb-4">
      {% if product.salePrice %}
        <span class="text-brand font-bold text-2xl">{{ product.salePrice }}₫</span>
        <span class="text-stone-400 line-through ml-2">{{ product.price }}₫</span>
      {% else %}
        <span class="font-bold text-2xl">{{ product.price }}₫</span>
      {% endif %}
    </div>
    {% if product.stock != nil and product.stock <= 0 %}
      <div class="text-red-700 text-sm mb-4">Hết hàng</div>
    {% else %}
      <button id="add-to-cart" data-id="{{ product.id }}" class="bg-brand hover:bg-brand-dark text-white border-none px-6 py-2.5 text-[0.95rem] cursor-pointer mb-4">Thêm vào giỏ</button>
      <span id="add-to-cart-msg" class="text-green-700 text-sm ml-2"></span>
    {% endif %}
  {% endif %}

  {% if product.description %}
    <div class="font-serif leading-relaxed text-left">{{ product.description | escape | newline_to_br }}</div>
  {% endif %}

  {% render "_custom-fields", fields: product.customFields %}

  {% if product.imageUrls.size > 1 %}
    <div class="flex gap-2 mt-6 flex-wrap justify-center">
      {% for url in product.imageUrls offset: 1 %}
        <img src="{{ url }}" alt="{{ product.name | escape }}" class="w-[90px] h-[90px] object-cover">
      {% endfor %}
    </div>
  {% endif %}
</article>

<section class="mt-10 border-t border-stone-200 pt-6 text-left">
  <h2 class="font-serif text-xl font-semibold">
    Đánh giá{% if avgRating %} — {{ avgRating }}★ ({{ reviews.size }} đánh giá){% endif %}
  </h2>

  {% if reviews.size == 0 %}
    <p class="text-stone-500 text-sm">Chưa có đánh giá nào.</p>
  {% else %}
    <div class="flex flex-col gap-3 mb-6 mt-4">
      {% for r in reviews %}
        <div class="border-b border-stone-100 pb-3">
          <div class="font-semibold">{{ r.customerName | escape }} <span class="text-amber-600 font-normal">{% for i in (1..r.rating) %}★{% endfor %}</span></div>
          {% if r.comment %}<div class="text-stone-600 text-sm mt-1">{{ r.comment | escape }}</div>{% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <details class="mt-4">
    <summary class="cursor-pointer text-brand text-sm">Viết đánh giá</summary>
    <form id="review-form" class="mt-3 flex flex-col gap-2.5 max-w-md">
      <input type="text" name="customerName" placeholder="Tên của bạn" required class="px-3 py-2 border border-stone-300 rounded-md">
      <select name="rating" class="px-3 py-2 border border-stone-300 rounded-md">
        <option value="5">5 sao</option>
        <option value="4">4 sao</option>
        <option value="3">3 sao</option>
        <option value="2">2 sao</option>
        <option value="1">1 sao</option>
      </select>
      <textarea name="comment" placeholder="Nhận xét (không bắt buộc)" class="px-3 py-2 border border-stone-300 rounded-md min-h-[80px]"></textarea>
      <button type="submit" class="bg-brand hover:bg-brand-dark text-white border-none px-5 py-2 rounded-md cursor-pointer">Gửi đánh giá</button>
      <div id="review-msg" class="text-sm"></div>
    </form>
  </details>
</section>

<script>
(function () {
  const reviewForm = document.getElementById("review-form");
  if (reviewForm) {
    reviewForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target;
      const msg = document.getElementById("review-msg");
      const res = await fetch("/products/{{ product.id }}/reviews", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          customerName: form.customerName.value,
          rating: Number(form.rating.value),
          comment: form.comment.value || undefined,
        }),
      });
      if (!res.ok) {
        msg.className = "text-sm text-red-700";
        msg.textContent = "Gửi thất bại, vui lòng thử lại.";
        return;
      }
      msg.className = "text-sm text-green-700";
      msg.textContent = "Cảm ơn bạn! Đánh giá đang chờ duyệt.";
      form.reset();
    });
  }
})();
</script>

<script>
(function () {
  const CART_KEY = "site_engine_cart";

  function addToCart(productId, variantId) {
    const cart = JSON.parse(localStorage.getItem(CART_KEY) || "[]");
    const existing = cart.find((c) => c.productId === productId && c.variantId === variantId);
    if (existing) {
      existing.quantity += 1;
    } else {
      cart.push({ productId, quantity: 1, variantId: variantId || undefined });
    }
    localStorage.setItem(CART_KEY, JSON.stringify(cart));
    const msg = document.getElementById("add-to-cart-msg");
    if (msg) msg.textContent = "Đã thêm vào giỏ — xem giỏ hàng";
  }

  const variantsEl = document.getElementById("variants-data");

  if (variantsEl) {
    const productId = "{{ product.id }}";
    const variants = JSON.parse(variantsEl.textContent);
    const attrNames = [...new Set(variants.flatMap((v) => Object.keys(v.attributes || {})))];
    const picker = document.getElementById("variant-picker");
    const priceEl = document.getElementById("variant-price");
    const stockEl = document.getElementById("variant-stock");
    const addBtn = document.getElementById("add-to-cart");
    const selected = {};

    function findMatchingVariant() {
      return variants.find((v) => attrNames.every((name) => (v.attributes || {})[name] === selected[name]));
    }

    function render() {
      const v = findMatchingVariant();
      if (!v) {
        priceEl.textContent = "";
        stockEl.textContent = "";
        addBtn.disabled = true;
        addBtn.style.opacity = "0.5";
        return;
      }
      priceEl.innerHTML = v.salePrice
        ? '<span class="text-brand font-bold text-2xl">' + v.salePrice + '₫</span> <span class="text-stone-400 line-through ml-2">' + v.price + '₫</span>'
        : '<span class="font-bold text-2xl">' + v.price + '₫</span>';
      const outOfStock = v.stock !== null && v.stock !== undefined && v.stock <= 0;
      stockEl.textContent = outOfStock ? "Hết hàng" : "";
      addBtn.disabled = outOfStock;
      addBtn.style.opacity = outOfStock ? "0.5" : "1";
      addBtn.dataset.variantId = v.id;
    }

    attrNames.forEach((name) => {
      const values = [...new Set(variants.map((v) => (v.attributes || {})[name]).filter(Boolean))];
      selected[name] = values[0];

      const wrap = document.createElement("div");
      const label = document.createElement("label");
      label.textContent = name + ": ";
      label.className = "text-sm mr-2";
      wrap.appendChild(label);

      const select = document.createElement("select");
      select.className = "px-2 py-1.5 border border-stone-300 rounded-md";
      values.forEach((val) => {
        const opt = document.createElement("option");
        opt.value = val;
        opt.textContent = val;
        select.appendChild(opt);
      });
      select.addEventListener("change", () => {
        selected[name] = select.value;
        render();
      });
      wrap.appendChild(select);
      picker.appendChild(wrap);
    });

    render();

    addBtn.addEventListener("click", () => {
      if (addBtn.disabled) return;
      addToCart(productId, addBtn.dataset.variantId);
    });
  } else {
    const btn = document.getElementById("add-to-cart");
    if (btn) {
      btn.addEventListener("click", () => addToCart(btn.dataset.id, null));
    }
  }
})();
</script>
{% endblock %}

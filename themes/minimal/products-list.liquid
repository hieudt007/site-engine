{% layout "layout" %}
{% block content %}
<h1 class="font-serif text-3xl font-bold text-center mb-10">{{ pageTitle }}</h1>

{% if products.size == 0 %}
  <p class="text-stone-500 text-center">Chưa có sản phẩm nào.</p>
{% else %}
  <div class="grid grid-cols-2 gap-8">
    {% for product in products %}
      <a href="/products/{{ product.id }}" class="no-underline text-inherit text-center block">
        {% if product.imageUrls.size > 0 %}
          <img src="{{ product.imageUrls[0] }}" alt="{{ product.name | escape }}" class="w-full h-48 object-cover mb-2">
        {% else %}
          <div class="w-full h-48 bg-stone-100 mb-2"></div>
        {% endif %}
        <div class="text-sm text-stone-900 mb-1">{{ product.name | escape }}</div>
        {% if product.salePrice %}
          <div><span class="text-brand font-semibold">{{ product.salePrice }}₫</span> <span class="text-stone-400 line-through text-sm">{{ product.price }}₫</span></div>
        {% else %}
          <div class="font-semibold">{{ product.price }}₫</div>
        {% endif %}
      </a>
    {% endfor %}
  </div>

  <div class="flex justify-between mt-8 text-sm">
    {% if hasPrev %}<a href="/products?page={{ prevPage }}" class="text-brand">← Trang trước</a>{% else %}<span></span>{% endif %}
    {% if hasNext %}<a href="/products?page={{ nextPage }}" class="text-brand">Trang sau →</a>{% endif %}
  </div>
{% endif %}
{% endblock %}

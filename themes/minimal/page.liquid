{% layout "layout" %}
{% block content %}
<article class="text-center">
  {% if page.coverImage %}
    <img src="{{ page.coverImage }}" alt="{{ page.title }}" class="w-full max-h-96 object-cover mb-6">
  {% endif %}
  <h1 class="font-serif text-4xl font-bold mb-8">{{ page.title | escape }}</h1>
  <div class="prose prose-stone font-serif max-w-none text-left leading-relaxed text-[1.05rem]">
    {{ page.body }}
  </div>
</article>
{% endblock %}

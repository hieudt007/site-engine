{% if fields.size > 0 %}
<div class="mt-8 border-t border-stone-200 pt-4 text-left">
  <h3 class="text-sm font-semibold uppercase tracking-wide text-stone-500 mb-2">Thông tin thêm</h3>
  <dl class="text-sm grid grid-cols-[auto,1fr] gap-x-4 gap-y-1">
    {% for pair in fields %}
      <dt class="text-stone-500">{{ pair[0] | escape }}</dt>
      <dd>{{ pair[1] | escape }}</dd>
    {% endfor %}
  </dl>
</div>
{% endif %}

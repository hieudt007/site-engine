<div class="plugin-chat-container" data-plugin-slug="{{ block.pluginSlug | escape }}" data-session-id="{{ chatSessionId | escape }}" data-hmac="{{ chatHmacToken | escape }}">
  <button class="plugin-chat-toggle" aria-label="Mở khung chat">
    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
  </button>

  <div class="plugin-chat-tooltip hidden">
    Xin chào, tôi có thể giúp gì cho bạn?
    <button class="plugin-chat-tooltip-close" aria-label="Đóng tooltip">&times;</button>
  </div>

  <div class="plugin-chat-drawer hidden">
    <div class="plugin-chat-header">
      <div class="plugin-chat-header-info">
        <div class="plugin-chat-avatar">🤖</div>
        <div class="plugin-chat-header-text">
          <h3>{{ block.title | default: "Hỗ trợ khách hàng" | escape }}</h3>
          <p>Luôn sẵn sàng hỗ trợ bạn</p>
        </div>
      </div>
      <button class="plugin-chat-close" aria-label="Đóng">&times;</button>
    </div>
    <div class="plugin-chat-messages">
      <!-- Messages load here -->
    </div>
    <div id="plugin-chat-preview" class="hidden p-2 bg-gray-100 border-t border-gray-200 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <img id="plugin-chat-preview-img" class="h-10 w-10 object-cover rounded border border-gray-300" src="" alt="preview">
        <span class="text-xs text-gray-600 truncate max-w-[150px]" id="plugin-chat-preview-name"></span>
      </div>
      <button id="plugin-chat-preview-close" class="text-gray-500 hover:text-red-500 font-bold px-2">&times;</button>
    </div>
    <form class="plugin-chat-form">
      {% if site.turnstileSiteKey %}
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
        <div class="cf-turnstile" data-sitekey="{{ site.turnstileSiteKey | escape }}" data-size="invisible"></div>
      {% endif %}
      <input type="file" id="plugin-chat-file" accept="image/jpeg, image/png, image/webp, image/gif" class="hidden">
      <button type="button" id="plugin-chat-attach" class="text-gray-400 hover:text-gray-600 p-1 mr-1 rounded hover:bg-gray-100 transition flex items-center" title="Đính kèm ảnh">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
      </button>
      <input type="text" class="plugin-chat-input" placeholder="Nhập tin nhắn..." autocomplete="off">
      <button type="submit" class="plugin-chat-submit" aria-label="Gửi">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
        </svg>
      </button>
    </form>
  </div>
</div>

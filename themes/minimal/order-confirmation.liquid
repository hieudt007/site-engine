{% layout "layout" %}
{% block content %}
<div class="text-center py-10">
  <div class="text-4xl">✅</div>
  <h1 class="font-serif text-3xl font-bold mt-3">Đặt hàng thành công</h1>
  <p class="text-stone-600">Cảm ơn <strong>{{ order.customerName | escape }}</strong>, chúng tôi đã nhận được đơn hàng và sẽ liên hệ sớm.</p>
  <p class="text-stone-400 text-sm">Mã đơn: {{ order.id }}</p>
</div>

<div class="max-w-md mx-auto border border-stone-200 p-6">
  <h2 class="font-serif text-lg font-semibold mt-0">Chi tiết đơn hàng</h2>
  {% for item in order.items %}
    <div class="flex justify-between py-2 border-b border-stone-100">
      <span>{{ item.name | escape }} × {{ item.quantity }}</span>
      <span>{{ item.price }}₫</span>
    </div>
  {% endfor %}
  <div class="flex justify-between font-bold mt-3">
    <span>Tổng cộng</span>
    <span>{{ order.total }}₫</span>
  </div>
  <div class="mt-3 text-sm text-stone-500">
    Giao tới: {{ order.customerAddress | default: "-" | escape }}<br>
    SĐT: {{ order.customerPhone | escape }}
  </div>
</div>

<div class="text-center mt-8">
  <a href="/products" class="text-brand">← Tiếp tục mua sắm</a>
</div>
{% endblock %}

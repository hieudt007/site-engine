// Schema của gói app-mẫu site-engine — mỗi Website chạy 1 bản DB riêng theo đúng schema này.
// KHÔNG có cột websiteId ở bất kỳ bảng nào (docs/system_design.md §1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Đúng 1 record duy nhất trong DB này — thông tin cơ bản + SEO mặc định của CHÍNH website
// đang chạy trên instance này. Không phải bảng registry (đó là việc của LeadBase).
model SiteConfig {
  id     String @id @default("singleton") // luôn đúng 1 row
  domain String // để chính app tự biết domain mình đang chạy (canonical URL, sitemap...)

  siteName        String
  tagline         String?
  logoUrl         String?
  faviconUrl      String?
  contactEmail    String?
  contactPhone    String?
  contactAddress  String?
  socialLinks     Json? // { facebook?, zalo?, tiktok?, youtube? } — cấu trúc CHƯA CHỐT
  businessLicense String? // "Số ĐKKD" — TBD bắt buộc hay không
  defaultOgImage  String?

  // 'blog' | 'ecommerce' - chan HAN toan bo route thuong mai (public: /products,/cart,
  // /payment/vnpay,/api/cart/*,/api/products/sync; admin: /admin/products,/admin/orders,
  // /admin/settings/payment,/admin/settings/shipping,/admin/stores,/admin/coupons,...) khi
  // 'blog' - xem server.ts onRequest hook. Mac dinh 'ecommerce' de KHONG lam gay cac site dang
  // chay that da co san (migration them cot voi default nay, khong can backfill).
  siteType String @default("ecommerce")

  // Prefix URL cho bai viet, trang tinh va san pham. Mac dinh /blog/:slug, /p/:slug va
  // /product/:slug; neu admin de rong string thi bo prefix. Rieng bai viet/san pham chi 1 trong 2
  // duoc de rong de tranh route goc qua mo ho.
  postSlugPrefix    String @default("blog")
  pageSlugPrefix    String @default("p")
  productSlugPrefix String @default("product")

  // Tracking pixel - chen thang vao HTML sau khi render (themeRenderer.ts injectAnalytics),
  // GIONG CACH schema.org dang lam (theme-agnostic, khong theme/AI nao can biet field nay ton
  // tai). gaId/fbPixelId chi can dan ID, tu build dung snippet script chuan. customHeadScript la
  // HTML/JS THO admin tu dan (vd TikTok Pixel, Hotjar...) - CHEN NGUYEN VAN khong escape, chap
  // nhan rui ro vi day la field CHI admin (da co toan quyen DB) moi sua duoc, khong phai input
  // khach hang.
  gaId              String?
  fbPixelId         String?
  customHeadScript  String?
  gscVerificationId String?

  updatedAt DateTime @updatedAt
}

// Tài khoản quản trị — đăng nhập qua OAuth THẬT của LeadBase (Laravel Passport, y hệt cách
// AI/MCP đang xác thực), KHÔNG có mật khẩu riêng. id = ĐÚNG User.id bên LeadBase — upsert mỗi
// lần đăng nhập thành công (routes/admin/oauth.ts). "role" (KHÔNG phải mảng permissions nữa) là
// 1 trong đúng 3 giá trị 'admin'|'manager'|'edit', LeadBase tự tính từ role Spatie thật và trả
// về qua GET /api/oauth/userinfo — đồng bộ lại mỗi lần login. Khác hoàn toàn "customer" (Phase 4,
// model Customer riêng bên dưới — khách mua hàng tự đăng ký phone+OTP, không liên quan gì User).
model User {
  leadbaseUserId Int      @id
  name           String
  email          String
  role           String // 'admin' | 'manager' | 'edit'
  lastLoginAt    DateTime
  createdAt      DateTime @default(now())

  posts     Post[]
  auditLogs AuditLog[]
  media     Media[]
  revisions Revision[]
}

// Session admin vào /admin — tạo sau khi hoàn tất OAuth code exchange + lấy userinfo từ LeadBase.
model Session {
  id        String   @id
  data      String // JSON: { userId, email, permissions }
  expiresAt DateTime
  // Trich tu chinh "data" luc ghi (services/sessionStore.ts) - cho phep tra "cac session KHAC
  // cua user nay" de xoa khi dang nhap lai (1 tai khoan chi dang nhap 1 thiet bi, giong
  // UserSessionService::keepOnlyCurrentSession() ben lead-base). Null cho session chua dang nhap.
  userId Int?

  @@index([userId])
}

// Lịch sử thao tác — trả lời "ai đã làm gì, lúc nào" cho các hành động nhạy cảm (xuất bản,
// xoá...). KHÔNG thay thế authorId/updatedByUserId trên chính Post (đó là tra cứu nhanh cho
// case phổ biến "ai sửa lần cuối"; bảng này là lịch sử ĐẦY ĐỦ theo thời gian, kể cả các lần
// sửa trước đó không còn thấy trên chính record).
model AuditLog {
  id         String   @id @default(cuid())
  userId     Int
  user       User     @relation(fields: [userId], references: [leadbaseUserId])
  action     String // vd 'post.create' | 'post.update' | 'post.publish' | 'post.delete'
  entityType String? // vd 'Post'
  entityId   String?
  metadata   Json? // chi tiết thêm, CHƯA CHỐT cấu trúc
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

// Lịch sử chỉnh sửa nội dung — snapshot TOÀN BỘ field nội dung của Post/Page/Product NGAY TRƯỚC
// mỗi lần PATCH sửa nội dung (KHÔNG snapshot khi chỉ đổi status/lên lịch/xuất bản, và KHÔNG
// snapshot khi LeadBase tự sync giá/tồn kho — chỉ khi ADMIN thật sự sửa nội dung). entityType
// dùng cùng quy ước với AuditLog.entityType ('Post'|'Page'|'Product') dù Post/Page chung 1 bảng
// Prisma — entityId luôn là Post.id hoặc ProductCache.id tương ứng. userId null nếu không xác
// định được người sửa (không xảy ra trong luồng hiện tại, chỉ để chỗ trống).
model Revision {
  id         String   @id @default(cuid())
  entityType String // 'Post' | 'Page' | 'Product'
  entityId   String
  data       Json // snapshot cac field noi dung TRUOC khi update (khong phai toan bo row)
  // [{field, label, old, new}] - chi cac field THAT SU doi gia tri (services/revisions.ts diffFields).
  // Row Revision chi duoc tao khi mang nay khong rong.
  changedFields Json?
  description   String? // cau tom tat doc duoc, vd "Đã sửa: Tiêu đề, Nội dung"
  userId     Int?
  user       User?    @relation(fields: [userId], references: [leadbaseUserId])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

// Danh mục bài viết VA danh mục sản phẩm GỘP CHUNG 1 bảng, phân biệt qua "type" ('post' |
// 'product') — cả 2 đều là 1 "trang danh mục" công khai thật (có excerpt/body/seo riêng, xem
// route /blog/danh-muc/:slug và /products/danh-muc/:slug), chỉ khác NGUỒN: 'post' CRUD hoàn
// toàn tại site-engine; 'product' đồng bộ name/slug từ LeadBase (routes/public/productsSync.ts
// resolveCategoryId — KHÔNG sửa tay 2 field đó), nhưng excerpt/body/seo vẫn site tự quản y hệt
// cách ProductCache.description không bị LeadBase ghi đè sau lần tạo đầu.
//
// 1 bài/sản phẩm gắn được NHIỀU category (nhiều-nhiều, xem Post.categories/ProductCache.categories
// dưới) - khác Topic (1 bài chỉ 1 topic). Có cha/con (parentId) - áp dụng cho CẢ 2 type, kể cả
// danh mục sản phẩm dù LeadBase không gửi cây phân cấp (site tự quản cha/con riêng ở đây).
model Category {
  id       String     @id @default(cuid())
  // 'post' | 'product' | 'brand' - 'brand' CHI ap dung cho ProductCache (xem ProductCache.brand
  // duoi, relation rieng "ProductBrand" - khac "products" ben duoi la danh muc thuong).
  type     String     @default("post")
  name     String
  slug     String
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  // Chi co gia tri khi type='product'/'brand' - LeadBase so huu, dong bo moi lan sync san pham.
  // Unique THEO TUNG type (khong phai toan bang) - vi id danh muc va id thuong hieu ben LeadBase
  // la 2 khong gian id KHAC NHAU (co the trung so, vd category id=5 va brand id=5 la 2 thu khac
  // nhau), gop chung 1 cot unique se gay upsert nham hang.
  leadbaseCategoryId String?
  syncedAt           DateTime?

  // Nội dung trang danh mục — site tự quản, áp dụng cho CẢ 3 type.
  excerpt String?
  body    String?
  seo     Json? // { metaTitle?, metaDescription?, ogImage?, noindex?, keyword?, score? }

  // Trường tùy biến do admin tự đặt tay (vd "Xuất xứ": "Việt Nam") — map string->string đơn giản,
  // KHÔNG dùng cho số liệu hệ thống tự tính (vd lượt xem) — xem services/customFields.ts.
  customFields Json?

  faq Json?

  // Denormalized count of items in this category. For type='post' counts posts; for
  // type='product' counts products in categories; for type='brand' counts products with brandId.
  itemCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts        Post[]
  products     ProductCache[]
  brandProducts ProductCache[] @relation("ProductBrand")

  @@unique([type, slug])
  @@unique([type, leadbaseCategoryId])
}

// Chủ đề bài viết — KHÁC Category ở chỗ 1 bài chỉ thuộc ĐÚNG 1 topic (Post.topicId, quan hệ
// 1-nhiều thường), không phân cấp cha/con, không có trang công khai riêng (chỉ dùng để lọc/gắn
// nhãn) - chỉ áp dụng cho Post, không áp dụng cho ProductCache.
model Topic {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  customFields Json?
  createdAt DateTime @default(now())

  posts Post[]
}

// Menu điều hướng public site — trước đây nav header hard-code cứng trong theme (3 link cố định).
// "slug" là vị trí gắn trong theme (vd "header", "footer") — theme tự quyết định vị trí nào render,
// KHÔNG bắt buộc tồn tại: nếu chưa tạo Menu cho 1 slug, theme tự dùng nav mặc định (xem
// themes/default/layout.liquid) để không vỡ site cũ khi nâng cấp lên tính năng này.
model Menu {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  items     MenuItem[]
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id        String @id @default(cuid())
  menuId    String
  menu      Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label     String
  url       String
  sortOrder Int    @default(0)

  @@index([menuId])
}

// Bai viet blog VA trang tinh GOP CHUNG 1 bang, phan biet qua "type" ('post' | 'page') - trang
// tinh (Gioi thieu, Lien he...) dung cau truc giong het bai viet nen khong can bang rieng nua
// (truoc day la model Page riêng). "type" khong doi duoc sau khi tao (khong co trong UPDATE
// schema o routes/admin/{posts,pages}.ts) - moi file van la 2 man hinh/route rieng (posts.ts
// luon set/loc type='post', pages.ts luon set/loc type='page'), chi gop o TANG DU LIEU.
// slug unique THEO TUNG type (khong global) - vd 1 post va 1 page co the cung slug "gioi-thieu"
// vi hien o 2 URL khac nhau (/blog/gioi-thieu vs /trang/gioi-thieu), khong that su dung do.
model Post {
  id    String @id @default(cuid())
  type  String @default("post") // 'post' | 'page'
  title String
  slug  String

  body       String // markdown hoặc HTML đã sanitize (chỉ khi layoutMode='standard', xem duoi)
  excerpt    String?
  coverImage String?

  // 'standard' (khung theme chuan, body da sanitize) | 'custom' (van co header/footer nhung body
  // render THO khong qua khung tieu de/category, KHONG sanitize - cho phep script/iframe) |
  // 'landing' (khong header/footer/layout gi ca, body render THO nguyen trang, KHONG sanitize) -
  // xem routes/public/{blog,pages,products}.ts resolveTemplate() + themes/*/{custom-content,landing}.liquid.
  // "khong sanitize" o 2 mode sau la CO CHU DICH (nguoi dung xac nhan luc thiet ke) - danh doi lay
  // kha nang nhung form/tracking pixel/video embed, chi nguoi co quyen edit/manager/admin moi
  // soan duoc, cung muc tin cay nhu customFields/theme customJS da co.
  layoutMode String @default("standard")

  // Bảo vệ bài viết bằng mật khẩu (chỉ type='post', lưu trơn KHÔNG hash - giống WordPress
  // post_password, đây là lớp "hạn chế xem" cho khách chưa có mã, KHÔNG phải tài khoản đăng
  // nhập nên admin cần thấy lại được mật khẩu mình đã đặt). null/rỗng = bài mở tự do.
  password String?

  authorId Int? // ai TẠO — User.leadbaseUserId
  author   User? @relation(fields: [authorId], references: [leadbaseUserId])

  // Nhiều-nhiều — 1 bài gắn được nhiều category (chỉ dùng khi type='post', page không có danh
  // mục/topic). Khác topicId dưới (1-1, mỗi bài đúng 1 topic).
  categories Category[]

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id])

  // { metaTitle?, metaDescription?, ogImage?, noindex?, keyword?, score? } - score la cho danh
  // truoc cho tinh nang cham diem SEO SAU NAY, hien CHUA co logic tinh, luon null.
  seo Json?

  // Trường tùy biến do admin tự đặt tay — xem services/customFields.ts, model Category.
  customFields Json?

  faq Json?

  // 'draft' | 'pending_review' | 'scheduled' | 'published' - xem services/contentStatus.ts cho
  // ma tran quyen chuyen trang thai theo role. scheduledAt tu dong -> published qua cron
  // (services/publishScheduler.ts), luc do publishedAt cung tu dong duoc set.
  status      String    @default("draft")
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([type, slug])
}

// Cau hinh AI Agent — noi vao 2 tinh nang: sinh/sua noi dung bai viet (routes/admin/postsAi.ts)
// va tuy chinh theme bang AI (routes/admin/themeCustomize.ts).
// provider: 'openai' | 'anthropic' | 'google' | 'deepseek' | 'openrouter' | 'ai-router' | 'custom'
// ('ai-router' = 9router, dung baseUrl mac dinh cua 9router; 'custom' bat buoc phai co baseUrl).
// purpose: 'content' | 'design' | null — agent nao co purpose nay se TU DONG duoc chon lam mac
// dinh cho dung tinh nang tuong ung (khong bat buoc — null = agent chung, khong tu chon o dau ca,
// van chon tay duoc o man tuy chinh theme). seedAgents.ts tao san 2 agent mac dinh (1 moi purpose,
// apiKey rong) moi khi 1 site moi duoc tao (xem WebsiteProvisionService ben lead-base).
model Agent {
  id           String   @id @default(cuid())
  key          String?  @unique
  name         String
  provider     String   @default("openai")
  model        String
  systemPrompt String?
  apiKey       String?
  baseUrl      String?
  purpose      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Sản phẩm liên kết với LeadBase — sở hữu dữ liệu CHIA ĐÔI, không phải cache thuần:
//   - Nội dung hiển thị (name, description, imageUrls, SEO...) do CHÍNH website này tự quản, LeadBase
//     không ghi đè sau lần tạo đầu.
//   - Giá/tồn/trạng thái do LeadBase đẩy sang mỗi khi đổi (POST /api/products/sync), instance
//     không tự sửa 3 field này, chỉ hiển thị.
model ProductCache {
  id                String @id @default(cuid())
  leadbaseProductId String @unique

  // --- Do LeadBase đẩy sang, instance chỉ đọc — KHÔNG sửa tay ---
  price          Decimal
  salePrice      Decimal?
  stock          Int?
  leadbaseStatus String // giá trị đồng bộ nguyên văn từ LeadBase — enum cụ thể TBD
  // Luot ban - LeadBase tu cong don tu OrderItem luc don hoan tat, day sang moi lan doi (giong
  // price/stock, khong phai site tu tinh). Mac dinh 0 (san pham moi tao, chua co don nao).
  soldCount      Int    @default(0)
  // Ma san pham - LeadBase so huu (Product.sku), chi de HIEN THI/tra cuu, khong dung lam khoa gi.
  sku            String?

  // --- Do CHÍNH website tự quản, LeadBase chỉ set giá trị khởi tạo lúc tạo mới, không ghi đè sau đó ---
  name        String
  slug        String? @unique
  // Mo ta ngan hien o trang danh sach - cung y nghia voi Post.excerpt (xem docblock o do).
  // LeadBase KHONG gui truong nay (site tu viet/sua qua /admin/products), khac description ben duoi.
  excerpt     String?
  // Khi layoutMode='standard': plain text, render escape+newline_to_br (KHONG phai HTML). Khi
  // 'custom'/'landing': HTML THO, render RAW khong escape/sanitize - xem Post.layoutMode o tren
  // cho day du ly do thiet ke.
  description String?
  imageUrls   String[]

  // Cung y nghia voi Post.layoutMode (xem docblock o do) - 'standard' | 'custom' | 'landing'.
  layoutMode String @default("standard")

  // Cùng cấu trúc với Post.seo — { metaTitle?, metaDescription?, ogImage?, noindex?, keyword?, score? }
  seo Json?

  // Trường tùy biến do admin tự đặt tay — xem services/customFields.ts.
  customFields Json?

  faq Json?

  // Cấu hình hiển thị Upsell / Cross-sell cho riêng sản phẩm này.
  // Cấu trúc:
  // {
  //   "upsell": { "mode": "specific" | "category", "productIds": ["id1"], "categoryId": "cat1" | null, "limit": 4 },
  //   "crossSell": { "mode": "specific" | "category", "productIds": ["id2"], "categoryId": "cat2" | null, "limit": 4 }
  // }
  relatedProducts Json?

  // Thong so ky thuat (RAM/CPU, chat lieu, kich thuoc...) - [{label, value}], CO THU TU hien thi,
  // KHAC customFields (map string->string khong dam bao thu tu, dung cho field tuy y rai rac).
  // Day la 1 khu vuc RIENG co y nghia co dinh "bang thong so san pham" hien o trang chi tiet.
  specs Json?

  // Cổng xuất bản riêng của website — sản phẩm mới từ LeadBase luôn vào ở trạng thái draft,
  // tenant phải tự vào /admin/products sửa/bổ sung nội dung rồi publish. Cùng 4 trạng thái với
  // Post/Page (services/contentStatus.ts) — thay cho publishStatus 2 trạng thái cũ.
  status      String    @default("draft") // 'draft' | 'pending_review' | 'scheduled' | 'published'
  scheduledAt DateTime?
  publishedAt DateTime?

  syncedAt DateTime @default(now()) // lần cuối nhận được cú đẩy từ LeadBase

  // Denormalize tu ProductReview (status='approved') - tranh phai JOIN/aggregate lai moi lan hien
  // trang danh sach/danh muc (N+1 neu tinh rieng tung san pham). Site TU tinh lai (KHONG phai
  // LeadBase gui) moi khi 1 review duoc duyet/tu choi (routes/admin/reviews.ts recomputeProductRatingAggregate) -
  // KHONG tinh luc tao review (luon tao o "pending", chua anh huong so nay).
  reviewCount Int   @default(0)
  avgRating   Float?

  // Sản phẩm có biến thể (màu/size...) — LeadBase Product.has_variants. Khi true, price/salePrice/
  // stock ở TRÊN vẫn giữ (= giá thấp nhất/tổng tồn, LeadBase tự tính) để chỗ nào chưa biết variant
  // vẫn hiển thị được số hợp lý — nhưng nguồn thật cho khách CHỌN mua là bảng variants dưới đây.
  hasVariants Boolean          @default(false)
  variants    ProductVariantCache[]

  // Danh mục — name/slug do LeadBase sở hữu (giống price/stock), excerpt/body/seo site tự quản.
  // Nhiều-nhiều (xem Category) — sync (productsSync.ts) chỉ gán ĐÚNG 1 category LeadBase gửi mỗi
  // lần, nhưng quan hệ nhiều-nhiều để sau này site tự gắn thêm category phụ nếu cần.
  categories Category[]

  // Thuong hieu - 1-nhieu (1 san pham dung 1 thuong hieu, khac categories la nhieu-nhieu) - dung
  // CHUNG bang Category voi type='brand' (thay vi tao model rieng) de tai su dung san CRUD/trang
  // danh muc + logic sync category da co. relation dat ten "ProductBrand" de phan biet voi
  // "categories" (Prisma bat buoc dat ten khi 1 model co >1 quan he toi cung 1 model dich).
  brandId String?
  brand   Category? @relation("ProductBrand", fields: [brandId], references: [id])

  reviews ProductReview[]
}

// Đánh giá sản phẩm — khách KHÔNG cần tài khoản (Customer/OTP đang tạm dừng), chỉ nhập tên. Luôn
// tạo ở "pending", PHẢI duyệt tay (manager/admin) mới hiện công khai — nội dung công khai không
// đăng nhập, bắt buộc kiểm duyệt để tránh spam/nội dung xấu hiện thẳng lên site.
model ProductReview {
  id             String       @id @default(cuid())
  productCacheId String
  product        ProductCache @relation(fields: [productCacheId], references: [id], onDelete: Cascade)

  customerName String
  rating       Int // 1-5
  comment      String?
  status       String @default("pending") // 'pending' | 'approved' | 'rejected'

  imageUrls    String[]

  // Trường tùy biến do admin tự đặt tay — xem services/customFields.ts.
  customFields Json?

  createdAt DateTime @default(now())
}

// 1 tổ hợp biến thể (vd "Đỏ / M") của 1 ProductCache — hoàn toàn do LeadBase đẩy sang, instance
// KHÔNG sửa tay (khác chính ProductCache, nơi name/description/imageUrls do website tự quản).
model ProductVariantCache {
  id                String       @id @default(cuid())
  productCacheId    String
  product           ProductCache @relation(fields: [productCacheId], references: [id], onDelete: Cascade)
  leadbaseVariantId String       @unique

  sku        String?
  attributes Json? // vd {"Màu":"Đỏ","Size":"M"} — dùng build bộ chọn ở trang sản phẩm

  price          Decimal
  salePrice      Decimal?
  stock          Int?
  leadbaseStatus String

  syncedAt DateTime @default(now())
}

model CartOrder {
  id                String    @id @default(cuid())
  customerId        String? // null = guest
  customer          Customer? @relation(fields: [customerId], references: [id])
  status            String // 'pending' | 'sent_to_leadbase' | 'failed'
  customerName      String
  customerPhone     String
  customerAddress   String?
  items             Json // [{ leadbaseProductId, name, price, quantity }]
  total             Decimal
  leadbaseOrderCode String?
  sendError         String?

  // Thanh toan (system_design.md §payment) - 'cod'|'bank_transfer'|'vnpay', khop key trong bang
  // PaymentMethod.method. cod/bank_transfer khong dung gateway nao - paymentStatus giu nguyen
  // 'unpaid' mai mai, xac nhan da nhan tien la viec THU CONG ben LeadBase (giong cach Order that
  // van duoc quan ly o do), site-engine chi hien thi thong tin. vnpay: paymentStatus chi chuyen
  // 'paid' qua IPN (routes/public/vnpay.ts) - KHONG qua vnp_ReturnUrl (browser return khong dang
  // tin cay de chot da thanh toan that, xem services/vnpay.ts).
  paymentMethod String  @default("cod")
  paymentStatus String  @default("unpaid") // 'unpaid' | 'paid' | 'failed'
  vnpayTxnRef   String? @unique
  paidAt        DateTime?

  // Phi van chuyen (khop ShippingRule ben duoi). customerProvince BAT BUOC nhap luc checkout (khac
  // customerAddress tu do) de co the khop rule theo tinh - LeadBase da co san cot Customer.province
  // tuong tu nen truyen thang qua, khong can chuan hoa lai o site-engine. "total" giu nguyen =
  // tien HANG (khong doi, van gui LeadBase dung nhu truoc), shippingFee tach rieng.
  customerProvince String?
  shippingFee      Int     @default(0)

  // Hinh thuc nhan hang - 'delivery' (giao tan noi, dung shippingFee/customerProvince nhu tren)
  // hoac 'pickup' (nhan tai cua hang, khong tinh phi ship, customerProvince khong bat buoc).
  // storeId chi co gia tri khi fulfillmentMethod='pickup'.
  fulfillmentMethod String  @default("delivery")
  storeId           String?
  store             Store?  @relation(fields: [storeId], references: [id])

  // Coupon (neu khach co ap ma luc checkout) - luu lai ma + so tien da giam de doi chieu sau nay,
  // KHONG luu quan he @relation toi Coupon (ma co the bi admin xoa sau, khong nen chan xoa vi don
  // cu con tham chieu - luu ma dang string doc lap).
  couponCode     String?
  discountAmount Int     @default(0)

  // Truong tuy bien do KHACH tu dien luc checkout - vd them 1 input "SDT phu" vao form o
  // cart.liquid/product-detail.liquid (khong can migration moi lan them field). Khac
  // customFields cua Post/Category/... (do ADMIN tu dat) - o day nguon la CHINH KHACH nhap qua
  // form public, xem routes/public/cart.ts checkoutSchema + collectCustomFields() trong theme.
  // KHONG day sang LeadBase (sendOrderToLeadbase khong biet field nay), chi luu o site-engine.
  customFields Json?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Danh sach phuong thuc thanh toan CO THE bat/tat + cau hinh ngay tren admin UI (Settings ->
// Thanh toan), KHONG can sua .env/SSH vao VPS - moi tenant tu dan API key/thong tin ngan hang cua
// ho. "config" la Json rieng theo tung method (vd bank_transfer: {bankName,accountNumber,...},
// vnpay: {tmnCode,hashSecret,sandbox}) - them method moi (MoMo, ZaloPay...) sau nay chi la 1 row
// moi voi config rieng, KHONG can migration. "hashSecret" cua vnpay luu PLAINTEXT trong config -
// giong cach Tenant.gatewaySecret ben chatbot-lite dang luu, khong ma hoa rieng.
model PaymentMethod {
  id        String   @id @default(cuid())
  method    String   @unique // 'cod' | 'bank_transfer' | 'vnpay'
  enabled   Boolean  @default(false)
  config    Json?
  updatedAt DateTime @updatedAt
}

// Bang phi ship - admin tu tao rule qua UI (Settings -> Van chuyen), khong hard-code. "provinces"
// RONG = rule mac dinh/fallback (ap dung cho tinh khong khop rule cu the nao khac) - vd tao 1 rule
// "HN & TP HCM" voi provinces=["Ha Noi","TP. Ho Chi Minh"] + 1 rule mac dinh provinces=[] cho phan
// con lai. Khong dung field "priority" rieng - rule co provinces cu the LUON duoc uu tien hon rule
// fallback (services/shipping.ts tu xu ly thu tu nay, khong can them cot).
model ShippingRule {
  id                String   @id @default(cuid())
  name              String
  provinces         String[] // [] = rule mac dinh/fallback
  baseFee           Int
  freeShipThreshold Int? // null = khong bao gio free ship theo tong don
  enabled           Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

// Bat/tat 2 hinh thuc nhan hang o muc TOAN HE THONG (giong PaymentMethod) - vd tenant chi ban tai
// cua hang thi tat 'delivery', hoac chua co cua hang nao thi tat 'pickup'.
model FulfillmentMethod {
  id        String   @id @default(cuid())
  method    String   @unique // 'delivery' | 'pickup'
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// Danh sach cua hang cho khach chon nhan tai cho (fulfillmentMethod='pickup') - admin tu khai bao
// qua /admin/stores, KHONG gioi han so luong nhu PaymentMethod (day la thuc the that, co the
// them/xoa tuy y).
model Store {
  id        String      @id @default(cuid())
  name      String
  address   String
  province  String?
  phone     String?
  enabled   Boolean     @default(true)
  updatedAt DateTime    @updatedAt
  orders    CartOrder[]
}

// Ma giam gia - admin tu tao qua /admin/coupons. "usedCount" tang moi khi 1 don CHECKOUT thanh
// cong ap dung ma nay (tang luc TAO don, khong doi thanh toan xong - giong cach shippingFee/total
// da tinh luc tao don, chap nhan don vnpay bi bo do van tinh 1 luot dung, tranh phai lam co che
// "tra lai luot" phuc tap cho 1 tinh huong hiem).
model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String // 'percent' | 'fixed'
  discountValue Int // percent: 1-100, fixed: so tien VND
  minOrderTotal Int       @default(0)
  maxUses       Int? // null = khong gioi han
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Tài khoản KHÁCH MUA HÀNG (đăng nhập phone+OTP) — khác hoàn toàn Session ở trên.
model Customer {
  id              String            @id @default(cuid())
  phone           String            @unique
  phoneVerifiedAt DateTime
  name            String?
  addresses       Json? // [{ label, address, isDefault }] — CHƯA CHỐT
  orders          CartOrder[]
  sessions        CustomerSession[]
  createdAt       DateTime          @default(now())
}

model CustomerOtp {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  purpose    String // 'login' | 'save_guest_order'
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone])
}

model CustomerSession {
  id         String   @id
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
}

model ThemeConfig {
  id          String   @id @default("singleton") // đúng 1 row, giống SiteConfig
  activeTheme String   @default("default")
  updatedAt   DateTime @updatedAt
}

model CustomTheme {
  id          String   @id @default(cuid())
  slug        String   @unique // tên thư mục theme, vd "custom-a1b2c3"
  name        String
  installedAt DateTime @default(now())
  source      String // 'agent-generated' — CHƯA CHỐT giá trị khác
}

// Lich su chat editor AI cho tung theme (services/themeChat.ts) — khoa bang slug (giong quy uoc
// file-he-thong dung slug lam nguon that, khong dung CustomTheme.id) vi ban chat gan voi thu muc
// theme tren dia, khong phai row DB. role: 'user' | 'assistant'. Day la NHAT KY DAY DU cho nguoi
// xem lai — khac voi themes/{slug}/THEME.md (tri nho NEN, luon nhet vao prompt AI, xem themeMemory.ts).
model ThemeChatMessage {
  id        String   @id @default(cuid())
  slug      String
  role      String
  content   String
  // Anh admin dinh kem khi gui yeu cau (vd anh mau giao dien muon lam theo) - URL tuyet doi
  // (khong phai duong dan tuong doi /uploads/...) vi AI goi qua API se tu tai anh, can URL
  // truy cap duoc tu ben ngoai. Chi 'user' message moi co the co gia tri nay.
  imageUrl  String?
  // Chi co gia tri tren 1 tin nhan 'assistant' dang la DE XUAT thiet ke lai TOAN BO 18 trang, cho
  // AI tong hop day du (phong cach + tinh nang giu/them/bot), CHO admin xac nhan - null nghia la
  // khong phai de xuat cho xac nhan. Nut "Xac nhan" tren UI (giong Plan Mode) chi hien khi day la
  // tin nhan MOI NHAT va co gia tri nay - bam vao se goi thang pipeline sua 18 file, KHONG qua lai
  // AI phan loai (xem routes/admin/themeChat.ts, endpoint /chat/confirm-redesign).
  redesignBrief String?
  // Di kem redesignBrief - vai tu khoa tieng Anh AI tu viet, dung tra kho du lieu UI/UX
  // (services/uiuxSearch.ts) luc bam "Xac nhan" (khong qua lai AI phan loai nen phai luu san).
  styleQuery String?
  createdAt DateTime @default(now())

  @@index([slug, createdAt])
}

// Plugin admin-only (phase 1): plugin khong chay code server tu do, chi la manifest khai bao
// trang admin/menu/quyen doc core model + storage rieng qua PluginRecord. Khac WordPress plugin:
// khong duoc import prisma/core DB truc tiep, khong hien public site trong phase nay.
model Plugin {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  version     String
  enabled     Boolean  @default(false)
  manifest    Json
  source      String   @default("uploaded")
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records PluginRecord[]
}

model PluginRecord {
  id         String @id @default(cuid())
  pluginSlug String
  plugin     Plugin @relation(fields: [pluginSlug], references: [slug], onDelete: Cascade)
  collection String
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([pluginSlug, collection])
}

// File upload thật (ảnh bìa bài viết, ảnh chèn nội dung...) — lưu trên đĩa VPS ở uploads/
// (services/mediaStorage.ts), KHÔNG resize/optimize (bỏ qua sharp — tránh phụ thuộc native binary
// khó cài trên VPS, đơn giản hoá có chủ đích). Trước đây ảnh chỉ là URL dán tay, không có nơi lưu.
model Media {
  id               String   @id @default(cuid())
  filename         String // tên file gốc lúc upload, chỉ để hiển thị
  url              String // /uploads/{uuid}.{ext} — dùng thẳng trong coverImage/imageUrls/body
  mimeType         String
  size             Int // bytes
  // Thuoc tinh alt cho <img> - admin tu nhap sau khi upload (routes/admin/media.ts PATCH), tu dong
  // do vao the <img> o nhung noi chon anh qua Media picker dung chung (views/admin/layout.liquid
  // openMediaPicker) - xem tung noi goi de biet co dung hay khong (vd danh sach URL rời rac nhu
  // Product.imageUrls thi khong gan duoc, chi noi thao tac truc tiep 1 the <img> moi dung).
  alt              String?
  uploadedByUserId Int?
  uploadedBy       User? @relation(fields: [uploadedByUserId], references: [leadbaseUserId])
  createdAt        DateTime @default(now())
}

// URL cũ -> URL mới, tránh 404 khi đổi slug bài viết/sản phẩm. Áp dụng qua
// app.setNotFoundHandler() (server.ts) — bất kỳ route không khớp nào cũng tự tra bảng này trước
// khi trả 404 thật. Tự động tạo khi đổi slug bài viết (routes/admin/posts.ts) — quản trị tay
// (routes/admin/redirects.ts) chỉ để bổ sung case đặc biệt, không phải nguồn chính.
model Redirect {
  id         String   @id @default(cuid())
  fromPath   String   @unique // vd "/blog/bai-viet-cu"
  toPath     String // vd "/blog/bai-viet-moi"
  statusCode Int      @default(301)
  createdAt  DateTime @default(now())
}

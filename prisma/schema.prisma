// Schema của gói app-mẫu site-engine — mỗi Website chạy 1 bản DB riêng theo đúng schema này.
// KHÔNG có cột websiteId ở bất kỳ bảng nào (docs/system_design.md §1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Đúng 1 record duy nhất trong DB này — thông tin cơ bản + SEO mặc định của CHÍNH website
// đang chạy trên instance này. Không phải bảng registry (đó là việc của LeadBase).
model SiteConfig {
  id     String @id @default("singleton") // luôn đúng 1 row
  domain String // để chính app tự biết domain mình đang chạy (canonical URL, sitemap...)

  siteName        String
  tagline         String?
  logoUrl         String?
  faviconUrl      String?
  contactEmail    String?
  contactPhone    String?
  contactAddress  String?
  socialLinks     Json? // { facebook?, zalo?, tiktok?, youtube? } — cấu trúc CHƯA CHỐT
  businessLicense String? // "Số ĐKKD" — TBD bắt buộc hay không
  defaultOgImage  String?

  updatedAt DateTime @updatedAt
}

// Tài khoản quản trị — đăng nhập qua OAuth THẬT của LeadBase (Laravel Passport, y hệt cách
// AI/MCP đang xác thực), KHÔNG có mật khẩu riêng. id = ĐÚNG User.id bên LeadBase — upsert mỗi
// lần đăng nhập thành công (routes/admin/oauth.ts). "role" (KHÔNG phải mảng permissions nữa) là
// 1 trong đúng 3 giá trị 'admin'|'manager'|'edit', LeadBase tự tính từ role Spatie thật và trả
// về qua GET /api/oauth/userinfo — đồng bộ lại mỗi lần login. Khác hoàn toàn "customer" (Phase 4,
// model Customer riêng bên dưới — khách mua hàng tự đăng ký phone+OTP, không liên quan gì User).
model User {
  leadbaseUserId Int      @id
  name           String
  email          String
  role           String // 'admin' | 'manager' | 'edit'
  lastLoginAt    DateTime
  createdAt      DateTime @default(now())

  posts     Post[]
  pages     Page[]
  auditLogs AuditLog[]
  media     Media[]
}

// Session admin vào /admin — tạo sau khi hoàn tất OAuth code exchange + lấy userinfo từ LeadBase.
model Session {
  id        String   @id
  data      String // JSON: { userId, email, permissions }
  expiresAt DateTime
}

// Lịch sử thao tác — trả lời "ai đã làm gì, lúc nào" cho các hành động nhạy cảm (xuất bản,
// xoá...). KHÔNG thay thế authorId/updatedByUserId trên chính Post (đó là tra cứu nhanh cho
// case phổ biến "ai sửa lần cuối"; bảng này là lịch sử ĐẦY ĐỦ theo thời gian, kể cả các lần
// sửa trước đó không còn thấy trên chính record).
model AuditLog {
  id         String   @id @default(cuid())
  userId     Int
  user       User     @relation(fields: [userId], references: [leadbaseUserId])
  action     String // vd 'post.create' | 'post.update' | 'post.publish' | 'post.delete'
  entityType String? // vd 'Post'
  entityId   String?
  metadata   Json? // chi tiết thêm, CHƯA CHỐT cấu trúc
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

// Danh mục bài viết — khái niệm CỦA RIÊNG website (không có gì tương ứng bên LeadBase), tự quản
// hoàn toàn qua CRUD trong site-engine (khác ProductCategoryCache dưới, chỉ đọc từ LeadBase).
model PostCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  posts Post[]
}

model Post {
  id         String  @id @default(cuid())
  title      String
  slug       String  @unique
  body       String // markdown hoặc HTML đã sanitize
  excerpt    String?
  coverImage String?
  authorName String? // để trống thì hiển thị SiteConfig.siteName — bút danh CÔNG KHAI, khác authorId

  authorId        Int? // ai TẠO bài — User.leadbaseUserId, không phải bút danh public
  author          User? @relation(fields: [authorId], references: [leadbaseUserId])
  updatedByUserId Int? // ai SỬA LẦN CUỐI — có thể khác authorId

  categoryId String?
  category   PostCategory? @relation(fields: [categoryId], references: [id])

  metaTitle       String?
  metaDescription String?
  ogImage         String?
  noindex         Boolean @default(false)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Cau hinh AI Agent — CHUA noi vao tinh nang nao (chatbot/tro ly viet noi dung se dung sau).
// provider: 'openai' | 'anthropic' | 'google' | 'deepseek' | 'openrouter' | 'ai-router' | 'custom'
// ('ai-router' = 9router, dung baseUrl mac dinh cua 9router; 'custom' bat buoc phai co baseUrl).
model Agent {
  id           String   @id @default(cuid())
  name         String
  provider     String   @default("openai")
  model        String
  systemPrompt String?
  apiKey       String?
  baseUrl      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Trang tĩnh của website (Giới thiệu, Liên hệ...) — CÙNG cấu trúc với Post nhưng KHÔNG có
// danh mục (khái niệm danh mục chỉ áp dụng cho bài viết blog). URL public: /trang/{slug}.
model Page {
  id         String  @id @default(cuid())
  title      String
  slug       String  @unique
  body       String // markdown hoặc HTML đã sanitize
  excerpt    String?
  coverImage String?
  authorName String? // để trống thì hiển thị SiteConfig.siteName — bút danh CÔNG KHAI, khác authorId

  authorId        Int? // ai TẠO trang — User.leadbaseUserId, không phải bút danh public
  author          User? @relation(fields: [authorId], references: [leadbaseUserId])
  updatedByUserId Int? // ai SỬA LẦN CUỐI — có thể khác authorId

  metaTitle       String?
  metaDescription String?
  ogImage         String?
  noindex         Boolean @default(false)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Sản phẩm liên kết với LeadBase — sở hữu dữ liệu CHIA ĐÔI, không phải cache thuần:
//   - Nội dung hiển thị (name, description, imageUrls, SEO...) do CHÍNH website này tự quản, LeadBase
//     không ghi đè sau lần tạo đầu.
//   - Giá/tồn/trạng thái do LeadBase đẩy sang mỗi khi đổi (POST /api/products/sync), instance
//     không tự sửa 3 field này, chỉ hiển thị.
model ProductCache {
  id                String @id @default(cuid())
  leadbaseProductId String @unique

  // --- Do LeadBase đẩy sang, instance chỉ đọc — KHÔNG sửa tay ---
  price          Decimal
  salePrice      Decimal?
  stock          Int?
  leadbaseStatus String // giá trị đồng bộ nguyên văn từ LeadBase — enum cụ thể TBD

  // --- Do CHÍNH website tự quản, LeadBase chỉ set giá trị khởi tạo lúc tạo mới, không ghi đè sau đó ---
  name            String
  description     String?
  imageUrls       String[]
  metaTitle       String?
  metaDescription String?

  // Cổng xuất bản riêng của website — sản phẩm mới từ LeadBase luôn vào ở trạng thái draft,
  // tenant phải tự vào /admin/products sửa/bổ sung nội dung rồi publish
  publishStatus String @default("draft") // 'draft' | 'published'

  syncedAt DateTime @default(now()) // lần cuối nhận được cú đẩy từ LeadBase

  // Sản phẩm có biến thể (màu/size...) — LeadBase Product.has_variants. Khi true, price/salePrice/
  // stock ở TRÊN vẫn giữ (= giá thấp nhất/tổng tồn, LeadBase tự tính) để chỗ nào chưa biết variant
  // vẫn hiển thị được số hợp lý — nhưng nguồn thật cho khách CHỌN mua là bảng variants dưới đây.
  hasVariants Boolean          @default(false)
  variants    ProductVariantCache[]

  // Danh mục — CŨNG do LeadBase sở hữu (giống price/stock), chỉ hiển thị, không CRUD ở đây.
  categoryId String?
  category   ProductCategoryCache? @relation(fields: [categoryId], references: [id])

  reviews ProductReview[]
}

// Danh mục sản phẩm — mirror phẳng (bỏ qua parent_id/cây phân cấp) từ LeadBase ProductCategory,
// đồng bộ qua CHÍNH endpoint productsSync.ts đã có (không route riêng) — sửa tên/gộp phải sửa ở
// LeadBase, instance chỉ đọc.
model ProductCategoryCache {
  id                 String   @id @default(cuid())
  leadbaseCategoryId String   @unique
  name               String
  slug               String
  syncedAt           DateTime @default(now())

  products ProductCache[]
}

// Đánh giá sản phẩm — khách KHÔNG cần tài khoản (Customer/OTP đang tạm dừng), chỉ nhập tên. Luôn
// tạo ở "pending", PHẢI duyệt tay (manager/admin) mới hiện công khai — nội dung công khai không
// đăng nhập, bắt buộc kiểm duyệt để tránh spam/nội dung xấu hiện thẳng lên site.
model ProductReview {
  id             String       @id @default(cuid())
  productCacheId String
  product        ProductCache @relation(fields: [productCacheId], references: [id], onDelete: Cascade)

  customerName String
  rating       Int // 1-5
  comment      String?
  status       String @default("pending") // 'pending' | 'approved' | 'rejected'

  createdAt DateTime @default(now())
}

// 1 tổ hợp biến thể (vd "Đỏ / M") của 1 ProductCache — hoàn toàn do LeadBase đẩy sang, instance
// KHÔNG sửa tay (khác chính ProductCache, nơi name/description/imageUrls do website tự quản).
model ProductVariantCache {
  id                String       @id @default(cuid())
  productCacheId    String
  product           ProductCache @relation(fields: [productCacheId], references: [id], onDelete: Cascade)
  leadbaseVariantId String       @unique

  sku        String?
  attributes Json? // vd {"Màu":"Đỏ","Size":"M"} — dùng build bộ chọn ở trang sản phẩm

  price          Decimal
  salePrice      Decimal?
  stock          Int?
  leadbaseStatus String

  syncedAt DateTime @default(now())
}

model CartOrder {
  id                String    @id @default(cuid())
  customerId        String? // null = guest
  customer          Customer? @relation(fields: [customerId], references: [id])
  status            String // 'pending' | 'sent_to_leadbase' | 'failed'
  customerName      String
  customerPhone     String
  customerAddress   String?
  items             Json // [{ leadbaseProductId, name, price, quantity }]
  total             Decimal
  leadbaseOrderCode String?
  sendError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Tài khoản KHÁCH MUA HÀNG (đăng nhập phone+OTP) — khác hoàn toàn Session ở trên.
model Customer {
  id              String            @id @default(cuid())
  phone           String            @unique
  phoneVerifiedAt DateTime
  name            String?
  addresses       Json? // [{ label, address, isDefault }] — CHƯA CHỐT
  orders          CartOrder[]
  sessions        CustomerSession[]
  createdAt       DateTime          @default(now())
}

model CustomerOtp {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  purpose    String // 'login' | 'save_guest_order'
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone])
}

model CustomerSession {
  id         String   @id
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
}

model ThemeConfig {
  id          String   @id @default("singleton") // đúng 1 row, giống SiteConfig
  activeTheme String   @default("default")
  updatedAt   DateTime @updatedAt
}

model CustomTheme {
  id          String   @id @default(cuid())
  slug        String   @unique // tên thư mục theme, vd "custom-a1b2c3"
  name        String
  installedAt DateTime @default(now())
  source      String // 'agent-generated' — CHƯA CHỐT giá trị khác
}

// File upload thật (ảnh bìa bài viết, ảnh chèn nội dung...) — lưu trên đĩa VPS ở uploads/
// (services/mediaStorage.ts), KHÔNG resize/optimize (bỏ qua sharp — tránh phụ thuộc native binary
// khó cài trên VPS, đơn giản hoá có chủ đích). Trước đây ảnh chỉ là URL dán tay, không có nơi lưu.
model Media {
  id               String   @id @default(cuid())
  filename         String // tên file gốc lúc upload, chỉ để hiển thị
  url              String // /uploads/{uuid}.{ext} — dùng thẳng trong coverImage/imageUrls/body
  mimeType         String
  size             Int // bytes
  uploadedByUserId Int?
  uploadedBy       User? @relation(fields: [uploadedByUserId], references: [leadbaseUserId])
  createdAt        DateTime @default(now())
}

// URL cũ -> URL mới, tránh 404 khi đổi slug bài viết/sản phẩm. Áp dụng qua
// app.setNotFoundHandler() (server.ts) — bất kỳ route không khớp nào cũng tự tra bảng này trước
// khi trả 404 thật. Tự động tạo khi đổi slug bài viết (routes/admin/posts.ts) — quản trị tay
// (routes/admin/redirects.ts) chỉ để bổ sung case đặc biệt, không phải nguồn chính.
model Redirect {
  id         String   @id @default(cuid())
  fromPath   String   @unique // vd "/blog/bai-viet-cu"
  toPath     String // vd "/blog/bai-viet-moi"
  statusCode Int      @default(301)
  createdAt  DateTime @default(now())
}

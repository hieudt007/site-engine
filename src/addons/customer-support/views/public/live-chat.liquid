<link rel="stylesheet" href="/addon-assets/customer-support/assets/chat-drawer.min.css">
<script src="/addon-assets/customer-support/assets/chat-drawer.min.js" defer></script>
<div id="plugin-chat-drawer" class="fixed bottom-4 right-4 z-50">
  <button id="plugin-chat-toggle" class="bg-blue-600 text-white rounded-full p-4 shadow-lg hover:bg-blue-700 transition">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
  </button>
  
  <div id="plugin-chat-container" class="hidden absolute bottom-16 right-0 w-80 md:w-96 bg-white rounded-lg shadow-xl overflow-hidden flex-col border border-gray-200" style="height: 500px; max-height: calc(100vh - 100px);">
    <div class="bg-blue-600 text-white p-4 font-bold flex justify-between items-center">
      <span>Live Chat Hỗ Trợ</span>
      <button id="plugin-chat-close" class="text-white hover:text-gray-200">&times;</button>
    </div>
    
    <div id="plugin-chat-messages" class="flex-1 overflow-y-auto p-4 flex flex-col gap-3 bg-gray-50">
      <div class="self-start bg-white p-3 rounded-lg shadow-sm text-sm border border-gray-100 max-w-[85%]">
        Xin chào! Tôi có thể giúp gì cho bạn?
      </div>
    </div>
    
    <div id="plugin-chat-preview" class="hidden p-2 bg-gray-100 border-t border-gray-200 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <img id="plugin-chat-preview-img" class="h-10 w-10 object-cover rounded border border-gray-300" src="" alt="preview">
        <span class="text-xs text-gray-600 truncate max-w-[150px]" id="plugin-chat-preview-name"></span>
      </div>
      <button id="plugin-chat-preview-close" class="text-gray-500 hover:text-red-500 font-bold px-2">&times;</button>
    </div>
    <form id="plugin-chat-form" class="p-3 bg-white border-t border-gray-200 flex gap-2 items-center">
      <input type="file" id="plugin-chat-file" accept="image/jpeg, image/png, image/webp, image/gif" class="hidden">
      <button type="button" id="plugin-chat-attach" class="text-gray-400 hover:text-gray-600 p-1 rounded hover:bg-gray-100 transition" title="Đính kèm ảnh">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
      </button>
      <input type="text" id="plugin-chat-input" placeholder="Nhập tin nhắn..." class="flex-1 px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500">
      <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 text-sm font-medium">Gửi</button>
    </form>
  </div>
</div>

{
  "name": "site-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --exclude themes --exclude uploads --exclude debug-ai --env-file=.env src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "release": "bash scripts/build-release.sh",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/session": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@fastify/view": "^11.0.0",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "clean-css": "^5.3.3",
    "fastify": "^5.2.1",
    "liquidjs": "^10.21.0",
    "node-cron": "^4.6.0",
    "sanitize-html": "^2.17.6",
    "terser": "^5.49.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/clean-css": "^4.2.11",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/sanitize-html": "^2.16.1",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "prisma": {
    "seed": "node dist/seedAgents.js && node dist/seedSiteConfig.js"
  }
}

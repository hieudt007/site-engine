{% layout "layout" %}
{% block content %}
<h1 style="margin:0 0 1.2rem;">Media</h1>

<div style="margin-bottom:1.2rem;">
  <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/gif" multiple>
  <span id="upload-status" style="font-size:0.85rem;color:#777;margin-left:0.5rem;"></span>
</div>

<div id="media-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem;">
  <p style="color:#999;">Đang tải...</p>
</div>
<div class="pagination" id="pagination"></div>

<script>
(function () {
  const CURRENT_ROLE = "{{ role }}";
  const canDelete = CURRENT_ROLE === "manager" || CURRENT_ROLE === "admin";
  const grid = document.getElementById("media-grid");
  const pagination = document.getElementById("pagination");
  const flash = document.getElementById("flash");
  const fileInput = document.getElementById("file-input");
  const status = document.getElementById("upload-status");

  let currentPage = 1;

  function showError(message) {
    flash.textContent = message;
    flash.className = "error";
  }

  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str ?? "";
    return div.innerHTML;
  }

  function cardHtml(m) {
    const deleteBtn = canDelete
      ? '<button class="btn btn-danger" data-id="' + m.id + '" style="width:100%;margin-top:0.4rem;font-size:0.75rem;">Xoá</button>'
      : "";
    return (
      '<div style="border:1px solid #eee;border-radius:8px;padding:0.6rem;background:#fff;">' +
      '<img src="' + m.url + '" alt="' + escapeHtml(m.filename) + '" style="width:100%;height:120px;object-fit:cover;border-radius:6px;">' +
      '<div style="font-size:0.75rem;color:#777;margin-top:0.4rem;word-break:break-all;">' + escapeHtml(m.filename) + '</div>' +
      '<button class="btn" data-copy="' + m.url + '" style="width:100%;margin-top:0.4rem;font-size:0.75rem;">Copy URL</button>' +
      deleteBtn +
      '</div>'
    );
  }

  async function load() {
    const res = await fetch("/admin/api/media?page=" + currentPage);
    const { media, hasNext, hasPrev } = await res.json();
    grid.innerHTML = media.length
      ? media.map(cardHtml).join("")
      : '<p style="color:#999;">Chưa có file nào.</p>';

    pagination.innerHTML =
      (hasPrev ? '<a href="#" data-page="' + (currentPage - 1) + '">← Trang trước</a>' : "<span></span>") +
      "<span>Trang " + currentPage + "</span>" +
      (hasNext ? '<a href="#" data-page="' + (currentPage + 1) + '">Trang sau →</a>' : "<span></span>");
  }

  pagination.addEventListener("click", (event) => {
    const link = event.target.closest("a[data-page]");
    if (!link) return;
    event.preventDefault();
    currentPage = Number(link.dataset.page);
    load();
  });

  fileInput.addEventListener("change", async () => {
    const files = [...fileInput.files];
    if (!files.length) return;

    let uploaded = 0;
    const failed = [];

    for (const file of files) {
      status.textContent = "Đang tải lên " + (uploaded + 1) + "/" + files.length + "...";
      const formData = new FormData();
      formData.append("file", file);

      const res = await fetch("/admin/api/media", { method: "POST", body: formData });
      if (res.ok) {
        uploaded++;
      } else {
        const body = await res.json().catch(() => ({}));
        failed.push(file.name + (typeof body.error === "string" ? ": " + body.error : ""));
      }
    }

    status.textContent = "";
    fileInput.value = "";

    if (failed.length) {
      showError("Lỗi " + failed.length + "/" + files.length + " file: " + failed.join("; "));
    }

    load();
  });

  grid.addEventListener("click", async (event) => {
    const copyBtn = event.target.closest("button[data-copy]");
    if (copyBtn) {
      navigator.clipboard.writeText(location.origin + copyBtn.dataset.copy);
      copyBtn.textContent = "Đã copy!";
      setTimeout(() => (copyBtn.textContent = "Copy URL"), 1200);
      return;
    }

    const deleteBtn = event.target.closest("button[data-id]");
    if (deleteBtn) {
      if (!confirm("Xoá file này? Nếu đang dùng trong bài viết/sản phẩm, ảnh sẽ mất.")) return;
      const res = await fetch("/admin/api/media/" + deleteBtn.dataset.id, { method: "DELETE" });
      if (!res.ok) {
        showError("Xoá thất bại");
        return;
      }
      load();
    }
  });

  load();
})();
</script>
{% endblock %}

{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.2rem;">
  <div>
    <h1 style="margin:0 0 0.3rem;">Sản phẩm</h1>
    <p style="color:#777;font-size:0.85rem;margin:0;">
      Đồng bộ tự động từ LeadBase (giá/tồn kho/trạng thái). Sửa tên/mô tả/ảnh/SEO tại đây, LeadBase không ghi đè.
    </p>
  </div>
  <a class="btn btn-primary" href="/admin/products/new">+ Tạo sản phẩm</a>
</div>

<div style="display:flex;gap:0.6rem;margin-bottom:1rem;flex-wrap:wrap;">
  <input type="search" id="search-input" class="search-input" placeholder="Tìm theo tên sản phẩm...">
  <select id="category-filter" style="max-width:220px;">
    <option value="">Tất cả danh mục</option>
    {% for c in categories %}
      <option value="{{ c.id }}">{{ c.name | escape }}</option>
    {% endfor %}
  </select>
  <select id="status-filter" style="max-width:180px;">
    <option value="">Tất cả trạng thái</option>
    <option value="draft">Nháp</option>
    <option value="pending_review">Chờ duyệt</option>
    <option value="scheduled">Đã lên lịch</option>
    <option value="published">Đã xuất bản</option>
  </select>
</div>

<div id="bulk-bar" style="display:none;align-items:center;gap:0.6rem;margin-bottom:0.8rem;padding:0.6rem 0.9rem;background:#eff6ff;border-radius:var(--radius-sm);font-size:0.85rem;">
  <span id="bulk-count"></span>
  <button type="button" class="btn" id="bulk-publish">Xuất bản</button>
</div>

<table>
  <thead>
    <tr>
      <th style="width:2rem;"><input type="checkbox" id="select-all"></th>
      <th class="hide-on-mobile" style="width:3rem;">Ảnh</th>
      <th style="min-width:180px;">Sản phẩm</th>
      <th class="hide-on-mobile">SKU</th>
      <th class="hide-on-mobile">Danh mục</th>
      <th>Giá</th>
      <th class="hide-on-mobile">Tồn kho</th>
      <th>Trạng thái</th>
      <th style="width:5rem;text-align:center;">SEO</th>
      <th></th>
    </tr>
  </thead>
  <tbody id="products-body">
    <tr><td colspan="10" style="color:#999;">Đang tải...</td></tr>
  </tbody>
</table>
<div class="pagination" id="pagination"></div>

<script>
(function () {
  const tbody = document.getElementById("products-body");
  const pagination = document.getElementById("pagination");
  const flash = document.getElementById("flash");
  const searchInput = document.getElementById("search-input");
  const categoryFilter = document.getElementById("category-filter");
  const statusFilter = document.getElementById("status-filter");

  let currentPage = 1;
  let searchTimer;

  function showError(message) {
    flash.textContent = message;
    flash.className = "error";
  }

  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str ?? "";
    return div.innerHTML;
  }

  const STATUS_LABEL = { draft: "Nháp", pending_review: "Chờ duyệt", scheduled: "Đã lên lịch", published: "Đã xuất bản" };

  function rowHtml(p) {
    const statusBadge = '<span class="status-badge status-' + p.status + '">' + (STATUS_LABEL[p.status] || p.status) + '</span>';
    const publishBtn = p.status !== "published"
      ? '<button class="btn" data-action="publish" data-id="' + p.id + '">Xuất bản</button>'
      : "";
    const category = (p.categories && p.categories.length) ? p.categories.map((c) => escapeHtml(c.name)).join(", ") : "-";
    const variantsBadge = p.hasVariants ? ' <span class="status-badge">Có biến thể</span>' : "";
    const score = (p.seo && p.seo.score) || 0;
    let color = "#ef4444";
    if (score >= 80) color = "#10b981";
    else if (score >= 50) color = "#f59e0b";
    
    const seoHtml = '<div style="width:28px;height:28px;border-radius:50%;background:conic-gradient(' + color + ' ' + score + '%, #e5e7eb 0);display:flex;align-items:center;justify-content:center;margin:0 auto;"><div style="width:22px;height:22px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;color:' + color + ';">' + score + '</div></div>';

    const thumbHtml = (p.imageUrls && p.imageUrls.length > 0) 
      ? '<img src="' + escapeHtml(p.imageUrls[0]) + '" style="width:32px;height:32px;object-fit:cover;border-radius:4px;vertical-align:middle;">' 
      : '<div style="width:32px;height:32px;background:#eee;border-radius:4px;display:inline-block;vertical-align:middle;"></div>';

    const priceHtml = p.salePrice 
      ? '<del style="color:#999;font-size:0.8rem;">' + p.price + '₫</del> <strong style="color:var(--color-primary);">' + p.salePrice + '₫</strong>'
      : p.price + '₫';

    return (
      "<tr>" +
      '<td><input type="checkbox" class="row-select" value="' + p.id + '"></td>' +
      '<td class="hide-on-mobile">' + thumbHtml + '</td>' +
      '<td><a href="/admin/products/' + p.id + '">' + escapeHtml(p.name) + "</a>" + variantsBadge + "</td>" +
      "<td class=\"hide-on-mobile\">" + (p.sku ? escapeHtml(p.sku) : "-") + "</td>" +
      "<td class=\"hide-on-mobile\">" + category + "</td>" +
      "<td>" + priceHtml + "</td>" +
      "<td class=\"hide-on-mobile\">" + (p.stock ?? "-") + "</td>" +
      "<td>" + statusBadge + "</td>" +
      '<td style="text-align:center;">' + seoHtml + '</td>' +
      '<td style="text-align:right;white-space:nowrap;">' + 
      '<button type="button" class="btn btn-icon" style="margin-right:0.2rem;" title="Xem trước" onclick="window.openPreview(\'/admin/preview/product/' + p.id + '\')">' + window.adminIcon("eye") + '</button>' +
      '<a href="/products/' + p.slug + '" target="_blank" class="btn btn-icon" style="margin-right:0.2rem;" title="Xem trên web">' + window.adminIcon("external-link") + '</a>' +
      publishBtn + 
      "</td>" +
      "</tr>"
    );
  }

  async function load() {
    const params = new URLSearchParams({ page: String(currentPage) });
    if (searchInput.value) params.set("q", searchInput.value);
    if (categoryFilter.value) params.set("categoryId", categoryFilter.value);
    if (statusFilter.value) params.set("status", statusFilter.value);

    const res = await fetch("/admin/api/products?" + params.toString());
    if (!res.ok) {
      showError("Không tải được danh sách sản phẩm");
      return;
    }
    const { products, totalPages } = await res.json();
    if (products.length === 0) {
      tbody.innerHTML = '<tr><td colspan="10" class="empty-state">Không tìm thấy sản phẩm nào.</td></tr>';
      pagination.innerHTML = "";
      return;
    }

    tbody.innerHTML = products.map(rowHtml).join("");
    window.renderPagination(pagination, currentPage, totalPages);
  }

  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => { currentPage = 1; load(); }, 300);
  });
  categoryFilter.addEventListener("change", () => { currentPage = 1; load(); });
  statusFilter.addEventListener("change", () => { currentPage = 1; load(); });

  pagination.addEventListener("click", (event) => {
    const link = event.target.closest("a[data-page]");
    if (!link) return;
    event.preventDefault();
    currentPage = Number(link.dataset.page);
    load();
  });

  tbody.addEventListener("click", async (event) => {
    const btn = event.target.closest("button[data-action=publish]");
    if (!btn) return;
    const res = await fetch("/admin/api/products/" + btn.dataset.id + "/publish", { method: "POST" });
    if (!res.ok) {
      showError("Xuất bản thất bại");
      return;
    }
    load();
  });

  const selectAll = document.getElementById("select-all");
  const bulkBar = document.getElementById("bulk-bar");
  const bulkCount = document.getElementById("bulk-count");

  function selectedIds() {
    return [...tbody.querySelectorAll(".row-select:checked")].map((el) => el.value);
  }

  function refreshBulkBar() {
    const ids = selectedIds();
    bulkBar.style.display = ids.length ? "flex" : "none";
    bulkCount.textContent = "Đã chọn " + ids.length + " sản phẩm";
  }

  tbody.addEventListener("change", (event) => {
    if (event.target.classList.contains("row-select")) refreshBulkBar();
  });

  selectAll.addEventListener("change", () => {
    tbody.querySelectorAll(".row-select").forEach((el) => (el.checked = selectAll.checked));
    refreshBulkBar();
  });

  document.getElementById("bulk-publish").addEventListener("click", async () => {
    const ids = selectedIds();
    if (!ids.length) return;
    await Promise.all(ids.map((id) => fetch("/admin/api/products/" + id + "/publish", { method: "POST" })));
    selectAll.checked = false;
    load();
  });

  load();
})();
</script>
{% endblock %}

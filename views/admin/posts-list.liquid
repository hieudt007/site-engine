{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;">
  <h1 style="margin:0;">Bài viết</h1>
  <a class="btn btn-primary" href="/admin/posts/new">+ Bài mới</a>
</div>

<div style="display:flex;gap:0.6rem;margin-bottom:1rem;flex-wrap:wrap;">
  <input type="search" id="search-input" class="search-input" placeholder="Tìm theo tiêu đề...">
  <select id="category-filter" style="max-width:220px;">
    <option value="">Tất cả danh mục</option>
    {% for c in categories %}
      <option value="{{ c.id }}">{{ c.name | escape }}</option>
    {% endfor %}
  </select>
  <select id="status-filter" style="max-width:180px;">
    <option value="">Tất cả trạng thái</option>
    <option value="draft">Nháp</option>
    <option value="pending_review">Chờ duyệt</option>
    <option value="scheduled">Đã lên lịch</option>
    <option value="published">Đã xuất bản</option>
  </select>
</div>

{% if role == "manager" or role == "admin" %}
<div id="bulk-bar" style="display:none;align-items:center;gap:0.6rem;margin-bottom:0.8rem;padding:0.6rem 0.9rem;background:#eff6ff;border-radius:var(--radius-sm);font-size:0.85rem;">
  <span id="bulk-count"></span>
  <button type="button" class="btn" id="bulk-publish">Xuất bản</button>
  <button type="button" class="btn btn-danger btn-icon" id="bulk-delete" title="Xoá" aria-label="Xoá">{% render "components/icon", name: "trash" %}</button>
</div>
{% endif %}

<table>
  <thead>
    <tr>
      {% if role == "manager" or role == "admin" %}<th style="width:2rem;"><input type="checkbox" id="select-all"></th>{% endif %}
      <th>Tiêu đề</th>
      <th>Danh mục</th>
      <th>Trạng thái</th>
      <th style="width:5rem;text-align:center;">SEO</th>
      <th style="width:6rem;text-align:center;">Inter Link</th>
      <th>Tác giả</th>
      <th>Cập nhật</th>
      <th></th>
    </tr>
  </thead>
  <tbody id="posts-body">
    <tr><td colspan="9" style="color:#999;">Đang tải...</td></tr>
  </tbody>
</table>
<div class="pagination" id="pagination"></div>

<script>
(function () {
  const CURRENT_ROLE = "{{ role }}";
  const canManage = CURRENT_ROLE === "manager" || CURRENT_ROLE === "admin";
  const tbody = document.getElementById("posts-body");
  const pagination = document.getElementById("pagination");
  const flash = document.getElementById("flash");
  const searchInput = document.getElementById("search-input");
  const categoryFilter = document.getElementById("category-filter");
  const statusFilter = document.getElementById("status-filter");

  let currentPage = 1;
  let searchTimer;

  function showError(message) {
    flash.textContent = message;
    flash.className = "error";
  }

  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str ?? "";
    return div.innerHTML;
  }

  const STATUS_LABEL = { draft: "Nháp", pending_review: "Chờ duyệt", scheduled: "Đã lên lịch", published: "Đã xuất bản" };

  function rowHtml(post) {
    const statusBadge = '<span class="status-badge status-' + post.status + '">' + (STATUS_LABEL[post.status] || post.status) + '</span>';
    const author = post.author ? escapeHtml(post.author.name) : "-";
    const category = (post.categories && post.categories.length) ? post.categories.map((c) => escapeHtml(c.name)).join(", ") : "-";
    const updated = new Date(post.updatedAt).toLocaleString("vi-VN");

    const score = (post.seo && post.seo.score) || 0;
    let color = "#ef4444";
    if (score >= 80) color = "#10b981";
    else if (score >= 50) color = "#f59e0b";
    
    const seoHtml = '<div style="width:28px;height:28px;border-radius:50%;background:conic-gradient(' + color + ' ' + score + '%, #e5e7eb 0);display:flex;align-items:center;justify-content:center;margin:0 auto;"><div style="width:22px;height:22px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;color:' + color + ';">' + score + '</div></div>';

    const internalLinks = (post.seo && post.seo.internalLinks !== undefined) ? post.seo.internalLinks : "-";

    const submitBtn = post.status === "draft"
      ? '<button class="btn" data-action="submit" data-id="' + post.id + '">Nộp duyệt</button>'
      : "";
    const publishBtn = (post.status === "pending_review" || post.status === "scheduled") && canManage
      ? '<button class="btn" data-action="publish" data-id="' + post.id + '">Xuất bản</button>'
      : "";
    const selectCell = canManage ? '<td><input type="checkbox" class="row-select" value="' + post.id + '"></td>' : "";
    return (
      "<tr>" +
      selectCell +
      '<td>' + (post.password ? '<span style="color:#f59e0b;vertical-align:-2px;margin-right:0.2rem;display:inline-block;width:14px;height:14px;" title="Có mật khẩu">' + window.adminIcon("lock") + '</span>' : '') + '<a href="/admin/posts/' + post.id + '">' + escapeHtml(post.title) + "</a></td>" +
      "<td>" + category + "</td>" +
      "<td>" + statusBadge + "</td>" +
      '<td style="text-align:center;">' + seoHtml + '</td>' +
      '<td style="text-align:center;">' + internalLinks + '</td>' +
      "<td>" + author + "</td>" +
      "<td>" + updated + "</td>" +
      '<td style="text-align:right;white-space:nowrap;">' +
      '<button type="button" class="btn btn-icon" style="margin-right:0.2rem;" title="Xem trước" onclick="window.openPreview(\'/admin/preview/post/' + post.id + '\')">' + window.adminIcon("eye") + '</button>' +
      '<a href="/blog/' + post.slug + '" target="_blank" class="btn btn-icon" style="margin-right:0.2rem;" title="Xem trên web">' + window.adminIcon("external-link") + '</a>' +
      submitBtn +
      publishBtn +
      "</td>" +
      "</tr>"
    );
  }

  function selectedIds() {
    return [...tbody.querySelectorAll(".row-select:checked")].map((el) => el.value);
  }

  if (canManage) {
    const selectAll = document.getElementById("select-all");
    const bulkBar = document.getElementById("bulk-bar");
    const bulkCount = document.getElementById("bulk-count");

    function refreshBulkBar() {
      const ids = selectedIds();
      bulkBar.style.display = ids.length ? "flex" : "none";
      bulkCount.textContent = "Đã chọn " + ids.length + " bài";
    }

    tbody.addEventListener("change", (event) => {
      if (event.target.classList.contains("row-select")) refreshBulkBar();
    });

    selectAll.addEventListener("change", () => {
      tbody.querySelectorAll(".row-select").forEach((el) => (el.checked = selectAll.checked));
      refreshBulkBar();
    });

    document.getElementById("bulk-publish").addEventListener("click", async () => {
      const ids = selectedIds();
      if (!ids.length) return;
      await Promise.all(ids.map((id) => fetch("/admin/api/posts/" + id + "/publish", { method: "POST" })));
      selectAll.checked = false;
      load();
    });

    document.getElementById("bulk-delete").addEventListener("click", async () => {
      const ids = selectedIds();
      if (!ids.length) return;
      if (!confirm("Xoá " + ids.length + " bài viết đã chọn?")) return;
      await Promise.all(ids.map((id) => fetch("/admin/api/posts/" + id, { method: "DELETE" })));
      selectAll.checked = false;
      load();
    });
  }

  async function load() {
    const params = new URLSearchParams({ page: String(currentPage) });
    if (searchInput.value) params.set("q", searchInput.value);
    if (categoryFilter.value) params.set("categoryId", categoryFilter.value);
    if (statusFilter.value) params.set("status", statusFilter.value);

    const res = await fetch("/admin/api/posts?" + params.toString());
    if (!res.ok) {
      showError("Không tải được danh sách bài viết");
      return;
    }
    const { posts, totalPages } = await res.json();
    if (posts.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="empty-state">Không tìm thấy bài viết nào.</td></tr>';
      pagination.innerHTML = "";
      return;
    }

    tbody.innerHTML = posts.map(rowHtml).join("");
    window.renderPagination(pagination, currentPage, totalPages);
  }

  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => { currentPage = 1; load(); }, 300);
  });
  categoryFilter.addEventListener("change", () => { currentPage = 1; load(); });
  statusFilter.addEventListener("change", () => { currentPage = 1; load(); });

  pagination.addEventListener("click", (event) => {
    const link = event.target.closest("a[data-page]");
    if (!link) return;
    event.preventDefault();
    currentPage = Number(link.dataset.page);
    load();
  });

  tbody.addEventListener("click", async (event) => {
    const btn = event.target.closest("button[data-action]");
    if (!btn) return;
    const { action, id } = btn.dataset;

    if (action === "delete" && !confirm("Xoá bài viết này?")) return;

    const res = await fetch(
      "/admin/api/posts/" + id + (action === "delete" ? "" : "/" + action),
      { method: action === "delete" ? "DELETE" : "POST" },
    );
    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showError(body.error || "Thao tác thất bại");
      return;
    }
    load();
  });

  load();
})();
</script>
{% endblock %}

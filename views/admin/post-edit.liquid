{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;">
  <h1 style="margin:0;">{% if post %}Sửa bài viết{% else %}Bài viết mới{% endif %}</h1>
  <div style="display:flex;gap:0.6rem;">
    {% if post %}<button type="button" class="btn btn-icon" onclick="window.openPreview('/admin/preview/post/{{ post.id }}')" title="Xem thử"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg></button>{% endif %}
    <span id="delete-slot"></span>
  </div>
</div>
<div id="ai-status" style="font-size:0.85rem;color:#777;margin-bottom:0.8rem;"></div>

<form id="post-form" class="edit-layout">
  <div class="edit-main">
    <div class="card">
      <label for="title" style="margin-bottom:0.2rem;">Tiêu đề</label>
      <input type="text" id="title" name="title" value="{% if post %}{{ post.title | escape }}{% endif %}" required style="margin-bottom:0.3rem;">

      <div style="font-size:0.85rem; color:#666; margin-bottom:1.2rem; display:flex; align-items:center; gap:0.4rem;">
        <span style="flex-shrink:0;">Đường dẫn:</span>
        <span style="flex: 1; min-width: 0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:var(--color-primary);" title="https://{{ siteDomain }}/{% if postSlugPrefix and postSlugPrefix != "" %}{{ postSlugPrefix }}/{% endif %}{% if post %}{{ post.slug | escape }}{% endif %}">
          <span id="base-url-display">https://{{ siteDomain }}/{% if postSlugPrefix and postSlugPrefix != "" %}{{ postSlugPrefix }}/{% endif %}</span><span style="font-weight:600;" id="slug-display">{% if post %}{{ post.slug | escape }}{% endif %}</span>
        </span>
        <button type="button" class="btn" id="slug-edit-btn" style="padding:0.1rem 0.4rem; font-size:0.75rem; margin-left:0.5rem; flex-shrink:0;">Sửa</button>
      </div>
      
      <div id="slug-edit-container" style="display:none; margin-bottom:1.2rem;">
        <input type="text" id="slug" name="slug" value="{% if post %}{{ post.slug | escape }}{% endif %}" required>
        <div class="field-hint">Chỉ chữ thường/số, cách nhau bằng dấu gạch ngang. Vd: bai-viet-dau-tien</div>
      </div>

      <label for="body">Nội dung</label>
      <textarea id="body" name="body" required>{% if post %}{{ post.body }}{% endif %}</textarea>
    </div>

    <div class="card">
      <h3 class="edit-card-title">Tóm tắt</h3>
      <div id="excerpt-body" style="margin-top:0.5rem;">
        <textarea id="excerpt" name="excerpt" style="min-height:80px;">{% if post %}{{ post.excerpt | escape }}{% endif %}</textarea>
      </div>
    </div>


      <div style="background:#fff;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;">
        <div style="padding:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:0.95rem;" onclick="const el=document.getElementById('seo-body');el.style.display=el.style.display==='none'?'block':'none';">
          SEO <span style="font-size:0.7rem;color:#888;">▼</span>
        </div>
        <div id="seo-body" style="display:none;padding:1rem;border-top:1px solid var(--color-border);">
          <label for="keyword" style="margin-top:0;">Từ khoá chính</label>
          <input type="text" id="keyword" name="keyword" value="{% if post.seo %}{{ post.seo.keyword | escape }}{% endif %}" placeholder="Ví dụ: máy hút bụi, thiết bị gia dụng">
          <div class="field-hint">Có thể nhập nhiều từ khoá, ngăn cách bởi dấu phẩy.</div>
          <label for="internalLinks" style="margin-top:0.5rem;">Số liên kết nội bộ</label>
          <input type="number" id="internalLinks" name="internalLinks" value="{% if post.seo %}{{ post.seo.internalLinks }}{% endif %}" placeholder="Ví dụ: 5">
          <label for="metaTitle" style="margin-top:0.5rem;">Meta title</label>
          <input type="text" id="metaTitle" name="metaTitle" value="{% if post.seo %}{{ post.seo.metaTitle | escape }}{% endif %}" placeholder="Để trống nếu dùng tiêu đề bài viết">
          <label for="metaDescription">Meta description</label>
          <input type="text" id="metaDescription" name="metaDescription" value="{% if post.seo %}{{ post.seo.metaDescription | escape }}{% endif %}" placeholder="Để trống nếu dùng tóm tắt bài viết">
          <label style="margin-bottom:0.5rem;display:block;">Ảnh chia sẻ (Open Graph, URL)</label>
          {% render "components/image-picker", id: "ogImage", name: "ogImage", value: post.seo.ogImage, width: "180px", height: "120px" %}
          <label style="display:flex;align-items:center;gap:0.4rem;margin-top:0.8rem;">
            <input type="checkbox" id="noindex" name="noindex" style="width:auto;" {% if post.seo.noindex %}checked{% endif %}>
            noindex (ẩn khỏi công cụ tìm kiếm)
          </label>
        </div>
      </div>

      <div style="background:#fff;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;">
        <div style="padding:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:0.95rem;" onclick="const el=document.getElementById('faq-container-body');el.style.display=el.style.display==='none'?'block':'none';">
          Câu hỏi thường gặp (FAQ) <span style="font-size:0.7rem;color:#888;">▼</span>
        </div>
        <div id="faq-container-body" style="display:none;padding:1rem;border-top:1px solid var(--color-border);">
          <div id="faq-rows">
            {% for item in post.faq %}
              <div class="faq-row" style="margin-bottom:0.5rem;position:relative;background:#f9fafb;padding:0.6rem;border-radius:4px;border:1px solid #e5e7eb;">
                <button type="button" class="btn btn-danger btn-icon faq-remove" title="Xoá" aria-label="Xoá" style="position:absolute;top:0.4rem;right:0.4rem;padding:0.15rem;">{% render "components/icon", name: "trash" %}</button>
                <div style="margin-bottom:0.4rem;padding-right:2rem;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu hỏi</label><input type="text" class="faq-q" value="{{ item.question | escape }}" style="margin:0;font-size:0.85rem;padding:0.3rem;"></div>
                <div><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu trả lời</label><textarea class="faq-a" style="margin:0;font-size:0.85rem;padding:0.3rem;min-height:60px;">{{ item.answer | escape }}</textarea></div>
              </div>
            {% endfor %}
          </div>
          <div style="margin-top:0.5rem;background:#f9fafb;padding:0.6rem;border-radius:4px;border:1px dashed #ccc;">
            <div style="margin-bottom:0.4rem;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu hỏi mới</label><input type="text" id="new-faq-q" style="margin:0;font-size:0.85rem;padding:0.3rem;"></div>
            <div style="margin-bottom:0.4rem;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu trả lời</label><textarea id="new-faq-a" style="margin:0;font-size:0.85rem;padding:0.3rem;min-height:60px;"></textarea></div>
            <button type="button" class="btn" id="faq-add-btn" style="width:100%;justify-content:center;">+ Thêm câu hỏi này</button>
          </div>
        </div>
      </div>

      <div style="background:#fff;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;">
        <div style="padding:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:0.95rem;" onclick="const el=document.getElementById('cf-body');el.style.display=el.style.display==='none'?'block':'none';">
          Trường tuỳ biến <span style="font-size:0.7rem;color:#888;">▼</span>
        </div>
        <div id="cf-body" style="display:none;padding:1rem;border-top:1px solid var(--color-border);">
          <div id="cf-rows" style="display:flex;flex-direction:column;gap:0.5rem;"></div>
          <div style="margin-top:0.5rem;background:#f9fafb;padding:0.6rem;border-radius:4px;border:1px dashed #ccc;">
            <div style="display:flex;gap:0.4rem;align-items:flex-end;">
              <div style="flex:1;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Tên trường</label><input type="text" id="new-cf-key" style="margin:0;font-size:0.85rem;padding:0.3rem;"></div>
              <div style="flex:1;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Giá trị</label><input type="text" id="new-cf-value" style="margin:0;font-size:0.85rem;padding:0.3rem;"></div>
              <button type="button" class="btn" id="cf-add-btn">+</button>
            </div>
          </div>
        </div>
      </div>

      <div style="background:#fff;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;">
        <div style="padding:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:0.95rem;" onclick="const el=document.getElementById('history-body');if(el)el.style.display=el.style.display==='none'?'block':'none';">
          Lịch sử chỉnh sửa <span style="font-size:0.7rem;color:#888;">▼</span>
        </div>
        <div id="history-body" style="display:none;padding:1rem;border-top:1px solid var(--color-border);">
          <div id="revisions-list" style="display:flex;flex-direction:column;gap:1rem;">
            <div class="empty-state" style="padding:0.5rem;">Đang tải...</div>
          </div>
        </div>
      </div>

  </div>

  <div class="edit-sidebar">
    <div class="card">
      <h3 class="edit-card-title">Xuất bản</h3>
      <div style="display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center;">
        <select id="status-select" name="status" style="width:auto;padding:0.35rem 1.5rem 0.35rem 0.5rem;font-size:0.85rem;border-radius:4px;border:1px solid #ccc;background-color:#f9fafb;">
          <option value="draft" {% if post == null or post.status == 'draft' %}selected{% endif %}>Nháp</option>
          <option value="pending_review" {% if post.status == 'pending_review' %}selected{% endif %}>Chờ duyệt</option>
          <option value="scheduled" {% if post.status == 'scheduled' %}selected{% endif %}>Đã lên lịch</option>
          <option value="published" {% if post.status == 'published' %}selected{% endif %}>Đã xuất bản</option>
        </select>
        <button type="submit" class="btn btn-primary">Lưu</button>
        <span id="submit-slot"></span>
        <span id="publish-slot"></span>
        <span id="schedule-slot"></span>
        <span id="unpublish-slot"></span>
      </div>
      {% if post and post.publishedAt %}
        <div id="publish-date-display" style="display: {% if post.status == 'published' %}flex{% else %}none{% endif %}; margin-top:0.8rem; padding:0.6rem; background:#f9fafb; border:1px solid #eee; border-radius:4px; align-items:center; gap:0.5rem; font-size:0.85rem; color:#555;">
          <span style="color:#888;">{% render "components/icon", name: "calendar" %}</span>
          <span>Đã xuất bản: <strong id="publishedAt-text">{{ post.publishedAt | date: "%d/%m/%Y %H:%M" }}</strong></span>
        </div>
      {% endif %}
      
      <div id="schedule-date-container" style="display: {% if post and post.status == 'scheduled' %}block{% else %}none{% endif %}; margin-top:0.8rem; padding:0.6rem; background:#f9fafb; border:1px solid #eee; border-radius:4px;">
        <label for="scheduledAt-input" style="font-size:0.8rem;margin:0 0 0.3rem;">Ngày/Giờ hẹn xuất bản</label>
        <input type="datetime-local" id="scheduledAt-input" value="{% if post and post.scheduledAt %}{{ post.scheduledAt | date: '%Y-%m-%dT%H:%M' }}{% endif %}" style="font-size:0.85rem;padding:0.4rem;">
      </div>
      <div style="margin-top:1rem;">
        <label style="display:flex;align-items:center;gap:0.6rem;font-weight:600;font-size:0.85rem;cursor:pointer;margin:0;">
          <div style="position:relative;display:inline-block;width:36px;height:20px;flex-shrink:0;">
            <input type="checkbox" id="protect-switch" style="opacity:0;width:0;height:0;position:absolute;" {% if post.password %}checked{% endif %} onchange="document.getElementById('password-container').style.display=this.checked?'block':'none'; if(!this.checked) document.getElementById('password').value=''; document.getElementById('protect-slider').style.backgroundColor=this.checked?'var(--color-primary)':'#e5e7eb'; document.getElementById('protect-knob').style.transform=this.checked?'translateX(16px)':'translateX(0)';">
            <span style="position:absolute;top:0;left:0;right:0;bottom:0;background-color:{% if post.password %}var(--color-primary){% else %}#e5e7eb{% endif %};transition:.3s;border-radius:20px;" id="protect-slider"></span>
            <span style="position:absolute;height:16px;width:16px;left:2px;bottom:2px;background-color:white;transition:.3s;border-radius:50%;transform:{% if post.password %}translateX(16px){% else %}translateX(0){% endif %};" id="protect-knob"></span>
          </div>
          Bảo vệ bài viết
        </label>
        <div id="password-container" style="margin-top:0.6rem; {% unless post.password %}display:none;{% endunless %}">
          <input type="text" id="password" name="password" value="{% if post %}{{ post.password | escape }}{% endif %}" placeholder="Nhập mật khẩu..." style="font-size:0.85rem;padding:0.4rem;">
        </div>
      </div>
    </div>

    {% render "components/seo-score", seo: post.seo %}


    <div class="card">
      <h3 class="edit-card-title">Ảnh bìa</h3>
      <input type="hidden" id="coverImage" name="coverImage" value="{% if post %}{{ post.coverImage | escape }}{% endif %}">
      
      <div id="coverImage-dropzone" style="border:1px dashed #ccc; border-radius:6px; padding:2rem 1rem; text-align:center; cursor:pointer; position:relative; background:#fafafa; overflow:hidden; min-height:140px; display:flex; flex-direction:column; justify-content:center; align-items:center;">
        <div id="coverImage-empty" style="{% if post.coverImage %}display:none;{% endif %}">
          <button type="button" class="btn" style="background:#fff; border:1px solid #ddd; margin-bottom:0.5rem;">Thêm ảnh</button>
          <div style="font-size:0.8rem; color:#888;">hoặc kéo thả ảnh vào đây</div>
        </div>
        <img id="coverImage-preview" src="{% if post %}{{ post.coverImage | escape }}{% endif %}" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit:cover; {% unless post.coverImage %}display:none;{% endunless %}">
        
        <div id="coverImage-overlay" style="display:none; position:absolute; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); align-items:center; justify-content:center;">
          <button type="button" id="coverImage-remove-btn" class="btn btn-danger btn-icon" style="border-radius:50%; padding:0.6rem; margin:0;" title="Xoá ảnh">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="card">
      <h3 class="edit-card-title">Phân loại</h3>
      <label style="margin-top:0;">Danh mục</label>
      <div style="display:flex;flex-direction:column;gap:0.4rem;max-height:200px;overflow-y:auto;border:1px solid var(--color-border);padding:0.6rem;border-radius:var(--radius-sm);margin-bottom:0.8rem;">
        {% if categories.size == 0 %}
          <span style="color:#999;font-size:0.85rem;">Chưa có danh mục nào.</span>
        {% endif %}
        {% for c in categories %}
          <label style="display:flex;align-items:center;gap:0.35rem;font-weight:400;margin:0;">
            <input type="checkbox" name="categoryIds" value="{{ c.id }}" style="width:auto;" {% if selectedCategoryIds contains c.id %}checked{% endif %}>
            {{ c.name | escape }}
          </label>
        {% endfor %}
      </div>

      <label for="topicId">Chủ đề</label>
      <select id="topicId" name="topicId">
        <option value="">— Không có chủ đề —</option>
        {% for t in topics %}
          <option value="{{ t.id }}" {% if post.topicId == t.id %}selected{% endif %}>{{ t.name | escape }}</option>
        {% endfor %}
      </select>
    </div>

    <div class="card">
      <h3 class="edit-card-title">Giao diện</h3>
      <select id="layoutMode" name="layoutMode">
        <option value="standard" {% if post == null or post.layoutMode == "standard" %}selected{% endif %}>Tiêu chuẩn</option>
        <option value="custom" {% if post.layoutMode == "custom" %}selected{% endif %}>Tuỳ biến</option>
        <option value="landing" {% if post.layoutMode == "landing" %}selected{% endif %}>Landing page</option>
      </select>
      <div class="field-hint">Tuỳ biến/Landing page: ô Nội dung chuyển sang nhập HTML thô.</div>
    </div>

  </div>
</form>

<script>
(function () {
  const CURRENT_ROLE = "{{ role }}";
  const canManage = CURRENT_ROLE === "manager" || CURRENT_ROLE === "admin";
  const postId = {% if post %}"{{ post.id }}"{% else %}null{% endif %};
  const status = {% if post %}"{{ post.status }}"{% else %}"draft"{% endif %};
  const locked = (status === "scheduled" || status === "published") && CURRENT_ROLE === "edit";
  const form = document.getElementById("post-form");
  const flash = document.getElementById("flash");

  function showFlash(message, ok) {
    flash.textContent = message;
    flash.className = ok ? "success" : "error";
  }

  const coverImageInput = document.getElementById("coverImage");
  const coverImagePreview = document.getElementById("coverImage-preview");
  const dropzone = document.getElementById("coverImage-dropzone");
  const emptyState = document.getElementById("coverImage-empty");
  const overlay = document.getElementById("coverImage-overlay");
  const removeBtn = document.getElementById("coverImage-remove-btn");

  dropzone.addEventListener("click", (e) => {
    if (e.target.closest("#coverImage-remove-btn")) return;
    openMediaPicker({
      title: "Chọn ảnh bìa",
      onSelect: (url, media) => {
        coverImageInput.value = url;
        coverImagePreview.src = url;
        coverImagePreview.style.display = "";
        emptyState.style.display = "none";
        overlay.style.display = "none";
      },
    });
  });

  dropzone.addEventListener("mouseenter", () => {
    if (coverImageInput.value) overlay.style.display = "flex";
  });
  dropzone.addEventListener("mouseleave", () => {
    overlay.style.display = "none";
  });

  removeBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    coverImageInput.value = "";
    coverImagePreview.src = "";
    coverImagePreview.style.display = "none";
    emptyState.style.display = "";
    overlay.style.display = "none";
  });

  const statusSelect = document.getElementById("status-select");
  const publishDateDisplay = document.getElementById("publish-date-display");
  const scheduleDateContainer = document.getElementById("schedule-date-container");
  
  if (statusSelect) {
    statusSelect.addEventListener("change", (e) => {
      if (scheduleDateContainer) scheduleDateContainer.style.display = e.target.value === 'scheduled' ? 'block' : 'none';
      if (publishDateDisplay) publishDateDisplay.style.display = e.target.value === 'published' ? 'flex' : 'none';
    });
  }

  const layoutModeSelect = document.getElementById("layoutMode");

  function applyEditorMode() {
    const editorBody = document.querySelector(".rich-editor-body");
    const toolbar = document.querySelector(".rich-editor-toolbar");

    if (layoutModeSelect.value === "standard") {
      if (!editorBody) initRichEditor("body");
    } else if (editorBody) {
      form.body.value = editorBody.innerHTML;
      toolbar.remove();
      editorBody.remove();
      form.body.style.display = "";
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    applyEditorMode();
    if (locked) {
      const editorBody = document.querySelector(".rich-editor-body");
      if (editorBody) editorBody.contentEditable = "false";
    }
  });

  layoutModeSelect.addEventListener("change", applyEditorMode);

  function setBodyContent(html) {
    form.body.value = html;
    const editorBody = document.querySelector(".rich-editor-body");
    if (editorBody) editorBody.innerHTML = html;
  }

  if (postId && locked) {
    [...form.elements].forEach((el) => (el.disabled = true));
    showFlash("Bài đã lên lịch/xuất bản — chỉ manager/admin được sửa.", false);
  }

  async function callAction(path, body) {
    const res = await fetch("/admin/api/posts/" + postId + path, {
      method: "POST",
      headers: body ? { "Content-Type": "application/json" } : undefined,
      body: body ? JSON.stringify(body) : undefined,
    });
    if (!res.ok) {
      const errBody = await res.json().catch(() => ({}));
      showFlash(typeof errBody.error === "string" ? errBody.error : "Thao tác thất bại", false);
      return false;
    }
    return true;
  }

  if (postId) {
    if (canManage) {
      const deleteBtn = document.createElement("button");
      deleteBtn.type = "button";
      deleteBtn.className = "btn btn-danger btn-icon";
      deleteBtn.title = "Xoá bài viết";
      deleteBtn.innerHTML = window.adminIcon ? window.adminIcon("trash") : "Xoá";
      deleteBtn.onclick = async () => {
        if (!confirm("Xoá bài viết này?")) return;
        const res = await fetch("/admin/api/posts/" + postId, { method: "DELETE" });
        if (!res.ok) {
          showFlash("Xoá thất bại", false);
          return;
        }
        window.location.href = "/admin/posts";
      };
      document.getElementById("delete-slot").appendChild(deleteBtn);
    }
  }

  const faqRows = document.getElementById("faq-rows");
  function addFaqRow(q, a) {
    const row = document.createElement("div");
    row.className = "faq-row";
    row.style.cssText = "margin-bottom:0.5rem;position:relative;background:#f9fafb;padding:0.6rem;border-radius:4px;border:1px solid #e5e7eb;";
    row.innerHTML =
      '<button type="button" class="btn btn-danger btn-icon faq-remove" title="Xoá" aria-label="Xoá" style="position:absolute;top:0.4rem;right:0.4rem;padding:0.15rem;">' + window.adminIcon("trash") + '</button>' +
      '<div style="margin-bottom:0.4rem;padding-right:2rem;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu hỏi</label><input type="text" class="faq-q" value="" style="margin:0;font-size:0.85rem;padding:0.3rem;"></div>' +
      '<div><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu trả lời</label><textarea class="faq-a" style="margin:0;font-size:0.85rem;padding:0.3rem;min-height:60px;"></textarea></div>';
    row.querySelector(".faq-q").value = q || "";
    row.querySelector(".faq-a").value = a || "";
    faqRows.appendChild(row);
  }
  
  document.getElementById("faq-add-btn").addEventListener("click", () => {
    const newQ = document.getElementById("new-faq-q");
    const newA = document.getElementById("new-faq-a");
    if(newQ.value.trim() && newA.value.trim()) {
      addFaqRow(newQ.value.trim(), newA.value.trim());
      newQ.value = "";
      newA.value = "";
    } else {
      alert("Vui lòng nhập cả câu hỏi và câu trả lời");
    }
  });

  function addCfRow(k, v) {
    const row = document.createElement("div");
    row.className = "cf-row";
    row.style.cssText = "display:flex;gap:0.4rem;";
    row.innerHTML =
      '<input type="text" class="cf-k" value="' + k.replace(/"/g, '&quot;') + '" style="flex:1;font-size:0.85rem;padding:0.3rem;">' +
      '<input type="text" class="cf-v" value="' + v.replace(/"/g, '&quot;') + '" style="flex:1;font-size:0.85rem;padding:0.3rem;">' +
      '<button type="button" class="btn btn-danger cf-remove">×</button>';
    document.getElementById("cf-rows").appendChild(row);
  }

  document.getElementById("cf-add-btn").addEventListener("click", () => {
    const newKey = document.getElementById("new-cf-key");
    const newValue = document.getElementById("new-cf-value");
    if(newKey.value.trim()) {
      addCfRow(newKey.value.trim(), newValue.value.trim());
      newKey.value = "";
      newValue.value = "";
    }
  });
  faqRows.addEventListener("click", (e) => {
    if (e.target.classList.contains("faq-remove")) e.target.closest(".faq-row").remove();
  });
  document.getElementById("cf-rows").addEventListener("click", (e) => {
    if (e.target.classList.contains("cf-remove")) e.target.closest(".cf-row").remove();
  });

  function collectFaq() {
    return [...faqRows.querySelectorAll(".faq-row")]
      .map(row => ({
        question: row.querySelector(".faq-q").value.trim(),
        answer: row.querySelector(".faq-a").value.trim()
      }))
      .filter(i => i.question && i.answer);
  }

  function collectCustomFields() {
    const result = {};
    document.querySelectorAll("#cf-rows .cf-row").forEach(row => {
      const key = row.querySelector(".cf-k").value.trim();
      const value = row.querySelector(".cf-v").value.trim();
      if (key) result[key] = value;
    });
    return result;
  }
  
  // Inject existing custom fields on load
  const rawCustomFields = {% if post and post.customFields %}{{ post.customFields | json }}{% else %}{}{% endif %};
  if (rawCustomFields && typeof rawCustomFields === "object") {
    for (const [k, v] of Object.entries(rawCustomFields)) {
      addCfRow(k, v);
    }
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    const categoryIds = [...form.querySelectorAll('input[name="categoryIds"]:checked')].map((el) => el.value);
    const payload = {
      title: form.title.value,
      slug: form.slug.value,
      body: form.body.value,
      excerpt: form.excerpt.value || undefined,
      coverImage: form.coverImage.value || undefined,
      categoryIds: categoryIds,
      topicId: form.topicId.value || null,
      layoutMode: form.layoutMode.value,
      password: form.password.value || null,
      status: document.getElementById("status-select").value,
      seo: {
        metaTitle: form.metaTitle.value || undefined,
        metaDescription: form.metaDescription.value || undefined,
        ogImage: form.ogImage.value || undefined,
        keyword: form.keyword.value || undefined,
        internalLinks: form.internalLinks.value ? parseInt(form.internalLinks.value, 10) : undefined,
        noindex: form.noindex.checked,
      },
      faq: collectFaq(),
      customFields: collectCustomFields(),
    };

    const res = await fetch(postId ? "/admin/api/posts/" + postId : "/admin/api/posts", {
      method: postId ? "PATCH" : "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showFlash(typeof body.error === "string" ? body.error : "Lưu nội dung thất bại", false);
      return;
    }

    const { post } = await res.json();
    const newId = postId || post.id;
    
    // Nếu có đổi trạng thái thì gọi thêm endpoint chuyển trạng thái (cần quyền tương ứng)
    const selectedStatus = document.getElementById("status-select").value;
    if (newId && selectedStatus !== status) {
      let actionEndpoint = null;
      if (selectedStatus === "pending_review") actionEndpoint = "/submit";
      else if (selectedStatus === "published") actionEndpoint = "/publish";
      else if (selectedStatus === "draft") actionEndpoint = "/unpublish";
      
      if (actionEndpoint) {
        const actionRes = await fetch("/admin/api/posts/" + newId + actionEndpoint, { method: "POST" });
        if (!actionRes.ok) {
          const errBody = await actionRes.json().catch(() => ({}));
          showFlash("Lưu nội dung thành công nhưng đổi trạng thái thất bại: " + (errBody.error || ""), false);
          if (!postId) window.location.href = "/admin/posts/" + newId;
          return;
        }
      } else if (selectedStatus === "scheduled") {
        const scheduledAtInput = document.getElementById("scheduledAt-input");
        const scheduledAt = scheduledAtInput ? scheduledAtInput.value : null;
        if (!scheduledAt) {
          showFlash("Vui lòng chọn thời gian lên lịch", false);
          return;
        }
        
        const actionRes = await fetch("/admin/api/posts/" + newId + "/schedule", { 
          method: "POST", 
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ scheduledAt }) 
        });
        if (!actionRes.ok) {
          const errBody = await actionRes.json().catch(() => ({}));
          showFlash("Lưu nội dung thành công nhưng hẹn giờ thất bại: " + (errBody.error || ""), false);
          if (!postId) window.location.href = "/admin/posts/" + newId;
          return;
        }
      }
    }

    showFlash("Đã lưu bài viết thành công.", true);
    if (!postId) {
      window.location.href = "/admin/posts/" + newId;
    } else {
      setTimeout(() => window.location.reload(), 800);
    }
  });

  async function loadRevisions() {
    const list = document.getElementById("revisions-list");
    if (!list || !postId) {
      if (list && !postId) list.innerHTML = '<div class="empty-state" style="padding:0.5rem 0;">Vui lòng lưu bài viết để xem lịch sử.</div>';
      return;
    }

    try {
      const res = await fetch("/admin/api/posts/" + postId + "/revisions");
      if (!res.ok) {
        list.innerHTML = '<div class="empty-state" style="padding:0.5rem 0;color:var(--color-danger);">Lỗi tải dữ liệu.</div>';
        return;
      }
      const data = await res.json();
      const revisions = data.revisions || [];

      list.innerHTML = revisions.length
        ? revisions.map((r) => {
            const when = new Date(r.createdAt).toLocaleString("vi-VN");
            const who = r.user ? r.user.name : "hệ thống";
            const desc = (r.description || "Cập nhật bài viết").replace(/</g, "&lt;");
            const restoreBtn = canManage || CURRENT_ROLE === "edit"
              ? '<button class="btn" data-revision-id="' + r.id + '" style="margin-top:0.4rem;font-size:0.75rem;padding:0.15rem 0.6rem;">Khôi phục</button>'
              : "";
            return '<div style="border-left:2px solid var(--color-primary);padding-left:0.8rem;position:relative;">' +
                   '<div style="width:8px;height:8px;border-radius:50%;background:var(--color-primary);position:absolute;left:-5px;top:6px;"></div>' +
                   '<div style="font-weight:600;font-size:0.8rem;color:#333;margin-bottom:0.2rem;">' + when + '</div>' +
                   '<div style="font-size:0.85rem;color:#666;">' + desc + ' bởi <span style="font-weight:500;color:#333;">' + who + '</span></div>' +
                   restoreBtn +
                   '</div>';
          }).join("")
        : '<div class="empty-state" style="padding:0.5rem 0;">Chưa có lịch sử chỉnh sửa nào.</div>';
    } catch (e) {
      console.error(e);
      list.innerHTML = '<div class="empty-state" style="padding:0.5rem 0;color:var(--color-danger);">Lỗi hệ thống khi tải lịch sử.</div>';
    }
  }

  const revisionsList = document.getElementById("revisions-list");
  if (revisionsList) {
    revisionsList.addEventListener("click", async (event) => {
      const btn = event.target.closest("button[data-revision-id]");
      if (!btn) return;
      if (!confirm("Khôi phục bài viết về bản ghi này? Nội dung hiện tại sẽ được lưu lại thành 1 bản ghi mới trước khi ghi đè.")) return;

      const res = await fetch("/admin/api/posts/" + postId + "/revisions/" + btn.dataset.revisionId + "/restore", { method: "POST" });
      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        showFlash(typeof body.error === "string" ? body.error : "Khôi phục thất bại", false);
        return;
      }
      window.location.reload();
    });
    loadRevisions();
  }
})();
</script>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const mainCol = document.querySelector('.edit-main');
  const sidebarCol = document.querySelector('.edit-sidebar');
  if (!mainCol || !sidebarCol) return;

  // 1. Assign deterministic IDs based on original DOM order (if they don't have one)
  // This ensures IDs are consistent across page reloads because Liquid always renders the same default order.
  Array.from(mainCol.children).forEach((el, i) => { if (!el.id) el.id = 'main-block-' + i; });
  Array.from(sidebarCol.children).forEach((el, i) => { if (!el.id) el.id = 'sidebar-block-' + i; });

  const pageType = window.location.pathname.split('/')[2]; // e.g. posts, products, pages
  const storageKey = 'layout_order_' + pageType;
  const savedOrder = JSON.parse(localStorage.getItem(storageKey) || '{"main":[], "sidebar":[]}');

  // 2. Reorder based on saved preference
  function applyOrder(col, orderArray) {
    if (!orderArray || !orderArray.length) return;
    orderArray.forEach(id => {
      const el = document.getElementById(id);
      if (el) col.appendChild(el); // appendChild moves the element to the end of the container
    });
  }

  applyOrder(mainCol, savedOrder.main);
  applyOrder(sidebarCol, savedOrder.sidebar);

  // 4. Initialize SortableJS
  if (typeof Sortable !== 'undefined') {
    const opts = {
      group: 'shared',
      animation: 150,
      delay: 3000,
      delayOnTouchOnly: true,
      filter: 'input, textarea, select, button, label', preventOnFilter: false,
      ghostClass: 'sortable-ghost',
      onEnd: function() {
        const newOrder = {
          main: Array.from(mainCol.children).map(el => el.id),
          sidebar: Array.from(sidebarCol.children).map(el => el.id)
        };
        localStorage.setItem(storageKey, JSON.stringify(newOrder));
      }
    };
    new Sortable(mainCol, opts);
    new Sortable(sidebarCol, opts);
  }
});
</script>
<style>
  .sortable-ghost { opacity: 0.4; background: #f8fafc; border: 1px dashed #cbd5e1; }
  
</style>

{% endblock %}

{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;">
  <h1 style="margin:0;">{% if post %}Sửa bài viết{% else %}Bài viết mới{% endif %}</h1>
  <a class="btn" href="/admin/posts">← Danh sách</a>
</div>

{% if post %}
  <div style="margin-bottom:1rem;">
    <span class="status-badge status-{{ post.status }}" id="status-badge-display">{{ post.status }}</span>
  </div>
{% endif %}

<form id="post-form" class="card">
  <label for="title">Tiêu đề</label>
  <input type="text" id="title" name="title" value="{% if post %}{{ post.title | escape }}{% endif %}" required>

  <label for="slug">Slug (đường dẫn)</label>
  <input type="text" id="slug" name="slug" value="{% if post %}{{ post.slug | escape }}{% endif %}" required>
  <div class="field-hint">Chỉ chữ thường/số, cách nhau bằng dấu gạch ngang. Vd: bai-viet-dau-tien</div>

  <label for="excerpt">Tóm tắt</label>
  <input type="text" id="excerpt" name="excerpt" value="{% if post %}{{ post.excerpt | escape }}{% endif %}">

  <label for="coverImage">Ảnh bìa</label>
  <div style="display:flex;gap:0.6rem;align-items:center;">
    <input type="text" id="coverImage" name="coverImage" value="{% if post %}{{ post.coverImage | escape }}{% endif %}" placeholder="URL ảnh hoặc bấm Chọn ảnh" style="flex:1;">
    <button type="button" class="btn" id="coverImage-pick-btn">Chọn ảnh</button>
  </div>
  <img id="coverImage-preview" src="{% if post %}{{ post.coverImage | escape }}{% endif %}" style="max-width:160px;max-height:100px;object-fit:cover;border-radius:6px;margin-top:0.5rem;{% unless post.coverImage %}display:none;{% endunless %}">

  <label>Danh mục (chọn được nhiều)</label>
  <div class="card" style="display:flex;flex-wrap:wrap;gap:0.6rem 1.2rem;padding:0.8rem 1rem;">
    {% if categories.size == 0 %}
      <span style="color:#999;font-size:0.85rem;">Chưa có danh mục nào.</span>
    {% endif %}
    {% for c in categories %}
      <label style="display:flex;align-items:center;gap:0.35rem;font-weight:400;margin:0;">
        <input type="checkbox" name="categoryIds" value="{{ c.id }}" style="width:auto;" {% if selectedCategoryIds contains c.id %}checked{% endif %}>
        {{ c.name | escape }}
      </label>
    {% endfor %}
  </div>

  <label for="topicId">Chủ đề</label>
  <select id="topicId" name="topicId">
    <option value="">— Không có chủ đề —</option>
    {% for t in topics %}
      <option value="{{ t.id }}" {% if post.topicId == t.id %}selected{% endif %}>{{ t.name | escape }}</option>
    {% endfor %}
  </select>

  <label for="password">Mật khẩu xem bài (để trống = mở tự do)</label>
  <input type="text" id="password" name="password" value="{% if post %}{{ post.password | escape }}{% endif %}" placeholder="Để trống nếu không cần bảo vệ">
  <div class="field-hint">Khách phải nhập đúng mật khẩu này mới đọc được bài — không phải tài khoản đăng nhập, chỉ là lớp hạn chế xem đơn giản.</div>

  <label for="body">Nội dung</label>
  <textarea id="body" name="body" required>{% if post %}{{ post.body }}{% endif %}</textarea>

  <h2 style="font-size:0.95rem;margin:1.5rem 0 0.5rem;border-top:1px solid #eee;padding-top:1rem;">SEO</h2>

  <label for="metaTitle">Meta title</label>
  <input type="text" id="metaTitle" name="metaTitle" value="{% if post.seo %}{{ post.seo.metaTitle | escape }}{% endif %}">

  <label for="metaDescription">Meta description</label>
  <input type="text" id="metaDescription" name="metaDescription" value="{% if post.seo %}{{ post.seo.metaDescription | escape }}{% endif %}">

  <label for="ogImage">Ảnh chia sẻ (Open Graph, URL)</label>
  <input type="text" id="ogImage" name="ogImage" value="{% if post.seo %}{{ post.seo.ogImage | escape }}{% endif %}">

  <label for="keyword">Từ khoá chính</label>
  <input type="text" id="keyword" name="keyword" value="{% if post.seo %}{{ post.seo.keyword | escape }}{% endif %}">

  {% if post.seo.score %}
    <div class="field-hint">Điểm SEO: {{ post.seo.score }}</div>
  {% endif %}

  <label style="display:flex;align-items:center;gap:0.4rem;">
    <input type="checkbox" id="noindex" name="noindex" style="width:auto;" {% if post.seo.noindex %}checked{% endif %}>
    noindex (ẩn khỏi công cụ tìm kiếm)
  </label>

  <div style="margin-top:1.5rem;display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center;">
    <button type="submit" class="btn btn-primary">Lưu</button>
    <span id="submit-slot"></span>
    <span id="publish-slot"></span>
    <span id="schedule-slot"></span>
    <span id="unpublish-slot"></span>
    <span id="delete-slot"></span>
    {% if post %}<a class="btn" href="/admin/preview/post/{{ post.id }}" target="_blank" rel="noopener">Xem thử</a>{% endif %}
  </div>
</form>

{% if post %}
<div class="card" style="margin-top:1.2rem;">
  <h2 style="font-size:0.95rem;margin:0 0 0.8rem;">Lịch sử chỉnh sửa</h2>
  <table>
    <thead><tr><th>Thời điểm</th><th>Người sửa</th><th></th></tr></thead>
    <tbody id="revisions-body">
      <tr><td colspan="3" style="color:#999;">Đang tải...</td></tr>
    </tbody>
  </table>
</div>
{% endif %}

<script>
(function () {
  const CURRENT_ROLE = "{{ role }}";
  const canManage = CURRENT_ROLE === "manager" || CURRENT_ROLE === "admin";
  const postId = {% if post %}"{{ post.id }}"{% else %}null{% endif %};
  const status = {% if post %}"{{ post.status }}"{% else %}"draft"{% endif %};
  const form = document.getElementById("post-form");
  const flash = document.getElementById("flash");

  function showFlash(message, ok) {
    flash.textContent = message;
    flash.className = ok ? "success" : "error";
  }

  const coverImageInput = document.getElementById("coverImage");
  const coverImagePreview = document.getElementById("coverImage-preview");
  document.getElementById("coverImage-pick-btn").addEventListener("click", () => {
    openMediaPicker({
      title: "Chọn ảnh bìa",
      onSelect: (url) => {
        coverImageInput.value = url;
        coverImagePreview.src = url;
        coverImagePreview.style.display = "";
      },
    });
  });
  coverImageInput.addEventListener("input", () => {
    coverImagePreview.src = coverImageInput.value;
    coverImagePreview.style.display = coverImageInput.value ? "" : "none";
  });

  document.addEventListener("DOMContentLoaded", () => {
    initRichEditor("body");
    if (locked) {
      const editorBody = document.querySelector(".rich-editor-body");
      if (editorBody) editorBody.contentEditable = "false";
    }
  });

  const locked = (status === "scheduled" || status === "published") && CURRENT_ROLE === "edit";
  if (postId && locked) {
    [...form.elements].forEach((el) => (el.disabled = true));
    showFlash("Bài đã lên lịch/xuất bản — chỉ manager/admin được sửa.", false);
  }

  async function callAction(path, body) {
    const res = await fetch("/admin/api/posts/" + postId + path, {
      method: "POST",
      headers: body ? { "Content-Type": "application/json" } : undefined,
      body: body ? JSON.stringify(body) : undefined,
    });
    if (!res.ok) {
      const errBody = await res.json().catch(() => ({}));
      showFlash(typeof errBody.error === "string" ? errBody.error : "Thao tác thất bại", false);
      return false;
    }
    return true;
  }

  if (postId) {
    if (status === "draft") {
      const submitBtn = document.createElement("button");
      submitBtn.type = "button";
      submitBtn.className = "btn";
      submitBtn.textContent = "Nộp duyệt";
      submitBtn.onclick = async () => {
        if (await callAction("/submit")) window.location.reload();
      };
      document.getElementById("submit-slot").appendChild(submitBtn);
    }

    if (canManage && (status === "pending_review" || status === "scheduled" || status === "draft")) {
      const publishBtn = document.createElement("button");
      publishBtn.type = "button";
      publishBtn.className = "btn";
      publishBtn.textContent = "Xuất bản ngay";
      publishBtn.onclick = async () => {
        if (await callAction("/publish")) window.location.reload();
      };
      document.getElementById("publish-slot").appendChild(publishBtn);

      const scheduleBtn = document.createElement("button");
      scheduleBtn.type = "button";
      scheduleBtn.className = "btn";
      scheduleBtn.textContent = "Lên lịch...";
      scheduleBtn.onclick = async () => {
        const value = prompt("Nhập thời điểm xuất bản (vd 2026-08-01T09:00):");
        if (!value) return;
        if (await callAction("/schedule", { scheduledAt: value })) window.location.reload();
      };
      document.getElementById("schedule-slot").appendChild(scheduleBtn);
    }

    if (canManage && (status === "scheduled" || status === "published")) {
      const unpublishBtn = document.createElement("button");
      unpublishBtn.type = "button";
      unpublishBtn.className = "btn";
      unpublishBtn.textContent = "Gỡ về nháp";
      unpublishBtn.onclick = async () => {
        if (!confirm("Gỡ bài viết này về nháp?")) return;
        if (await callAction("/unpublish")) window.location.reload();
      };
      document.getElementById("unpublish-slot").appendChild(unpublishBtn);
    }

    if (canManage) {
      const deleteBtn = document.createElement("button");
      deleteBtn.type = "button";
      deleteBtn.className = "btn btn-danger";
      deleteBtn.textContent = "Xoá";
      deleteBtn.onclick = async () => {
        if (!confirm("Xoá bài viết này?")) return;
        const res = await fetch("/admin/api/posts/" + postId, { method: "DELETE" });
        if (!res.ok) {
          showFlash("Xoá thất bại", false);
          return;
        }
        window.location.href = "/admin/posts";
      };
      document.getElementById("delete-slot").appendChild(deleteBtn);
    }
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    const categoryIds = [...form.querySelectorAll('input[name="categoryIds"]:checked')].map((el) => el.value);
    const payload = {
      title: form.title.value,
      slug: form.slug.value,
      body: form.body.value,
      excerpt: form.excerpt.value || undefined,
      coverImage: form.coverImage.value || undefined,
      categoryIds: categoryIds,
      topicId: form.topicId.value || null,
      password: form.password.value || null,
      seo: {
        metaTitle: form.metaTitle.value || undefined,
        metaDescription: form.metaDescription.value || undefined,
        ogImage: form.ogImage.value || undefined,
        keyword: form.keyword.value || undefined,
        noindex: form.noindex.checked,
      },
    };

    const res = await fetch(postId ? "/admin/api/posts/" + postId : "/admin/api/posts", {
      method: postId ? "PATCH" : "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showFlash(typeof body.error === "string" ? body.error : "Lưu thất bại", false);
      return;
    }

    const { post } = await res.json();
    showFlash("Đã lưu.", true);
    if (!postId) {
      window.location.href = "/admin/posts/" + post.id;
    }
  });

  async function loadRevisions() {
    const tbody = document.getElementById("revisions-body");
    if (!tbody || !postId) return;

    const res = await fetch("/admin/api/posts/" + postId + "/revisions");
    if (!res.ok) return;
    const { revisions } = await res.json();

    tbody.innerHTML = revisions.length
      ? revisions.map((r) => {
          const when = new Date(r.createdAt).toLocaleString("vi-VN");
          const who = r.user ? r.user.name : "-";
          const restoreBtn = canManage || CURRENT_ROLE === "edit"
            ? '<button class="btn" data-revision-id="' + r.id + '">Khôi phục</button>'
            : "";
          return "<tr><td>" + when + "</td><td>" + who + "</td><td style=\"text-align:right;\">" + restoreBtn + "</td></tr>";
        }).join("")
      : '<tr><td colspan="3" class="empty-state">Chưa có lịch sử chỉnh sửa nào.</td></tr>';
  }

  const revisionsBody = document.getElementById("revisions-body");
  if (revisionsBody) {
    revisionsBody.addEventListener("click", async (event) => {
      const btn = event.target.closest("button[data-revision-id]");
      if (!btn) return;
      if (!confirm("Khôi phục bài viết về bản ghi này? Nội dung hiện tại sẽ được lưu lại thành 1 bản ghi mới trước khi ghi đè.")) return;

      const res = await fetch("/admin/api/posts/" + postId + "/revisions/" + btn.dataset.revisionId + "/restore", { method: "POST" });
      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        showFlash(typeof body.error === "string" ? body.error : "Khôi phục thất bại", false);
        return;
      }
      window.location.reload();
    });
    loadRevisions();
  }
})();
</script>
{% endblock %}

{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;">
  <h1 style="margin:0;">Sửa sản phẩm</h1>
  <a class="btn" href="/admin/products">← Danh sách</a>
</div>

<div style="margin-bottom:1rem;">
  <span class="status-badge status-{{ product.status }}">{{ product.status }}</span>
</div>

{% if product.categories.size > 0 %}
  <div style="font-size:0.85rem;color:#555;margin-bottom:0.8rem;">
    Danh mục: <strong>{% for c in product.categories %}{{ c.name | escape }}{% unless forloop.last %}, {% endunless %}{% endfor %}</strong> <span style="color:#999;">(đồng bộ từ LeadBase, chỉ đọc)</span>
  </div>
{% endif %}

{% if product.hasVariants %}
  <div class="card" style="margin-bottom:1.2rem;">
    <strong style="font-size:0.85rem;color:#555;">Biến thể — đồng bộ từ LeadBase, chỉ đọc:</strong>
    <table style="margin-top:0.6rem;">
      <thead>
        <tr>
          <th>SKU</th>
          <th>Thuộc tính</th>
          <th>Giá</th>
          <th>Giá KM</th>
          <th>Tồn</th>
          <th>Trạng thái</th>
        </tr>
      </thead>
      <tbody>
        {% for v in product.variants %}
          <tr>
            <td>{{ v.sku | default: "-" }}</td>
            <td>
              {% for pair in v.attributes %}{{ pair[0] }}: {{ pair[1] }}{% unless forloop.last %}, {% endunless %}{% endfor %}
            </td>
            <td>{{ v.price }}₫</td>
            <td>{% if v.salePrice %}{{ v.salePrice }}₫{% else %}-{% endif %}</td>
            <td>{{ v.stock | default: "-" }}</td>
            <td>{{ v.leadbaseStatus }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    <div style="margin-top:0.5rem;font-size:0.8rem;color:#999;">Đồng bộ lần cuối: {{ product.syncedAt }}</div>
  </div>
{% else %}
  <div class="card" style="margin-bottom:1.2rem;font-size:0.85rem;color:#555;">
    <strong>Đồng bộ từ LeadBase (chỉ đọc):</strong>
    Giá <strong>{{ product.price }}₫</strong>{% if product.salePrice %} · Giá KM <strong>{{ product.salePrice }}₫</strong>{% endif %}
    · Tồn kho <strong>{{ product.stock | default: "-" }}</strong>
    · Trạng thái LeadBase <strong>{{ product.leadbaseStatus }}</strong>
    <div style="margin-top:0.3rem;color:#999;">Đồng bộ lần cuối: {{ product.syncedAt }}</div>
  </div>
{% endif %}

<form id="product-form" class="card">
  <label for="name">Tên sản phẩm</label>
  <input type="text" id="name" name="name" value="{{ product.name | escape }}" required>

  <label for="slug">Slug sản phẩm</label>
  <input type="text" id="slug" name="slug" value="{{ product.slug | escape }}" required>
  <div class="field-hint">Đường dẫn mặc định: /product/{{ product.slug | default: product.id }}</div>

  <label for="layoutMode">Định dạng trang</label>
  <select id="layoutMode" name="layoutMode">
    <option value="standard" {% if product.layoutMode == "standard" %}selected{% endif %}>Tiêu chuẩn</option>
    <option value="custom" {% if product.layoutMode == "custom" %}selected{% endif %}>Tuỳ biến (giữ header/footer, mô tả tự soạn HTML)</option>
    <option value="landing" {% if product.layoutMode == "landing" %}selected{% endif %}>Landing page (không header/footer)</option>
  </select>
  <div class="field-hint">Tuỳ biến/Landing page: ô Mô tả trở thành HTML thô (render nguyên văn, không escape), cho phép cả &lt;script&gt;/&lt;iframe&gt; — chỉ dùng khi thật sự cần.</div>

  <label for="description">Mô tả<span id="description-mode-hint" style="font-weight:400;color:#888;"></span></label>
  <textarea id="description" name="description" style="min-height:140px;">{{ product.description }}</textarea>

  <label for="imageUrls">Ảnh (mỗi dòng 1 URL, dòng đầu tiên là ảnh đại diện)</label>
  <textarea id="imageUrls" name="imageUrls" style="min-height:100px;font-family:inherit;">{% for url in product.imageUrls %}{{ url }}
{% endfor %}</textarea>
  <div style="margin-top:0.5rem;">
    <button type="button" class="btn" id="imageUrls-pick-btn">+ Thêm ảnh từ thư viện</button>
  </div>
  <div id="imageUrls-preview" style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.6rem;"></div>

  <h2 style="font-size:0.95rem;margin:1.5rem 0 0.5rem;border-top:1px solid #eee;padding-top:1rem;">Thông số sản phẩm</h2>
  <div id="specs-rows">
    {% for spec in product.specs %}
      <div class="specs-row" style="display:flex;gap:0.5rem;margin-bottom:0.5rem;align-items:center;">
        <input type="text" class="specs-label" placeholder="Tên thông số (VD: RAM)" value="{{ spec.label | escape }}" style="flex:1;">
        <input type="text" class="specs-value" placeholder="Giá trị (VD: 8GB)" value="{{ spec.value | escape }}" style="flex:1;">
        <button type="button" class="btn btn-danger specs-remove">×</button>
      </div>
    {% endfor %}
  </div>
  <button type="button" class="btn" id="specs-add-btn">+ Thêm thông số</button>

  <h2 style="font-size:0.95rem;margin:1.5rem 0 0.5rem;border-top:1px solid #eee;padding-top:1rem;">Sản phẩm liên kết</h2>
  
  <div style="margin-bottom:1rem; border: 1px solid #eee; padding: 1rem; border-radius: 4px;">
    <h3 style="font-size:0.9rem; margin-top:0;">Upsell (Bán thêm / Nâng cấp)</h3>
    <div style="display:flex; gap:1rem; margin-bottom: 0.5rem;">
      <label><input type="radio" name="upsell_mode" value="specific" checked> Cụ thể</label>
      <label><input type="radio" name="upsell_mode" value="category"> Danh mục</label>
    </div>
    
    <div id="upsell-specific-section">
      <input type="text" id="upsell-search" placeholder="Tìm sản phẩm..." autocomplete="off">
      <div id="upsell-search-results" style="border:1px solid #ccc; max-height:150px; overflow-y:auto; display:none; background:#fff; position:absolute; z-index:10; width:300px;"></div>
      <div id="upsell-selected" style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:0.5rem;"></div>
    </div>
    
    <div id="upsell-category-section" style="display:none;">
      <input type="text" id="upsell-cat-search" placeholder="Tìm danh mục..." autocomplete="off">
      <div id="upsell-cat-results" style="border:1px solid #ccc; max-height:150px; overflow-y:auto; display:none; background:#fff; position:absolute; z-index:10; width:300px;"></div>
      <div id="upsell-cat-selected" style="margin-top:0.5rem; font-weight:bold; color:#0056b3;"></div>
    </div>
  </div>

  <div style="margin-bottom:1rem; border: 1px solid #eee; padding: 1rem; border-radius: 4px;">
    <h3 style="font-size:0.9rem; margin-top:0;">Cross-sell (Thường mua cùng)</h3>
    <div style="display:flex; gap:1rem; margin-bottom: 0.5rem;">
      <label><input type="radio" name="crossSell_mode" value="specific" checked> Cụ thể</label>
      <label><input type="radio" name="crossSell_mode" value="category"> Danh mục</label>
    </div>
    
    <div id="crossSell-specific-section">
      <input type="text" id="crossSell-search" placeholder="Tìm sản phẩm..." autocomplete="off">
      <div id="crossSell-search-results" style="border:1px solid #ccc; max-height:150px; overflow-y:auto; display:none; background:#fff; position:absolute; z-index:10; width:300px;"></div>
      <div id="crossSell-selected" style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:0.5rem;"></div>
    </div>
    
    <div id="crossSell-category-section" style="display:none;">
      <input type="text" id="crossSell-cat-search" placeholder="Tìm danh mục..." autocomplete="off">
      <div id="crossSell-cat-results" style="border:1px solid #ccc; max-height:150px; overflow-y:auto; display:none; background:#fff; position:absolute; z-index:10; width:300px;"></div>
      <div id="crossSell-cat-selected" style="margin-top:0.5rem; font-weight:bold; color:#0056b3;"></div>
    </div>
  </div>

  <h2 style="font-size:0.95rem;margin:1.5rem 0 0.5rem;border-top:1px solid #eee;padding-top:1rem;">Câu hỏi thường gặp (FAQ)</h2>
  <div id="faq-rows">
    {% for item in product.faq %}
      <div class="faq-row card" style="margin-bottom:0.5rem;position:relative;">
        <button type="button" class="btn btn-danger faq-remove" style="position:absolute;top:0.5rem;right:0.5rem;">×</button>
        <label>Câu hỏi</label>
        <input type="text" class="faq-q" value="{{ item.question | escape }}" style="margin-bottom:0.5rem;">
        <label>Câu trả lời</label>
        <textarea class="faq-a" style="min-height:80px;">{{ item.answer | escape }}</textarea>
      </div>
    {% endfor %}
  </div>
  <button type="button" class="btn" id="faq-add-btn">+ Thêm câu hỏi</button>

  <h2 style="font-size:0.95rem;margin:1.5rem 0 0.5rem;border-top:1px solid #eee;padding-top:1rem;">SEO</h2>

  <label for="metaTitle">Meta title</label>
  <input type="text" id="metaTitle" name="metaTitle" value="{% if product.seo %}{{ product.seo.metaTitle | escape }}{% endif %}">

  <label for="metaDescription">Meta description</label>
  <input type="text" id="metaDescription" name="metaDescription" value="{% if product.seo %}{{ product.seo.metaDescription | escape }}{% endif %}">

  <label for="ogImage">Ảnh chia sẻ (Open Graph, URL)</label>
  <input type="text" id="ogImage" name="ogImage" value="{% if product.seo %}{{ product.seo.ogImage | escape }}{% endif %}">

  <label for="keyword">Từ khoá chính</label>
  <input type="text" id="keyword" name="keyword" value="{% if product.seo %}{{ product.seo.keyword | escape }}{% endif %}">

  {% if product.seo.score %}
    <div class="field-hint">Điểm SEO: {{ product.seo.score }}</div>
  {% endif %}

  <label style="display:flex;align-items:center;gap:0.4rem;">
    <input type="checkbox" id="noindex" name="noindex" style="width:auto;" {% if product.seo.noindex %}checked{% endif %}>
    noindex (ẩn khỏi công cụ tìm kiếm)
  </label>

  <div style="margin-top:1.5rem;display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center;">
    <button type="submit" class="btn btn-primary">Lưu</button>
    <span id="publish-slot"></span>
    <span id="schedule-slot"></span>
    <span id="unpublish-slot"></span>
    <a class="btn" href="/admin/preview/product/{{ product.id }}" target="_blank" rel="noopener">Xem thử</a>
    <button type="button" class="btn" id="custom-fields-btn">Trường tùy biến</button>
  </div>
</form>

<div class="card" style="margin-top:1.2rem;">
  <h2 style="font-size:0.95rem;margin:0 0 0.8rem;">Lịch sử chỉnh sửa</h2>
  <table>
    <thead><tr><th>Thời điểm</th><th>Người sửa</th><th></th></tr></thead>
    <tbody id="revisions-body">
      <tr><td colspan="3" style="color:#999;">Đang tải...</td></tr>
    </tbody>
  </table>
</div>

<script>
(function () {
  const productId = "{{ product.id }}";
  const status = "{{ product.status }}";
  const form = document.getElementById("product-form");
  const flash = document.getElementById("flash");

  function showFlash(message, ok) {
    flash.textContent = message;
    flash.className = ok ? "success" : "error";
  }

  const layoutModeSelect = document.getElementById("layoutMode");
  const descriptionModeHint = document.getElementById("description-mode-hint");

  function updateDescriptionHint() {
    descriptionModeHint.textContent = layoutModeSelect.value === "standard" ? "" : " (HTML thô)";
  }
  layoutModeSelect.addEventListener("change", updateDescriptionHint);
  updateDescriptionHint();

  const imageUrlsTextarea = document.getElementById("imageUrls");
  const imageUrlsPreview = document.getElementById("imageUrls-preview");

  function currentImageUrls() {
    return imageUrlsTextarea.value.split("\n").map((s) => s.trim()).filter(Boolean);
  }

  function renderImageUrlsPreview() {
    const urls = currentImageUrls();
    imageUrlsPreview.innerHTML = urls
      .map(
        (url, i) =>
          '<div class="image-preview-thumb"><img src="' + url + '">' +
          '<button type="button" class="btn btn-danger" data-remove-index="' + i + '">×</button></div>',
      )
      .join("");
  }

  imageUrlsTextarea.addEventListener("input", renderImageUrlsPreview);

  imageUrlsPreview.addEventListener("click", (event) => {
    const btn = event.target.closest("button[data-remove-index]");
    if (!btn) return;
    const urls = currentImageUrls();
    urls.splice(Number(btn.dataset.removeIndex), 1);
    imageUrlsTextarea.value = urls.join("\n");
    renderImageUrlsPreview();
  });

  document.getElementById("imageUrls-pick-btn").addEventListener("click", () => {
    openMediaPicker({
      title: "Thêm ảnh sản phẩm",
      onSelect: (url) => {
        const urls = currentImageUrls();
        urls.push(url);
        imageUrlsTextarea.value = urls.join("\n");
        renderImageUrlsPreview();
      },
    });
  });

  renderImageUrlsPreview();

  const specsRows = document.getElementById("specs-rows");

  function addSpecRow(label, value) {
    const row = document.createElement("div");
    row.className = "specs-row";
    row.style.cssText = "display:flex;gap:0.5rem;margin-bottom:0.5rem;align-items:center;";
    row.innerHTML =
      '<input type="text" class="specs-label" placeholder="Tên thông số (VD: RAM)" style="flex:1;">' +
      '<input type="text" class="specs-value" placeholder="Giá trị (VD: 8GB)" style="flex:1;">' +
      '<button type="button" class="btn btn-danger specs-remove">×</button>';
    row.querySelector(".specs-label").value = label || "";
    row.querySelector(".specs-value").value = value || "";
    specsRows.appendChild(row);
  }

  document.getElementById("specs-add-btn").addEventListener("click", () => addSpecRow("", ""));

  specsRows.addEventListener("click", (event) => {
    const btn = event.target.closest(".specs-remove");
    if (btn) btn.closest(".specs-row").remove();
  });

  function collectSpecs() {
    return [...specsRows.querySelectorAll(".specs-row")]
      .map((row) => ({
        label: row.querySelector(".specs-label").value.trim(),
        value: row.querySelector(".specs-value").value.trim(),
      }))
      .filter((s) => s.label && s.value);
  }

  const faqRows = document.getElementById("faq-rows");
  function addFaqRow(q, a) {
    const row = document.createElement("div");
    row.className = "faq-row card";
    row.style.cssText = "margin-bottom:0.5rem;position:relative;";
    row.innerHTML =
      '<button type="button" class="btn btn-danger faq-remove" style="position:absolute;top:0.5rem;right:0.5rem;">×</button>' +
      '<label>Câu hỏi</label><input type="text" class="faq-q" style="margin-bottom:0.5rem;">' +
      '<label>Câu trả lời</label><textarea class="faq-a" style="min-height:80px;"></textarea>';
    row.querySelector(".faq-q").value = q || "";
    row.querySelector(".faq-a").value = a || "";
    faqRows.appendChild(row);
  }
  document.getElementById("faq-add-btn").addEventListener("click", () => addFaqRow("", ""));
  faqRows.addEventListener("click", (e) => {
    if (e.target.classList.contains("faq-remove")) e.target.closest(".faq-row").remove();
  });
  function collectFaq() {
    return [...faqRows.querySelectorAll(".faq-row")]
      .map(row => ({
        question: row.querySelector(".faq-q").value.trim(),
        answer: row.querySelector(".faq-a").value.trim()
      }))
      .filter(i => i.question && i.answer);
  }

  document.getElementById("custom-fields-btn").addEventListener("click", async () => {
    const res = await fetch("/admin/api/products/" + productId);
    const { product: current } = await res.json();
    openCustomFieldsEditor({
      title: "Trường tùy biến — sản phẩm",
      initial: current.customFields || {},
      onSave: async (customFields) => {
        const saveRes = await fetch("/admin/api/products/" + productId, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ customFields }),
        });
        if (!saveRes.ok) throw new Error("Lưu thất bại");
        showFlash("Đã lưu trường tùy biến.", true);
      },
    });
  });

  async function callAction(path, body) {
    const res = await fetch("/admin/api/products/" + productId + path, {
      method: "POST",
      headers: body ? { "Content-Type": "application/json" } : undefined,
      body: body ? JSON.stringify(body) : undefined,
    });
    if (!res.ok) {
      const errBody = await res.json().catch(() => ({}));
      showFlash(typeof errBody.error === "string" ? errBody.error : "Thao tác thất bại", false);
      return false;
    }
    return true;
  }

  if (status !== "published") {
    const publishBtn = document.createElement("button");
    publishBtn.type = "button";
    publishBtn.className = "btn";
    publishBtn.textContent = "Xuất bản ngay";
    publishBtn.onclick = async () => {
      if (await callAction("/publish")) window.location.reload();
    };
    document.getElementById("publish-slot").appendChild(publishBtn);

    const scheduleBtn = document.createElement("button");
    scheduleBtn.type = "button";
    scheduleBtn.className = "btn";
    scheduleBtn.textContent = "Lên lịch...";
    scheduleBtn.onclick = async () => {
      const value = prompt("Nhập thời điểm xuất bản (vd 2026-08-01T09:00):");
      if (!value) return;
      if (await callAction("/schedule", { scheduledAt: value })) window.location.reload();
    };
    document.getElementById("schedule-slot").appendChild(scheduleBtn);
  }

  if (status === "scheduled" || status === "published") {
    const unpublishBtn = document.createElement("button");
    unpublishBtn.type = "button";
    unpublishBtn.className = "btn";
    unpublishBtn.textContent = "Gỡ về nháp";
    unpublishBtn.onclick = async () => {
      if (!confirm("Gỡ sản phẩm này về nháp?")) return;
      if (await callAction("/unpublish")) window.location.reload();
    };
    document.getElementById("unpublish-slot").appendChild(unpublishBtn);
  }

  // RELATED PRODUCTS LOGIC
  const state = {
    upsell: { mode: "specific", productIds: [], products: [], categoryId: null, category: null },
    crossSell: { mode: "specific", productIds: [], products: [], categoryId: null, category: null }
  };

  async function loadRelatedProducts() {
    const res = await fetch("/admin/api/products/" + productId);
    if (!res.ok) return;
    const { resolvedRelatedProducts } = await res.json();
    if (resolvedRelatedProducts) {
      if (resolvedRelatedProducts.upsell) {
        state.upsell.mode = resolvedRelatedProducts.upsell.mode || "specific";
        if (state.upsell.mode === "specific") {
           state.upsell.productIds = resolvedRelatedProducts.upsell.productIds || [];
           state.upsell.products = resolvedRelatedProducts.upsell.resolvedProducts || [];
        } else {
           state.upsell.categoryId = resolvedRelatedProducts.upsell.categoryId || null;
           state.upsell.category = resolvedRelatedProducts.upsell.resolvedCategory || null;
        }
      }
      if (resolvedRelatedProducts.crossSell) {
        state.crossSell.mode = resolvedRelatedProducts.crossSell.mode || "specific";
        if (state.crossSell.mode === "specific") {
           state.crossSell.productIds = resolvedRelatedProducts.crossSell.productIds || [];
           state.crossSell.products = resolvedRelatedProducts.crossSell.resolvedProducts || [];
        } else {
           state.crossSell.categoryId = resolvedRelatedProducts.crossSell.categoryId || null;
           state.crossSell.category = resolvedRelatedProducts.crossSell.resolvedCategory || null;
        }
      }
      renderRelatedUI("upsell");
      renderRelatedUI("crossSell");
    }
  }

  function renderRelatedUI(type) {
    const s = state[type];
    document.querySelector(`input[name="${type}_mode"][value="${s.mode}"]`).checked = true;
    document.getElementById(`${type}-specific-section`).style.display = s.mode === "specific" ? "block" : "none";
    document.getElementById(`${type}-category-section`).style.display = s.mode === "category" ? "block" : "none";

    // render specific products
    const selectedDiv = document.getElementById(`${type}-selected`);
    selectedDiv.innerHTML = s.products.map((p, i) => 
      `<div style="background:#eef; padding:0.2rem 0.5rem; border-radius:4px; font-size:0.85rem; display:flex; align-items:center; gap:0.3rem;">
        ${p.name} <span style="cursor:pointer; color:red; font-weight:bold;" data-${type}-remove="${i}">×</span>
      </div>`
    ).join("");

    // render category
    const catDiv = document.getElementById(`${type}-cat-selected`);
    if (s.category) {
       catDiv.innerHTML = `Danh mục: ${s.category.name} <span style="cursor:pointer; color:red; margin-left:0.5rem;" data-${type}-cat-remove>Xoá</span>`;
    } else {
       catDiv.innerHTML = "<span style='color:#999'>Để trống sẽ bị bỏ qua.</span>";
    }
  }

  ["upsell", "crossSell"].forEach(type => {
    // Mode toggles
    document.querySelectorAll(`input[name="${type}_mode"]`).forEach(radio => {
      radio.addEventListener("change", (e) => {
        state[type].mode = e.target.value;
        renderRelatedUI(type);
      });
    });

    // Remove buttons delegation
    document.getElementById(`${type}-selected`).addEventListener("click", e => {
      if (e.target.hasAttribute(`data-${type}-remove`)) {
         const idx = Number(e.target.getAttribute(`data-${type}-remove`));
         state[type].productIds.splice(idx, 1);
         state[type].products.splice(idx, 1);
         renderRelatedUI(type);
      }
    });
    document.getElementById(`${type}-cat-selected`).addEventListener("click", e => {
      if (e.target.hasAttribute(`data-${type}-cat-remove`)) {
         state[type].categoryId = null;
         state[type].category = null;
         renderRelatedUI(type);
      }
    });

    // Autocomplete
    let timeoutId;
    const searchInput = document.getElementById(`${type}-search`);
    const searchResults = document.getElementById(`${type}-search-results`);
    
    searchInput.addEventListener("input", e => {
      clearTimeout(timeoutId);
      const q = e.target.value.trim();
      if (!q) { searchResults.style.display = "none"; return; }
      timeoutId = setTimeout(async () => {
        const res = await fetch(`/admin/api/search?q=${encodeURIComponent(q)}&type=product`);
        if (res.ok) {
          const { results } = await res.json();
          searchResults.innerHTML = results.map(r => 
            `<div class="ac-item" style="padding:0.5rem; cursor:pointer; border-bottom:1px solid #eee;" data-id="${r.id}" data-name="${r.name}">${r.name}</div>`
          ).join("");
          searchResults.style.display = "block";
        }
      }, 300);
    });

    searchResults.addEventListener("click", e => {
      const item = e.target.closest(".ac-item");
      if (item) {
        const id = item.getAttribute("data-id");
        if (id === productId) { alert("Không thể thêm chính sản phẩm này"); return; }
        if (!state[type].productIds.includes(id)) {
          state[type].productIds.push(id);
          state[type].products.push({ id, name: item.getAttribute("data-name") });
          renderRelatedUI(type);
        }
        searchInput.value = "";
        searchResults.style.display = "none";
      }
    });

    // Cat Autocomplete
    const catInput = document.getElementById(`${type}-cat-search`);
    const catResults = document.getElementById(`${type}-cat-results`);
    catInput.addEventListener("input", e => {
      clearTimeout(timeoutId);
      const q = e.target.value.trim();
      if (!q) { catResults.style.display = "none"; return; }
      timeoutId = setTimeout(async () => {
        const res = await fetch(`/admin/api/search?q=${encodeURIComponent(q)}&type=category`);
        if (res.ok) {
          const { results } = await res.json();
          catResults.innerHTML = results.filter(r => r.entityType === "product").map(r => 
            `<div class="ac-item" style="padding:0.5rem; cursor:pointer; border-bottom:1px solid #eee;" data-id="${r.id}" data-name="${r.name}">${r.name}</div>`
          ).join("");
          catResults.style.display = "block";
        }
      }, 300);
    });

    catResults.addEventListener("click", e => {
      const item = e.target.closest(".ac-item");
      if (item) {
        state[type].categoryId = item.getAttribute("data-id");
        state[type].category = { id: state[type].categoryId, name: item.getAttribute("data-name") };
        renderRelatedUI(type);
        catInput.value = "";
        catResults.style.display = "none";
      }
    });
    
    // Hide autocomplete on blur
    document.addEventListener("click", e => {
      if (!e.target.closest(`#${type}-specific-section`)) searchResults.style.display = "none";
      if (!e.target.closest(`#${type}-category-section`)) catResults.style.display = "none";
    });
  });

  loadRelatedProducts();

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    const payload = {
      name: form.name.value,
      slug: form.slug.value,
      description: form.description.value || undefined,
      imageUrls: form.imageUrls.value.split("\n").map((s) => s.trim()).filter(Boolean),
      layoutMode: form.layoutMode.value,
      specs: collectSpecs(),
      faq: collectFaq(),
      seo: {
        metaTitle: form.metaTitle.value || undefined,
        metaDescription: form.metaDescription.value || undefined,
        ogImage: form.ogImage.value || undefined,
        keyword: form.keyword.value || undefined,
        noindex: form.noindex.checked,
      },
      relatedProducts: {
        upsell: { mode: state.upsell.mode, productIds: state.upsell.productIds, categoryId: state.upsell.categoryId, limit: 4 },
        crossSell: { mode: state.crossSell.mode, productIds: state.crossSell.productIds, categoryId: state.crossSell.categoryId, limit: 4 }
      }
    };

    const res = await fetch("/admin/api/products/" + productId, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showFlash(typeof body.error === "string" ? body.error : "Lưu thất bại", false);
      return;
    }

    showFlash("Đã lưu.", true);
  });

  async function loadRevisions() {
    const res = await fetch("/admin/api/products/" + productId + "/revisions");
    if (!res.ok) return;
    const { revisions } = await res.json();
    const tbody = document.getElementById("revisions-body");

    tbody.innerHTML = revisions.length
      ? revisions.map((r) => {
          const when = new Date(r.createdAt).toLocaleString("vi-VN");
          const who = r.user ? r.user.name : "-";
          const restoreBtn = '<button class="btn" data-revision-id="' + r.id + '">Khôi phục</button>';
          return "<tr><td>" + when + "</td><td>" + who + "</td><td style=\"text-align:right;\">" + restoreBtn + "</td></tr>";
        }).join("")
      : '<tr><td colspan="3" class="empty-state">Chưa có lịch sử chỉnh sửa nào.</td></tr>';
  }

  document.getElementById("revisions-body").addEventListener("click", async (event) => {
    const btn = event.target.closest("button[data-revision-id]");
    if (!btn) return;
    if (!confirm("Khôi phục sản phẩm về bản ghi này? Nội dung hiện tại sẽ được lưu lại thành 1 bản ghi mới trước khi ghi đè.")) return;

    const res = await fetch("/admin/api/products/" + productId + "/revisions/" + btn.dataset.revisionId + "/restore", { method: "POST" });
    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showFlash(typeof body.error === "string" ? body.error : "Khôi phục thất bại", false);
      return;
    }
    window.location.reload();
  });
  loadRevisions();
})();
</script>
{% endblock %}

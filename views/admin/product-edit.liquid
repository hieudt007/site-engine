{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;">
  <h1 style="margin:0;">Sửa sản phẩm</h1>
  <div style="display:flex;gap:0.6rem;">
    {% if product %}<button type="button" class="btn btn-icon" onclick="window.openPreview('/admin/preview/product/{{ product.id }}')" title="Xem thử"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg></button>{% endif %}
    <a class="btn" href="/admin/products">← Danh sách</a>
  </div>
</div>

<form id="product-form" class="edit-layout">
  <div class="edit-main">
    <div class="card">
      <label for="name" style="margin-bottom:0.2rem;">Tên sản phẩm</label>
      <input type="text" id="name" name="name" value="{{ product.name | escape }}" required style="margin-bottom:0.3rem;">

      <div style="font-size:0.85rem; color:#666; margin-bottom:1.2rem; display:flex; align-items:center; gap:0.4rem;">
        <span>Đường dẫn:</span>
        <span style="display:inline-flex; align-items:center;"><span style="color:var(--color-primary);" id="base-url-display">https://{{ siteDomain }}/{% if productSlugPrefix and productSlugPrefix != "" %}{{ productSlugPrefix }}/{% endif %}</span><span style="color:var(--color-primary);font-weight:600;" id="slug-display">{% if product %}{{ product.slug | escape }}{% endif %}</span></span>
        <button type="button" class="btn" id="slug-edit-btn" style="padding:0.1rem 0.4rem; font-size:0.75rem; margin-left:0.5rem;">Sửa</button>
      </div>

      <div id="slug-edit-container" style="display:none; margin-bottom:1.2rem;">
        <input type="text" id="slug" name="slug" value="{{ product.slug | escape }}" required>
        <div class="field-hint">Chỉ chữ thường/số, cách nhau bằng dấu gạch ngang. Vd: may-hut-bui</div>
      </div>

      <label for="description">Mô tả<span id="description-mode-hint" style="font-weight:400;color:#888;"></span></label>
      <textarea id="description" name="description" style="min-height:140px;">{{ product.description }}</textarea>
    </div>


    <div class="card">
      <h3 class="edit-card-title">Thông tin bán hàng</h3>
      <div style="display:flex; gap:1rem; flex-wrap:wrap;">
        <div style="flex:1; min-width:200px;">
          <label for="price">Giá bán (₫)</label>
          <input type="number" id="price" name="price" value="{% if product %}{{ product.price }}{% else %}0{% endif %}" required min="0" style="margin-bottom:0.3rem;">
        </div>
        <div style="flex:1; min-width:200px;">
          <label for="salePrice">Giá khuyến mãi (₫) <span id="sale-price-error" style="color:var(--color-danger); font-size:0.85rem; display:none; vertical-align:middle; margin-left:0.3rem;" title="Giá khuyến mãi không được lớn hơn giá bán">● Phải nhỏ hơn hoặc bằng giá bán</span></label>
          <input type="number" id="salePrice" name="salePrice" value="{% if product %}{{ product.salePrice }}{% endif %}" min="0" style="margin-bottom:0.3rem;">
        </div>
      </div>
      <div style="display:flex; gap:1rem; flex-wrap:wrap; margin-top:0.8rem;">
        <div style="flex:1; min-width:200px;">
          <label for="sku">Mã sản phẩm (SKU)</label>
          <input type="text" id="sku" name="sku" value="{% if product %}{{ product.sku | escape }}{% endif %}" style="margin-bottom:0.3rem;">
        </div>
        <div style="flex:1; min-width:200px;">
          <label for="stock">Tồn kho</label>
          <input type="number" id="stock" name="stock" value="{% if product %}{{ product.stock }}{% endif %}" min="0" style="margin-bottom:0.3rem;">
        </div>
      </div>
      <div class="field-hint" style="margin-top:0.5rem;color:var(--color-warning);">Lưu ý: Nếu sản phẩm vẫn liên kết LeadBase, dữ liệu trên sẽ bị ghi đè mỗi khi có đồng bộ.</div>
    </div>

    <div class="card">
      <h3 class="edit-card-title">Thông số sản phẩm</h3>
      <div id="specs-rows">
        {% if product and product.specs %}
        {% for spec in product.specs %}
          <div class="specs-row" style="display:flex;gap:0.5rem;margin-bottom:0.5rem;align-items:center;">
            <input type="text" class="specs-label" placeholder="Tên thông số (VD: RAM)" value="{{ spec.label | escape }}" style="flex:1;">
            <input type="text" class="specs-value" placeholder="Giá trị (VD: 8GB)" value="{{ spec.value | escape }}" style="flex:1;">
            <button type="button" class="btn btn-danger specs-remove">×</button>
          </div>
        {% endfor %}
        {% endif %}
      </div>
      <button type="button" class="btn" id="specs-add-btn" style="margin-top:0.5rem;">+ Thêm thông số</button>
    </div>




      <div style="background:#fff;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;margin-bottom:0.8rem;">
        <div style="padding:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:0.95rem;" onclick="const el=document.getElementById('excerpt-body');el.style.display=el.style.display==='none'?'block':'none';">
          Tóm tắt sản phẩm <span style="font-size:0.7rem;color:#888;">▼</span>
        </div>
        <div id="excerpt-body" style="display:none;padding:1rem;border-top:1px solid var(--color-border);">
          <style>
            #excerpt-body .rich-editor-body { min-height: 100px !important; max-height: 250px !important; }
          </style>
          <textarea id="excerpt" name="excerpt" rows="3" style="width:100%;">{{ product.excerpt }}</textarea>
        </div>
      </div>

      <div style="background:#fff;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;">
        <div style="padding:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:0.95rem;" onclick="const el=document.getElementById('related-body');el.style.display=el.style.display==='none'?'block':'none';">
          Sản phẩm liên kết <span style="font-size:0.7rem;color:#888;">▼</span>
        </div>
        <div id="related-body" style="display:none;padding:1rem;border-top:1px solid var(--color-border);">
      
      <div style="margin-bottom:1.5rem; border: 1px solid #eee; padding: 1rem; border-radius: 4px; background:#fafafa;">
        <h3 style="font-size:0.9rem; margin-top:0;">Upsell (Bán thêm / Nâng cấp)</h3>
        <div style="display:flex; gap:1rem; margin-bottom: 0.8rem;">
          <label style="display:flex;align-items:center;margin:0;"><input type="radio" name="upsell_mode" value="specific" checked style="margin-right:0.3rem;"> Cụ thể</label>
          <label style="display:flex;align-items:center;margin:0;"><input type="radio" name="upsell_mode" value="category" style="margin-right:0.3rem;"> Danh mục</label>
        </div>
        
        <div id="upsell-specific-section">
          <input type="text" id="upsell-search" placeholder="Tìm sản phẩm..." autocomplete="off">
          <div id="upsell-search-results" style="border:1px solid #ccc; max-height:150px; overflow-y:auto; display:none; background:#fff; position:absolute; z-index:10; width:300px;"></div>
          <div id="upsell-selected" style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:0.5rem;"></div>
        </div>
        
        <div id="upsell-category-section" style="display:none;">
          <input type="text" id="upsell-cat-search" placeholder="Tìm danh mục..." autocomplete="off">
          <div id="upsell-cat-results" style="border:1px solid #ccc; max-height:150px; overflow-y:auto; display:none; background:#fff; position:absolute; z-index:10; width:300px;"></div>
          <div id="upsell-cat-selected" style="margin-top:0.5rem; font-weight:bold; color:var(--color-primary);"></div>
        </div>
      </div>

      <div style="margin-bottom:0; border: 1px solid #eee; padding: 1rem; border-radius: 4px; background:#fafafa;">
        <h3 style="font-size:0.9rem; margin-top:0;">Cross-sell (Thường mua cùng)</h3>
        <div style="display:flex; gap:1rem; margin-bottom: 0.8rem;">
          <label style="display:flex;align-items:center;margin:0;"><input type="radio" name="crossSell_mode" value="specific" checked style="margin-right:0.3rem;"> Cụ thể</label>
          <label style="display:flex;align-items:center;margin:0;"><input type="radio" name="crossSell_mode" value="category" style="margin-right:0.3rem;"> Danh mục</label>
        </div>
        
        <div id="crossSell-specific-section">
          <input type="text" id="crossSell-search" placeholder="Tìm sản phẩm..." autocomplete="off">
          <div id="crossSell-search-results" style="border:1px solid #ccc; max-height:150px; overflow-y:auto; display:none; background:#fff; position:absolute; z-index:10; width:300px;"></div>
          <div id="crossSell-selected" style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:0.5rem;"></div>
        </div>
        
        <div id="crossSell-category-section" style="display:none;">
          <input type="text" id="crossSell-cat-search" placeholder="Tìm danh mục..." autocomplete="off">
          <div id="crossSell-cat-results" style="border:1px solid #ccc; max-height:150px; overflow-y:auto; display:none; background:#fff; position:absolute; z-index:10; width:300px;"></div>
          <div id="crossSell-cat-selected" style="margin-top:0.5rem; font-weight:bold; color:var(--color-primary);"></div>
        </div>
      </div>
        </div>
      </div>

      <div style="background:#fff;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;">
        <div style="padding:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:0.95rem;" onclick="const el=document.getElementById('seo-body');el.style.display=el.style.display==='none'?'block':'none';">
          SEO <span style="font-size:0.7rem;color:#888;">▼</span>
        </div>
        <div id="seo-body" style="display:none;padding:1rem;border-top:1px solid var(--color-border);">
          <label for="keyword" style="margin-top:0;">Từ khoá chính</label>
          <input type="text" id="keyword" name="keyword" value="{% if product.seo %}{{ product.seo.keyword | escape }}{% endif %}" placeholder="Ví dụ: máy hút bụi, thiết bị gia dụng">
          <div class="field-hint">Có thể nhập nhiều từ khoá, ngăn cách bởi dấu phẩy.</div>
          <label for="metaTitle">Meta title</label>
          <input type="text" id="metaTitle" name="metaTitle" value="{% if product.seo %}{{ product.seo.metaTitle | escape }}{% endif %}" placeholder="Để trống nếu dùng tên sản phẩm">
          <label for="metaDescription">Meta description</label>
          <input type="text" id="metaDescription" name="metaDescription" value="{% if product.seo %}{{ product.seo.metaDescription | escape }}{% endif %}" placeholder="Để trống nếu dùng tóm tắt sản phẩm">
          <label style="margin-bottom:0.5rem;display:block;">Ảnh chia sẻ (Open Graph, URL)</label>
          {% render "components/image-picker", id: "ogImage", name: "ogImage", value: product.seo.ogImage, width: "180px", height: "120px" %}
          <label style="display:flex;align-items:center;gap:0.4rem;margin-top:0.8rem;">
            <input type="checkbox" id="noindex" name="noindex" style="width:auto;" {% if product.seo.noindex %}checked{% endif %}>
            noindex (ẩn khỏi công cụ tìm kiếm)
          </label>
        </div>
      </div>
      <div style="background:#fff;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;">
        <div style="padding:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:0.95rem;" onclick="const el=document.getElementById('faq-container-body');el.style.display=el.style.display==='none'?'block':'none';">
          Câu hỏi thường gặp (FAQ) <span style="font-size:0.7rem;color:#888;">▼</span>
        </div>
        <div id="faq-container-body" style="display:none;padding:1rem;border-top:1px solid var(--color-border);">
          <div id="faq-rows">
            {% if product and product.faq %}
            {% for item in product.faq %}
              <div class="faq-row" style="margin-bottom:0.5rem;position:relative;background:#f9fafb;padding:0.6rem;border-radius:4px;border:1px solid #e5e7eb;">
                <button type="button" class="btn btn-danger btn-icon faq-remove" title="Xoá" aria-label="Xoá" style="position:absolute;top:0.4rem;right:0.4rem;padding:0.15rem;">{% render "components/icon", name: "trash" %}</button>
                <div style="margin-bottom:0.4rem;padding-right:2rem;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu hỏi</label><input type="text" class="faq-q" value="{{ item.question | escape }}" style="margin:0;font-size:0.85rem;padding:0.3rem;"></div>
                <div><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu trả lời</label><textarea class="faq-a" style="margin:0;font-size:0.85rem;padding:0.3rem;min-height:60px;">{{ item.answer | escape }}</textarea></div>
              </div>
            {% endfor %}
            {% endif %}
          </div>
          <div style="margin-top:0.5rem;background:#f9fafb;padding:0.6rem;border-radius:4px;border:1px dashed #ccc;">
            <div style="margin-bottom:0.4rem;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu hỏi mới</label><input type="text" id="new-faq-q" style="margin:0;font-size:0.85rem;padding:0.3rem;"></div>
            <div><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu trả lời mới</label><textarea id="new-faq-a" style="margin:0;font-size:0.85rem;padding:0.3rem;min-height:60px;"></textarea></div>
            <button type="button" class="btn" id="faq-add-btn" style="margin-top:0.5rem;">+ Thêm FAQ</button>
          </div>
        </div>
      </div>
      <div style="background:#fff;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;">
        <div style="padding:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:0.95rem;" onclick="const el=document.getElementById('cf-body');el.style.display=el.style.display==='none'?'block':'none';">
          Trường tuỳ biến <span style="font-size:0.7rem;color:#888;">▼</span>
        </div>
        <div id="cf-body" style="display:none;padding:1rem;border-top:1px solid var(--color-border);">
          <div id="cf-rows" style="display:flex;flex-direction:column;gap:0.5rem;"></div>
          <div style="margin-top:0.5rem;background:#f9fafb;padding:0.6rem;border-radius:4px;border:1px dashed #ccc;">
            <div style="display:flex;gap:0.4rem;align-items:flex-end;">
              <div style="flex:1;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Tên trường</label><input type="text" id="new-cf-key" style="margin:0;font-size:0.85rem;padding:0.3rem;"></div>
              <div style="flex:1;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Giá trị</label><input type="text" id="new-cf-value" style="margin:0;font-size:0.85rem;padding:0.3rem;"></div>
              <button type="button" class="btn" id="cf-add-btn">+</button>
            </div>
          </div>
        </div>
      </div>
      <div style="background:#fff;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;">
        <div style="padding:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:0.95rem;" onclick="const el=document.getElementById('history-body');if(el)el.style.display=el.style.display==='none'?'block':'none';">
          Lịch sử chỉnh sửa <span style="font-size:0.7rem;color:#888;">▼</span>
        </div>
        <div id="history-body" style="display:none;padding:1rem;border-top:1px solid var(--color-border);">
          <div id="revisions-list" style="display:flex;flex-direction:column;gap:1rem;">
            <div class="empty-state" style="padding:0.5rem;">Đang tải...</div>
          </div>
    </div>
    </div>

</div>
</div>

<div class="edit-sidebar">
    <div class="card">
      <h3 class="edit-card-title">Lưu & Xuất bản</h3>
      <div style="display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center;">
        <select id="status-select" name="status" style="width:auto;padding:0.35rem 1.5rem 0.35rem 0.5rem;font-size:0.85rem;border-radius:4px;border:1px solid #ccc;background-color:#f9fafb;">
          <option value="draft" {% if product == null or product.status == 'draft' %}selected{% endif %}>Nháp</option>
          <option value="pending_review" {% if product.status == 'pending_review' %}selected{% endif %}>Chờ duyệt</option>
          <option value="scheduled" {% if product.status == 'scheduled' %}selected{% endif %}>Đã lên lịch</option>
          <option value="published" {% if product.status == 'published' %}selected{% endif %}>Đã xuất bản</option>
        </select>
        <button type="submit" class="btn btn-primary">Lưu</button>
      </div>
      {% if product and product.publishedAt %}
        <div id="publish-date-display" style="display: {% if product.status == 'published' %}flex{% else %}none{% endif %}; margin-top:0.8rem; padding:0.6rem; background:#f9fafb; border:1px solid #eee; border-radius:4px; align-items:center; gap:0.5rem; font-size:0.85rem; color:#555;">
          <span style="color:#888;">{% render "components/icon", name: "calendar" %}</span>
          <span>Đã xuất bản: <strong id="publishedAt-text">{{ product.publishedAt | date: "%d/%m/%Y %H:%M" }}</strong></span>
        </div>
      {% endif %}
      
      <div id="schedule-date-container" style="display: {% if product and product.status == 'scheduled' %}block{% else %}none{% endif %}; margin-top:0.8rem; padding:0.6rem; background:#f9fafb; border:1px solid #eee; border-radius:4px;">
        <label for="scheduledAt-input" style="font-size:0.8rem;margin:0 0 0.3rem;">Ngày/Giờ hẹn xuất bản</label>
        <input type="datetime-local" id="scheduledAt-input" value="{% if product and product.scheduledAt %}{{ product.scheduledAt | date: '%Y-%m-%dT%H:%M' }}{% endif %}" style="font-size:0.85rem;padding:0.4rem;">
      </div>
    </div>

    {% render "components/seo-score", seo: product.seo %}


    <div class="card">
      <h3 class="edit-card-title">Hình ảnh</h3>
      <textarea id="imageUrls" name="imageUrls" style="display:none;">{% if product and product.imageUrls %}{% for url in product.imageUrls %}{{ url }}
{% endfor %}{% endif %}</textarea>
      <div id="imageUrls-dropzone" style="border:1px dashed #ccc; border-radius:6px; padding:1.5rem 1rem; text-align:center; cursor:pointer; background:#fafafa; margin-bottom:0.8rem;">
        <button type="button" class="btn" style="background:#fff; border:1px solid #ddd; margin-bottom:0.5rem; pointer-events:none;">Thêm ảnh</button>
        <div style="font-size:0.8rem; color:#888;">Chọn ảnh từ thư viện</div>
      </div>
      <div id="imageUrls-preview" style="display:grid; grid-template-columns: repeat(4, 1fr); gap:0.5rem;"></div>
    </div>

    <div class="card">
      <h3 class="edit-card-title">Phân loại</h3>
      <label style="margin-top:0;">Danh mục</label>
      <div style="display:flex;flex-direction:column;gap:0.4rem;max-height:200px;overflow-y:auto;border:1px solid var(--color-border);padding:0.6rem;border-radius:var(--radius-sm);margin-bottom:0.8rem;">
        {% if categories.size == 0 %}
          <span style="color:#999;font-size:0.85rem;">Chưa có danh mục nào.</span>
        {% endif %}
        {% for c in categories %}
          <label style="display:flex;align-items:center;gap:0.35rem;font-weight:400;margin:0;">
            <input type="checkbox" name="categoryIds" value="{{ c.id }}" style="width:auto;" {% if selectedCategoryIds contains c.id %}checked{% endif %}>
            {{ c.name | escape }}
          </label>
        {% endfor %}
      </div>

      <label for="brandId">Thương hiệu</label>
      <select id="brandId" name="brandId">
        <option value="">— Không có thương hiệu —</option>
        {% for b in brands %}
          <option value="{{ b.id }}" {% if product.brandId == b.id %}selected{% endif %}>{{ b.name | escape }}</option>
        {% endfor %}
      </select>
    </div>

    <div class="card">
      <h3 class="edit-card-title">Giao diện</h3>
      <select id="layoutMode" name="layoutMode">
        <option value="standard" {% if product.layoutMode == "standard" %}selected{% endif %}>Tiêu chuẩn</option>
        <option value="custom" {% if product.layoutMode == "custom" %}selected{% endif %}>Tuỳ biến</option>
        <option value="landing" {% if product.layoutMode == "landing" %}selected{% endif %}>Landing page</option>
      </select>
      <div class="field-hint">Tuỳ biến/Landing page: ô Mô tả chuyển sang HTML thô.</div>
    </div>

    <div class="card">
      <h3 class="edit-card-title">LeadBase</h3>
      
      <div style="margin-bottom:1rem;">
        <input type="text" id="leadbaseProductId" name="leadbaseProductId" placeholder="ID Sản phẩm LeadBase" value="{{ product.leadbaseProductId | escape }}" required style="font-size:0.9rem;padding:0.4rem;width:100%;" {% if product %}disabled{% endif %}>
        {% if product %}
          <div class="field-hint" style="font-size:0.75rem;">Không thể thay đổi ID sau khi tạo để đảm bảo đồng bộ.</div>
        {% else %}
          <div class="field-hint" style="font-size:0.75rem;">Nhập ID tương ứng trên LeadBase để nhận đồng bộ giá & tồn kho.</div>
        {% endif %}
      </div>

      {% if product %}
        <div style="font-size:0.85rem;color:#555;margin-bottom:0.5rem;">
          Trạng thái đồng bộ: <strong>{{ product.leadbaseStatus }}</strong>
        </div>
        {% if product.hasVariants %}
        <strong style="font-size:0.85rem;color:#555;">Sản phẩm có nhiều biến thể (chỉ xem):</strong>
        <div style="margin-top:0.6rem; font-size:0.85rem; color:#666;">
          {% for v in product.variants %}
            <div style="margin-bottom:0.5rem; padding-bottom:0.5rem; border-bottom:1px dashed #eee;">
              <div><strong style="color:#333;">{% for pair in v.attributes %}{{ pair[0] }}: {{ pair[1] }}{% unless forloop.last %}, {% endunless %}{% endfor %}</strong></div>
              <div>Giá: <strong>{{ v.price }}₫</strong> {% if v.salePrice %}· KM: <strong>{{ v.salePrice }}₫</strong>{% endif %}</div>
              <div>Tồn kho: {{ v.stock | default: "-" }}</div>
              <div>Trạng thái: {{ v.leadbaseStatus }}</div>
            </div>
          {% endfor %}
        </div>
        </div>
      {% endif %}
      <div style="margin-top:0.5rem;font-size:0.8rem;color:#999;">Đồng bộ lần cuối: {{ product.syncedAt }}</div>
      
      {% endif %}
    </div>

  </div>
</form>

<script>
(function () {
  const productId = {% if product %}"{{ product.id }}"{% else %}null{% endif %};
  const status = {% if product %}"{{ product.status }}"{% else %}"draft"{% endif %};
  const form = document.getElementById("product-form");
  const flash = document.getElementById("flash");

  function showFlash(message, ok) {
    flash.textContent = message;
    flash.className = ok ? "success" : "error";
  }

  // Slug edit
  const slugInput = document.getElementById("slug");
  const slugDisplay = document.getElementById("slug-display");
  const slugBtn = document.getElementById("slug-edit-btn");
  const slugContainer = document.getElementById("slug-edit-container");
  
  if (slugBtn) {
    slugBtn.addEventListener("click", () => {
      const isVisible = slugContainer.style.display !== "none";
      slugContainer.style.display = isVisible ? "none" : "block";
      slugBtn.textContent = isVisible ? "Sửa" : "Đóng";
    });
  }
  if (slugInput) {
    slugInput.addEventListener("input", () => {
      slugDisplay.textContent = slugInput.value;
    });
  }

  const layoutModeSelect = document.getElementById("layoutMode");
  const descriptionModeHint = document.getElementById("description-mode-hint");

  function applyEditorMode() {
    descriptionModeHint.textContent = layoutModeSelect.value === "standard" ? "" : " (HTML thô)";
    
    const editorBodies = document.querySelectorAll(".rich-editor-body");
    const toolbars = document.querySelectorAll(".rich-editor-toolbar");

    if (layoutModeSelect.value === "standard") {
      if (editorBodies.length === 0 && typeof initRichEditor === "function") {
        initRichEditor("description");
        initRichEditor("excerpt");
      }
    } else if (editorBodies.length > 0) {
      toolbars.forEach(t => t.remove());
      editorBodies.forEach(b => b.remove());
      document.getElementById("description").style.display = "";
    }
  }

  // Khởi tạo lần đầu
  document.addEventListener("DOMContentLoaded", () => {
    applyEditorMode();
  });

  layoutModeSelect.addEventListener("change", applyEditorMode);

  const imageUrlsTextarea = document.getElementById("imageUrls");
  const imageUrlsPreview = document.getElementById("imageUrls-preview");

  function currentImageUrls() {
    return imageUrlsTextarea.value.split("\n").map((s) => s.trim()).filter(Boolean);
  }

  function renderImageUrlsPreview() {
    const urls = currentImageUrls();
    imageUrlsPreview.innerHTML = urls
      .map(
        (url, i) =>
          '<div style="position:relative; aspect-ratio:1; border-radius:6px; overflow:hidden; border:1px solid #ddd;">' +
          '<img src="' + url + '" style="width:100%; height:100%; object-fit:cover;">' +
          '<button type="button" class="btn btn-danger btn-icon" data-remove-index="' + i + '" style="position:absolute; top:4px; right:4px; width:22px; height:22px; padding:0; border-radius:50%; min-width:0; min-height:0; display:flex; align-items:center; justify-content:center; line-height:1;" title="Xoá">×</button></div>',
      )
      .join("");
  }

  imageUrlsTextarea.addEventListener("input", renderImageUrlsPreview);

  imageUrlsPreview.addEventListener("click", (event) => {
    const btn = event.target.closest("button[data-remove-index]");
    if (!btn) return;
    const urls = currentImageUrls();
    urls.splice(Number(btn.dataset.removeIndex), 1);
    imageUrlsTextarea.value = urls.join("\n");
    renderImageUrlsPreview();
  });

  document.getElementById("imageUrls-dropzone").addEventListener("click", () => {
    openMediaPicker({
      title: "Thêm ảnh sản phẩm",
      multiple: true,
      onSelect: (url) => {
        const urls = currentImageUrls();
        urls.push(url);
        imageUrlsTextarea.value = urls.join("\n");
        renderImageUrlsPreview();
      },
    });
  });

  renderImageUrlsPreview();

  const specsRows = document.getElementById("specs-rows");

  function addSpecRow(label, value) {
    const row = document.createElement("div");
    row.className = "specs-row";
    row.style.cssText = "display:flex;gap:0.5rem;margin-bottom:0.5rem;align-items:center;";
    row.innerHTML =
      '<input type="text" class="specs-label" placeholder="Tên thông số (VD: RAM)" style="flex:1;">' +
      '<input type="text" class="specs-value" placeholder="Giá trị (VD: 8GB)" style="flex:1;">' +
      '<button type="button" class="btn btn-danger specs-remove">×</button>';
    row.querySelector(".specs-label").value = label || "";
    row.querySelector(".specs-value").value = value || "";
    specsRows.appendChild(row);
  }

  document.getElementById("specs-add-btn").addEventListener("click", () => addSpecRow("", ""));

  document.querySelectorAll(".specs-remove").forEach(btn => btn.addEventListener("click", e => e.target.closest(".specs-row").remove()));
  document.querySelectorAll(".faq-remove").forEach(btn => btn.addEventListener("click", e => e.target.closest(".faq-row").remove()));

  const statusSelect = document.getElementById("status-select");
  const publishDateDisplay = document.getElementById("publish-date-display");
  const scheduleDateContainer = document.getElementById("schedule-date-container");
  
  if (statusSelect) {
    statusSelect.addEventListener("change", (e) => {
      if (scheduleDateContainer) scheduleDateContainer.style.display = e.target.value === 'scheduled' ? 'block' : 'none';
      if (publishDateDisplay) publishDateDisplay.style.display = e.target.value === 'published' ? 'flex' : 'none';
    });
  }

  specsRows.addEventListener("click", (event) => {
    const btn = event.target.closest(".specs-remove");
    if (btn) btn.closest(".specs-row").remove();
  });

  function collectSpecs() {
    return [...specsRows.querySelectorAll(".specs-row")]
      .map((row) => ({
        label: row.querySelector(".specs-label").value.trim(),
        value: row.querySelector(".specs-value").value.trim(),
      }))
      .filter((s) => s.label && s.value);
  }

  const faqRows = document.getElementById("faq-rows");
  const faqAddBtn = document.getElementById("faq-add-btn");
  const newFaqQ = document.getElementById("new-faq-q");
  const newFaqA = document.getElementById("new-faq-a");

  function appendFaqRow(q, a) {
    const row = document.createElement("div");
    row.className = "faq-row";
    row.style.cssText = "margin-bottom:0.5rem;position:relative;background:#f9fafb;padding:0.6rem;border-radius:4px;border:1px solid #e5e7eb;";
    row.innerHTML =
      '<button type="button" class="btn btn-danger btn-icon faq-remove" title="Xoá" aria-label="Xoá" style="position:absolute;top:0.4rem;right:0.4rem;padding:0.15rem;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg></button>' +
      '<div style="margin-bottom:0.4rem;padding-right:2rem;"><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu hỏi</label><input type="text" class="faq-q" style="margin:0;font-size:0.85rem;padding:0.3rem;"></div>' +
      '<div><label style="margin:0 0 0.2rem;font-size:0.75rem;">Câu trả lời</label><textarea class="faq-a" style="margin:0;font-size:0.85rem;padding:0.3rem;min-height:60px;"></textarea></div>';
    row.querySelector(".faq-q").value = q || "";
    row.querySelector(".faq-a").value = a || "";
    faqRows.appendChild(row);
  }

  faqAddBtn.addEventListener("click", () => {
    const q = newFaqQ.value.trim();
    const a = newFaqA.value.trim();
    if (q || a) {
      appendFaqRow(q, a);
      newFaqQ.value = "";
      newFaqA.value = "";
    } else {
      appendFaqRow("", "");
    }
  });

  faqRows.addEventListener("click", (e) => {
    const removeBtn = e.target.closest(".faq-remove");
    if (removeBtn) removeBtn.closest(".faq-row").remove();
  });

  function collectFaq() {
    return [...faqRows.querySelectorAll(".faq-row")]
      .map(row => ({
        question: row.querySelector(".faq-q").value.trim(),
        answer: row.querySelector(".faq-a").value.trim()
      }))
      .filter(i => i.question && i.answer);
  }

  const cfBtn = document.getElementById("custom-fields-btn");
  if (cfBtn) {
    cfBtn.addEventListener("click", async () => {
      const res = await fetch("/admin/api/products/" + productId);
    const { product: current } = await res.json();
    openCustomFieldsEditor({
      title: "Trường tùy biến — sản phẩm",
      initial: current.customFields || {},
      onSave: async (customFields) => {
        const saveRes = await fetch("/admin/api/products/" + productId, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ customFields }),
        });
        if (!saveRes.ok) throw new Error("Lưu thất bại");
        showFlash("Đã lưu trường tùy biến.", true);
      },
    });
  });
  }
  async function callAction(path, body) {
    const res = await fetch("/admin/api/products/" + productId + path, {
      method: "POST",
      headers: body ? { "Content-Type": "application/json" } : undefined,
      body: body ? JSON.stringify(body) : undefined,
    });
    if (!res.ok) {
      const errBody = await res.json().catch(() => ({}));
      let msg = "Thao tác thất bại";
      if (errBody.error && typeof errBody.error === "object") {
        if (errBody.error.fieldErrors) {
          const firstField = Object.keys(errBody.error.fieldErrors)[0];
          const errorMsg = errBody.error.fieldErrors[firstField][0];
          msg = firstField + ": " + errorMsg;
        } else if (errBody.error.formErrors && errBody.error.formErrors.length > 0) {
          msg = errBody.error.formErrors[0];
        } else if (errBody.message) {
          msg = errBody.message;
        }
      } else if (errBody.message) {
        msg = errBody.message;
      } else if (typeof errBody.error === "string") {
        msg = errBody.error;
      }
      showFlash(msg, false);
      return false;
    }
    return true;
  }



  // RELATED PRODUCTS LOGIC
  const state = {
    upsell: { mode: "specific", productIds: [], products: [], categoryId: null, category: null },
    crossSell: { mode: "specific", productIds: [], products: [], categoryId: null, category: null }
  };

  
  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (typeof validatePrice === "function" && !validatePrice()) {
      showFlash("Giá khuyến mãi không được lớn hơn giá bán", false);
      return;
    }

    const payload = {
      name: form.name.value,
      leadbaseProductId: form.leadbaseProductId ? form.leadbaseProductId.value : undefined,
      slug: form.slug.value || undefined,
      description: form.description.value || undefined,
      excerpt: form.excerpt ? form.excerpt.value : undefined,
      categoryIds: Array.from(document.querySelectorAll('input[name="categoryIds"]:checked')).map(cb => cb.value),
      brandId: form.brandId ? (form.brandId.value || null) : undefined,
      price: form.price ? Number(form.price.value) : undefined,
      salePrice: form.salePrice && form.salePrice.value ? Number(form.salePrice.value) : null,
      stock: form.stock && form.stock.value ? Number(form.stock.value) : null,
      sku: form.sku ? form.sku.value : undefined,
      imageUrls: currentImageUrls(),
      layoutMode: form.layoutMode.value,
      status: document.getElementById("status-select").value,
      seo: {
        metaTitle: form.metaTitle.value || undefined,
        metaDescription: form.metaDescription.value || undefined,
        ogImage: form.ogImage.value || undefined,
        keyword: form.keyword.value || undefined,
        noindex: form.noindex.checked,
      },
      faq: collectFaq(),
      specs: collectSpecs(),
      relatedProducts: {
        upsell: { mode: state.upsell.mode, productIds: state.upsell.productIds, categoryId: state.upsell.categoryId || null, limit: 4 },
        crossSell: { mode: state.crossSell.mode, productIds: state.crossSell.productIds, categoryId: state.crossSell.categoryId || null, limit: 4 }
      }
    };

    const res = await fetch(productId ? '/admin/api/products/' + productId : '/admin/api/products', {
      method: productId ? "PATCH" : "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      let msg = "Lưu thất bại";
      
      const fieldNames = {
        name: "Tên sản phẩm",
        leadbaseProductId: "ID LeadBase",
        slug: "Đường dẫn (slug)",
        price: "Giá bán",
        salePrice: "Giá khuyến mãi",
        stock: "Tồn kho",
        sku: "Mã SKU",
        excerpt: "Mô tả ngắn",
        description: "Mô tả",
      };

      if (body.error && typeof body.error === "object") {
        if (body.error.fieldErrors) {
          const firstField = Object.keys(body.error.fieldErrors)[0];
          const errorMsg = body.error.fieldErrors[firstField][0];
          const friendlyName = fieldNames[firstField] || firstField;
          msg = friendlyName + ": " + errorMsg;
        } else if (body.error.formErrors && body.error.formErrors.length > 0) {
          msg = body.error.formErrors[0];
        } else if (body.message) {
          msg = body.message;
        }
      } else if (body.message) {
        msg = body.message;
      } else if (typeof body.error === "string") {
        msg = body.error;
      }
      showFlash(msg, false);
      return;
    }

    const { product } = await res.json();
    const newId = productId || product.id;
    
    const selectedStatus = document.getElementById("status-select").value;
    if (newId && selectedStatus !== status) {
      let actionEndpoint = null;
      if (selectedStatus === "pending_review") actionEndpoint = "/submit";
      else if (selectedStatus === "published") actionEndpoint = "/publish";
      else if (selectedStatus === "draft") actionEndpoint = "/unpublish";
      
      if (actionEndpoint) {
        const actionRes = await fetch('/admin/api/products/' + newId + actionEndpoint, { method: "POST" });
        if (!actionRes.ok) {
          showFlash("Lưu nội dung thành công nhưng đổi trạng thái thất bại", false);
          if (!productId) window.location.href = '/admin/products/' + newId;
          return;
        }
      } else if (selectedStatus === "scheduled") {
        const scheduledAtInput = document.getElementById("scheduledAt-input");
        const scheduledAt = scheduledAtInput ? scheduledAtInput.value : null;
        if (!scheduledAt) {
          showFlash("Vui lòng chọn thời gian lên lịch", false);
          return;
        }
        
        const actionRes = await fetch('/admin/api/products/' + newId + "/schedule", { 
          method: "POST", 
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ scheduledAt }) 
        });
        if (!actionRes.ok) {
          showFlash("Lưu nội dung thành công nhưng hẹn giờ thất bại", false);
          if (!productId) window.location.href = '/admin/products/' + newId;
          return;
        }
      }
    }

    showFlash("Đã lưu thành công.", true);
    if (!productId) {
      window.location.href = '/admin/products/' + newId;
    } else {
      setTimeout(() => window.location.reload(), 800);
    }
  });

  async function loadRelatedProducts() {
    const res = await fetch("/admin/api/products/" + productId);
    if (!res.ok) return;
    const { resolvedRelatedProducts } = await res.json();
    if (resolvedRelatedProducts) {
      if (resolvedRelatedProducts.upsell) {
        state.upsell.mode = resolvedRelatedProducts.upsell.mode || "specific";
        if (state.upsell.mode === "specific") {
           state.upsell.productIds = resolvedRelatedProducts.upsell.productIds || [];
           state.upsell.products = resolvedRelatedProducts.upsell.resolvedProducts || [];
        } else {
           state.upsell.categoryId = resolvedRelatedProducts.upsell.categoryId || null;
           state.upsell.category = resolvedRelatedProducts.upsell.resolvedCategory || null;
        }
      }
      if (resolvedRelatedProducts.crossSell) {
        state.crossSell.mode = resolvedRelatedProducts.crossSell.mode || "specific";
        if (state.crossSell.mode === "specific") {
           state.crossSell.productIds = resolvedRelatedProducts.crossSell.productIds || [];
           state.crossSell.products = resolvedRelatedProducts.crossSell.resolvedProducts || [];
        } else {
           state.crossSell.categoryId = resolvedRelatedProducts.crossSell.categoryId || null;
           state.crossSell.category = resolvedRelatedProducts.crossSell.resolvedCategory || null;
        }
      }
      renderRelatedUI("upsell");
      renderRelatedUI("crossSell");
    }
  }

  function renderRelatedUI(type) {
    const s = state[type];
    document.querySelector(`input[name="${type}_mode"][value="${s.mode}"]`).checked = true;
    document.getElementById(`${type}-specific-section`).style.display = s.mode === "specific" ? "block" : "none";
    document.getElementById(`${type}-category-section`).style.display = s.mode === "category" ? "block" : "none";

    // render specific products
    const selectedDiv = document.getElementById(`${type}-selected`);
    selectedDiv.innerHTML = s.products.map((p, i) => 
      `<div style="background:#eef; padding:0.2rem 0.5rem; border-radius:4px; font-size:0.85rem; display:flex; align-items:center; gap:0.3rem;">
        ${p.name} <span style="cursor:pointer; color:red; font-weight:bold;" data-${type}-remove="${i}">×</span>
      </div>`
    ).join("");

    // render category
    const catDiv = document.getElementById(`${type}-cat-selected`);
    if (s.category) {
       catDiv.innerHTML = `Danh mục: ${s.category.name} <span style="cursor:pointer; color:red; margin-left:0.5rem;" data-${type}-cat-remove>Xoá</span>`;
    } else {
       catDiv.innerHTML = "<span style='color:#999; font-weight:normal;'>Để trống sẽ bị bỏ qua.</span>";
    }
  }

  ["upsell", "crossSell"].forEach(type => {
    // Mode toggles
    document.querySelectorAll(`input[name="${type}_mode"]`).forEach(radio => {
      radio.addEventListener("change", (e) => {
        state[type].mode = e.target.value;
        renderRelatedUI(type);
      });
    });

    // Remove buttons delegation
    document.getElementById(`${type}-selected`).addEventListener("click", e => {
      if (e.target.hasAttribute(`data-${type}-remove`)) {
         const idx = Number(e.target.getAttribute(`data-${type}-remove`));
         state[type].productIds.splice(idx, 1);
         state[type].products.splice(idx, 1);
         renderRelatedUI(type);
      }
    });
    document.getElementById(`${type}-cat-selected`).addEventListener("click", e => {
      if (e.target.hasAttribute(`data-${type}-cat-remove`)) {
         state[type].categoryId = null;
         state[type].category = null;
         renderRelatedUI(type);
      }
    });

    // Autocomplete
    let timeoutId;
    const searchInput = document.getElementById(`${type}-search`);
    const searchResults = document.getElementById(`${type}-search-results`);
    
    searchInput.addEventListener("input", e => {
      clearTimeout(timeoutId);
      const q = e.target.value.trim();
      if (!q) { searchResults.style.display = "none"; return; }
      timeoutId = setTimeout(async () => {
        const res = await fetch(`/admin/api/search?q=${encodeURIComponent(q)}&type=product`);
        if (res.ok) {
          const { results } = await res.json();
          searchResults.innerHTML = results.map(r => 
            `<div class="ac-item" style="padding:0.5rem; cursor:pointer; border-bottom:1px solid #eee;" data-id="${r.id}" data-name="${r.name}">${r.name}</div>`
          ).join("");
          searchResults.style.display = "block";
        }
      }, 300);
    });

    searchResults.addEventListener("click", e => {
      const item = e.target.closest(".ac-item");
      if (item) {
        const id = item.getAttribute("data-id");
        if (id === productId) { alert("Không thể thêm chính sản phẩm này"); return; }
        if (!state[type].productIds.includes(id)) {
          state[type].productIds.push(id);
          state[type].products.push({ id, name: item.getAttribute("data-name") });
          renderRelatedUI(type);
        }
        searchInput.value = "";
        searchResults.style.display = "none";
      }
    });

    // Cat Autocomplete
    const catInput = document.getElementById(`${type}-cat-search`);
    const catResults = document.getElementById(`${type}-cat-results`);
    catInput.addEventListener("input", e => {
      clearTimeout(timeoutId);
      const q = e.target.value.trim();
      if (!q) { catResults.style.display = "none"; return; }
      timeoutId = setTimeout(async () => {
        const res = await fetch(`/admin/api/search?q=${encodeURIComponent(q)}&type=category`);
        if (res.ok) {
          const { results } = await res.json();
          catResults.innerHTML = results.filter(r => r.entityType === "product").map(r => 
            `<div class="ac-item" style="padding:0.5rem; cursor:pointer; border-bottom:1px solid #eee;" data-id="${r.id}" data-name="${r.name}">${r.name}</div>`
          ).join("");
          catResults.style.display = "block";
        }
      }, 300);
    });

    catResults.addEventListener("click", e => {
      const item = e.target.closest(".ac-item");
      if (item) {
        state[type].categoryId = item.getAttribute("data-id");
        state[type].category = { id: state[type].categoryId, name: item.getAttribute("data-name") };
        renderRelatedUI(type);
        catInput.value = "";
        catResults.style.display = "none";
      }
    });
    
    // Hide autocomplete on blur
    document.addEventListener("click", e => {
      if (!e.target.closest(`#${type}-specific-section`)) searchResults.style.display = "none";
      if (!e.target.closest(`#${type}-category-section`)) catResults.style.display = "none";
    });
  });

  loadRelatedProducts();

  const priceInput = document.getElementById("price");
  const salePriceInput = document.getElementById("salePrice");
  const salePriceError = document.getElementById("sale-price-error");

  function validatePrice() {
    if (priceInput && salePriceInput && salePriceError) {
      const price = Number(priceInput.value) || 0;
      const sale = Number(salePriceInput.value) || 0;
      if (sale > price && sale > 0) {
        salePriceError.style.display = "inline-block";
        return false;
      } else {
        salePriceError.style.display = "none";
        return true;
      }
    }
    return true;
  }

  if (priceInput && salePriceInput) {
    priceInput.addEventListener("input", validatePrice);
    salePriceInput.addEventListener("input", validatePrice);
  }



  async function loadRevisions() {
    const tbody = document.getElementById("revisions-list");
    if (!tbody || !productId) return;

    const res = await fetch("/admin/api/products/" + productId + "/revisions");
    if (!res.ok) return;
    const { revisions } = await res.json();

    tbody.innerHTML = revisions.length
      ? revisions.map((r) => {
          const when = new Date(r.createdAt).toLocaleString("vi-VN");
          const who = r.user ? r.user.name : "-";
          const restoreBtn = '<button class="btn btn-outline" data-revision-id="' + r.id + '" style="font-size:0.75rem;padding:0.2rem 0.5rem;">Khôi phục</button>';
          return '<div style="display:flex;justify-content:space-between;align-items:center;padding:0.5rem;background:#f9fafb;border-radius:4px;border:1px solid #eee;">' +
                 '<div><div style="font-weight:600;font-size:0.85rem;">' + when + '</div><div style="font-size:0.75rem;color:#666;">Bởi: ' + who + '</div></div>' +
                 '<div>' + restoreBtn + '</div></div>';
        }).join("")
      : '<div class="empty-state" style="padding:0.5rem;">Chưa có lịch sử chỉnh sửa nào.</div>';
  }

  const revisionsBody = document.getElementById("history-body");
  if (revisionsBody) {
    revisionsBody.addEventListener("click", async (event) => {
      const btn = event.target.closest("button[data-revision-id]");
      if (!btn) return;
      if (!confirm("Khôi phục sản phẩm về bản ghi này? Nội dung hiện tại sẽ được lưu lại thành 1 bản ghi mới trước khi ghi đè.")) return;

      const res = await fetch("/admin/api/products/" + productId + "/revisions/" + btn.dataset.revisionId + "/restore", { method: "POST" });
      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        showFlash(typeof body.error === "string" ? body.error : "Khôi phục thất bại", false);
        return;
      }
      window.location.reload();
    });
    loadRevisions();
  }
})();
</script>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const mainCol = document.querySelector('.edit-main');
  const sidebarCol = document.querySelector('.edit-sidebar');
  if (!mainCol || !sidebarCol) return;

  // 1. Assign deterministic IDs based on original DOM order (if they don't have one)
  // This ensures IDs are consistent across page reloads because Liquid always renders the same default order.
  Array.from(mainCol.children).forEach((el, i) => { if (!el.id) el.id = 'main-block-' + i; });
  Array.from(sidebarCol.children).forEach((el, i) => { if (!el.id) el.id = 'sidebar-block-' + i; });

  const pageType = window.location.pathname.split('/')[2]; // e.g. posts, products, pages
  const storageKey = 'layout_order_' + pageType;
  const savedOrder = JSON.parse(localStorage.getItem(storageKey) || '{"main":[], "sidebar":[]}');

  // 2. Reorder based on saved preference
  function applyOrder(col, orderArray) {
    if (!orderArray || !orderArray.length) return;
    orderArray.forEach(id => {
      const el = document.getElementById(id);
      if (el) col.appendChild(el); // appendChild moves the element to the end of the container
    });
  }

  applyOrder(mainCol, savedOrder.main);
  applyOrder(sidebarCol, savedOrder.sidebar);

  // 4. Initialize SortableJS
  if (typeof Sortable !== 'undefined') {
    const opts = {
      group: 'shared',
      animation: 150,
      filter: 'input, textarea, select, button, label', preventOnFilter: false,
      ghostClass: 'sortable-ghost',
      onEnd: function() {
        const newOrder = {
          main: Array.from(mainCol.children).map(el => el.id),
          sidebar: Array.from(sidebarCol.children).map(el => el.id)
        };
        localStorage.setItem(storageKey, JSON.stringify(newOrder));
      }
    };
    new Sortable(mainCol, opts);
    new Sortable(sidebarCol, opts);
  }
});
</script>
<style>
  .sortable-ghost { opacity: 0.4; background: #f8fafc; border: 1px dashed #cbd5e1; }
  
</style>

{% endblock %}

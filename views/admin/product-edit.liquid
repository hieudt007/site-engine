{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;">
  <h1 style="margin:0;">Sửa sản phẩm</h1>
  <a class="btn" href="/admin/products">← Danh sách</a>
</div>

<div style="margin-bottom:1rem;">
  <span class="status-badge status-{{ product.status }}">{{ product.status }}</span>
</div>

{% if product.categories.size > 0 %}
  <div style="font-size:0.85rem;color:#555;margin-bottom:0.8rem;">
    Danh mục: <strong>{% for c in product.categories %}{{ c.name | escape }}{% unless forloop.last %}, {% endunless %}{% endfor %}</strong> <span style="color:#999;">(đồng bộ từ LeadBase, chỉ đọc)</span>
  </div>
{% endif %}

{% if product.hasVariants %}
  <div class="card" style="margin-bottom:1.2rem;">
    <strong style="font-size:0.85rem;color:#555;">Biến thể — đồng bộ từ LeadBase, chỉ đọc:</strong>
    <table style="margin-top:0.6rem;">
      <thead>
        <tr>
          <th>SKU</th>
          <th>Thuộc tính</th>
          <th>Giá</th>
          <th>Giá KM</th>
          <th>Tồn</th>
          <th>Trạng thái</th>
        </tr>
      </thead>
      <tbody>
        {% for v in product.variants %}
          <tr>
            <td>{{ v.sku | default: "-" }}</td>
            <td>
              {% for pair in v.attributes %}{{ pair[0] }}: {{ pair[1] }}{% unless forloop.last %}, {% endunless %}{% endfor %}
            </td>
            <td>{{ v.price }}₫</td>
            <td>{% if v.salePrice %}{{ v.salePrice }}₫{% else %}-{% endif %}</td>
            <td>{{ v.stock | default: "-" }}</td>
            <td>{{ v.leadbaseStatus }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    <div style="margin-top:0.5rem;font-size:0.8rem;color:#999;">Đồng bộ lần cuối: {{ product.syncedAt }}</div>
  </div>
{% else %}
  <div class="card" style="margin-bottom:1.2rem;font-size:0.85rem;color:#555;">
    <strong>Đồng bộ từ LeadBase (chỉ đọc):</strong>
    Giá <strong>{{ product.price }}₫</strong>{% if product.salePrice %} · Giá KM <strong>{{ product.salePrice }}₫</strong>{% endif %}
    · Tồn kho <strong>{{ product.stock | default: "-" }}</strong>
    · Trạng thái LeadBase <strong>{{ product.leadbaseStatus }}</strong>
    <div style="margin-top:0.3rem;color:#999;">Đồng bộ lần cuối: {{ product.syncedAt }}</div>
  </div>
{% endif %}

<form id="product-form" class="card">
  <label for="name">Tên sản phẩm</label>
  <input type="text" id="name" name="name" value="{{ product.name | escape }}" required>

  <label for="description">Mô tả</label>
  <textarea id="description" name="description" style="min-height:140px;">{{ product.description }}</textarea>

  <label for="imageUrls">Ảnh (mỗi dòng 1 URL, dòng đầu tiên là ảnh đại diện)</label>
  <textarea id="imageUrls" name="imageUrls" style="min-height:100px;font-family:inherit;">{% for url in product.imageUrls %}{{ url }}
{% endfor %}</textarea>
  <div style="margin-top:0.5rem;">
    <button type="button" class="btn" id="imageUrls-pick-btn">+ Thêm ảnh từ thư viện</button>
  </div>
  <div id="imageUrls-preview" style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.6rem;"></div>

  <h2 style="font-size:0.95rem;margin:1.5rem 0 0.5rem;border-top:1px solid #eee;padding-top:1rem;">SEO</h2>

  <label for="metaTitle">Meta title</label>
  <input type="text" id="metaTitle" name="metaTitle" value="{% if product.seo %}{{ product.seo.metaTitle | escape }}{% endif %}">

  <label for="metaDescription">Meta description</label>
  <input type="text" id="metaDescription" name="metaDescription" value="{% if product.seo %}{{ product.seo.metaDescription | escape }}{% endif %}">

  <label for="ogImage">Ảnh chia sẻ (Open Graph, URL)</label>
  <input type="text" id="ogImage" name="ogImage" value="{% if product.seo %}{{ product.seo.ogImage | escape }}{% endif %}">

  <label for="keyword">Từ khoá chính</label>
  <input type="text" id="keyword" name="keyword" value="{% if product.seo %}{{ product.seo.keyword | escape }}{% endif %}">

  {% if product.seo.score %}
    <div class="field-hint">Điểm SEO: {{ product.seo.score }}</div>
  {% endif %}

  <label style="display:flex;align-items:center;gap:0.4rem;">
    <input type="checkbox" id="noindex" name="noindex" style="width:auto;" {% if product.seo.noindex %}checked{% endif %}>
    noindex (ẩn khỏi công cụ tìm kiếm)
  </label>

  <div style="margin-top:1.5rem;display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center;">
    <button type="submit" class="btn btn-primary">Lưu</button>
    <span id="publish-slot"></span>
    <span id="schedule-slot"></span>
    <span id="unpublish-slot"></span>
    <a class="btn" href="/admin/preview/product/{{ product.id }}" target="_blank" rel="noopener">Xem thử</a>
  </div>
</form>

<div class="card" style="margin-top:1.2rem;">
  <h2 style="font-size:0.95rem;margin:0 0 0.8rem;">Lịch sử chỉnh sửa</h2>
  <table>
    <thead><tr><th>Thời điểm</th><th>Người sửa</th><th></th></tr></thead>
    <tbody id="revisions-body">
      <tr><td colspan="3" style="color:#999;">Đang tải...</td></tr>
    </tbody>
  </table>
</div>

<script>
(function () {
  const productId = "{{ product.id }}";
  const status = "{{ product.status }}";
  const form = document.getElementById("product-form");
  const flash = document.getElementById("flash");

  function showFlash(message, ok) {
    flash.textContent = message;
    flash.className = ok ? "success" : "error";
  }

  const imageUrlsTextarea = document.getElementById("imageUrls");
  const imageUrlsPreview = document.getElementById("imageUrls-preview");

  function currentImageUrls() {
    return imageUrlsTextarea.value.split("\n").map((s) => s.trim()).filter(Boolean);
  }

  function renderImageUrlsPreview() {
    const urls = currentImageUrls();
    imageUrlsPreview.innerHTML = urls
      .map(
        (url, i) =>
          '<div class="image-preview-thumb"><img src="' + url + '">' +
          '<button type="button" class="btn btn-danger" data-remove-index="' + i + '">×</button></div>',
      )
      .join("");
  }

  imageUrlsTextarea.addEventListener("input", renderImageUrlsPreview);

  imageUrlsPreview.addEventListener("click", (event) => {
    const btn = event.target.closest("button[data-remove-index]");
    if (!btn) return;
    const urls = currentImageUrls();
    urls.splice(Number(btn.dataset.removeIndex), 1);
    imageUrlsTextarea.value = urls.join("\n");
    renderImageUrlsPreview();
  });

  document.getElementById("imageUrls-pick-btn").addEventListener("click", () => {
    openMediaPicker({
      title: "Thêm ảnh sản phẩm",
      onSelect: (url) => {
        const urls = currentImageUrls();
        urls.push(url);
        imageUrlsTextarea.value = urls.join("\n");
        renderImageUrlsPreview();
      },
    });
  });

  renderImageUrlsPreview();

  async function callAction(path, body) {
    const res = await fetch("/admin/api/products/" + productId + path, {
      method: "POST",
      headers: body ? { "Content-Type": "application/json" } : undefined,
      body: body ? JSON.stringify(body) : undefined,
    });
    if (!res.ok) {
      const errBody = await res.json().catch(() => ({}));
      showFlash(typeof errBody.error === "string" ? errBody.error : "Thao tác thất bại", false);
      return false;
    }
    return true;
  }

  if (status !== "published") {
    const publishBtn = document.createElement("button");
    publishBtn.type = "button";
    publishBtn.className = "btn";
    publishBtn.textContent = "Xuất bản ngay";
    publishBtn.onclick = async () => {
      if (await callAction("/publish")) window.location.reload();
    };
    document.getElementById("publish-slot").appendChild(publishBtn);

    const scheduleBtn = document.createElement("button");
    scheduleBtn.type = "button";
    scheduleBtn.className = "btn";
    scheduleBtn.textContent = "Lên lịch...";
    scheduleBtn.onclick = async () => {
      const value = prompt("Nhập thời điểm xuất bản (vd 2026-08-01T09:00):");
      if (!value) return;
      if (await callAction("/schedule", { scheduledAt: value })) window.location.reload();
    };
    document.getElementById("schedule-slot").appendChild(scheduleBtn);
  }

  if (status === "scheduled" || status === "published") {
    const unpublishBtn = document.createElement("button");
    unpublishBtn.type = "button";
    unpublishBtn.className = "btn";
    unpublishBtn.textContent = "Gỡ về nháp";
    unpublishBtn.onclick = async () => {
      if (!confirm("Gỡ sản phẩm này về nháp?")) return;
      if (await callAction("/unpublish")) window.location.reload();
    };
    document.getElementById("unpublish-slot").appendChild(unpublishBtn);
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    const payload = {
      name: form.name.value,
      description: form.description.value || undefined,
      imageUrls: form.imageUrls.value.split("\n").map((s) => s.trim()).filter(Boolean),
      seo: {
        metaTitle: form.metaTitle.value || undefined,
        metaDescription: form.metaDescription.value || undefined,
        ogImage: form.ogImage.value || undefined,
        keyword: form.keyword.value || undefined,
        noindex: form.noindex.checked,
      },
    };

    const res = await fetch("/admin/api/products/" + productId, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showFlash(typeof body.error === "string" ? body.error : "Lưu thất bại", false);
      return;
    }

    showFlash("Đã lưu.", true);
  });

  async function loadRevisions() {
    const res = await fetch("/admin/api/products/" + productId + "/revisions");
    if (!res.ok) return;
    const { revisions } = await res.json();
    const tbody = document.getElementById("revisions-body");

    tbody.innerHTML = revisions.length
      ? revisions.map((r) => {
          const when = new Date(r.createdAt).toLocaleString("vi-VN");
          const who = r.user ? r.user.name : "-";
          const restoreBtn = '<button class="btn" data-revision-id="' + r.id + '">Khôi phục</button>';
          return "<tr><td>" + when + "</td><td>" + who + "</td><td style=\"text-align:right;\">" + restoreBtn + "</td></tr>";
        }).join("")
      : '<tr><td colspan="3" class="empty-state">Chưa có lịch sử chỉnh sửa nào.</td></tr>';
  }

  document.getElementById("revisions-body").addEventListener("click", async (event) => {
    const btn = event.target.closest("button[data-revision-id]");
    if (!btn) return;
    if (!confirm("Khôi phục sản phẩm về bản ghi này? Nội dung hiện tại sẽ được lưu lại thành 1 bản ghi mới trước khi ghi đè.")) return;

    const res = await fetch("/admin/api/products/" + productId + "/revisions/" + btn.dataset.revisionId + "/restore", { method: "POST" });
    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showFlash(typeof body.error === "string" ? body.error : "Khôi phục thất bại", false);
      return;
    }
    window.location.reload();
  });
  loadRevisions();
})();
</script>
{% endblock %}

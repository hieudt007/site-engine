  <script>
  (function () {
    const input = document.getElementById("admin-search-input");
    const results = document.getElementById("admin-search-results");
    let searchTimer;

    function escapeHtml(str) {
      const div = document.createElement("div");
      div.textContent = str ?? "";
      return div.innerHTML;
    }

    function groupHtml(label, items, hrefFor, labelFor) {
      if (!items.length) return "";
      return (
        '<div class="search-group-label">' + label + "</div>" +
        items.map((item) => '<a href="' + hrefFor(item) + '">' + escapeHtml(labelFor(item)) + "</a>").join("")
      );
    }

    async function search(q) {
      const res = await fetch("/admin/api/search?q=" + encodeURIComponent(q));
      if (!res.ok) {
        results.style.display = "none";
        return;
      }
      const { posts, pages, products, media } = await res.json();
      const html =
        groupHtml("Bài viết", posts, (p) => "/admin/posts/" + p.id, (p) => p.title) +
        groupHtml("Trang", pages, (p) => "/admin/pages/" + p.id, (p) => p.title) +
        groupHtml("Sản phẩm", products, (p) => "/admin/products/" + p.id, (p) => p.name) +
        groupHtml("Media", media, (m) => "/admin/media", (m) => m.filename);

      results.innerHTML = html || '<div class="search-empty">Không tìm thấy kết quả.</div>';
      results.style.display = "block";
    }

    if (input) {
      input.addEventListener("input", () => {
        clearTimeout(searchTimer);
        const q = input.value.trim();
        if (!q) {
          results.style.display = "none";
          return;
        }
        searchTimer = setTimeout(() => search(q), 300);
      });
    }

    document.addEventListener("click", (event) => {
      if (!event.target.closest("#admin-search-box")) results.style.display = "none";
    });
  })();

  window.generateSlug = function (str) {
    str = str.toLowerCase();
    str = str.replace(/à|á|ạ|ả|ã|â|ầ|ấ|ậ|ẩ|ẫ|ă|ằ|ắ|ặ|ẳ|ẵ/g, "a");
    str = str.replace(/è|é|ẹ|ẻ|ẽ|ê|ề|ế|ệ|ể|ễ/g, "e");
    str = str.replace(/ì|í|ị|ỉ|ĩ/g, "i");
    str = str.replace(/ò|ó|ọ|ỏ|õ|ô|ồ|ố|ộ|ổ|ỗ|ơ|ờ|ớ|ợ|ở|ỡ/g, "o");
    str = str.replace(/ù|ú|ụ|ủ|ũ|ư|ừ|ứ|ự|ử|ữ/g, "u");
    str = str.replace(/ỳ|ý|ỵ|ỷ|ỹ/g, "y");
    str = str.replace(/đ/g, "d");
    str = str.replace(/[^a-z0-9\s-]/g, "");
    str = str.replace(/\s+/g, "-");
    str = str.replace(/-+/g, "-");
    return str.replace(/^-+|-+$/g, "");
  };

  document.addEventListener("DOMContentLoaded", function() {
    const sourceInput = document.getElementById("title") || document.getElementById("name");
    const targetSlug = document.getElementById("slug");
    const displaySlug = document.getElementById("slug-display");
    const slugBtn = document.getElementById("slug-edit-btn");
    
    // Only auto-generate if it's a new item (slug is currently empty)
    if (sourceInput && targetSlug) {
      let autoGenerateSlug = !targetSlug.value;
      
      // Stop auto-generating if user manually edits the slug or clicks edit
      if (slugBtn) {
        slugBtn.addEventListener("click", () => { autoGenerateSlug = false; });
      }
      targetSlug.addEventListener("input", () => { autoGenerateSlug = false; });

      sourceInput.addEventListener("input", function() {
        if (autoGenerateSlug) {
          const newSlug = window.generateSlug(this.value);
          targetSlug.value = newSlug;
          if (displaySlug) {
            displaySlug.textContent = newSlug;
          }
        }
      });
    }
  });

  // Add global Ctrl+S shortcut for forms
  document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 's') {
      const submitBtn = document.querySelector('button[type="submit"]');
      if (submitBtn) {
        e.preventDefault();
        submitBtn.click();
      }
    }
  });

  // Warn on unsaved changes
  document.addEventListener("DOMContentLoaded", function() {
    let isDirty = false;
    const form = document.querySelector('form.edit-layout') || document.querySelector('form');
    if (form) {
      form.addEventListener('input', () => { isDirty = true; });
      form.addEventListener('change', () => { isDirty = true; });
      
      const flashEl = document.getElementById('flash');
      if (flashEl) {
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.attributeName === 'class' && flashEl.classList.contains('success')) {
              isDirty = false;
            }
          });
        });
        observer.observe(flashEl, { attributes: true });
      }
      
      window.addEventListener('beforeunload', function(e) {
        if (isDirty) {
          e.preventDefault();
          e.returnValue = '';
        }
      });
    }
  });
  </script>

  <dialog id="preview-modal">
    <div class="preview-modal-header">
      <div style="display:flex;align-items:center;gap:1rem;">
        <h3 style="margin:0;">Xem trước</h3>
        <div class="preview-device-controls" style="display:flex;gap:0.2rem;">
          <button type="button" class="btn btn-icon active" onclick="window.setPreviewDevice('desktop', this)" title="Desktop"><svg class="admin-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg></button>
          <button type="button" class="btn btn-icon" onclick="window.setPreviewDevice('tablet', this)" title="Tablet"><svg class="admin-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg></button>
          <button type="button" class="btn btn-icon" onclick="window.setPreviewDevice('mobile', this)" title="Mobile"><svg class="admin-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg></button>
        </div>
      </div>
      <button class="preview-modal-close" onclick="closePreview()">&times;</button>
    </div>
    <div id="preview-wrapper" style="width:100%;height:calc(100% - 43px);background:#e5e7eb;display:flex;justify-content:center;">
      <iframe id="preview-iframe" src="about:blank" style="width:100%;height:100%;border:none;background:#fff;transition:width 0.3s ease;box-shadow:0 0 15px rgba(0,0,0,0.1);"></iframe>
    </div>
  </dialog>
</body>
</html>

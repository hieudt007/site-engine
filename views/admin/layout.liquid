        linkTooltip.activeNode.href = url;
        if (blankCheck.checked) {
          linkTooltip.activeNode.target = "_blank";
        } else {
          linkTooltip.activeNode.removeAttribute("target");
        }
        linkTooltip.querySelector(".tooltip-url").textContent = url;
        linkTooltip.querySelector(".tooltip-url").href = url;

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.8rem;">
        <strong id="custom-fields-title">Trường tùy biến</strong>
        <button type="button" class="btn" id="custom-fields-close">Đóng</button>
      </div>
      <div id="custom-fields-rows" style="display:flex;flex-direction:column;gap:0.5rem;"></div>
      <div style="margin-top:0.8rem;display:flex;gap:0.6rem;">
        <button type="button" class="btn" id="custom-fields-add">+ Thêm trường</button>
        <button type="button" class="btn btn-primary" id="custom-fields-save">Lưu</button>

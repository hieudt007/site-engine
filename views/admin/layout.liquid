  <div id="media-picker-overlay">
    <div id="media-picker-panel">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.8rem;">
        <strong id="media-picker-title">Chọn ảnh</strong>
        <div>
          <button type="button" class="btn btn-primary" id="media-picker-confirm" style="display:none;margin-right:0.5rem;">Xong (0)</button>
          <button type="button" class="btn" id="media-picker-close">Đóng</button>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;gap:1rem;">
        <input type="search" id="media-picker-search" placeholder="Tìm ảnh..." style="flex:1;">
        <label class="btn btn-primary" style="cursor:pointer;display:inline-flex;align-items:center;gap:0.4rem;margin:0;white-space:nowrap;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
          Tải lên
          <input type="file" id="media-picker-file-input" accept="image/jpeg,image/png,image/webp,image/gif" multiple style="display:none;">
        </label>
      </div>
      <div id="media-picker-upload-status" style="font-size:0.8rem;color:#777;margin-bottom:0.8rem;"></div>
      <div id="media-picker-grid"></div>
      <div class="pagination" id="media-picker-pagination" style="margin-top:0.8rem;"></div>
    </div>
  </div>

  <script>
  (function () {
    const overlay = document.getElementById("media-picker-overlay");
    const grid = document.getElementById("media-picker-grid");
    const pagination = document.getElementById("media-picker-pagination");
    const fileInput = document.getElementById("media-picker-file-input");
    const status = document.getElementById("media-picker-upload-status");
    const closeBtn = document.getElementById("media-picker-close");
    const confirmBtn = document.getElementById("media-picker-confirm");
    const titleEl = document.getElementById("media-picker-title");

    const searchInput = document.getElementById("media-picker-search");

    let currentPage = 1;
    let onSelectCallback = null;
    let isMultiple = false;
    let selectedMedia = [];
    let searchTimer;

    function escapeHtml(str) {
      const div = document.createElement("div");
      div.textContent = str ?? "";
      return div.innerHTML;
    }

    async function loadGrid() {
      grid.innerHTML = '<p style="color:#999;grid-column:1/-1;">Đang tải...</p>';
      const params = new URLSearchParams({ page: String(currentPage) });
      if (searchInput.value) params.set("q", searchInput.value.trim());

      const res = await fetch("/admin/api/media?" + params.toString());
      if (!res.ok) {
        grid.innerHTML = '<p style="color:#c00;grid-column:1/-1;">Tải thất bại</p>';
        return;
      }
      const { media, totalPages } = await res.json();
      const gridEl = document.getElementById("media-picker-grid");
      const paginationEl = document.getElementById("media-picker-pagination");

      gridEl.innerHTML = media.map(m => {
        const isSel = selectedMedia.some(s => s.url === m.url);
        const selStyle = isSel ? 'border:3px solid var(--color-primary);opacity:0.7;' : '';
        return '<div class="media-picker-item" data-id="' + m.id + '" data-url="' + m.url + '" data-alt="' + escapeHtml(m.alt || "") + '" style="' + selStyle + ' position: relative;">' +
               '<img src="' + m.url + '" alt="' + escapeHtml(m.alt || m.filename) + '">' +
               '<button type="button" class="btn btn-icon edit-alt-btn" style="position:absolute; top:4px; right:4px; background:rgba(255,255,255,0.9); padding:0.2rem; width:24px; height:24px;" title="Sửa thẻ Alt ảnh này">' +
               '<svg class="admin-icon" viewBox="0 0 24 24" aria-hidden="true" style="width:14px;height:14px;"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>' +
               '</button></div>';
      }).join("");

      if (media.length === 0) {
        gridEl.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:2rem;color:#666;">Chưa có tệp nào.</div>';
      }

      window.renderPagination(paginationEl, mediaPickerPage, totalPages);
    }

    searchInput.addEventListener("input", () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => { currentPage = 1; loadGrid(); }, 300);
    });

    function close() {
      overlay.style.display = "none";
      onSelectCallback = null;
      fileInput.value = "";
      status.textContent = "";
      isMultiple = false;
      selectedMedia = [];
      confirmBtn.style.display = "none";
      confirmBtn.textContent = "Xong (0)";
    }

    function select(media) {
      if (onSelectCallback) onSelectCallback(media.url, media);
      close();
    }

    closeBtn.addEventListener("click", close);
    overlay.addEventListener("click", (event) => {
      if (event.target === overlay) close();
    });

    confirmBtn.addEventListener("click", () => {
      if (onSelectCallback) {
        selectedMedia.forEach(m => onSelectCallback(m.url, m));
      }
      close();
    });

    pagination.addEventListener("click", (event) => {
      const link = event.target.closest("a[data-page]");
      if (!link) return;
      event.preventDefault();
      currentPage = Number(link.dataset.page);
      loadGrid();
    });

    grid.addEventListener("click", async (event) => {
      const editBtn = event.target.closest(".edit-alt-btn");
      if (editBtn) {
        event.stopPropagation();
        const item = editBtn.closest(".media-picker-item");
        const currentAlt = item.dataset.alt || "";
        const newAlt = prompt("Nhập thẻ Alt cho ảnh này:", currentAlt);
        if (newAlt !== null && newAlt !== currentAlt) {
          const res = await fetch("/admin/api/media/" + item.dataset.id, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ alt: newAlt })
          });
          if (res.ok) {
            item.dataset.alt = newAlt;
            alert("Đã lưu thẻ Alt!");
            window.dispatchEvent(new CustomEvent('mediaAltUpdated', { detail: { url: item.dataset.url, alt: newAlt } }));
          } else {
            alert("Lỗi khi lưu thẻ Alt");
          }
        }
        return;
      }

      const item = event.target.closest("[data-url]");
      if (!item) return;
      const mediaObj = { url: item.dataset.url, alt: item.dataset.alt || "" };
      
      if (isMultiple) {
        const index = selectedMedia.findIndex(m => m.url === mediaObj.url);
        if (index > -1) {
          selectedMedia.splice(index, 1);
          item.style.border = "";
          item.style.opacity = "";
        } else {
          selectedMedia.push(mediaObj);
          item.style.border = "3px solid var(--color-primary)";
          item.style.opacity = "0.7";
        }
        confirmBtn.textContent = "Xong (" + selectedMedia.length + ")";
      } else {
        select(mediaObj);
      }
    });

    fileInput.addEventListener("change", async () => {
      const files = [...fileInput.files];
      if (!files.length) return;

      const failed = [];
      for (let i = 0; i < files.length; i++) {
        status.textContent = "Đang tải lên " + (i + 1) + "/" + files.length + "...";
        const formData = new FormData();
        formData.append("file", files[i]);

        const res = await fetch("/admin/api/media", { method: "POST", body: formData });
        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          failed.push(files[i].name + (typeof body.error === "string" ? ": " + body.error : ""));
          continue;
        }

        const { media } = await res.json();
        if (onSelectCallback) onSelectCallback(media.url, media);
      }

      status.textContent = failed.length ? "Lỗi " + failed.length + "/" + files.length + " file: " + failed.join("; ") : "";
      fileInput.value = "";
      if (!failed.length) close();
    });

    document.addEventListener('click', (e) => {
      const box = e.target.closest('.image-picker-box');
      if (box) {
        const removeBtn = e.target.closest('.image-picker-remove');
        const input = box.querySelector('input');
        const img = box.querySelector('.image-picker-preview');
        const empty = box.querySelector('.image-picker-empty');
        const btn = box.querySelector('.image-picker-remove');

        if (removeBtn) {
          e.stopPropagation();
          input.value = '';
          img.src = '';
          img.style.display = 'none';
          empty.style.display = 'block';
          btn.style.display = 'none';
          input.dispatchEvent(new Event('change', { bubbles: true }));
          return;
        }

        window.openMediaPicker({
          title: 'Chọn ảnh',
          onSelect: (url) => {
            input.value = url;
            img.src = url;
            img.style.display = 'block';
            empty.style.display = 'none';
            btn.style.display = 'flex';
            input.dispatchEvent(new Event('change', { bubbles: true }));
          }
        });
      }
    });

    window.openMediaPicker = function (options) {
      options = options || {};
      onSelectCallback = options.onSelect || null;
      titleEl.textContent = options.title || "Chọn ảnh";
      isMultiple = options.multiple || false;
      selectedMedia = [];
      confirmBtn.style.display = isMultiple ? "inline-block" : "none";
      confirmBtn.textContent = "Xong (0)";
      currentPage = 1;
      searchInput.value = options.searchQuery || "";
      overlay.style.display = "flex";
      loadGrid();
    };
  })();
  </script>

  <script>
  // Editor rich-text nhe (khong phu thuoc thu vien ngoai) - dung contenteditable + document.execCommand,
  // du cho nhu cau bold/italic/heading/list/link/chen anh cua bai viet/trang. Dong bo 2 chieu voi
  // <textarea> goc (form submit doc tu textarea) qua onInput. API: initRichEditor(textareaId).
  window.initRichEditor = function (textareaId) {
    const textarea = document.getElementById(textareaId);
    if (!textarea) return;

    const toolbar = document.createElement("div");
    toolbar.className = "rich-editor-toolbar";

    const body = document.createElement("div");
    body.className = "rich-editor-body";
    body.contentEditable = "true";
    body.innerHTML = textarea.value;

    let selectedImage = null;
    let linkBtn, imageBtn;
    let linkTooltip, wrapper;

    function updateToolbarState() {
      const sel = window.getSelection();
      let isLink = false;
      let activeLinkNode = null;
      if (sel.rangeCount > 0) {
        let node = sel.anchorNode;
        while (node && node !== body) {
          if (node.nodeType === 1 && node.tagName === "A") {
            isLink = true;
            activeLinkNode = node;
            break;
          }
          node = node.parentNode;
        }
      }
      if (linkBtn) {
        if (isLink) linkBtn.classList.add("active");
        else linkBtn.classList.remove("active");
      }
      if (imageBtn) {
        if (selectedImage) imageBtn.classList.add("active");
        else imageBtn.classList.remove("active");
      }
      
      // Update Tooltip
      if (linkTooltip && wrapper) {
        if (isLink && activeLinkNode) {
          const rect = activeLinkNode.getBoundingClientRect();
          const wrapperRect = wrapper.getBoundingClientRect();
          const bodyRect = body.getBoundingClientRect();
          
          if (rect.bottom < bodyRect.top || rect.top > bodyRect.bottom) {
            linkTooltip.style.display = "none";
          } else {
            linkTooltip.style.display = "flex";
            // offset inside wrapper
            linkTooltip.style.top = (rect.bottom - wrapperRect.top + 4) + "px";
            linkTooltip.style.left = Math.max(0, rect.left - wrapperRect.left) + "px";
            
            const urlEl = linkTooltip.querySelector(".tooltip-url");
            urlEl.href = activeLinkNode.href;
            urlEl.textContent = activeLinkNode.href;
            
            // Reset to view mode only if changing links
            if (linkTooltip.activeNode !== activeLinkNode) {
              const viewMode = linkTooltip.querySelector(".tooltip-view");
              const editMode = linkTooltip.querySelector(".tooltip-edit");
              if (viewMode && editMode) {
                viewMode.style.display = "flex";
                editMode.style.display = "none";
              }
            }
            
            linkTooltip.activeNode = activeLinkNode;
          }
        } else {
          linkTooltip.style.display = "none";
          linkTooltip.activeNode = null;
        }
      }
    }

    body.addEventListener("click", function(e) {
      if (e.target.tagName === "IMG") {
        selectedImage = e.target;
        const selection = window.getSelection();
        const range = document.createRange();
        range.selectNode(e.target);
        selection.removeAllRanges();
        selection.addRange(range);
      } else {
        selectedImage = null;
      }
      updateToolbarState();
    });

    body.addEventListener("keyup", updateToolbarState);

    window.addEventListener('mediaAltUpdated', (e) => {
      const { url, alt } = e.detail;
      const images = body.querySelectorAll('img[src="' + url + '"]');
      images.forEach(img => {
        img.alt = alt;
        img.title = alt;
      });
      if (images.length > 0) sync();
    });

    function sync() {
      if (textarea.style.display !== "none") {
        body.innerHTML = textarea.value; // reverse sync if in source mode
      } else {
        textarea.value = body.innerHTML;
      }
      textarea.dispatchEvent(new Event("input", { bubbles: true }));
    }

    function editorIcon(name) {
      const paths = {
        sparkles: '<path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6z"></path><path d="M19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8z"></path><path d="M5 14l.8 2.2L8 17l-2.2.8L5 20l-.8-2.2L2 17l2.2-.8z"></path>',
        list: '<path d="M8 6h13M8 12h13M8 18h13"></path><path d="M3 6h.01M3 12h.01M3 18h.01"></path>',
        "list-ordered": '<path d="M10 6h11M10 12h11M10 18h11"></path><path d="M4 6h1v4"></path><path d="M4 10h2"></path><path d="M4 14h2l-2 4h2"></path>',
        link: '<path d="M10 13a5 5 0 0 0 7.1 0l2-2a5 5 0 0 0-7.1-7.1l-1.1 1.1"></path><path d="M14 11a5 5 0 0 0-7.1 0l-2 2A5 5 0 0 0 12 20.1l1.1-1.1"></path>',
        edit: '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>',
        unlink: '<path d="M15 7h2a5 5 0 0 1 0 10h-2m-6 0H7A5 5 0 0 1 7 7h2"></path><line x1="8" y1="12" x2="16" y2="12"></line><line x1="2" y1="2" x2="22" y2="22"></line>',
        image: '<rect x="3" y="5" width="18" height="14" rx="2"></rect><circle cx="8.5" cy="10" r="1.5"></circle><path d="M21 15l-4-4-9 8"></path>',
        video: '<rect x="3" y="5" width="14" height="14" rx="2"></rect><path d="M17 10l4-2v8l-4-2z"></path>',
        table: '<rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M3 10h18M3 16h18M9 4v16M15 4v16"></path>',
        code: '<path d="M8 17l-5-5 5-5"></path><path d="M16 7l5 5-5 5"></path><path d="M14 4l-4 16"></path>',
        fullscreen: '<path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>',
        minimize: '<path d="M8 3v3h-3m18 0h-3V3m0 18v-3h3M3 16h3v3"></path>',
      };
      return '<svg class="editor-icon" viewBox="0 0 24 24" aria-hidden="true">' + (paths[name] || paths.code) + "</svg>";
    }

    function addButton(html, title, action) {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.innerHTML = html;
      btn.title = title;
      btn.setAttribute("aria-label", title);
      btn.addEventListener("click", () => {
        body.focus();
        action();
        sync();
      });
      toolbar.appendChild(btn);
      return btn;
    }

    function addSep() {
      const sep = document.createElement("div");
      sep.className = "sep";
      toolbar.appendChild(sep);
    }

    // AI Rewrite

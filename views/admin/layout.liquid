        sync();
      }
      editMode.style.display = "none";
      viewMode.style.display = "flex";
    });

    urlInput.addEventListener("keyup", (e) => {
      if (e.key === "Enter") linkTooltip.querySelector(".apply-link-btn").click();
    });

    linkTooltip.querySelector(".unlink-btn").addEventListener("click", () => {
      if (!linkTooltip.activeNode) return;
      const selection = window.getSelection();
      const range = document.createRange();
      range.selectNodeContents(linkTooltip.activeNode);
      selection.removeAllRanges();
      selection.addRange(range);
      document.execCommand("unlink", false, null);
      updateToolbarState();
      sync();
    });
  };
  </script>

  <script>
  // Modal sua "customFields" (Post/Page/Product/Category/Topic/ProductReview, xem
  // services/customFields.ts) - dung chung 1 modal cho moi man hinh admin thay vi 7 UI rieng.
  // API: openCustomFieldsEditor({ title, initial: {k:v,...}, onSave: async (obj) => {...} }).
  // Luu NGAY khi bam nut Luu trong modal (goi onSave rieng, khong gop vao form chinh cua trang).
  (function () {
    const overlay = document.getElementById("custom-fields-overlay");
    const titleEl = document.getElementById("custom-fields-title");
    const rowsEl = document.getElementById("custom-fields-rows");
    const errorEl = document.getElementById("custom-fields-error");
    const closeBtn = document.getElementById("custom-fields-close");
    const addBtn = document.getElementById("custom-fields-add");
    const saveBtn = document.getElementById("custom-fields-save");

    let onSaveCallback = null;

    function addRow(key, value) {
      const row = document.createElement("div");
      row.style.display = "flex";
      row.style.gap = "0.5rem";
      row.innerHTML =
        '<input type="text" class="cf-key" placeholder="Tên trường" style="flex:1;">' +
        '<input type="text" class="cf-value" placeholder="Giá trị" style="flex:1;">' +
        '<button type="button" class="btn btn-danger btn-icon" data-remove title="Xoá" aria-label="Xoá">' + window.adminIcon("trash") + '</button>';
      row.querySelector(".cf-key").value = key || "";
      row.querySelector(".cf-value").value = value || "";
      rowsEl.appendChild(row);
    }

    function collect() {
      const result = {};
      rowsEl.querySelectorAll("div").forEach((row) => {
        const key = row.querySelector(".cf-key").value.trim();
        const value = row.querySelector(".cf-value").value.trim();
        if (key) result[key] = value;
      });
      return result;
    }

    function close() {
      overlay.style.display = "none";
      onSaveCallback = null;
      errorEl.textContent = "";
    }

    closeBtn.addEventListener("click", close);
    overlay.addEventListener("click", (event) => {
      if (event.target === overlay) close();
    });

    addBtn.addEventListener("click", () => addRow("", ""));

    rowsEl.addEventListener("click", (event) => {
      const btn = event.target.closest("button[data-remove]");
      if (!btn) return;
      btn.closest("div").remove();
    });

    saveBtn.addEventListener("click", async () => {
      errorEl.textContent = "";
      try {
        await onSaveCallback(collect());
        close();
      } catch (err) {
        errorEl.textContent = err && err.message ? err.message : "Lưu thất bại";
      }
    });

    window.openCustomFieldsEditor = function (options) {
      options = options || {};
      titleEl.textContent = options.title || "Trường tùy biến";
      onSaveCallback = options.onSave || (async () => {});
      rowsEl.innerHTML = "";
      const initial = options.initial || {};
      const keys = Object.keys(initial);
      if (keys.length === 0) {
        addRow("", "");
      } else {
        keys.forEach((k) => addRow(k, initial[k]));
      }
      overlay.style.display = "flex";
    };
  })();
  </script>


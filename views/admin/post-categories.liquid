{% layout "layout" %}
{% block content %}
<h1 style="margin:0 0 1.2rem;">Danh mục bài viết</h1>

<form id="new-category-form" class="card" style="display:flex;gap:0.6rem;align-items:flex-start;margin-bottom:1.2rem;">
  <input type="text" id="new-name" placeholder="Tên danh mục" required style="flex:1;">
  <input type="text" id="new-slug" placeholder="slug-danh-muc" required style="flex:1;">
  <button type="submit" class="btn btn-primary">+ Thêm</button>
</form>

<table>
  <thead>
    <tr><th>Tên</th><th>Danh mục cha</th><th>Slug</th><th></th></tr>
  </thead>
  <tbody id="categories-body">
    <tr><td colspan="3" style="color:#999;">Đang tải...</td></tr>
  </tbody>
</table>

<script>
(function () {
  const tbody = document.getElementById("categories-body");
  const flash = document.getElementById("flash");

  function showError(message) {
    flash.textContent = message;
    flash.className = "error";
  }

  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str ?? "";
    return div.innerHTML;
  }

  async function load() {
    const res = await fetch("/admin/api/post-categories");
    const { categories } = await res.json();
    tbody.innerHTML = categories.length
      ? categories.map((c) =>
          '<tr><td><a href="/admin/post-categories/' + c.id + '">' + escapeHtml(c.name) + "</a></td>" +
          "<td>" + (c.parent ? escapeHtml(c.parent.name) : "-") + "</td>" +
          "<td>" + escapeHtml(c.slug) + "</td>" +
          '<td style="text-align:right;display:flex;gap:0.4rem;justify-content:flex-end;">' +
          '<a class="btn" href="/admin/post-categories/' + c.id + '">Sửa nội dung</a>' +
          '<button class="btn btn-danger" data-id="' + c.id + '">Xoá</button></td></tr>'
        ).join("")
      : '<tr><td colspan="4" class="empty-state">Chưa có danh mục nào.</td></tr>';
  }

  document.getElementById("new-category-form").addEventListener("submit", async (event) => {
    event.preventDefault();
    const name = document.getElementById("new-name").value;
    const slug = document.getElementById("new-slug").value;

    const res = await fetch("/admin/api/post-categories", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name, slug }),
    });

    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showError(typeof body.error === "string" ? body.error : "Tạo thất bại");
      return;
    }

    document.getElementById("new-name").value = "";
    document.getElementById("new-slug").value = "";
    load();
  });

  tbody.addEventListener("click", async (event) => {
    const btn = event.target.closest("button[data-id]");
    if (!btn) return;
    if (!confirm("Xoá danh mục này? Bài viết đang gán sẽ về trạng thái không có danh mục.")) return;

    const res = await fetch("/admin/api/post-categories/" + btn.dataset.id, { method: "DELETE" });
    if (!res.ok) {
      showError("Xoá thất bại");
      return;
    }
    load();
  });

  load();
})();
</script>
{% endblock %}

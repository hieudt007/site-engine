{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;">
  <h1 style="margin:0;">Sửa danh mục: {{ category.name | escape }}</h1>
  <a class="btn" href="/admin/product-categories">← Danh sách</a>
</div>

<div class="card" style="margin-bottom:1.2rem;font-size:0.85rem;color:#555;">
  <strong>Đồng bộ từ LeadBase (chỉ đọc):</strong> Tên <strong>{{ category.name | escape }}</strong> · Slug <strong>{{ category.slug | escape }}</strong>
  <div style="margin-top:0.3rem;color:#999;">Đồng bộ lần cuối: {{ category.syncedAt }}</div>
</div>

<form id="category-form" class="card">
  <label for="parentId">Danh mục cha</label>
  <select id="parentId" name="parentId">
    <option value="">— Không có (danh mục gốc) —</option>
    {% for c in categories %}
      <option value="{{ c.id }}" {% if category.parentId == c.id %}selected{% endif %}>{{ c.name | escape }}</option>
    {% endfor %}
  </select>
  <div class="field-hint">LeadBase không gửi cây danh mục — chọn cha ở đây là tự quản riêng tại site.</div>

  <label for="excerpt">Tóm tắt</label>
  <input type="text" id="excerpt" name="excerpt" value="{{ category.excerpt | escape }}">

  <label for="body">Nội dung trang danh mục (hiện phía trên danh sách sản phẩm)</label>
  <textarea id="body" name="body" style="min-height:160px;">{{ category.body }}</textarea>

  <h2 style="font-size:0.95rem;margin:1.5rem 0 0.5rem;border-top:1px solid #eee;padding-top:1rem;">Câu hỏi thường gặp (FAQ)</h2>
  <div id="faq-rows">
    {% for item in category.faq %}
      <div class="faq-row card" style="margin-bottom:0.5rem;position:relative;">
        <button type="button" class="btn btn-danger btn-icon faq-remove" title="Xoá" aria-label="Xoá" style="position:absolute;top:0.5rem;right:0.5rem;">{% render "components/icon", name: "trash" %}</button>
        <label>Câu hỏi</label>
        <input type="text" class="faq-q" value="{{ item.question | escape }}" style="margin-bottom:0.5rem;">
        <label>Câu trả lời</label>
        <textarea class="faq-a" style="min-height:80px;">{{ item.answer | escape }}</textarea>
      </div>
    {% endfor %}
  </div>
  <button type="button" class="btn" id="faq-add-btn">+ Thêm câu hỏi</button>

  <h2 style="font-size:0.95rem;margin:1.5rem 0 0.5rem;border-top:1px solid #eee;padding-top:1rem;">SEO</h2>

  <label for="keyword">Từ khoá chính</label>
  <input type="text" id="keyword" name="keyword" value="{% if category.seo %}{{ category.seo.keyword | escape }}{% endif %}" placeholder="Ví dụ: máy hút bụi, thiết bị gia dụng">
  <div class="field-hint">Có thể nhập nhiều từ khoá, ngăn cách bởi dấu phẩy.</div>

  <label for="metaTitle">Meta title</label>
  <input type="text" id="metaTitle" name="metaTitle" value="{% if category.seo %}{{ category.seo.metaTitle | escape }}{% endif %}" placeholder="Để trống nếu dùng tên danh mục">

  <label for="metaDescription">Meta description</label>
  <input type="text" id="metaDescription" name="metaDescription" value="{% if category.seo %}{{ category.seo.metaDescription | escape }}{% endif %}" placeholder="Để trống nếu dùng tóm tắt danh mục">

  <div style="margin-top:1.5rem;display:flex;gap:0.6rem;">
    <button type="submit" class="btn btn-primary">Lưu</button>
    <button type="button" class="btn" id="custom-fields-btn">Trường tùy biến</button>
  </div>
</form>

<script>
(function () {
  const categoryId = "{{ category.id }}";
  const form = document.getElementById("category-form");
  const flash = document.getElementById("flash");

  function showFlash(message, ok) {
    flash.textContent = message;
    flash.className = ok ? "success" : "error";
  }

  const faqRows = document.getElementById("faq-rows");
  function addFaqRow(q, a) {
    const row = document.createElement("div");
    row.className = "faq-row card";
    row.style.cssText = "margin-bottom:0.5rem;position:relative;";
    row.innerHTML =
      '<button type="button" class="btn btn-danger btn-icon faq-remove" title="Xoá" aria-label="Xoá" style="position:absolute;top:0.5rem;right:0.5rem;">' + window.adminIcon("trash") + '</button>' +
      '<label>Câu hỏi</label><input type="text" class="faq-q" style="margin-bottom:0.5rem;">' +
      '<label>Câu trả lời</label><textarea class="faq-a" style="min-height:80px;"></textarea>';
    row.querySelector(".faq-q").value = q || "";
    row.querySelector(".faq-a").value = a || "";
    faqRows.appendChild(row);
  }
  document.getElementById("faq-add-btn").addEventListener("click", () => addFaqRow("", ""));
  faqRows.addEventListener("click", (e) => {
    const removeBtn = e.target.closest(".faq-remove");
    if (removeBtn) removeBtn.closest(".faq-row").remove();
  });
  function collectFaq() {
    return [...faqRows.querySelectorAll(".faq-row")]
      .map(row => ({
        question: row.querySelector(".faq-q").value.trim(),
        answer: row.querySelector(".faq-a").value.trim()
      }))
      .filter(i => i.question && i.answer);
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    const payload = {
      parentId: form.parentId.value || null,
      excerpt: form.excerpt.value || undefined,
      body: form.body.value || undefined,
      seo: {
        metaTitle: form.metaTitle.value || undefined,
        metaDescription: form.metaDescription.value || undefined,
        keyword: form.keyword.value || undefined,
      },
      faq: collectFaq(),
    };

    const res = await fetch("/admin/api/product-categories/" + categoryId, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showFlash(typeof body.error === "string" ? body.error : "Lưu thất bại", false);
      return;
    }

    showFlash("Đã lưu.", true);
  });

  document.getElementById("custom-fields-btn").addEventListener("click", async () => {
    const res = await fetch("/admin/api/product-categories/" + categoryId);
    const { category: current } = await res.json();
    openCustomFieldsEditor({
      title: "Trường tùy biến — danh mục",
      initial: current.customFields || {},
      onSave: async (customFields) => {
        const saveRes = await fetch("/admin/api/product-categories/" + categoryId, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ customFields }),
        });
        if (!saveRes.ok) throw new Error("Lưu thất bại");
        showFlash("Đã lưu trường tùy biến.", true);
      },
    });
  });
})();
</script>
{% endblock %}

{% layout "layout" %}
{% block content %}
<h1 style="margin:0 0 1.2rem;">Redirect URL</h1>
<p style="color:#777;font-size:0.85rem;margin-top:-0.8rem;margin-bottom:1.2rem;">
  Đa số redirect tự tạo khi đổi slug bài viết. Dùng form dưới để bổ sung tay case đặc biệt.
</p>

<form id="new-redirect-form" style="display:flex;gap:0.5rem;margin-bottom:1.2rem;">
  <input type="text" id="new-from" placeholder="/blog/duong-dan-cu" required style="flex:1;padding:0.5rem 0.7rem;border:1px solid #d1d5db;border-radius:6px;">
  <input type="text" id="new-to" placeholder="/blog/duong-dan-moi" required style="flex:1;padding:0.5rem 0.7rem;border:1px solid #d1d5db;border-radius:6px;">
  <button type="submit" class="btn btn-primary">+ Thêm</button>
</form>

<table>
  <thead>
    <tr><th>Từ</th><th>Đến</th><th>Mã</th><th></th></tr>
  </thead>
  <tbody id="redirects-body">
    <tr><td colspan="4" style="color:#999;">Đang tải...</td></tr>
  </tbody>
</table>

<script>
(function () {
  const tbody = document.getElementById("redirects-body");
  const flash = document.getElementById("flash");

  function showError(message) {
    flash.textContent = message;
    flash.className = "error";
  }

  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str ?? "";
    return div.innerHTML;
  }

  async function load() {
    const res = await fetch("/admin/api/redirects");
    const { redirects } = await res.json();
    tbody.innerHTML = redirects.length
      ? redirects.map((r) =>
          "<tr><td>" + escapeHtml(r.fromPath) + "</td><td>" + escapeHtml(r.toPath) + "</td><td>" + r.statusCode + "</td>" +
          '<td style="text-align:right;"><button class="btn btn-danger" data-id="' + r.id + '">Xoá</button></td></tr>'
        ).join("")
      : '<tr><td colspan="4" style="color:#999;">Chưa có redirect nào.</td></tr>';
  }

  document.getElementById("new-redirect-form").addEventListener("submit", async (event) => {
    event.preventDefault();
    const fromPath = document.getElementById("new-from").value;
    const toPath = document.getElementById("new-to").value;

    const res = await fetch("/admin/api/redirects", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ fromPath, toPath }),
    });

    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showError(typeof body.error === "string" ? body.error : "Tạo thất bại");
      return;
    }

    document.getElementById("new-from").value = "";
    document.getElementById("new-to").value = "";
    load();
  });

  tbody.addEventListener("click", async (event) => {
    const btn = event.target.closest("button[data-id]");
    if (!btn) return;
    if (!confirm("Xoá redirect này?")) return;

    const res = await fetch("/admin/api/redirects/" + btn.dataset.id, { method: "DELETE" });
    if (!res.ok) {
      showError("Xoá thất bại");
      return;
    }
    load();
  });

  load();
})();
</script>
{% endblock %}

{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;">
  <h1 style="margin:0;">Trang tĩnh</h1>
  <a class="btn btn-primary" href="/admin/pages/new">+ Trang mới</a>
</div>

<div style="display:flex;gap:0.6rem;margin-bottom:1rem;flex-wrap:wrap;">
  <input type="search" id="search-input" class="search-input" placeholder="Tìm theo tiêu đề...">
  <select id="status-filter" style="max-width:180px;">
    <option value="">Tất cả trạng thái</option>
    <option value="draft">Nháp</option>
    <option value="pending_review">Chờ duyệt</option>
    <option value="scheduled">Đã lên lịch</option>
    <option value="published">Đã xuất bản</option>
  </select>
</div>

<table>
  <thead>
    <tr>
      <th>Tiêu đề</th>
      <th>Trạng thái</th>
      <th style="width:5rem;text-align:center;">SEO</th>
      <th>Tác giả</th>
      <th>Cập nhật</th>
      <th></th>
    </tr>
  </thead>
  <tbody id="pages-body">
    <tr><td colspan="6" style="color:#999;">Đang tải...</td></tr>
  </tbody>
</table>
<div class="pagination" id="pagination"></div>

<script>
(function () {
  const CURRENT_ROLE = "{{ role }}";
  const canManage = CURRENT_ROLE === "manager" || CURRENT_ROLE === "admin";
  const tbody = document.getElementById("pages-body");
  const pagination = document.getElementById("pagination");
  const flash = document.getElementById("flash");
  const searchInput = document.getElementById("search-input");
  const statusFilter = document.getElementById("status-filter");

  let currentPage = 1;
  let searchTimer;

  function showError(message) {
    flash.textContent = message;
    flash.className = "error";
  }

  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str ?? "";
    return div.innerHTML;
  }

  const STATUS_LABEL = { draft: "Nháp", pending_review: "Chờ duyệt", scheduled: "Đã lên lịch", published: "Đã xuất bản" };

  function rowHtml(page) {
    const statusBadge = '<span class="status-badge status-' + page.status + '">' + (STATUS_LABEL[page.status] || page.status) + '</span>';
    const author = page.author ? escapeHtml(page.author.name) : "-";
    const updated = new Date(page.updatedAt).toLocaleString("vi-VN");
    const submitBtn = page.status === "draft"
      ? '<button class="btn" data-action="submit" data-id="' + page.id + '">Nộp duyệt</button>'
      : "";
    const publishBtn = (page.status === "pending_review" || page.status === "scheduled") && canManage
      ? '<button class="btn" data-action="publish" data-id="' + page.id + '">Xuất bản</button>'
      : "";
    const deleteBtn = canManage
      ? '<button class="btn btn-danger btn-icon" data-action="delete" data-id="' + page.id + '" title="Xoá" aria-label="Xoá">' + window.adminIcon("trash") + '</button>'
      : "";
    const score = (page.seo && page.seo.score) || 0;
    let color = "#ef4444";
    if (score >= 80) color = "#10b981";
    else if (score >= 50) color = "#f59e0b";
    
    const seoHtml = '<div style="width:28px;height:28px;border-radius:50%;background:conic-gradient(' + color + ' ' + score + '%, #e5e7eb 0);display:flex;align-items:center;justify-content:center;margin:0 auto;"><div style="width:22px;height:22px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;color:' + color + ';">' + score + '</div></div>';

    return (
      "<tr>" +
      '<td><a href="/admin/pages/' + page.id + '">' + escapeHtml(page.title) + "</a></td>" +
      "<td>" + statusBadge + "</td>" +
      '<td style="text-align:center;">' + seoHtml + '</td>' +
      "<td>" + author + "</td>" +
      "<td>" + updated + "</td>" +
      '<td style="text-align:right;white-space:nowrap;">' +
      '<button type="button" class="btn btn-icon" style="margin-right:0.2rem;" title="Xem trước" onclick="window.openPreview(\'/admin/preview/page/' + page.id + '\')">' + window.adminIcon("eye") + '</button>' +
      '<a href="/' + page.slug + '" target="_blank" class="btn btn-icon" style="margin-right:0.2rem;" title="Xem trên web">' + window.adminIcon("external-link") + '</a>' +
      submitBtn +
      publishBtn +
      deleteBtn +
      "</td>" +
      "</tr>"
    );
  }

  async function load() {
    const params = new URLSearchParams({ page: String(currentPage) });
    if (searchInput.value) params.set("q", searchInput.value);
    if (statusFilter.value) params.set("status", statusFilter.value);

    const res = await fetch("/admin/api/pages?" + params.toString());
    if (!res.ok) {
      showError("Không tải được danh sách trang");
      return;
    }
    const { pages, totalPages } = await res.json();
    
    if (pages.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="empty-state">Không tìm thấy trang nào.</td></tr>';
      pagination.innerHTML = "";
      return;
    }

    tbody.innerHTML = pages.map(rowHtml).join("");
    window.renderPagination(pagination, currentPage, totalPages);
  }

  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => { currentPage = 1; load(); }, 300);
  });
  statusFilter.addEventListener("change", () => { currentPage = 1; load(); });

  pagination.addEventListener("click", (event) => {
    const link = event.target.closest("a[data-page]");
    if (!link) return;
    event.preventDefault();
    currentPage = Number(link.dataset.page);
    load();
  });

  tbody.addEventListener("click", async (event) => {
    const btn = event.target.closest("button[data-action]");
    if (!btn) return;
    const { action, id } = btn.dataset;

    if (action === "delete" && !confirm("Xoá trang này?")) return;

    const res = await fetch(
      "/admin/api/pages/" + id + (action === "delete" ? "" : "/" + action),
      { method: action === "delete" ? "DELETE" : "POST" },
    );
    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showError(body.error || "Thao tác thất bại");
      return;
    }
    load();
  });

  load();
})();
</script>
{% endblock %}

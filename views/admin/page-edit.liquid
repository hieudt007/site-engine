{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;">
  <h1 style="margin:0;">{% if page %}Sửa trang{% else %}Trang mới{% endif %}</h1>
  <a class="btn" href="/admin/pages">← Danh sách</a>
</div>

{% if page %}
  <div style="margin-bottom:1rem;">
    <span class="status-badge status-{{ page.status }}">{{ page.status }}</span>
  </div>
{% endif %}

<form id="page-form" class="card">
  <label for="title">Tiêu đề</label>
  <input type="text" id="title" name="title" value="{% if page %}{{ page.title | escape }}{% endif %}" required>

  <label for="slug">Slug (đường dẫn — /trang/slug)</label>
  <input type="text" id="slug" name="slug" value="{% if page %}{{ page.slug | escape }}{% endif %}" required>
  <div class="field-hint">Chỉ chữ thường/số, cách nhau bằng dấu gạch ngang. Vd: gioi-thieu</div>

  <label for="excerpt">Tóm tắt</label>
  <input type="text" id="excerpt" name="excerpt" value="{% if page %}{{ page.excerpt | escape }}{% endif %}">

  <label for="coverImage">Ảnh bìa (URL)</label>
  <input type="text" id="coverImage" name="coverImage" value="{% if page %}{{ page.coverImage | escape }}{% endif %}">

  <label for="body">Nội dung (HTML đã làm sạch)</label>
  <textarea id="body" name="body" required>{% if page %}{{ page.body }}{% endif %}</textarea>
  <div class="field-hint">Chưa có trình soạn thảo rich-text (đang TBD) — nhập HTML/markdown thô.</div>

  <h2 style="font-size:0.95rem;margin:1.5rem 0 0.5rem;border-top:1px solid #eee;padding-top:1rem;">SEO</h2>

  <label for="metaTitle">Meta title</label>
  <input type="text" id="metaTitle" name="metaTitle" value="{% if page.seo %}{{ page.seo.metaTitle | escape }}{% endif %}">

  <label for="metaDescription">Meta description</label>
  <input type="text" id="metaDescription" name="metaDescription" value="{% if page.seo %}{{ page.seo.metaDescription | escape }}{% endif %}">

  <label for="ogImage">Ảnh chia sẻ (Open Graph, URL)</label>
  <input type="text" id="ogImage" name="ogImage" value="{% if page.seo %}{{ page.seo.ogImage | escape }}{% endif %}">

  <label for="keyword">Từ khoá chính</label>
  <input type="text" id="keyword" name="keyword" value="{% if page.seo %}{{ page.seo.keyword | escape }}{% endif %}">

  {% if page.seo.score %}
    <div class="field-hint">Điểm SEO: {{ page.seo.score }}</div>
  {% endif %}

  <label style="display:flex;align-items:center;gap:0.4rem;">
    <input type="checkbox" id="noindex" name="noindex" style="width:auto;" {% if page.seo.noindex %}checked{% endif %}>
    noindex (ẩn khỏi công cụ tìm kiếm)
  </label>

  <div style="margin-top:1.5rem;display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center;">
    <button type="submit" class="btn btn-primary">Lưu</button>
    <span id="submit-slot"></span>
    <span id="publish-slot"></span>
    <span id="schedule-slot"></span>
    <span id="unpublish-slot"></span>
    <span id="delete-slot"></span>
  </div>
</form>

<script>
(function () {
  const CURRENT_ROLE = "{{ role }}";
  const canManage = CURRENT_ROLE === "manager" || CURRENT_ROLE === "admin";
  const pageId = {% if page %}"{{ page.id }}"{% else %}null{% endif %};
  const status = {% if page %}"{{ page.status }}"{% else %}"draft"{% endif %};
  const form = document.getElementById("page-form");
  const flash = document.getElementById("flash");

  function showFlash(message, ok) {
    flash.textContent = message;
    flash.className = ok ? "success" : "error";
  }

  const locked = (status === "scheduled" || status === "published") && CURRENT_ROLE === "edit";
  if (pageId && locked) {
    [...form.elements].forEach((el) => (el.disabled = true));
    showFlash("Trang đã lên lịch/xuất bản — chỉ manager/admin được sửa.", false);
  }

  async function callAction(path, body) {
    const res = await fetch("/admin/api/pages/" + pageId + path, {
      method: "POST",
      headers: body ? { "Content-Type": "application/json" } : undefined,
      body: body ? JSON.stringify(body) : undefined,
    });
    if (!res.ok) {
      const errBody = await res.json().catch(() => ({}));
      showFlash(typeof errBody.error === "string" ? errBody.error : "Thao tác thất bại", false);
      return false;
    }
    return true;
  }

  if (pageId) {
    if (status === "draft") {
      const submitBtn = document.createElement("button");
      submitBtn.type = "button";
      submitBtn.className = "btn";
      submitBtn.textContent = "Nộp duyệt";
      submitBtn.onclick = async () => {
        if (await callAction("/submit")) window.location.reload();
      };
      document.getElementById("submit-slot").appendChild(submitBtn);
    }

    if (canManage && (status === "pending_review" || status === "scheduled" || status === "draft")) {
      const publishBtn = document.createElement("button");
      publishBtn.type = "button";
      publishBtn.className = "btn";
      publishBtn.textContent = "Xuất bản ngay";
      publishBtn.onclick = async () => {
        if (await callAction("/publish")) window.location.reload();
      };
      document.getElementById("publish-slot").appendChild(publishBtn);

      const scheduleBtn = document.createElement("button");
      scheduleBtn.type = "button";
      scheduleBtn.className = "btn";
      scheduleBtn.textContent = "Lên lịch...";
      scheduleBtn.onclick = async () => {
        const value = prompt("Nhập thời điểm xuất bản (vd 2026-08-01T09:00):");
        if (!value) return;
        if (await callAction("/schedule", { scheduledAt: value })) window.location.reload();
      };
      document.getElementById("schedule-slot").appendChild(scheduleBtn);
    }

    if (canManage && (status === "scheduled" || status === "published")) {
      const unpublishBtn = document.createElement("button");
      unpublishBtn.type = "button";
      unpublishBtn.className = "btn";
      unpublishBtn.textContent = "Gỡ về nháp";
      unpublishBtn.onclick = async () => {
        if (!confirm("Gỡ trang này về nháp?")) return;
        if (await callAction("/unpublish")) window.location.reload();
      };
      document.getElementById("unpublish-slot").appendChild(unpublishBtn);
    }

    if (canManage) {
      const deleteBtn = document.createElement("button");
      deleteBtn.type = "button";
      deleteBtn.className = "btn btn-danger";
      deleteBtn.textContent = "Xoá";
      deleteBtn.onclick = async () => {
        if (!confirm("Xoá trang này?")) return;
        const res = await fetch("/admin/api/pages/" + pageId, { method: "DELETE" });
        if (!res.ok) {
          showFlash("Xoá thất bại", false);
          return;
        }
        window.location.href = "/admin/pages";
      };
      document.getElementById("delete-slot").appendChild(deleteBtn);
    }
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    const payload = {
      title: form.title.value,
      slug: form.slug.value,
      body: form.body.value,
      excerpt: form.excerpt.value || undefined,
      coverImage: form.coverImage.value || undefined,
      seo: {
        metaTitle: form.metaTitle.value || undefined,
        metaDescription: form.metaDescription.value || undefined,
        ogImage: form.ogImage.value || undefined,
        keyword: form.keyword.value || undefined,
        noindex: form.noindex.checked,
      },
    };

    const res = await fetch(pageId ? "/admin/api/pages/" + pageId : "/admin/api/pages", {
      method: pageId ? "PATCH" : "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showFlash(typeof body.error === "string" ? body.error : "Lưu thất bại", false);
      return;
    }

    const { page } = await res.json();
    showFlash("Đã lưu.", true);
    if (!pageId) {
      window.location.href = "/admin/pages/" + page.id;
    }
  });
})();
</script>
{% endblock %}

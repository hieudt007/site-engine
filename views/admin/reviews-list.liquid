{% layout "layout" %}
{% block content %}
<h1 style="margin:0 0 1.2rem;">Đánh giá sản phẩm</h1>

<div class="filter-tabs" id="status-tabs">
  <a href="#" data-status="pending" class="filter-tab">Chờ duyệt</a>
  <a href="#" data-status="approved" class="filter-tab">Đã duyệt</a>
  <a href="#" data-status="rejected" class="filter-tab">Từ chối</a>
</div>

<table>
  <thead>
    <tr><th>Sản phẩm</th><th>Người đánh giá</th><th>Sao</th><th>Nhận xét</th><th></th></tr>
  </thead>
  <tbody id="reviews-body">
    <tr><td colspan="5" style="color:#999;">Đang tải...</td></tr>
  </tbody>
</table>
<div class="pagination" id="pagination"></div>

<script>
(function () {
  const tbody = document.getElementById("reviews-body");
  const pagination = document.getElementById("pagination");
  const tabs = document.getElementById("status-tabs");
  const flash = document.getElementById("flash");
  let currentStatus = "{{ initialStatus }}";
  let currentPage = 1;

  function showError(message) {
    flash.textContent = message;
    flash.className = "error";
  }

  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str ?? "";
    return div.innerHTML;
  }

  let currentReviews = [];

  function rowHtml(r) {
    const actions = r.status === "pending"
      ? '<button class="btn" data-action="approve" data-id="' + r.id + '">Duyệt</button> ' +
        '<button class="btn btn-danger" data-action="reject" data-id="' + r.id + '">Từ chối</button> '
      : "";
    return (
      "<tr>" +
      "<td>" + escapeHtml(r.product ? r.product.name : "-") + "</td>" +
      "<td>" + escapeHtml(r.customerName) + "</td>" +
      "<td>" + "★".repeat(r.rating) + "</td>" +
      "<td>" + escapeHtml(r.comment || "-") + "</td>" +
      '<td style="white-space:nowrap;">' + actions +
      '<button class="btn" data-custom-fields="' + r.id + '">Trường tùy biến</button></td>' +
      "</tr>"
    );
  }

  function renderTabs() {
    tabs.querySelectorAll(".filter-tab").forEach((tab) => {
      tab.classList.toggle("active", tab.dataset.status === currentStatus);
    });
  }

  async function load() {
    const params = new URLSearchParams({ page: String(currentPage), status: currentStatus });

    const res = await fetch("/admin/api/reviews?" + params.toString());
    const { reviews, hasNext, hasPrev } = await res.json();
    currentReviews = reviews;

    tbody.innerHTML = reviews.length
      ? reviews.map(rowHtml).join("")
      : '<tr><td colspan="5" class="empty-state">Không có đánh giá nào.</td></tr>';

    pagination.innerHTML =
      (hasPrev ? '<a href="#" data-page="' + (currentPage - 1) + '">← Trang trước</a>' : "<span></span>") +
      "<span>Trang " + currentPage + "</span>" +
      (hasNext ? '<a href="#" data-page="' + (currentPage + 1) + '">Trang sau →</a>' : "<span></span>");
  }

  tabs.addEventListener("click", (event) => {
    const tab = event.target.closest("a[data-status]");
    if (!tab) return;
    event.preventDefault();
    currentStatus = tab.dataset.status;
    currentPage = 1;
    renderTabs();
    load();
  });

  pagination.addEventListener("click", (event) => {
    const link = event.target.closest("a[data-page]");
    if (!link) return;
    event.preventDefault();
    currentPage = Number(link.dataset.page);
    load();
  });

  tbody.addEventListener("click", async (event) => {
    const cfBtn = event.target.closest("button[data-custom-fields]");
    if (cfBtn) {
      const review = currentReviews.find((r) => r.id === cfBtn.dataset.customFields);
      openCustomFieldsEditor({
        title: "Trường tùy biến — đánh giá",
        initial: (review && review.customFields) || {},
        onSave: async (customFields) => {
          const res = await fetch("/admin/api/reviews/" + cfBtn.dataset.customFields, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ customFields }),
          });
          if (!res.ok) throw new Error("Lưu thất bại");
          load();
        },
      });
      return;
    }

    const btn = event.target.closest("button[data-action]");
    if (!btn) return;
    const { action, id } = btn.dataset;

    const res = await fetch("/admin/api/reviews/" + id + "/" + action, { method: "POST" });
    if (!res.ok) {
      showError("Thao tác thất bại");
      return;
    }
    load();
  });

  renderTabs();
  load();
})();
</script>
{% endblock %}

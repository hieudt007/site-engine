<div class="image-picker-box" style="width:{{ width | default: '120px' }};height:{{ height | default: '120px' }};">
  <input type="hidden" id="{{ id }}" name="{{ name }}" {% if dataField %}data-field="{{ dataField }}"{% endif %} value="{{ value | escape }}">
  
  <div class="image-picker-empty" style="{% if value and value != '' %}display:none;{% endif %}">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
    <div style="font-size:0.75rem;margin-top:0.3rem;">Chọn ảnh</div>
  </div>

  <img class="image-picker-preview" src="{{ value }}" style="{% if value == null or value == '' %}display:none;{% endif %}">
  
  <button type="button" class="image-picker-remove btn btn-danger btn-icon" style="{% if value == null or value == '' %}display:none;{% endif %}" title="Xoá ảnh">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </button>
</div>

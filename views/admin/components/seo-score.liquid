{% if seo and seo.score != nil %}
  <div class="card">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.8rem;">
      <div>
        <h3 class="edit-card-title" style="margin-bottom:0;">Chấm điểm SEO</h3>
        {% if seo.analyzedAt %}<div class="field-hint" style="margin-top:0.2rem;">Tính toán sau lần lưu cuối.</div>{% endif %}
      </div>
      <div class="seo-score-number">{{ seo.score }}/100</div>
    </div>
    {% if seo.checks and seo.checks.size > 0 %}
      <ul class="seo-check-list" style="border-top:1px dashed #eee; padding-top:0.8rem;">
        {% for check in seo.checks %}
          <li class="seo-check-{{ check.status }}">
            <span class="seo-check-dot"></span>
            <span>{{ check.message | escape }}</span>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
{% endif %}

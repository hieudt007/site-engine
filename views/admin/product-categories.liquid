{% layout "layout" %}
{% block content %}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
  <div>
    <h1 style="margin:0 0 0.3rem;">Phân loại Sản phẩm</h1>
    <p style="color:#777;font-size:0.85rem;margin-bottom:0;">
      Đồng bộ tự động từ LeadBase, nhưng bạn có thể tạo/xoá thủ công ở đây.
    </p>
  </div>
  <button class="btn btn-primary" id="open-add-modal">+ Thêm phân loại</button>
</div>

<div id="empty-state-container" style="display:none;text-align:center;padding:4rem 2rem;border:1px dashed #d1d5db;border-radius:8px;background:#fafafa;margin-bottom:2rem;">
  <div style="font-size:3rem;margin-bottom:1rem;opacity:0.5;">📂</div>
  <h3 style="margin-top:0;color:#374151;">Chưa có phân loại nào</h3>
  <p style="color:#6b7280;margin-bottom:1.5rem;">Thêm danh mục hoặc thương hiệu để phân loại sản phẩm tốt hơn.</p>
  <button class="btn btn-primary" onclick="document.getElementById('open-add-modal').click()">+ Thêm phân loại</button>
</div>

<div id="taxonomies-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start;">
  <!-- CATEGORIES -->
  <div>
    <h2 style="margin:0 0 1rem;font-size:1.2rem;">Danh mục</h2>
    <table style="margin-bottom:2rem;">
      <thead>
        <tr><th>Tên</th><th>Danh mục cha</th><th>Slug</th><th>Số SP</th><th>Đồng bộ</th><th></th></tr>
      </thead>
      <tbody id="categories-body">
        <tr><td colspan="6" style="color:#999;">Đang tải...</td></tr>
      </tbody>
    </table>
  </div>

  <!-- BRANDS -->
  <div>
    <h2 style="margin:0 0 0.5rem;font-size:1.2rem;">Thương hiệu</h2>
    <table>
      <thead>
        <tr><th>Tên</th><th>Slug</th><th>Số SP</th><th>Đồng bộ</th><th></th></tr>
      </thead>
      <tbody id="brands-body">
        <tr><td colspan="5" style="color:#999;">Đang tải...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- NATIVE DIALOG FOR ADDING -->
<dialog id="taxonomy-modal" style="border:none;border-radius:8px;box-shadow:0 10px 25px rgba(0,0,0,0.2);padding:1.5rem;width:400px;max-width:90vw;">
  <form id="taxonomy-form" method="dialog">
    <h3 style="margin-top:0;margin-bottom:1.2rem;font-size:1.1rem;">Thêm phân loại mới</h3>
    
    <label for="tax-type">Loại phân loại</label>
    <select id="tax-type" style="margin-bottom:1rem;width:100%;box-sizing:border-box;">
      <option value="product">Danh mục sản phẩm</option>
      <option value="brand">Thương hiệu</option>
    </select>

    <label for="tax-name">Tên hiển thị</label>
    <input type="text" id="tax-name" required style="margin-bottom:1rem;width:100%;box-sizing:border-box;">

    <label for="tax-slug">Slug</label>
    <input type="text" id="tax-slug" required style="margin-bottom:1rem;width:100%;box-sizing:border-box;">

    <div id="parent-category-group">
      <label for="tax-parent">Danh mục cha (tuỳ chọn)</label>
      <select id="tax-parent" style="margin-bottom:1rem;width:100%;box-sizing:border-box;">
        <option value="">-- Không có --</option>
      </select>
    </div>

    <div style="display:flex;justify-content:flex-end;gap:0.5rem;margin-top:0.5rem;">
      <button type="button" class="btn" id="close-modal-btn">Huỷ</button>
      <button type="submit" class="btn btn-primary" id="save-modal-btn">Lưu</button>
    </div>
  </form>
</dialog>

<script>
(function () {
  const flash = document.getElementById("flash");
  function showError(message) {
    flash.textContent = message;
    flash.className = "error";
  }
  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str ?? "";
    return div.innerHTML;
  }

  const modal = document.getElementById("taxonomy-modal");
  const typeSelect = document.getElementById("tax-type");
  const parentGroup = document.getElementById("parent-category-group");
  const parentSelect = document.getElementById("tax-parent");
  const nameInput = document.getElementById("tax-name");
  const slugInput = document.getElementById("tax-slug");

  document.getElementById("open-add-modal").addEventListener("click", () => {
    nameInput.value = "";
    slugInput.value = "";
    typeSelect.value = "product";
    parentSelect.value = "";
    parentGroup.style.display = "block";
    modal.showModal();
  });

  document.getElementById("close-modal-btn").addEventListener("click", () => {
    modal.close();
  });

  typeSelect.addEventListener("change", (e) => {
    if (e.target.value === "product") {
      parentGroup.style.display = "block";
    } else {
      parentGroup.style.display = "none";
    }
  });

  const catBody = document.getElementById("categories-body");
  const brandBody = document.getElementById("brands-body");

  async function loadData() {
    const res = await fetch("/admin/api/product-categories");
    if (!res.ok) {
      catBody.innerHTML = '<tr><td colspan="6">Lỗi tải danh mục.</td></tr>';
      brandBody.innerHTML = '<tr><td colspan="5">Lỗi tải thương hiệu.</td></tr>';
      return;
    }
    const { categories } = await res.json();
    
    if (categories.length === 0) {
      document.getElementById("taxonomies-grid").style.display = "none";
      document.getElementById("empty-state-container").style.display = "block";
      return;
    } else {
      document.getElementById("taxonomies-grid").style.display = "grid";
      document.getElementById("empty-state-container").style.display = "none";
    }

    const products = categories.filter(c => c.type === "product");
    const brands = categories.filter(c => c.type === "brand");

    // Update parent select
    parentSelect.innerHTML = '<option value="">-- Không có --</option>' + products.map(c => 
      '<option value="' + c.id + '">' + escapeHtml(c.name) + '</option>'
    ).join("");

    catBody.innerHTML = products.length
      ? products.map((c) =>
          '<tr><td><a href="/admin/product-categories/' + c.id + '">' + escapeHtml(c.name) + "</a></td>" +
          "<td>" + (c.parent ? escapeHtml(c.parent.name) : "-") + "</td>" +
          "<td>" + escapeHtml(c.slug) + "</td>" +
          "<td>" + (c._count && c._count.products !== undefined ? c._count.products : 0) + "</td>" +
          "<td>" + (c.syncedAt ? new Date(c.syncedAt).toLocaleString("vi-VN") : "-") + "</td>" +
          '<td style="text-align:right;display:flex;gap:0.4rem;justify-content:flex-end;">' +
          '<a class="btn" href="/admin/product-categories/' + c.id + '">Sửa</a>' +
          '<button class="btn btn-danger btn-icon" data-id="' + c.id + '" title="Xoá" aria-label="Xoá">' + window.adminIcon("trash") + '</button></td></tr>'
        ).join("")
      : '<tr><td colspan="6" class="empty-state">Chưa có danh mục nào.</td></tr>';

    brandBody.innerHTML = brands.length
      ? brands.map((b) =>
          '<tr><td><a href="/admin/product-categories/' + b.id + '">' + escapeHtml(b.name) + "</a></td>" +
          "<td>" + escapeHtml(b.slug) + "</td>" +
          "<td>" + (b._count && b._count.products !== undefined ? b._count.products : 0) + "</td>" +
          "<td>" + (b.syncedAt ? new Date(b.syncedAt).toLocaleString("vi-VN") : "-") + "</td>" +
          '<td style="text-align:right;display:flex;gap:0.4rem;justify-content:flex-end;">' +
          '<a class="btn" href="/admin/product-categories/' + b.id + '">Sửa</a>' +
          '<button class="btn btn-danger btn-icon" data-id="' + b.id + '" title="Xoá" aria-label="Xoá">' + window.adminIcon("trash") + '</button></td></tr>'
        ).join("")
      : '<tr><td colspan="5" class="empty-state">Chưa có thương hiệu nào.</td></tr>';
  }

  function handleTableClick(event) {
    const btn = event.target.closest("button[data-id]");
    if (!btn) return;
    if (!confirm("Xoá phân loại này?")) return;
    fetch("/admin/api/product-categories/" + btn.dataset.id, { method: "DELETE" })
      .then(res => {
        if (!res.ok) showError("Xoá thất bại");
        else loadData();
      });
  }

  catBody.addEventListener("click", handleTableClick);
  brandBody.addEventListener("click", handleTableClick);

  document.getElementById("taxonomy-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const payload = {
      name: nameInput.value,
      slug: slugInput.value,
      type: typeSelect.value,
      parentId: typeSelect.value === "product" && parentSelect.value ? parentSelect.value : null
    };
    
    const res = await fetch("/admin/api/product-categories", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload)
    });

    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showError(body.error || "Lỗi khi tạo");
      return;
    }

    modal.close();
    loadData();
  });

  loadData();
})();
</script>
{% endblock %}

{% layout "layout" %}
{% block content %}
<style>
  .tl-list { list-style: none; margin: 0; padding: 0; }
  .tl-item { display: flex; gap: 0.5rem; }
  .tl-dotcol { display: flex; flex-direction: column; align-items: center; }
  .tl-dot { width: 14px; height: 14px; border-radius: 999px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 9px; line-height: 1; color: #fff; }
  .tl-dot-pending { background: #fff; border: 2px solid #d1d5db; width: 10px; height: 10px; margin: 2px; }
  .tl-dot-active { background: var(--color-primary); border: 2px solid var(--color-primary); animation: tl-spin 0.8s linear infinite; border-top-color: transparent; }
  .tl-dot-done { background: #16a34a; }
  .tl-dot-failed { background: var(--color-danger); }
  .tl-line { width: 2px; flex: 1; min-height: 12px; background: #d1d5db; }
  .tl-line-done { background: #16a34a; }
  .tl-body { min-width: 0; flex: 1; padding-bottom: 0.5rem; }
  .tl-label { font-size: 0.78rem; color: #9ca3af; }
  .tl-label-active { color: var(--color-primary); font-weight: 600; }
  .tl-label-done { color: #374151; }
  .tl-label-failed { color: var(--color-danger); font-weight: 600; }
  .tl-msg { font-size: 0.72rem; color: #9ca3af; }
  .tl-note { font-size: 0.75rem; color: #888; margin-top: 0.2rem; }
  @keyframes tl-spin { to { transform: rotate(360deg); } }
</style>
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.8rem;">
  <h1 style="margin:0;">Sửa theme — {{ theme.name | escape }}</h1>
  <div style="display:flex;gap:0.5rem;">
    <button type="button" class="btn btn-danger" id="delete-theme-btn">Xoá theme</button>
    <a class="btn" href="/admin/settings/theme">← Danh sách theme</a>
  </div>
</div>

<div style="display:flex;gap:1rem;height:calc(100vh - 180px);min-height:500px;">
  <div class="card" style="width:220px;flex-shrink:0;overflow-y:auto;padding:0.8rem;">
    <div style="font-weight:600;font-size:0.85rem;margin-bottom:0.5rem;">File</div>
    <div id="file-list"></div>
  </div>

  <div class="card" style="flex:1;min-width:0;display:flex;flex-direction:column;padding:0.8rem;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
      <div id="file-view-title" style="font-weight:600;font-size:0.85rem;">Chọn 1 file để xem</div>
      <div style="display:flex;gap:0.3rem;align-items:center;">
        <div id="preview-size-toolbar" style="display:none;gap:0.25rem;margin-right:0.4rem;">
          <button type="button" class="btn" data-size="desktop" title="Desktop" style="padding:0.25rem 0.5rem;font-size:0.8rem;">🖥️</button>
          <button type="button" class="btn" data-size="tablet" title="iPad" style="padding:0.25rem 0.5rem;font-size:0.8rem;">📱</button>
          <button type="button" class="btn" data-size="mobile" title="Mobile" style="padding:0.25rem 0.5rem;font-size:0.8rem;">📲</button>
          <button type="button" class="btn" id="inline-edit-toggle" title="Sửa trực tiếp trên xem trước" style="padding:0.25rem 0.5rem;font-size:0.8rem;">🖊️</button>
        </div>
        <button type="button" class="btn" id="tab-preview" style="padding:0.3rem 0.7rem;font-size:0.78rem;">Xem trước</button>
        <button type="button" class="btn" id="tab-code" style="display:none;padding:0.3rem 0.7rem;font-size:0.78rem;">Code</button>
      </div>
    </div>
    <pre id="file-view-content" style="flex:1;overflow:auto;background:#0f172a;color:#e2e8f0;padding:0.8rem;border-radius:6px;font-size:0.8rem;line-height:1.5;white-space:pre-wrap;word-break:break-all;margin:0;"></pre>
    <div id="preview-wrap" style="flex:1;overflow:auto;display:none;background:#e5e7eb;border-radius:6px;padding:0.8rem;">
      <iframe id="preview-frame" style="border:1px solid #ccc;border-radius:6px;background:#fff;display:block;margin:0 auto;width:100%;height:100%;transition:width 0.2s;"></iframe>
    </div>
  </div>

  <div class="card" style="width:340px;flex-shrink:0;display:flex;flex-direction:column;padding:0.8rem;">
    <div style="font-weight:600;font-size:0.85rem;margin-bottom:0.5rem;">Chat sửa giao diện bằng AI</div>
    <div id="chat-messages" style="flex:1;overflow-y:auto;border:1px solid #eee;border-radius:6px;padding:0.6rem;margin-bottom:0.6rem;font-size:0.85rem;"></div>
    <div id="chat-progress" style="font-size:0.78rem;color:#888;max-height:110px;overflow-y:auto;margin-bottom:0.4rem;display:flex;flex-direction:column;gap:0.15rem;"></div>
    <div id="chat-image-preview" style="display:none;align-items:center;gap:0.4rem;margin-bottom:0.4rem;">
      <img id="chat-image-preview-thumb" style="width:36px;height:36px;object-fit:cover;border-radius:4px;border:1px solid #eee;">
      <span style="font-size:0.72rem;color:#666;flex:1;">Sẽ gửi kèm ảnh này cho AI</span>
      <button type="button" id="chat-image-remove" class="btn" style="padding:0.15rem 0.5rem;font-size:0.72rem;">✕</button>
    </div>
    <div style="display:flex;gap:0.5rem;">
      <textarea id="chat-input" placeholder="Vd: đổi màu nút mua hàng sang cam..." style="flex:1;min-height:50px;"></textarea>
      <div style="display:flex;flex-direction:column;gap:0.3rem;align-self:flex-end;">
        <input type="file" id="chat-image-input" accept="image/png,image/jpeg,image/webp,image/gif" style="display:none;">
        <button type="button" class="btn" id="chat-image-btn" title="Đính kèm ảnh tham khảo">🖼️</button>
        <button type="button" class="btn btn-primary" id="chat-send">Gửi</button>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const slug = {{ theme.slug | json }};
  const files = {{ files | json }};
  const flash = document.getElementById("flash");

  function showFlash(message, ok) {
    flash.textContent = message;
    flash.className = ok ? "success" : "error";
  }

  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str ?? "";
    return div.innerHTML;
  }

  // --- File tree (trai) + xem noi dung (giua) ---
  const fileList = document.getElementById("file-list");
  const fileViewTitle = document.getElementById("file-view-title");
  const fileViewContent = document.getElementById("file-view-content");
  let activeFile = null;

  function renderFileList() {
    fileList.innerHTML = files.map((f) =>
      '<a href="#" data-file="' + f.file + '" title="' + escapeHtml(f.description) + '" style="display:block;padding:0.35rem 0.4rem;border-radius:4px;font-size:0.8rem;text-decoration:none;color:' +
      (f.file === activeFile ? "#2563eb;background:#eff6ff;font-weight:600" : "#333") + ';">' + escapeHtml(f.file) + "</a>"
    ).join("");
  }

  async function openFile(file) {
    activeFile = file;
    renderFileList();
    document.getElementById("tab-code").style.display = "inline-block";
    fileViewTitle.textContent = file;
    fileViewContent.textContent = "Đang tải...";
    const res = await fetch("/admin/api/themes/" + slug + "/file?file=" + encodeURIComponent(file));
    if (!res.ok) {
      fileViewContent.textContent = "Không tải được file.";
      return;
    }
    const { content } = await res.json();
    fileViewContent.textContent = content;
  }

  // File nao la 1 trang doc lap thi map sang key preview rieng (routes/admin/themePreview.ts) -
  // file KHONG co trong map (layout/header/footer/custom-fields/assets/blog-post-locked/
  // custom-content/landing...) la "manh ghep" dung chung nhieu trang, khong co preview rieng ->
  // chi reload lai preview dang xem, khong doi sang trang nao khac.
  const FILE_TO_PREVIEW_KEY = {
    "home.liquid": "home",
    "blog-list.liquid": "blog-list",
    "blog-post.liquid": "blog-post",
    "blog-category.liquid": "blog-category",
    "page.liquid": "page",
    "products-list.liquid": "products-list",
    "product-category.liquid": "product-category",
    "product-detail.liquid": "product-detail",
    "cart.liquid": "cart",
    "order-confirmation.liquid": "order-confirmation",
    "404.liquid": "404",
  };

  fileList.addEventListener("click", (event) => {
    const link = event.target.closest("a[data-file]");
    if (!link) return;
    event.preventDefault();
    const file = link.dataset.file;
    openFile(file);
    const previewKey = FILE_TO_PREVIEW_KEY[file];
    if (previewKey) currentPreviewKey = previewKey;
    // Giu nguyen tab dang mo (Code/Xem truoc) - chi doi NOI DUNG ben trong theo file vua bam,
    // khong tu y chuyen tab.
    if (activeTab === "preview") reloadPreview();
  });

  renderFileList();

  // --- Tab Code / Xem truoc (iframe render bang dung theme nay, xem routes/admin/themePreview.ts) ---
  const codeEl = document.getElementById("file-view-content");
  const previewFrame = document.getElementById("preview-frame");
  const tabCodeBtn = document.getElementById("tab-code");
  const tabPreviewBtn = document.getElementById("tab-preview");
  let activeTab = "code";
  let currentPreviewKey = "home";

  function reloadPreview() {
    previewFrame.src = "/admin/themes/" + slug + "/preview?page=" + currentPreviewKey + "&t=" + Date.now();
  }

  const previewWrap = document.getElementById("preview-wrap");
  const previewSizeToolbar = document.getElementById("preview-size-toolbar");
  const PREVIEW_SIZES = { desktop: "100%", tablet: "768px", mobile: "375px" };

  function setPreviewSize(size) {
    previewFrame.style.width = PREVIEW_SIZES[size] || PREVIEW_SIZES.desktop;
    previewSizeToolbar.querySelectorAll("button[data-size]").forEach((btn) => {
      btn.className = btn.dataset.size === size ? "btn btn-primary" : "btn";
      btn.style.padding = "0.25rem 0.5rem";
      btn.style.fontSize = "0.8rem";
    });
  }

  previewSizeToolbar.addEventListener("click", (event) => {
    const btn = event.target.closest("button[data-size]");
    if (btn) setPreviewSize(btn.dataset.size);
  });

  function setTab(tab) {
    activeTab = tab;
    codeEl.style.display = tab === "code" ? "block" : "none";
    previewWrap.style.display = tab === "preview" ? "block" : "none";
    previewSizeToolbar.style.display = tab === "preview" ? "flex" : "none";
    tabCodeBtn.className = tab === "code" ? "btn btn-primary" : "btn";
    tabPreviewBtn.className = tab === "preview" ? "btn btn-primary" : "btn";
    tabCodeBtn.style.padding = tabPreviewBtn.style.padding = "0.3rem 0.7rem";
    tabCodeBtn.style.fontSize = tabPreviewBtn.style.fontSize = "0.78rem";
    if (tab === "preview" && !previewFrame.src) reloadPreview();
  }

  setPreviewSize("desktop");
  tabCodeBtn.addEventListener("click", () => setTab("code"));
  tabPreviewBtn.addEventListener("click", () => setTab("preview"));
  setTab("preview");

  // --- Sua truc tiep tren khung xem truoc (click-to-edit) - CHI cho text/anh CO DINH (tim thay
  // CHINH XAC 1 lan trong file .liquid), mau/font-size/kich thuoc anh (luon ghi thang vao CSS
  // rieng cua trang) va URL link - KHONG qua AI. Truy cap thang previewFrame.contentDocument vi
  // preview cung-origin (route /admin/themes/:slug/preview, khong phai iframe ngoai domain).
  // Mac dinh TAT - bat qua nut 🖊️ - vi bat luon se chan het click link (khong the bam link de
  // chuyen trang xem thu binh thuong nua).
  let inlineEditOn = false;
  let inlinePopupEl = null;

  function currentLiquidFile() {
    return currentPreviewKey + ".liquid";
  }

  // header.liquid/footer.liquid duoc render RIENG (qua render trong layout.liquid) va bao QUANH
  // moi trang, KHONG phai 1 phan cua file trang hien tai - phan tu nam trong <header>/<footer> cua
  // trang render ra phai tim/sua dung file do, khong phai file trang (vd home.liquid) dang xem.
  function resolveTargetFile(el) {
    if (el.closest("header")) return "header.liquid";
    if (el.closest("footer")) return "footer.liquid";
    return currentLiquidFile();
  }

  function rgbToHex(rgb) {
    const m = rgb.match(/\d+/g);
    if (!m) return "#000000";
    return "#" + m.slice(0, 3).map((n) => Number(n).toString(16).padStart(2, "0")).join("");
  }

  // Sinh selector on dinh theo vi tri (nth-child tu body) - kieu "Copy selector" cua devtools, du
  // dung de ghi 1 rule CSS nham dung phan tu vua click (uu tien id neu co, gon va chac chan hon).
  function cssPathFor(el) {
    if (el.id) return "#" + el.id;
    const parts = [];
    let node = el;
    while (node && node.nodeType === 1 && node.tagName.toLowerCase() !== "body") {
      let selector = node.tagName.toLowerCase();
      const parent = node.parentElement;
      if (parent) {
        const siblings = [...parent.children].filter((c) => c.tagName === node.tagName);
        if (siblings.length > 1) selector += ":nth-child(" + ([...parent.children].indexOf(node) + 1) + ")";
      }
      parts.unshift(selector);
      node = parent;
    }
    return parts.join(" > ");
  }

  async function inlineReplaceText(file, oldText, newText) {
    const res = await fetch("/admin/api/themes/" + slug + "/inline-edit/replace-text", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ file, oldText, newText }),
    });
    if (res.ok) return { ok: true };
    const body = await res.json().catch(() => ({}));
    return { ok: false, error: typeof body.error === "string" ? body.error : "Lỗi không xác định" };
  }

  // Nguon that de biet noi dung TINH hay DONG: hoi thang server (tim trong file that) - heuristic
  // cau truc DOM da bo (sai ca 2 chieu, xem determineDynamic). Dung cho ca text lan src anh.
  async function checkIsStatic(file, text) {
    try {
      const res = await fetch("/admin/api/themes/" + slug + "/inline-edit/check-static", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ file, text }),
      });
      if (!res.ok) return false;
      const body = await res.json();
      return Boolean(body.static);
    } catch {
      return false;
    }
  }

  function removeInlinePopup() {
    if (inlinePopupEl) {
      inlinePopupEl.remove();
      inlinePopupEl = null;
    }
  }

  // Quyet dinh cuoi cung 1 phan tu la tinh/dong: LUON hoi thang check-static (nguon dang tin cay
  // duy nhat, doi chieu voi noi dung file that). Heuristic cau truc DOM (dua vao tag/class lap
  // lai) sai ca 2 chieu - bao dong nham khi nhieu section/the khac nhau tinh co dung chung 1 class
  // Tailwind (khong phai do vong lap Liquid sinh ra), va bao tinh nham khi vong lap chi co dung 1
  // phan tu (khong con "lap lai" de nhan ra) - nen KHONG dung heuristic de quyet dinh cuoi nua.
  async function determineDynamic(el, isImg, file) {
    const probe = isImg ? el.getAttribute("src") : el.textContent.trim();
    if (!probe) return false;
    const isStatic = await checkIsStatic(file, probe);
    return !isStatic;
  }

  async function showInlinePopup(el) {
    removeInlinePopup();
    const isImg = el.tagName === "IMG";
    const targetFile = resolveTargetFile(el);
    const dynamic = await determineDynamic(el, isImg, targetFile);
    if (inlinePopupEl !== null) return; // popup khac da mo trong luc cho (double click nhanh)

    const rect = el.getBoundingClientRect();
    const frameRect = previewFrame.getBoundingClientRect();
    const popup = document.createElement("div");
    popup.style.cssText =
      "position:fixed;z-index:500;background:#fff;border:1px solid #ddd;border-radius:8px;" +
      "box-shadow:0 4px 16px rgba(0,0,0,0.15);padding:0.6rem;display:flex;flex-direction:column;gap:0.4rem;" +
      "font-size:0.78rem;min-width:200px;";
    popup.style.top = frameRect.top + rect.bottom + 6 + "px";
    popup.style.left = Math.min(frameRect.left + rect.left, window.innerWidth - 240) + "px";

    const bgImage = getComputedStyle(el).backgroundImage;
    const hasBgImage = !isImg && bgImage && bgImage !== "none";
    const linkEl = el.tagName === "A" ? el : el.closest("a");

    let html = "";
    if (dynamic) {
      const what = isImg ? "sửa ảnh" : "sửa text";
      html += '<div style="color:#b45309;background:#fffbeb;padding:0.3rem 0.4rem;border-radius:4px;">⚠️ Không thể ' + what + '.</div>';
    }
    if (isImg) {
      if (!dynamic) {
        html += '<button type="button" class="btn" data-action="change-image" style="font-size:0.75rem;">🖼️ Đổi ảnh</button>';
      }
      html += '<label>Rộng (px) <input type="number" data-action="width" value="' + (el.naturalWidth ? el.width : "") + '" style="width:70px;"></label>';
      html += '<label>Cao (px) <input type="number" data-action="height" value="' + (el.naturalWidth ? el.height : "") + '" style="width:70px;"></label>';
    } else {
      if (hasBgImage) {
        html += '<button type="button" class="btn" data-action="change-bg-image" style="font-size:0.75rem;">🖼️ Đổi ảnh nền</button>';
      }
      html += '<label>Màu chữ <input type="color" data-action="color" value="' + rgbToHex(getComputedStyle(el).color) + '"></label>';
      html += '<label>Cỡ chữ (px) <input type="number" data-action="font-size" value="' + parseInt(getComputedStyle(el).fontSize, 10) + '" style="width:60px;"></label>';
    }
    if (linkEl && !dynamic) {
      html += '<label>Link <input type="text" data-action="href" value="' + escapeHtml(linkEl.getAttribute("href") || "") + '" style="width:170px;"></label>';
    }
    html +=
      '<div style="display:flex;gap:0.3rem;"><button type="button" class="btn btn-primary" data-action="apply" style="font-size:0.75rem;flex:1;">Áp dụng</button>' +
      '<button type="button" class="btn" data-action="close" style="font-size:0.75rem;">✕</button></div>';
    if (!isImg) html += '<div style="font-size:0.68rem;color:#999;">Nhấp đúp để sửa chữ trực tiếp</div>';
    html += '<div data-action="status" style="font-size:0.7rem;"></div>';
    popup.innerHTML = html;
    document.body.appendChild(popup);
    inlinePopupEl = popup;

    const statusEl = popup.querySelector('[data-action="status"]');
    function setStatus(text, ok) {
      statusEl.textContent = text;
      statusEl.style.color = ok ? "#16a34a" : "#dc2626";
    }

    popup.querySelector('[data-action="close"]').addEventListener("click", removeInlinePopup);

    const changeImgBtn = popup.querySelector('[data-action="change-image"]');
    if (changeImgBtn) {
      changeImgBtn.addEventListener("click", () => {
        window.openMediaPicker({
          title: "Chọn ảnh thay thế",
          onSelect: async (url, media) => {
            setStatus("Đang lưu...", true);
            const oldSrc = el.getAttribute("src");
            const result = await inlineReplaceText(targetFile, oldSrc, url);
            if (!result.ok) {
              setStatus(result.error, false);
              return;
            }
            // Doi alt/title la viec THEM, khong lam hong ket qua chinh (doi src) neu that bai - vd
            // alt/title cu khong tim thay chinh xac 1 lan trong file (thuong vi rong/dong, hoac
            // the <img> von khong co san thuoc tinh do de thay).
            const oldAlt = el.getAttribute("alt") || "";
            if (media && media.alt && media.alt !== oldAlt) {
              await inlineReplaceText(targetFile, 'alt="' + oldAlt + '"', 'alt="' + media.alt + '"');
            }
            const oldTitle = el.getAttribute("title") || "";
            if (media && media.alt && media.alt !== oldTitle) {
              await inlineReplaceText(targetFile, 'title="' + oldTitle + '"', 'title="' + media.alt + '"');
            }
            setStatus("Đã đổi ảnh", true);
            reloadPreview();
          },
        });
      });
    }

    const changeBgImgBtn = popup.querySelector('[data-action="change-bg-image"]');
    if (changeBgImgBtn) {
      changeBgImgBtn.addEventListener("click", () => {
        window.openMediaPicker({
          title: "Chọn ảnh nền",
          onSelect: async (url) => {
            setStatus("Đang lưu...", true);
            const styleRes = await fetch("/admin/api/themes/" + slug + "/inline-edit/style", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                file: targetFile,
                selector: cssPathFor(el),
                declarations: { "background-image": 'url("' + window.location.origin + url + '")' },
              }),
            });
            if (styleRes.ok) {
              setStatus("Đã đổi ảnh nền", true);
              reloadPreview();
            } else {
              const b = await styleRes.json().catch(() => ({}));
              setStatus(typeof b.error === "string" ? b.error : "Lỗi lưu ảnh nền", false);
            }
          },
        });
      });
    }

    popup.querySelector('[data-action="apply"]').addEventListener("click", async () => {
      setStatus("Đang lưu...", true);
      const declarations = {};
      const widthInput = popup.querySelector('[data-action="width"]');
      const heightInput = popup.querySelector('[data-action="height"]');
      const colorInput = popup.querySelector('[data-action="color"]');
      const fontSizeInput = popup.querySelector('[data-action="font-size"]');
      const hrefInput = popup.querySelector('[data-action="href"]');
      if (widthInput && widthInput.value) declarations.width = widthInput.value + "px";
      if (heightInput && heightInput.value) declarations.height = heightInput.value + "px";
      if (colorInput) declarations.color = colorInput.value;
      if (fontSizeInput && fontSizeInput.value) declarations["font-size"] = fontSizeInput.value + "px";

      let ok = true;
      let errMsg = "";
      if (Object.keys(declarations).length) {
        const res = await fetch("/admin/api/themes/" + slug + "/inline-edit/style", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ file: targetFile, selector: cssPathFor(el), declarations }),
        });
        if (!res.ok) {
          ok = false;
          const b = await res.json().catch(() => ({}));
          errMsg = typeof b.error === "string" ? b.error : "Lỗi lưu CSS";
        }
      }

      if (ok && hrefInput && linkEl) {
        const oldHref = linkEl.getAttribute("href") || "";
        const newHref = hrefInput.value;
        if (newHref !== oldHref) {
          const result = await inlineReplaceText(targetFile, 'href="' + oldHref + '"', 'href="' + newHref + '"');
          if (!result.ok) {
            ok = false;
            errMsg = result.error;
          }
        }
      }

      if (ok) {
        setStatus("Đã lưu", true);
        reloadPreview();
      } else {
        setStatus(errMsg, false);
      }
    });
  }

  async function startInlineTextEdit(el) {
    if (el.tagName === "IMG") return;
    const targetFile = resolveTargetFile(el);
    if (await determineDynamic(el, false, targetFile)) {
      alert("Không thể sửa text ở đây — dữ liệu thật (dùng chat).");
      return;
    }
    removeInlinePopup();
    const original = el.textContent;
    el.contentEditable = "true";
    el.style.outline = "2px solid #16a34a";
    el.focus();
    const onBlur = async () => {
      el.contentEditable = "false";
      el.style.outline = "";
      el.removeEventListener("blur", onBlur);
      const updated = el.textContent;
      if (updated.trim() === original.trim()) return;
      const result = await inlineReplaceText(targetFile, original.trim(), updated.trim());
      if (!result.ok) {
        alert(result.error);
        el.textContent = original;
      } else {
        reloadPreview();
      }
    };
    el.addEventListener("blur", onBlur);
  }

  // Link trong preview tro toi URL PUBLIC that (/products, /blog...) - neu click di thang, iframe
  // se navigate ra route cong khai that, route do render bang theme DANG ACTIVE cho site (khong
  // phai theme dang sua), thoat khoi override cua trang preview nay ngay. Doi sang dung loai trang
  // qua lai preview (van giu slug theme dang sua) thay vi cho navigate that.
  function mapHrefToPreviewKey(href) {
    let pathname;
    try {
      pathname = new URL(href, window.location.origin).pathname;
    } catch {
      return null;
    }
    if (pathname === "/") return "home";
    if (pathname === "/blog") return "blog-list";
    if (pathname.startsWith("/danh-muc/") || pathname.startsWith("/chu-de/")) return "blog-category";
    if (pathname !== "/" && !pathname.startsWith("/admin") && !pathname.startsWith("/products") && !pathname.startsWith("/cart")) return "blog-post";
    if (pathname === "/products") return "products-list";
    if (pathname.startsWith("/products/danh-muc/")) return "product-category";
    if (pathname.startsWith("/products/")) return "product-detail";
    if (pathname === "/cart") return "cart";
    if (pathname.startsWith("/order-confirmation/")) return "order-confirmation";
    return "home"; // khong ro loai trang - ve trang chu (giong fallback cua themePreview.ts)
  }

  function attachInlineEditListeners(doc) {
    let hoverEl = null;
    doc.addEventListener("mouseover", (e) => {
      if (!inlineEditOn) return;
      if (hoverEl) hoverEl.style.outline = "";
      hoverEl = e.target;
      if (hoverEl && hoverEl.nodeType === 1) hoverEl.style.outline = "2px dashed #2563eb";
    });
    doc.addEventListener("mouseout", (e) => {
      if (!inlineEditOn) return;
      if (e.target && e.target.style) e.target.style.outline = "";
    });
    doc.addEventListener(
      "click",
      (e) => {
        if (!inlineEditOn) {
          const link = e.target.closest && e.target.closest("a[href]");
          if (!link) return;
          const href = link.getAttribute("href");
          if (!href || href.startsWith("#") || /^[a-z]+:/i.test(href)) return; // #anchor, mailto:, tel:... - de trinh duyet tu xu ly
          e.preventDefault();
          const key = mapHrefToPreviewKey(href);
          if (key) {
            currentPreviewKey = key;
            reloadPreview();
          }
          return;
        }
        e.preventDefault();
        e.stopPropagation();
        showInlinePopup(e.target);
      },
      true,
    );
    doc.addEventListener(
      "dblclick",
      (e) => {
        if (!inlineEditOn) return;
        e.preventDefault();
        e.stopPropagation();
        startInlineTextEdit(e.target);
      },
      true,
    );
  }

  previewFrame.addEventListener("load", () => {
    const doc = previewFrame.contentDocument;
    if (doc) attachInlineEditListeners(doc);
  });

  const inlineEditToggle = document.getElementById("inline-edit-toggle");
  inlineEditToggle.addEventListener("click", () => {
    inlineEditOn = !inlineEditOn;
    inlineEditToggle.className = inlineEditOn ? "btn btn-primary" : "btn";
    inlineEditToggle.style.padding = "0.25rem 0.5rem";
    inlineEditToggle.style.fontSize = "0.8rem";
    removeInlinePopup();
  });

  document.getElementById("delete-theme-btn").addEventListener("click", async () => {
    if (!confirm("Xoá theme này? Không thể hoàn tác.")) return;
    const res = await fetch("/admin/api/themes/" + slug, { method: "DELETE" });
    if (!res.ok) {
      const body = await res.json().catch(() => ({}));
      showFlash(typeof body.error === "string" ? body.error : "Xoá theme thất bại", false);
      return;
    }
    window.location.href = "/admin/settings/theme";
  });

  // --- Chat (phai) ---
  function chatMessageHtml(role, content, imageUrl) {
    const isUser = role === "user";
    const imageHtml = imageUrl
      ? '<img src="' + escapeHtml(imageUrl) + '" style="display:block;max-width:160px;border-radius:6px;margin-bottom:0.3rem;">'
      : "";
    return (
      '<div style="margin-bottom:0.5rem;text-align:' + (isUser ? "right" : "left") + ';">' +
      '<div style="display:inline-block;max-width:90%;padding:0.4rem 0.6rem;border-radius:6px;background:' +
      (isUser ? "#2563eb;color:#fff" : "#f3f4f6;color:#111") + ';white-space:pre-wrap;">' +
      imageHtml + escapeHtml(content) + "</div></div>"
    );
  }

  // --- Dinh kem anh tham khao cho AI (upload truoc qua thu vien Media dung chung, giong
  // media-list.liquid) - luu URL TUYET DOI (window.location.origin + Media.url tuong doi) vi
  // server goi AI qua API can URL truy cap duoc tu ben ngoai, khong phai duong dan noi bo.
  const chatImageInput = document.getElementById("chat-image-input");
  const chatImageBtn = document.getElementById("chat-image-btn");
  const chatImagePreview = document.getElementById("chat-image-preview");
  const chatImagePreviewThumb = document.getElementById("chat-image-preview-thumb");
  const chatImageRemove = document.getElementById("chat-image-remove");
  let pendingImageUrl = null;

  function clearPendingImage() {
    pendingImageUrl = null;
    chatImageInput.value = "";
    chatImagePreview.style.display = "none";
  }

  chatImageBtn.addEventListener("click", () => chatImageInput.click());
  chatImageRemove.addEventListener("click", clearPendingImage);

  chatImageInput.addEventListener("change", async () => {
    const file = chatImageInput.files[0];
    if (!file) return;
    chatImageBtn.disabled = true;
    try {
      const formData = new FormData();
      formData.append("file", file);
      const res = await fetch("/admin/api/media", { method: "POST", body: formData });
      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        showFlash(typeof body.error === "string" ? body.error : "Tải ảnh lên thất bại", false);
        chatImageInput.value = "";
        return;
      }
      const { media } = await res.json();
      pendingImageUrl = window.location.origin + media.url;
      chatImagePreviewThumb.src = media.url;
      chatImagePreview.style.display = "flex";
    } finally {
      chatImageBtn.disabled = false;
    }
  });

  // Nut "Xac nhan" (kieu Plan Mode) - chi hien khi tin nhan MOI NHAT la de xuat thiet ke lai toan
  // site dang cho xac nhan (redesignBrief != null). Bam vao goi thang /chat/confirm-redesign,
  // KHONG qua lai AI phan loai - dam bao chay dung ke hoach da de xuat, khong bi AI doan sai.
  function renderConfirmButton(box) {
    const wrap = document.createElement("div");
    wrap.style.marginBottom = "0.5rem";
    wrap.innerHTML =
      '<button type="button" class="btn btn-primary" id="confirm-redesign-btn">✅ Xác nhận thiết kế lại toàn bộ</button>';
    box.appendChild(wrap);
    box.scrollTop = box.scrollHeight;
    document.getElementById("confirm-redesign-btn").addEventListener("click", handleConfirmRedesign);
  }

  async function loadChatHistory() {
    const box = document.getElementById("chat-messages");
    const res = await fetch("/admin/api/themes/" + slug + "/chat/history");
    if (!res.ok) {
      box.innerHTML = '<p style="color:#999;">Không tải được lịch sử chat</p>';
      return;
    }
    const { messages } = await res.json();
    box.innerHTML = messages.length
      ? messages.map((m) => chatMessageHtml(m.role, m.content, m.imageUrl)).join("")
      : '<p style="color:#999;">Chưa có tin nhắn nào — hỏi AI để bắt đầu chỉnh sửa theme này.</p>';
    box.scrollTop = box.scrollHeight;

    const last = messages[messages.length - 1];
    if (last && last.role === "assistant" && last.redesignBrief) renderConfirmButton(box);
  }

  // Duoi 3 buoc (nhom file): chi 1 dong trang thai GHI DE lien tuc (khong xep chong) - it buoc
  // thi xem lai lich su tung dong khong can thiet, ghi de gon hon. Tu 3 buoc tro len: hien timeline
  // tung buoc (dang/xong/loi) giong kieu timeline tao landing page ben leadbase.
  function renderProgressLine(progress, text) {
    progress.innerHTML = "";
    const line = document.createElement("div");
    line.textContent = text;
    progress.appendChild(line);
  }

  const TL_ICON = { pending: "", active: "", done: "✓", failed: "✕" };
  let timelineMode = false;
  let timelineSteps = [];
  let activeStepIndex = -1;

  function renderTimeline(progress, tasks) {
    progress.innerHTML = '<ol class="tl-list"></ol><div class="tl-note"></div>';
    const list = progress.querySelector(".tl-list");
    timelineSteps = tasks.map((group, i) => {
      const li = document.createElement("li");
      li.className = "tl-item";
      li.innerHTML =
        '<div class="tl-dotcol"><span class="tl-dot tl-dot-pending"></span>' +
        (i < tasks.length - 1 ? '<span class="tl-line"></span>' : "") +
        '</div><div class="tl-body"><div class="tl-label">' + escapeHtml(group) + '</div><div class="tl-msg"></div></div>';
      list.appendChild(li);
      return {
        dotEl: li.querySelector(".tl-dot"),
        lineEl: li.querySelector(".tl-line"),
        labelEl: li.querySelector(".tl-label"),
        msgEl: li.querySelector(".tl-msg"),
      };
    });
  }

  function setStepState(index, state) {
    const step = timelineSteps[index];
    if (!step) return;
    step.dotEl.className = "tl-dot tl-dot-" + state;
    step.dotEl.textContent = TL_ICON[state];
    step.labelEl.className = "tl-label tl-label-" + state;
    if (state === "done" && step.lineEl) step.lineEl.className = "tl-line tl-line-done";
  }

  function setStepMessage(index, text) {
    const step = timelineSteps[index];
    if (step) step.msgEl.textContent = text;
  }

  // Bong bong "reply" (lan goi phan loai) chi la tin TAM THOI - server KHONG luu vao DB (xem
  // routes/admin/themeChat.ts), nen phai tu XOA khoi khung chat ngay khi tin tom tat cuoi (done)
  // ve toi, tranh luc dang chat thay 2 tin nhung reload lai chi con 1 tin (lech nhau, gay hieu lam).
  let tempReplyEl = null;

  function handleChatEvent(event, progress, box) {
    if (event.step === "reply") {
      if (tempReplyEl) tempReplyEl.remove();
      const wrapper = document.createElement("div");
      wrapper.innerHTML = chatMessageHtml("assistant", event.reply);
      tempReplyEl = wrapper.firstElementChild;
      box.appendChild(tempReplyEl);
      box.scrollTop = box.scrollHeight;
    } else if (event.step === "plan") {
      // Tu 3 buoc (nhom file) tro len moi dang timeline - it hon thi 1 dong ghi de la du, khong
      // can bay ra ca danh sach cho vai buoc.
      timelineMode = event.tasks.length >= 3;
      if (timelineMode) renderTimeline(progress, event.tasks);
      else progress.innerHTML = "";
    } else if (event.step === "group_start") {
      activeStepIndex = event.index;
      if (timelineMode) setStepState(event.index, "active");
      else renderProgressLine(progress, "⏳ " + event.label);
    } else if (event.step === "group_done") {
      if (timelineMode) setStepState(event.index, event.ok ? "done" : "failed");
    } else if (event.step === "done") {
      progress.innerHTML = ""; // xong roi - xoa het timeline/dong trang thai, tin tom tat cuoi da du
      if (tempReplyEl) {
        tempReplyEl.remove();
        tempReplyEl = null;
      }
      box.insertAdjacentHTML("beforeend", chatMessageHtml("assistant", event.reply));
      box.scrollTop = box.scrollHeight;
      if (event.needsRedesignConfirm) renderConfirmButton(box);
      // File vua sua co the la file dang mo - tai lai cho khop noi dung moi.
      if (activeFile && event.files && event.files.some((f) => f.file === activeFile && f.ok && !f.skipped)) {
        openFile(activeFile);
      }
      // Co file thuc su doi thi luon chuyen sang tab Xem truoc + tai lai ngay, khong doi nguoi
      // dung tu bam - AI vua sua xong la thay ket qua luon.
      if (event.files && event.files.some((f) => f.ok && !f.skipped)) {
        setTab("preview");
        reloadPreview();
      }
    } else if (event.step === "validating") {
      const text = event.ok ? "Đã sửa " + event.file : "Lỗi " + event.file;
      if (timelineMode) setStepMessage(activeStepIndex, text);
      else renderProgressLine(progress, (event.ok ? "✅ " : "❌ ") + text + (event.ok ? "" : " — giữ bản cũ"));
    } else if (event.step === "error") {
      showFlash("AI lỗi: " + event.label, false);
    } else if (event.step === "intent_updated" || event.step === "files") {
      // Khong can hien - thong tin thua, tin tom tat cuoi da du.
    } else if (event.label) {
      // Truoc khi biet ke hoach (vd "classify") thi chua co timeline - ghi de 1 dong binh thuong.
      // Sau khi timeline da dung (vd "bundling", chay sau khi het nhom) thi ghi vao dong note rieng
      // ben duoi, KHONG duoc xoa timeline dang hien ket qua tung buoc.
      const note = timelineMode ? progress.querySelector(".tl-note") : null;
      if (note) note.textContent = "⏳ " + event.label;
      else renderProgressLine(progress, "⏳ " + event.label);
    }
  }

  // Dung chung cho ca gui chat thuong (POST /chat) lan bam nut xac nhan (POST /chat/confirm-redesign)
  // - doc SSE, phat tung event qua handleChatEvent. Khong dong cham input/nut gui (goi rieng o tung
  // noi goi, vi luc bam nut xac nhan input van dang bo trong, khong can khoa).
  async function streamChatRequest(url, body) {
    const box = document.getElementById("chat-messages");
    const progress = document.getElementById("chat-progress");
    progress.innerHTML = "";
    timelineMode = false;
    timelineSteps = [];
    activeStepIndex = -1;

    try {
      const res = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      if (!res.ok || !res.body) {
        progress.textContent = "";
        const errBody = await res.json().catch(() => ({}));
        showFlash(typeof errBody.error === "string" ? errBody.error : "Gửi chat thất bại", false);
        return;
      }

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });

        const parts = buffer.split("\n\n");
        buffer = parts.pop();
        for (const part of parts) {
          const line = part.trim();
          if (!line.startsWith("data:")) continue;
          const event = JSON.parse(line.slice(5).trim());
          handleChatEvent(event, progress, box);
        }
      }
    } catch (err) {
      progress.textContent = "";
      console.error("Lỗi kết nối khi chat với AI:", err);
      showFlash("Lỗi kết nối khi chat với AI: " + (err && err.message ? err.message : String(err)), false);
    }
  }

  async function sendChatMessage() {
    const input = document.getElementById("chat-input");
    const message = input.value.trim();
    if (!message) return;

    const box = document.getElementById("chat-messages");
    const sendBtn = document.getElementById("chat-send");

    const imageUrl = pendingImageUrl;
    box.insertAdjacentHTML("beforeend", chatMessageHtml("user", message, imageUrl));
    box.scrollTop = box.scrollHeight;
    input.value = "";
    input.disabled = true;
    sendBtn.disabled = true;
    clearPendingImage();

    try {
      await streamChatRequest("/admin/api/themes/" + slug + "/chat", imageUrl ? { message, imageUrl } : { message });
    } finally {
      input.disabled = false;
      sendBtn.disabled = false;
      input.focus();
    }
  }

  async function handleConfirmRedesign() {
    const btn = document.getElementById("confirm-redesign-btn");
    if (btn) {
      btn.disabled = true;
      btn.textContent = "Đang tiến hành...";
    }
    const input = document.getElementById("chat-input");
    const sendBtn = document.getElementById("chat-send");
    input.disabled = true;
    sendBtn.disabled = true;
    try {
      await streamChatRequest("/admin/api/themes/" + slug + "/chat/confirm-redesign", {});
    } finally {
      input.disabled = false;
      sendBtn.disabled = false;
    }
  }

  document.getElementById("chat-send").addEventListener("click", sendChatMessage);
  document.getElementById("chat-input").addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendChatMessage();
    }
  });

  loadChatHistory();
})();
</script>
{% endblock %}
